msgid "Export vouchers to CSV"
msgstr "تصدير بطاقات الهدية إلى CSV"

msgid "Cloned {} vouchers."
msgstr "تم تكرار {} بطاقات هدية."

msgid "Clone selected vouchers"
msgstr "تكرار البطاقات المحددة"

