msgstr "Chỉ áp dụng khi phạm vi là \"Sản phẩm cụ thể\" hoặc \"Danh mục cụ thể\""

msgid "Validity Period"
msgstr "Thời hạn sử dụng"

msgid "Leave end_date blank for no expiry. days_valid overrides end_date."
msgstr ""
"Để trống end_date nếu không muốn hết hạn. days_valid sẽ ưu tiên hơn "
"end_date."

