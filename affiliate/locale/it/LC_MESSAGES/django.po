msgid "Login required (guest registration disabled)"
msgstr "Accesso richiesto (registrazione ospite disattivata)"

msgid "You must be logged in to register as an affiliate."
msgstr "Devi essere autenticato per registrarti come affiliato."

msgid "Email is required."
msgstr "L'email è obbligatori."

msgid "Password is required."
msgstr "La password è obbligatori."

msgid "An account with this email already exists. Please log in instead."
msgstr "Un account con questa email esiste già. Accedi invece."

msgid "Failed to create user account. Please try again."
msgstr "Impossibile creare l'account utente. Riprova."

msgid "You already have an affiliate account."
msgstr "Hai già un account affiliato."

msgid "You must accept the terms and conditions to register."
msgstr "Devi accettare i termini e le condizioni per registrarti."

msgid "Thank you for registering! Your application is being reviewed."
msgstr "Grazie per la registrazione! La tua domanda è in fase di revisione."

msgid "You must be an affiliate to create links."
msgstr "Devi essere un affiliato per creare link."

msgid "You are not approved for this program."
msgstr "Non sei approvato per questo programma."

msgid "Program activated successfully."
msgstr "Programma attivato con successo."

msgid "Program cannot be activated from its current status."
msgstr "Il programma non può essere attivato dallo stato corrente."

msgid "Program paused successfully."
msgstr "Programma sospeso con successo."

msgid "Only active programs can be paused."
msgstr "Solo i programmi attivi possono essere sospesi."

msgid "Invalid action."
msgstr "Azione non valida."

msgid "Program not found."
msgstr "Programma non trovato."

msgid "Program name must be 200 characters or fewer."
msgstr "Il nome del programma deve essere di 200 caratteri o meno."

msgid "Commission value is required."
msgstr "Il valore della commissione è obbligatorio."

msgid "Commission value must be positive."
msgstr "Il valore della commissione deve essere positivo."

msgid "Percentage cannot exceed 100%."
msgstr "La percentuale non può superare il 100%."

msgid "Invalid commission value."
msgstr "Valore della commissione non valido."

msgid "Cookie lifetime must be between 1 and 365 days."
msgstr "La durata del cookie deve essere compresa tra 1 e 365 giorni."

msgid "Invalid cookie lifetime."
msgstr "Durata del cookie non valida."

msgid "Minimum payout must be positive."
msgstr "L'importo minimo deve essere positivo."

msgid "Invalid minimum payout."
msgstr "Importo minimo non valido."

msgid "Affiliate program created successfully."
msgstr "Programma affiliato creato con successo."

msgid "Program is live and accepting affiliates"
msgstr "Il programma è attivo e accetta affiliati"

msgid "Program is temporarily paused"
msgstr "Il programma è temporaneamente sospeso"

msgid "Affiliate approved successfully."
msgstr "Affiliato approvato con successo."

msgid "Only pending affiliates can be approved."
msgstr "Solo gli affiliati in sospeso possono essere approvati."

msgid "Affiliate suspended successfully."
msgstr "Affiliato sospeso con successo."

msgid "Only active affiliates can be suspended."
msgstr "Solo gli affiliati attivi possono essere sospesi."

msgid "Affiliate activated successfully."
msgstr "Affiliato attivato con successo."

msgid "Affiliate cannot be activated from current status."
msgstr "L'affiliato non può essere attivato dallo stato corrente."

msgid "Affiliate not found."
msgstr "Affiliato non trovato."

msgid "Membership approved successfully."
msgstr "Membro approvato con successo."

msgid "Only pending memberships can be approved."
msgstr "Solo le iscrizioni in sospeso possono essere approvate."

msgid "Membership rejected successfully."
msgstr "Membro rifiutato con successo."

msgid "Only pending memberships can be rejected."
msgstr "Solo le iscrizioni in sospeso possono essere rifiutate."

msgid "Membership not found."
msgstr "Membro non trovato."

msgid "Invalid status."
msgstr "Stato non valido."

msgid "Program archived successfully."
msgstr "Programma archiviato con successo."
