msgid "Register as affiliate"
msgstr "S'inscrire en tant qu'affilié"

msgid ""
"Register as an affiliate. Supports both authenticated users and guest "
"registration (if allow_guest_registration is enabled). Creates affiliate "
"profile, saves custom form response if configured, and returns success with "
"affiliate code and redirect URL."
msgstr ""
"S'inscrire en tant que affilié. Prend en charge à la fois les utilisateurs "
"authentifiés et l'inscription en tant que visiteur (si "
"allow_guest_registration est activé). Crée un profil affilié, enregistre la "
"réponse du formulaire personnalisé si configuré, et retourne un succès avec "
"le code affilié et l'URL de redirection."

msgid "Affiliate registered successfully"
msgstr "Affilié enregistré avec succès"

msgid "Validation error or duplicate affiliate account"
msgstr "Erreur de validation ou compte affilié en double"

msgid "Login required (guest registration disabled)"
msgstr "Connection requise (l'inscription en tant que visiteur est désactivée)"

msgid "You must be logged in to register as an affiliate."
msgstr "Vous devez être connecté pour vous inscrire en tant qu'affilié."

msgid "Email is required."
msgstr "L'e-mail est requis."

msgid "Password is required."
msgstr "Le mot de passe est requis."

msgid "An account with this email already exists. Please log in instead."
msgstr ""
"Un compte avec cette adresse e-mail existe déjà. Veuillez vous connecter au "
"lieu de vous inscrire."

msgid "Failed to create user account. Please try again."
msgstr "Échec de la création du compte utilisateur. Veuillez réessayer."

msgid "You already have an affiliate account."
msgstr "Vous avez déjà un compte d'affilié."

msgid "You must accept the terms and conditions to register."
msgstr "Vous devez accepter les termes et conditions pour vous inscrire."

msgid "Thank you for registering! Your application is being reviewed."
msgstr "Merci de votre inscription ! Votre demande est en cours d'examen."

msgid "You must be an affiliate to create links."
msgstr "Vous devez être affilié pour créer des liens."

msgid "You are not approved for this program."
msgstr "Vous n'êtes pas approuvé pour ce programme."

msgid "Program activated successfully."
msgstr "Le programme a été activé avec succès."

msgid "Program cannot be activated from its current status."
msgstr "Le programme ne peut pas être activé à partir de son statut actuel."

msgid "Program paused successfully."
msgstr "Le programme a été mis en pause avec succès."

msgid "Only active programs can be paused."
msgstr "Seuls les programmes actifs peuvent être mis en pause."

msgid "Invalid action."
msgstr "Action invalide."

msgid "Program not found."
msgstr "Programme non trouvé."

msgid "Program name must be 200 characters or fewer."
msgstr "Le nom du programme doit comporter 200 caractères ou moins."

msgid "Commission value is required."
msgstr "La valeur de la commission est requise."

msgid "Commission value must be positive."
msgstr "La valeur de la commission doit être positive."

msgid "Percentage cannot exceed 100%."
msgstr "Le pourcentage ne peut pas dépasser 100%."

msgid "Invalid commission value."
msgstr "Valeur de commission invalide."

msgid "Cookie lifetime must be between 1 and 365 days."
msgstr "La durée de vie du cookie doit être comprise entre 1 et 365 jours."

msgid "Invalid cookie lifetime."
msgstr "Durée de vie du cookie invalide."

msgid "Minimum payout must be positive."
msgstr "Le versement minimum doit être positif."

msgid "Invalid minimum payout."
msgstr "Versement minimum invalide."

msgid "Affiliate program created successfully."
msgstr "Le programme d'affiliation a été créé avec succès."

msgid "Program is live and accepting affiliates"
msgstr "Le programme est en ligne et accepte les affiliés"

msgid "Program is temporarily paused"
msgstr "Le programme est temporairement mis en pause"

msgid "Affiliate approved successfully."
msgstr "L'affilié a été approuvé avec succès."

msgid "Only pending affiliates can be approved."
msgstr "Seuls les affiliés en attente peuvent être approuvés."

msgid "Affiliate suspended successfully."
msgstr "L'affilié a été suspendu avec succès."

msgid "Only active affiliates can be suspended."
msgstr "Seuls les affiliés actifs peuvent être suspendus."

msgid "Affiliate activated successfully."
msgstr "L'affilié a été activé avec succès."

msgid "Affiliate cannot be activated from current status."
msgstr "L'affilié ne peut pas être activé à partir de son statut actuel."

msgid "Affiliate not found."
msgstr "Affilié non trouvé."

msgid "Membership approved successfully."
msgstr "La demande de membre a été approuvée avec succès."

msgid "Only pending memberships can be approved."
msgstr "Seuls les membres en attente peuvent être approuvés."

msgid "Membership rejected successfully."
msgstr "La demande de membre a été rejetée avec succès."

msgid "Only pending memberships can be rejected."
msgstr "Seuls les membres en attente peuvent être rejetés."

msgid "Membership not found."
msgstr "Membre non trouvé."

msgid "Invalid status."
msgstr "Statut invalide."

msgid "Program archived successfully."
msgstr "Le programme a été archivé avec succès."
