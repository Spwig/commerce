msgstr "Hanya program aktif yang dapat dijeda."

msgid "Invalid action."
msgstr "Tindakan tidak valid."

msgid "Program not found."
msgstr "Program tidak ditemukan."

msgid "Program name must be 200 characters or fewer."
msgstr "Nama program harus 200 karakter atau lebih sedikit."

msgid "Commission value is required."
msgstr "Nilai komisi diperlukan."

msgid "Commission value must be positive."
msgstr "Nilai komisi harus positif."

msgid "Percentage cannot exceed 100%."
msgstr "Persentase tidak dapat melebihi 100%."

msgid "Invalid commission value."
msgstr "Nilai komisi tidak valid."

msgid "Cookie lifetime must be between 1 and 365 days."
msgstr "Umur cookie harus antara 1 dan 365 hari."

msgid "Invalid cookie lifetime."
msgstr "Durasi cookie tidak valid."

msgid "Minimum payout must be positive."
msgstr "Pembayaran minimum harus positif."

msgid "Invalid minimum payout."
msgstr "Pembayaran minimum tidak valid."

