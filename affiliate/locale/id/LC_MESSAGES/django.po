msgid "You need an affiliate account to access this page."
msgstr "Anda membutuhkan akun afiliasi untuk mengakses halaman ini."

msgid "You need merchant access to view this page."
msgstr "Anda membutuhkan akses penjual untuk melihat halaman ini."

msgid "Get program statistics"
msgstr "Dapatkan statistik program"

msgid "Apply to join a program"
msgstr "Ajukan untuk bergabung dengan program"

msgid "You must be registered as an affiliate first."
msgstr "Anda harus terlebih dahulu terdaftar sebagai mitra afiliasi."

msgid "Application submitted successfully."
msgstr "Aplikasi berhasil dikirim."

msgid "Get affiliate dashboard data"
msgstr "Dapatkan data dashboard afiliasi"

msgid "Register as affiliate"
msgstr "Daftar sebagai afiliasi"

msgid ""
"Register as an affiliate. Supports both authenticated users and guest "
"registration (if allow_guest_registration is enabled). Creates affiliate "
"profile, saves custom form response if configured, and returns success with "
"affiliate code and redirect URL."
msgstr ""
"Daftar sebagai afiliasi. Mendukung pengguna yang sudah terautentikasi dan "
"pendaftaran tamu (jika allow_guest_registration diaktifkan). Membuat profil "
"afiliasi, menyimpan respons formulir kustom jika dikonfigurasi, dan "
"mengembalikan keberhasilan dengan kode afiliasi dan URL redirect."

msgid "Affiliate registered successfully"
msgstr "Afiliasi berhasil didaftarkan"

msgid "Validation error or duplicate affiliate account"
msgstr "Kesalahan validasi atau akun afiliasi duplikat"

msgid "Login required (guest registration disabled)"
msgstr "Login diperlukan (pendaftaran tamu dinonaktifkan)"

msgid "You must be logged in to register as an affiliate."
msgstr "Anda harus masuk untuk mendaftar sebagai afiliasi."

msgid "Email is required."
msgstr "Email diperlukan."

msgid "Password is required."
msgstr "Kata sandi diperlukan."

msgid "An account with this email already exists. Please log in instead."
msgstr "Akun dengan email ini sudah ada. Silakan masuk saja."

msgid "Failed to create user account. Please try again."
msgstr "Gagal membuat akun pengguna. Silakan coba lagi."

msgid "You already have an affiliate account."
msgstr "Anda sudah memiliki akun afiliasi."

msgid "You must accept the terms and conditions to register."
msgstr "Anda harus menerima ketentuan dan kondisi untuk mendaftar."

msgid "Thank you for registering! Your application is being reviewed."
msgstr "Terima kasih telah mendaftar! Permohonan Anda sedang ditinjau."

msgid "You must be an affiliate to create links."
msgstr "Anda harus menjadi mitra afiliasi untuk membuat tautan."

msgid "You are not approved for this program."
msgstr "Anda belum disetujui untuk program ini."

msgid "Program activated successfully."
msgstr "Program berhasil diaktifkan."

msgid "Program cannot be activated from its current status."
msgstr "Program tidak dapat diaktifkan dari status saat ini."

msgid "Program paused successfully."
