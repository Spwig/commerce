msgid ""
"Register as an affiliate. Supports both authenticated users and guest "
"registration (if allow_guest_registration is enabled). Creates affiliate "
"profile, saves custom form response if configured, and returns success with "
"affiliate code and redirect URL."
msgstr ""
"Зарегистрироваться как аффилиат. Поддерживает как авторизованных "
"пользователей, так и регистрацию гостей (если allow_guest_registration "
"включен). Создает профиль аффилиата, сохраняет ответ на пользовательскую "
"форму, если она настроена, и возвращает успех с кодом аффилиата и URL "
"перенаправления."

msgid "Affiliate registered successfully"
msgstr "Аффилиат успешно зарегистрирован"

msgid "Validation error or duplicate affiliate account"
msgstr "Ошибка валидации или дублирующийся аккаунт аффилиат"

msgid "Login required (guest registration disabled)"
msgstr "Требуется вход (регистрация гостей отключена)"

msgid "You must be logged in to register as an affiliate."
msgstr "Вы должны быть авторизованы для регистрации как партнер."

msgid "Email is required."
msgstr "Требуется электронная почта."

msgid "Password is required."
msgstr "Требуется пароль."

msgid "An account with this email already exists. Please log in instead."
msgstr ""
"Учетная запись с этим адресом электронной почты уже существует. Пожалуйста, "
"войдите вместо регистрации."

msgid "Failed to create user account. Please try again."
msgstr ""
"Не удалось создать учетную запись пользователя. Пожалуйста, попробуйте еще "
"раз."

msgid "You already have an affiliate account."
msgstr "У вас уже есть учетная запись партнера."

msgid "You must accept the terms and conditions to register."
msgstr "Вы должны принять условия и положения для регистрации."

msgid "Thank you for registering! Your application is being reviewed."
msgstr "Спасибо за регистрацию! Ваша заявка рассматривается."

msgid "You must be an affiliate to create links."
msgstr "Чтобы создавать ссылки, вы должны быть аффилиатом."

msgid "You are not approved for this program."
msgstr "Вам не одобрили участие в этой программе."

msgid "Program activated successfully."
msgstr "Программа успешно активирована."

msgid "Program cannot be activated from its current status."
msgstr "Программу нельзя активировать из текущего состояния."

msgid "Program paused successfully."
msgstr "Программа успешно приостановлена."

