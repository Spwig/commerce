msgid "You must accept the terms and conditions to register."
msgstr "Bạn phải chấp nhận các điều khoản và điều kiện để đăng ký."

msgid "Thank you for registering! Your application is being reviewed."
msgstr "Cảm ơn bạn đã đăng ký! Đơn đăng ký của bạn đang được xem xét."

msgid "You must be an affiliate to create links."
msgstr "Bạn phải là đại lý để tạo liên kết."

msgid "You are not approved for this program."
msgstr "Bạn chưa được phê duyệt cho chương trình này."

msgid "Program activated successfully."
msgstr "Chương trình đã được kích hoạt thành công."

msgid "Program cannot be activated from its current status."
msgstr "Chương trình không thể được kích hoạt từ trạng thái hiện tại của nó."

msgid "Program paused successfully."
msgstr "Chương trình đã được tạm dừng thành công."

msgid "Only active programs can be paused."
msgstr "Chỉ các chương trình đang hoạt động mới có thể được tạm dừng."

msgid "Invalid action."
msgstr "Hành động không hợp lệ."

msgid "Program not found."
msgstr "Không tìm thấy chương trình."

msgid "Program name must be 200 characters or fewer."
msgstr "Tên chương trình phải có ít nhất 200 ký tự hoặc ít hơn."

msgid "Commission value is required."
msgstr "Giá trị hoa hồng là bắt buộc."

msgid "Commission value must be positive."
msgstr "Giá trị hoa hồng phải là dương."

msgid "Percentage cannot exceed 100%."
msgstr "Tỷ lệ không thể vượt quá 100%."

msgid "Invalid commission value."
msgstr "Giá trị hoa hồng không hợp lệ."

msgid "Cookie lifetime must be between 1 and 365 days."
msgstr "Thời gian sống của cookie phải nằm trong khoảng từ 1 đến 365 ngày."

msgid "Invalid cookie lifetime."
msgstr "Thời gian sống cookie không hợp lệ."

msgid "Minimum payout must be positive."
msgstr "Số tiền thanh toán tối thiểu phải là dương."

msgid "Invalid minimum payout."
msgstr "Số tiền thanh toán tối thiểu không hợp lệ."

msgid "Affiliate program created successfully."
msgstr "Chương trình đại lý đã được tạo thành công."

msgid "Program is live and accepting affiliates"
msgstr "Chương trình đang hoạt động và đang chấp nhận đối tác"

msgid "Program is temporarily paused"
msgstr "Chương trình đang tạm dừng"

msgid "Affiliate approved successfully."
msgstr "Đại lý đã được phê duyệt thành công."

msgid "Only pending affiliates can be approved."
msgstr "Chỉ các đối tác đang chờ xử lý mới có thể được phê duyệt."

msgid "Affiliate suspended successfully."
msgstr "Đại lý đã bị đình chỉ thành công."

msgid "Only active affiliates can be suspended."
msgstr "Chỉ các đối tác đang hoạt động mới có thể bị đình chỉ."

msgid "Affiliate activated successfully."
msgstr "Đại lý đã được kích hoạt thành công."

msgid "Affiliate cannot be activated from current status."
msgstr "Đối tác không thể được kích hoạt từ trạng thái hiện tại."

msgid "Affiliate not found."
msgstr "Không tìm thấy đại lý."

msgid "Membership approved successfully."
msgstr "Thành viên đã được phê duyệt thành công."

msgid "Only pending memberships can be approved."
msgstr "Chỉ các thành viên đang chờ xử lý mới có thể được phê duyệt."

msgid "Membership rejected successfully."
msgstr "Thành viên đã bị từ chối thành công."

msgid "Only pending memberships can be rejected."
msgstr "Chỉ các thành viên đang chờ xử lý mới có thể bị từ chối."

msgid "Membership not found."
msgstr "Không tìm thấy thành viên."

msgid "Invalid status."
msgstr "Trạng thái không hợp lệ."

msgid "Program archived successfully."
msgstr "Chương trình đã được lưu trữ thành công."
