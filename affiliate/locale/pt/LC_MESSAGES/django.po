msgstr "Erro de validação ou conta de afiliado duplicada"

msgid "Login required (guest registration disabled)"
msgstr "Login necessário (registro de visitante desativado)"

msgid "You must be logged in to register as an affiliate."
msgstr "Você deve estar conectado para se registrar como afiliado."

msgid "Email is required."
msgstr "O e-mail é obrigatório."

msgid "Password is required."
msgstr "A senha é obrigatória."

msgid "An account with this email already exists. Please log in instead."
msgstr ""
"Uma conta com este endereço de e-mail já existe. Por favor, faça login em "
"vez disso."

msgid "Failed to create user account. Please try again."
msgstr "Falha ao criar a conta de usuário. Por favor, tente novamente."

msgid "You already have an affiliate account."
msgstr "Você já tem uma conta de afiliado."

msgid "You must accept the terms and conditions to register."
msgstr "Você deve aceitar os termos e condições para se registrar."

msgid "Thank you for registering! Your application is being reviewed."
msgstr "Obrigado por se registrar! Seu aplicativo está sendo revisado."

msgid "You must be an affiliate to create links."
msgstr "Você deve ser um afiliado para criar links."

msgid "You are not approved for this program."
msgstr "Você não está aprovado para este programa."

msgid "Program activated successfully."
msgstr "Programa ativado com sucesso."

msgid "Program cannot be activated from its current status."
msgstr "O programa não pode ser ativado a partir do seu status atual."

msgid "Program paused successfully."
msgstr "Programa pausado com sucesso."

msgid "Only active programs can be paused."
msgstr "Apenas programas ativos podem ser pausados."

msgid "Invalid action."
msgstr "Ação inválida."

msgid "Program not found."
msgstr "Programa não encontrado."

msgid "Program name must be 200 characters or fewer."
msgstr "O nome do programa deve ter 200 caracteres ou menos."

msgid "Commission value is required."
msgstr "O valor da comissão é obrigatório."

msgid "Commission value must be positive."
msgstr "O valor da comissão deve ser positivo."

msgid "Percentage cannot exceed 100%."
msgstr "A porcentagem não pode exceder 100%."

msgid "Invalid commission value."
msgstr "Valor de comissão inválido."

msgid "Cookie lifetime must be between 1 and 365 days."
msgstr "A vida útil do cookie deve ser entre 1 e 365 dias."

msgid "Invalid cookie lifetime."
msgstr "Tempo de vida do cookie inválido."

msgid "Minimum payout must be positive."
msgstr "O valor mínimo de pagamento deve ser positivo."

msgid "Invalid minimum payout."
msgstr "Valor mínimo de pagamento inválido."

msgid "Affiliate program created successfully."
msgstr "Programa de afiliados criado com sucesso."

msgid "Program is live and accepting affiliates"
msgstr "O programa está ativo e aceitando afiliados"

msgid "Program is temporarily paused"
msgstr "Programa está temporariamente pausado"

msgid "Affiliate approved successfully."
msgstr "Afiliado aprovado com sucesso."

msgid "Only pending affiliates can be approved."
msgstr "Apenas afiliados pendentes podem ser aprovados."

msgid "Affiliate suspended successfully."
msgstr "Afiliado suspenso com sucesso."

msgid "Only active affiliates can be suspended."
msgstr "Apenas afiliados ativos podem ser suspensos."

msgid "Affiliate activated successfully."
msgstr "Afiliado ativado com sucesso."

msgid "Affiliate cannot be activated from current status."
msgstr "O afiliado não pode ser ativado a partir do seu status atual."

msgid "Affiliate not found."
msgstr "Afiliado não encontrado."

msgid "Membership approved successfully."
msgstr "Membro aprovado com sucesso."

msgid "Only pending memberships can be approved."
msgstr "Apenas associações pendentes podem ser aprovadas."

msgid "Membership rejected successfully."
msgstr "Membro rejeitado com sucesso."

msgid "Only pending memberships can be rejected."
msgstr "Apenas associações pendentes podem ser rejeitadas."

msgid "Membership not found."
msgstr "Membro não encontrado."

msgid "Invalid status."
msgstr "Status inválido."

msgid "Program archived successfully."
msgstr "Programa arquivado com sucesso."
