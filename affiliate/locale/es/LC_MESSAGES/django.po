msgstr "Solicitud enviada con éxito."

msgid "Get affiliate dashboard data"
msgstr "Obtener datos del tablero de afiliado"

msgid "Register as affiliate"
msgstr "Registrarse como afiliado"

msgid ""
"Register as an affiliate. Supports both authenticated users and guest "
"registration (if allow_guest_registration is enabled). Creates affiliate "
"profile, saves custom form response if configured, and returns success with "
"affiliate code and redirect URL."
msgstr ""
"Regístrese como afiliado. Soporta tanto a usuarios autenticados como a "
"registros de invitados (si allow_guest_registration está habilitado). Crea "
"un perfil de afiliado, guarda la respuesta del formulario personalizado si "
"está configurado y devuelve un éxito con el código de afiliado y la URL de "
"redirección."

msgid "Affiliate registered successfully"
msgstr "Afiliado registrado con éxito"

msgid "Validation error or duplicate affiliate account"
msgstr "Error de validación o cuenta de afiliado duplicada"

msgid "Login required (guest registration disabled)"
msgstr "Inicio de sesión requerido (registro de invitados deshabilitado)"

msgid "You must be logged in to register as an affiliate."
msgstr "Debe iniciar sesión para registrarse como afiliado."

msgid "Email is required."
msgstr "El correo electrónico es requerido."

msgid "Password is required."
msgstr "La contraseña es requerida."

msgid "An account with this email already exists. Please log in instead."
msgstr ""
"Ya existe una cuenta con este correo electrónico. Por favor, inicie sesión "
"en su lugar."

msgid "Failed to create user account. Please try again."
msgstr "No se pudo crear la cuenta de usuario. Por favor, inténtelo de nuevo."

msgid "You already have an affiliate account."
msgstr "Ya tiene una cuenta de afiliado."

msgid "You must accept the terms and conditions to register."
msgstr "Debe aceptar los términos y condiciones para registrarse."

msgid "Thank you for registering! Your application is being reviewed."
msgstr "¡Gracias por registrarse! Su solicitud está siendo revisada."

msgid "You must be an affiliate to create links."
msgstr "Debes ser afiliado para crear enlaces."

msgid "You are not approved for this program."
msgstr "No estás aprobado para este programa."

msgid "Program activated successfully."
msgstr "Programa activado con éxito."

msgid "Program cannot be activated from its current status."
msgstr "El programa no puede ser activado desde su estado actual."

msgid "Program paused successfully."
msgstr "Programa pausado con éxito."

msgid "Only active programs can be paused."
msgstr "Solo los programas activos pueden ser pausados."

msgid "Invalid action."
msgstr "Acción inválida."

msgid "Program not found."
msgstr "Programa no encontrado."

msgid "Program name must be 200 characters or fewer."
msgstr "El nombre del programa debe tener 200 caracteres o menos."

msgid "Commission value is required."
msgstr "El valor de la comisión es requerido."

msgid "Commission value must be positive."
msgstr "El valor de la comisión debe ser positivo."

msgid "Percentage cannot exceed 100%."
msgstr "El porcentaje no puede exceder el 100%."

msgid "Invalid commission value."
msgstr "Valor de comisión inválido."

msgid "Cookie lifetime must be between 1 and 365 days."
msgstr "La vida útil de la cookie debe estar entre 1 y 365 días."

msgid "Invalid cookie lifetime."
msgstr "Tiempo de vida de la cookie inválido."

msgid "Minimum payout must be positive."
msgstr "El monto mínimo de pago debe ser positivo."

msgid "Invalid minimum payout."
msgstr "Monto mínimo de pago inválido."

msgid "Affiliate program created successfully."
msgstr "Programa de afiliados creado exitosamente."

msgid "Program is live and accepting affiliates"
msgstr "El programa está en vivo y aceptando afiliados"

msgid "Program is temporarily paused"
msgstr "El programa está temporalmente pausado"

msgid "Affiliate approved successfully."
msgstr "Afiliado aprobado exitosamente."

msgid "Only pending affiliates can be approved."
msgstr "Solo los afiliados pendientes pueden ser aprobados."

msgid "Affiliate suspended successfully."
msgstr "Afiliado suspendido exitosamente."

msgid "Only active affiliates can be suspended."
msgstr "Solo los afiliados activos pueden ser suspendidos."

msgid "Affiliate activated successfully."
msgstr "Afiliado activado exitosamente."

msgid "Affiliate cannot be activated from current status."
msgstr "El afiliado no puede ser activado desde su estado actual."

msgid "Affiliate not found."
msgstr "Afiliado no encontrado."

msgid "Membership approved successfully."
msgstr "Miembro aprobado exitosamente."

msgid "Only pending memberships can be approved."
msgstr "Solo las membresías pendientes pueden ser aprobadas."

msgid "Membership rejected successfully."
msgstr "Miembro rechazado exitosamente."

msgid "Only pending memberships can be rejected."
msgstr "Solo las membresías pendientes pueden ser rechazadas."

msgid "Membership not found."
msgstr "Miembro no encontrado."

msgid "Invalid status."
msgstr "Estado inválido."

msgid "Program archived successfully."
msgstr "Programa archivado exitosamente."
