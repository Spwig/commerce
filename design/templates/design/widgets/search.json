{
  "type": "search",
  "icon": "fa-search",
  "label": "Search",
  "groups": [
    {
      "id": "general",
      "title": "General Settings",
      "expanded": true,
      "fields": [
        {
          "key": "placeholder",
          "label": "Placeholder",
          "type": "text",
          "default": "Search...",
          "placeholder": "Search..."
        },
        {
          "key": "search_url",
          "label": "Search URL",
          "type": "url",
          "default": "/search/",
          "placeholder": "/search/"
        }
      ]
    },
    {
      "id": "autocomplete",
      "title": "Autocomplete",
      "expanded": true,
      "fields": [
        {
          "key": "autocomplete_enabled",
          "label": "Enable Autocomplete",
          "type": "toggle",
          "default": true
        },
        {
          "key": "max_results",
          "label": "Max Results",
          "type": "number",
          "default": 8,
          "min": 1,
          "max": 20
        },
        {
          "key": "debounce_ms",
          "label": "Debounce (ms)",
          "type": "number",
          "default": 300,
          "min": 100,
          "max": 1000
        },
        {
          "key": "min_chars",
          "label": "Min Characters",
          "type": "number",
          "default": 2,
          "min": 1,
          "max": 5
        },
        {
          "key": "show_recent",
          "label": "Show Recent Searches",
          "type": "toggle",
          "default": true
        },
        {
          "key": "show_image_preview",
          "label": "Show Image Previews",
          "type": "toggle",
          "default": true
        }
      ]
    },
    {
      "id": "categories",
      "title": "Category Filter",
      "expanded": false,
      "fields": [
        {
          "key": "show_categories",
          "label": "Show Category Dropdown",
          "type": "toggle",
          "default": false,
          "help": "Allow filtering by category"
        }
      ]
    },
    {
      "id": "display",
      "title": "Display Options",
      "expanded": false,
      "fields": [
        { "key": "show_text", "label": "Show Button Text", "type": "toggle", "default": false },
        { "key": "autofocus", "label": "Autofocus on Load", "type": "toggle", "default": false },
        {
          "key": "voice_search",
          "label": "Enable Voice Search",
          "type": "toggle",
          "default": false
        }
      ]
    }
  ]
}
