msgstr "현재 단계를 완료한 후 다음 단계를 자동으로 열きます."

msgid "Show step numbers"
msgstr "단계 번호 표시"

msgid "Display numbered circles next to each checkout step."
msgstr "각 체크아웃 단계 옆에 번호가 있는 원을 표시합니다."

msgid "Show trust badges"
msgstr "신뢰 배지 표시"

msgid "Display security and trust badges below the payment section."
msgstr "결제 섹션 아래에 보안 및 신뢰 배지를 표시합니다."

msgid "Show express checkout"
msgstr "빠른 결제 표시"

msgid "Show express checkout buttons (Apple Pay, Google Pay) at the top."
msgstr "상단에 빠른 체크아웃 버튼 (Apple Pay, Google Pay)을 표시합니다."

msgid "Display order summary alongside each step."
msgstr "각 단계와 함께 주문 요약을 표시합니다."

msgid "Progress indicator style"
msgstr "진행 지시기 스타일"

msgid "How the progress through checkout steps is displayed."
msgstr "체크아웃 단계를 통한 진행 상황이 어떻게 표시되는지."

msgid "Display security badges on the payment step."
msgstr "결제 단계에 보안 배지를 표시합니다."

msgid "Show express checkout buttons at the top of the first step."
msgstr "첫 번째 단계 상단에 빠른 체크아웃 버튼을 표시합니다."

msgid "Step transition animation"
msgstr "단계 전환 애니메이션"

msgid "Animation style when transitioning between steps."
msgstr "단계 간 전환 시 애니메이션 스타일."

msgid "Display a sticky order summary sidebar."
msgstr "고정된 주문 요약 사이드바를 표시합니다."

msgid "Sticky summary on scroll"
msgstr "스크롤 시 고정된 요약"

msgid "Keep the order summary visible while scrolling the form."
msgstr "폼을 스크롤하는 동안 주문 요약을 보입니다."

msgid "Display security badges near the payment section."
msgstr "결제 섹션 근처에 보안 배지를 표시합니다."

msgid "Show section dividers"
msgstr "섹션 구분선 표시"

msgid "Display visual dividers between form sections."
msgstr "폼 섹션 사이에 시각적인 구분선을 표시합니다."

msgid "Show express checkout buttons at the top."
msgstr "상단에 빠른 체크아웃 버튼을 표시합니다."

msgid "Show order summary"
msgstr "주문 요약 표시"

msgid "Display a compact order summary."
msgstr "간단한 주문 요약 표시."

msgid "Allow address change"
msgstr "주소 변경 허용"

msgid "Allow customers to modify their pre-filled address."
msgstr "고객이 사전에 입력된 주소를 수정할 수 있도록 허용합니다."

msgid "Display security badges below the place order button."
msgstr "주문하기 버튼 아래에 보안 배지를 표시합니다."

msgid "Fallback for new customers"
msgstr "신규 고객 대비 대체 옵션"

msgid "Template to use when customer has no saved details."
msgstr "고객이 저장된 정보가 없을 때 사용할 템플릿."

msgid "Show SKU"
msgstr "SKU 표시"

msgid "Display the product SKU on the product page."
msgstr "제품 페이지에 제품 SKU를 표시합니다."

msgid "Show brand name"
msgstr "브랜드 이름 표시"

msgid "Display the brand name above the product title."
msgstr "제품 제목 위에 브랜드 이름을 표시합니다."

msgid "Show breadcrumb"
msgstr "브레드크럼 표시"

msgid "Display breadcrumb navigation above the product."
msgstr "제품 위에 빵屑 네비게이션을 표시합니다."

msgid "Show short description"
msgstr "짧은 설명 표시"

msgid "Display the short description above the add-to-cart button."
msgstr "추가 버튼 위에 짧은 설명을 표시합니다."

msgid "Show social share buttons"
msgstr "소셜 공유 버튼 표시"

msgid "Display social media sharing buttons."
msgstr "소셜 미디어 공유 버튼 표시."

msgid "Show stock indicator"
msgstr "재고 지시표 표시"

msgid "Display stock availability status."
msgstr "재고 상태 표시."

msgid "Floating add-to-cart bar"
msgstr "상단에 추가 버튼 바 표시"

msgid "Show a sticky add-to-cart bar when the main button scrolls out of view."
msgstr "메인 버튼이 화면에서 사라질 때 고정된 추가 버튼 바를 표시합니다."

msgid "Floating bar position"
msgstr "상단 바 위치"

msgid "Where to show the floating add-to-cart bar."
msgstr "부유하는 추가 버튼 바를 표시할 위치."

msgid "Image zoom on hover"
msgstr "마우스 호버 시 이미지 확대"

msgid "Enable image magnification on hover."
msgstr "마우스 호버 시 이미지 확대 기능 활성화."

msgid "Info sections layout"
msgstr "정보 섹션 레이아웃"

msgid "How description, specifications, and reviews are displayed."
msgstr "설명, 사양 및 리뷰가 어떻게 표시되는지."

msgid "Display the product SKU."
msgstr "제품 SKU 표시."

msgid "Display breadcrumb navigation."
msgstr "브레드크럼 네비게이션 표시."

msgid "Display social sharing buttons."
msgstr "소셜 공유 버튼 표시."

msgid "Display stock availability."
msgstr "재고 상태 표시."

msgid "Show a sticky add-to-cart bar on scroll."
msgstr "스크롤 시 고정된 추가 버튼 바를 표시합니다."

msgid "Gallery hero height"
msgstr "갤러리 히어로 높이"

msgid "Height of the full-width gallery hero section."
msgstr "전체 너비 갤러리 히어로 섹션의 높이."

msgid "Content alignment"
msgstr "콘텐츠 정렬"

msgid "Alignment of product info below the gallery."
msgstr "갤러리 아래에 제품 정보의 정렬."

msgid "How description, specs, and reviews are displayed."
msgstr "설명, 사양 및 리뷰가 표시되는 방식."

msgid "Display the brand name."
msgstr "브랜드 이름 표시."

msgid "Sticky product info"
msgstr "고정된 제품 정보"

msgid "Keep product info sidebar visible while scrolling the gallery."
msgstr "갤러리 스크롤 시 제품 정보 사이드바를 보여줍니다."

msgid "Gallery grid columns"
msgstr "갤러리 격자 열"

msgid "Number of columns in the gallery grid."
msgstr "갤러리 그리드의 열 수."

msgid "Display the brand/publisher name."
msgstr "브랜드/출판사 이름 표시."

msgid "Instant delivery badge"
msgstr "즉시 배송 배지"

msgid "Show \"Instant Digital Delivery\" badge near add-to-cart."
msgstr "추가 버튼 근처에 \"즉시 디지털 배송\" 배지 표시."

msgid "Show features list"
msgstr "기능 목록 표시"

msgid "Display a \"What's Included\" checklist section."
msgstr "\"포함 내용\" 확인 목록 섹션을 표시합니다."

msgid "Show license info"
msgstr "라이선스 정보 표시"

msgid "Display license type and terms if available."
msgstr "라이선스 유형 및 조건이 있다면 표시합니다."

msgid "Display the short description in the header bar."
msgstr "헤더 바에 짧은 설명을 표시합니다."

msgid ""
"How description, specifications, and reviews are displayed below the editor."
msgstr "편집기 아래에 설명, 사양 및 리뷰가 어떻게 표시되는지 확인합니다."

msgid "Show category banner"
msgstr "카테고리 배너 표시"

msgid "Display a hero banner when the category has a banner image."
msgstr "카테고리에 배너 이미지가 있을 때 히어로 배너를 표시합니다."

msgid "Card image fallback"
msgstr "카드 이미지 대체"

msgid ""
"When a category has no image: show first product image, or a placeholder "
"icon."
msgstr ""
"카테고리에 이미지가 없을 경우: 첫 번째 제품 이미지 또는 플레이스홀더 아이콘"
"을 표시합니다."

msgid "Products per page"
msgstr "페이지당 제품 수"

msgid "Number of products to display per page."
msgstr "페이지당 표시할 제품 수."

msgid "Products per row"
msgstr "행당 제품 수"

msgid ""
"Number of products per row on desktop. Auto adjusts based on screen size."
msgstr "데스크탑의 행당 제품 수. 화면 크기에 따라 자동 조정됩니다."

msgid "Display breadcrumb navigation at the top of the page."
msgstr "페이지 상단에 빵屑 네비게이션을 표시합니다."

msgid "Show subcategories"
msgstr "하위 카테고리 표시"

msgid "Display subcategory chips when viewing a category with children."
msgstr ""
"자식 카테고리가 있는 카테고리를 보고 있을 때 하위 카테고리 칩을 표시합니다."

msgid "Show category description"
msgstr "카테고리 설명 표시"

msgid "Display the category description below the title."
msgstr "제목 아래에 카테고리 설명을 표시합니다."

msgid "Show sort bar"
msgstr "정렬 바 표시"

msgid "Display the sort and product count toolbar above the product grid."
msgstr "제품 그리드 위에 정렬 및 제품 수 툴바를 표시합니다."

msgid "Show product count"
msgstr "제품 수 표시"

msgid "Display the total number of products in the toolbar."
msgstr "툴바에 총 제품 수를 표시합니다."

msgid "Show help section"
msgstr "도움 섹션 표시"

msgid ""
"Display the \"Can't Find What You're Looking For?\" section at the bottom."
msgstr "하단에 \"필요한 항목을 찾지 못하셨나요?\" 섹션을 표시합니다."

msgid "Pagination style"
msgstr "페이지네이션 스타일"

msgid "How additional pages of products are loaded."
msgstr "추가 제품 페이지가 로드되는 방식."

msgid "Default sort order"
msgstr "기본 정렬 순서"

msgid "The default sort order when no sort is specified."
msgstr "정렬이 지정되지 않은 경우의 기본 정렬 순서."

msgid "Show product image"
msgstr "상품 이미지 표시"

msgid "Display product thumbnail images in each list row."
msgstr "리스트 행마다 제품 썸네일 이미지를 표시합니다."

msgid "Image position"
msgstr "이미지 위치"

msgid "Which side of the row the product image appears on."
msgstr "제품 이미지가 행의 어느 쪽에 나타나는지 설정합니다."

msgid "Display the product short description in each list row."
msgstr "리스트 행마다 제품의 짧은 설명을 표시합니다."

msgid "Display the sort and product count toolbar above the product list."
msgstr "제품 목록 위에 정렬 및 제품 수 도구 모음을 표시합니다."

msgid "Slides per view"
msgstr "보기당 슬라이드 수"

msgid "Number of product cards visible at once on desktop."
msgstr "데스크탑에서 한 번에 보이는 제품 카드 수."

msgid "Autoplay"
msgstr "자동 재생"

msgid "Automatically advance slides without user interaction."
msgstr "사용자 상호작용 없이 슬라이드를 자동으로 진행합니다."

msgid "Autoplay speed"
msgstr "자동 재생 속도"

msgid "Time in milliseconds between automatic slide transitions."
msgstr "자동 슬라이드 전환 사이의 시간(밀리초 단위)."

msgid "Show navigation arrows"
msgstr "네비게이션 화살표 표시"

msgid "Display left and right arrow buttons for manual navigation."
msgstr "수동 탐색을 위한 좌우 화살표 버튼을 표시합니다."

msgid "Show dot indicators"
msgstr "점 표시기 표시"

msgid "Display dot navigation below the carousel."
msgstr "캐러셀 아래에 점 네비게이션을 표시합니다."

msgid "Infinite loop"
msgstr "무한 루프"

msgid "Loop back to the beginning after reaching the last slide."
msgstr "마지막 슬라이드에 도달한 후 처음으로 루프됩니다."

msgid "Display the sort and product count toolbar above the carousel."
msgstr "캐러셀 위에 정렬 및 제품 수 도구 모음을 표시합니다."

msgid ""
"Maximum products in each carousel row. Rows stack vertically — extra "
"products create a new row below."
msgstr ""
"각 캐러셀 행에 표시할 최대 상품 수. 행은 수직으로 쌓이며, 추가 상품은 아래에 "
"새로운 행을 생성합니다."

msgid "Columns"
msgstr "열"

msgid "Number of columns in the masonry grid on desktop."
msgstr "데스크탑에서 마스터리 그리드의 열 수."

msgid "Gap size"
msgstr "간격 크기"

msgid "Spacing between items in the masonry grid."
msgstr "마스터리 그리드 내 항목 간 간격."

msgid "Display the sort and product count toolbar above the masonry grid."
msgstr "마스터리 그리드 위에 정렬 및 제품 수 도구 모음을 표시합니다."

msgid "Featured products count"
msgstr "특징 제품 수"

msgid "Number of products to highlight in the hero spotlight area."
msgstr "히어로 스폟라이트 영역에서 강조할 제품 수."

msgid "Hero layout"
msgstr "헤로 레이아웃"

msgid ""
"Layout of the featured product hero section. Full width spans the page; "
"split shows image and details side by side."
msgstr ""
"주요 상품 히어로 섹션의 레이아웃. 전체 너비는 페이지를 가득 채우고, 분할은 이"
"미지와 세부 정보를 옆으로 나란히 표시합니다."

msgid "Panels per row"
msgstr "행당 패널 수"

msgid ""
"Maximum category panels per accordion row. When categories exceed this, "
"additional rows are created below."
msgstr ""
"각 액ordion 행에 표시할 최대 카테고리 패널 수. 카테고리 수가 이 수치를 초과하"
"면 아래에 추가 행이 생성됩니다."

msgid "Panel height"
msgstr "패널 높이"

msgid ""
"Height of the accordion panels. Larger values create a more dramatic visual "
"effect."
msgstr "에코드 페널의 높이. 더 큰 값은 더 극적인 시각 효과를 만듭니다."

msgid "Expand ratio"
msgstr "확장 비율"

msgid "How much wider the active panel becomes relative to collapsed panels."
msgstr "접힌 패널에 비해 활성 패널이 얼마나 넓어지는지 설정합니다."

msgid "Transition speed"
msgstr "전환 속도"

msgid "Duration in milliseconds for panel expand and collapse animations."
msgstr "패널 확장 및 축소 애니메이션의 지속 시간(밀리초 단위)."

msgid "Overlay style"
msgstr "오버레이 스타일"

msgid "How the category name and info are displayed over the panel image."
msgstr "패널 이미지 위에 카테고리 이름 및 정보가 어떻게 표시되는지 설정합니다."

msgid "Mobile layout"
msgstr "모바일 레이아웃"

msgid ""
"How panels are displayed on mobile devices. Stack shows them vertically; "
"grid uses a compact grid."
msgstr ""
"모바일 기기에서 패널이 어떻게 표시되는지 설정합니다. 스택은 수직으로 표시하"
"고, 그리드는 컴팩트한 그리드를 사용합니다."

msgid "Show product count per category"
msgstr "카테고리별 제품 수 표시"

msgid "Display the number of products in each category panel."
msgstr "각 카테고리 패널에 있는 제품 수를 표시합니다."

msgid ""
"All checkout steps on one page with collapsible sections. Steps collapse "
"after completion, showing a summary. Great for general-purpose stores."
msgstr ""
"한 페이지에 모든 체크아웃 단계를 포함하고, 단계가 완료되면 요약을 표시하는 접"
"을 수 있는 섹션. 일반용 스토어에 적합합니다."

msgid ""
"One step per screen with a progress bar at top. Clean, focused input with "
"smooth transitions. Ideal for mobile-first stores and impulse purchases."
msgstr ""
"스크린당 하나의 단계와 상단의 진행 표시줄. 깔끔하고 집중적인 입력과 부드러운 "
"전환. 모바일 중심 스토어와 즉흥 구매에 이상적입니다."

msgid ""
"All checkout fields visible at once in a two-column layout. No collapsing or "
"stepping. Perfect for B2B, repeat buyers, and digital products."
msgstr ""
"두 열 레이아웃에서 모든 체크아웃 필드를 한 번에 표시. 접거나 단계별로 이동하"
"지 않음. B2B, 반복 구매자, 디지털 제품에 완벽합니다."

msgid ""
"Streamlined checkout for returning customers with saved addresses and "
"payment methods. Falls back to another template for new customers."
msgstr ""
"저장된 주소와 결제 수단이 있는 재방문 고객을 위한 간소화된 체크아웃. 새 고객"
"은 다른 템플릿으로 전환됩니다."

msgid ""
"Classic responsive grid of product cards with configurable columns. The most "
"versatile layout for general-purpose stores."
msgstr ""
"설정 가능한 열을 가진 전통적인 반응형 상품 카드 그리드. 일반용 스토어에 가장 "
"유연한 레이아웃입니다."

msgid ""
"Product rows with image and details side by side. Great for categories where "
"customers need to compare specs at a glance."
msgstr ""
"이미지와 세부 정보를 옆으로 나란히 표시하는 상품 행. 고객이 명세를 한눈에 비"
"교해야 하는 카테고리에 적합합니다."

msgid ""
"Horizontal product slider with navigation arrows and dot indicators. Ideal "
"for curated collections and featured selections."
msgstr ""
"네비게이션 화살표와 점 표시기를 가진 수평 상품 슬라이더. 엄선된 컬렉션과 주"
"요 선택 항목에 이상적입니다."

msgid ""
"Pinterest-style staggered grid that adapts to varying image heights. Best "
"for visual products like fashion, art, and photography."
msgstr ""
"Pinterest 스타일의 계단식 그리드로 이미지 높이에 따라 조정됩니다. 패션, 예"
"술, 사진과 같은 시각적 상품에 가장 적합합니다."

msgid ""
"Large hero spotlight for top products with a supporting grid below. Perfect "
"for categories with standout items or new arrivals."
msgstr ""
"상위 상품을 위한 대형 히어로 스폟라이트와 아래에 지원 그리드가 있습니다. 독특"
"한 상품이나 신상품이 있는 카테고리에 완벽합니다."

msgid ""
"Interactive horizontal image panels for browsing categories. Each panel "
"expands on hover to reveal the category. Best for 3-8 categories."
msgstr ""
"카테고리 탐색을 위한 상호작용형 수평 이미지 패널. 각 패널을 호버하면 카테고리"
"를 표시합니다. 3~8개 카테고리에 적합합니다."

msgid ""
"Gallery left, product info right. The familiar two-column layout used by "
"major retailers. Tabs below for details, specs, and reviews."
