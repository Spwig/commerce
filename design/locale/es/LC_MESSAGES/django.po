msgstr ""
"Mostrar la sección completa de biografía del autor debajo del artículo."

msgid "Grid columns"
msgstr "Columnas de cuadrícula"

msgid "Number of columns in the blog post grid."
msgstr "Número de columnas en la cuadrícula de la publicación del blog."

msgid "Show excerpt"
msgstr "Mostrar resumen"

msgid "Display post excerpt below the title."
msgstr "Mostrar el resumen de la publicación debajo del título."

msgid "Show date"
msgstr "Mostrar fecha"

msgid "Display the published date."
msgstr "Mostrar la fecha de publicación."

msgid "Show category"
msgstr "Mostrar categoría"

msgid "Display the post category badge."
msgstr "Mostrar el distintivo de categoría de la entrada."

msgid "Display post excerpt in each row."
msgstr "Mostrar el resumen de la publicación en cada fila."

msgid "Show image"
msgstr "Mostrar imagen"

msgid "Display featured image thumbnail."
msgstr "Mostrar miniatura de imagen destacada."

