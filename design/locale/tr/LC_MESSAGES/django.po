msgstr "Adımlar arasında geçiş yaparken animasyon stili."

msgid "Display a sticky order summary sidebar."
msgstr "Sabit bir sipariş özeti yan çubuğu görüntüle."

msgid "Sticky summary on scroll"
msgstr "Kaydırırken sabit sipariş özeti"

msgid "Keep the order summary visible while scrolling the form."
msgstr "Formu kaydırırken sipariş özeti görünür kalsın."

msgid "Display security badges near the payment section."
msgstr "Ödeme bölümü yakınında güvenlik badgesini göster."

msgid "Show section dividers"
msgstr "Bölüm ayırıcılarını göster"

msgid "Display visual dividers between form sections."
msgstr "Form bölümleri arasında görsel ayırıcılar göster."

msgid "Show express checkout buttons at the top."
msgstr "Üstte hızlı ödeme butonlarını göster."

msgid "Show order summary"
msgstr "Sipariş özeti göster"

msgid "Display a compact order summary."
msgstr "Sıkışık bir sipariş özeti göster."

msgid "Allow address change"
msgstr "Adres değişikliği izni ver"

msgid "Allow customers to modify their pre-filled address."
msgstr "Müşterilere ön doldurulmuş adresi değiştirmelerine izin ver."

msgid "Display security badges below the place order button."
msgstr "Sipariş ver butonunun altında güvenlik badgesini göster."

msgid "Fallback for new customers"
msgstr "Yeni müşteriler için yedek"

msgid "Template to use when customer has no saved details."
msgstr "Müşteri kaydedilmiş bilgisi yoksa kullanılacak şablon."

msgid "Show SKU"
msgstr "SKU'yu göster"

msgid "Display the product SKU on the product page."
msgstr "Ürün sayfasında ürün SKU'sunu göster."

msgid "Show brand name"
msgstr "Marka adını göster"

