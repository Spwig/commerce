msgstr "主題品牌"

msgid "Relative path within theme"
msgstr "主題內的相對路徑"

msgid "Whether this is critical CSS for initial render"
msgstr "這是否是用於初始渲染的關鍵 CSS"

msgid "Specific route for critical CSS (e.g., home, plp, pdp)"
msgstr "關鍵 CSS 的特定路由（例如：首頁、plp、pdp）"

