msgstr "已套用的 Token 迁移列表"

msgid "Per-component style overrides"
msgstr "每個組件的樣式覆蓋"

msgid "Custom CSS code (use sparingly)"
msgstr "自定義 CSS 程式碼（請謹慎使用）"

msgid "Compiled brand CSS"
msgstr "編譯的品牌 CSS"

msgid "Hash for cache busting"
msgstr "用於強制刷新快取的雜湊值"

msgid "Theme Branding"
msgstr "主題品牌"

