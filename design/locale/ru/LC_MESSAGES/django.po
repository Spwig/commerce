msgstr ""
"Количество карточек товаров, отображаемых одновременно на рабочем столе."

msgid "Autoplay"
msgstr "Автовоспроизведение"

msgid "Automatically advance slides without user interaction."
msgstr "Автоматически переключать слайды без взаимодействия пользователя."

msgid "Autoplay speed"
msgstr "Скорость автовоспроизведения"

msgid "Time in milliseconds between automatic slide transitions."
msgstr "Время в миллисекундах между автоматическими переходами слайдов."

msgid "Show navigation arrows"
msgstr "Показывать навигационные стрелки"

