msgstr "Exibir a seção completa da biografia do autor abaixo do artigo."

msgid "Grid columns"
msgstr "Colunas da grade"

msgid "Number of columns in the blog post grid."
msgstr "Número de colunas na grade da postagem do blog."

msgid "Show excerpt"
msgstr "Mostrar resumo"

msgid "Display post excerpt below the title."
msgstr "Exibir o resumo da postagem abaixo do título."

msgid "Show date"
msgstr "Mostrar data"

msgid "Display the published date."
msgstr "Exibir a data de publicação."

msgid "Show category"
msgstr "Mostrar categoria"

msgid "Display the post category badge."
msgstr "Exibir o distintivo da categoria da postagem."

msgid "Display post excerpt in each row."
msgstr "Exibir o resumo da postagem em cada linha."

msgid "Show image"
msgstr "Mostrar imagem"

msgid "Display featured image thumbnail."
msgstr "Exibir miniatura da imagem em destaque."

