msgstr ""
"Afficher la section de la biographie complète de l'auteur en dessous de "
"l'article."

msgid "Grid columns"
msgstr "Colonnes de grille"

msgid "Number of columns in the blog post grid."
msgstr "Nombre de colonnes dans la grille d'articles du blog."

msgid "Show excerpt"
msgstr "Afficher l'aperçu"

msgid "Display post excerpt below the title."
msgstr "Afficher l'aperçu de l'article en dessous du titre."

msgid "Show date"
msgstr "Afficher la date"

msgid "Display the published date."
msgstr "Afficher la date de publication."

msgid "Show category"
msgstr "Afficher la catégorie"

msgid "Display the post category badge."
msgstr "Afficher le badge de catégorie de la publication."

msgid "Display post excerpt in each row."
msgstr "Afficher l'aperçu de l'article dans chaque ligne."

msgid "Show image"
msgstr "Afficher l'image"

msgid "Display featured image thumbnail."
msgstr "Afficher la miniature de l'image mise en avant."

msgid "Show reading time"
msgstr "Afficher le temps de lecture"

msgid "Display estimated reading time."
msgstr "Afficher le temps de lecture estimé."

msgid "Featured posts"
msgstr "Publications en vedette"

msgid "Number of featured/hero posts at the top."
msgstr "Nombre de posts à l'honneur/héroïne en haut."

msgid "Display the post category."
msgstr "Afficher la catégorie de la publication."

