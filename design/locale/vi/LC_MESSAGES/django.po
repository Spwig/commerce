msgstr "Vị trí hình ảnh"

msgid "Which side of the row the product image appears on."
msgstr "Bên nào của hàng hiển thị hình ảnh sản phẩm."

msgid "Display the product short description in each list row."
msgstr "Hiển thị mô tả ngắn của sản phẩm trong mỗi hàng danh sách."

msgid "Display the sort and product count toolbar above the product list."
msgstr ""
"Hiển thị thanh công cụ sắp xếp và đếm sản phẩm phía trên danh sách sản phẩm."

msgid "Slides per view"
msgstr "Số lượng slide hiển thị"

msgid "Number of product cards visible at once on desktop."
msgstr "Số lượng thẻ sản phẩm có thể hiển thị cùng lúc trên máy tính để bàn."

msgid "Autoplay"
msgstr "Tự động phát"

msgid "Automatically advance slides without user interaction."
msgstr "Tự động chuyển slide mà không cần tương tác từ người dùng."

msgid "Autoplay speed"
msgstr "Tốc độ tự động phát"

msgid "Time in milliseconds between automatic slide transitions."
msgstr "Thời gian (tính bằng mili giây) giữa các lần chuyển slide tự động."

msgid "Show navigation arrows"
msgstr "Hiển thị mũi tên điều hướng"

msgid "Display left and right arrow buttons for manual navigation."
msgstr "Hiển thị nút mũi tên trái và phải để điều hướng thủ công."

msgid "Show dot indicators"
msgstr "Hiển thị chỉ báo chấm"

msgid "Display dot navigation below the carousel."
msgstr "Hiển thị thanh điều hướng chấm dưới carousel."

msgid "Infinite loop"
msgstr "Vòng lặp vô hạn"

msgid "Loop back to the beginning after reaching the last slide."
msgstr "Quay lại đầu sau khi đến slide cuối cùng."

msgid "Display the sort and product count toolbar above the carousel."
msgstr "Hiển thị thanh công cụ sắp xếp và đếm sản phẩm phía trên carousel."

msgid ""
"Maximum products in each carousel row. Rows stack vertically — extra "
"products create a new row below."
msgstr ""
"Số lượng tối đa sản phẩm trong mỗi hàng carousel. Các hàng sẽ được xếp chồng "
"lên nhau — các sản phẩm dư ra sẽ tạo thành hàng mới bên dưới."

msgid "Columns"
msgstr "Cột"

msgid "Number of columns in the masonry grid on desktop."
msgstr "Số cột trong lưới masonry trên máy tính để bàn."

msgid "Gap size"
msgstr "Khoảng cách"

msgid "Spacing between items in the masonry grid."
msgstr "Khoảng cách giữa các mục trong lưới masonry."

msgid "Display the sort and product count toolbar above the masonry grid."
msgstr "Hiển thị thanh công cụ sắp xếp và đếm sản phẩm phía trên lưới masonry."

msgid "Featured products count"
msgstr "Số lượng sản phẩm nổi bật"

msgid "Number of products to highlight in the hero spotlight area."
msgstr "Số lượng sản phẩm cần nổi bật trong khu vực spotlight trang chủ."

msgid "Hero layout"
msgstr "Bố cục hero"

msgid ""
"Layout of the featured product hero section. Full width spans the page; "
"split shows image and details side by side."
msgstr ""
"Bố cục của phần giới thiệu sản phẩm nổi bật. Chiếm toàn bộ chiều rộng trang; "
"chế độ chia sẽ hiển thị hình ảnh và chi tiết song song nhau."

msgid "Panels per row"
msgstr "Số lượng bảng mỗi hàng"

msgid ""
"Maximum category panels per accordion row. When categories exceed this, "
"additional rows are created below."
msgstr ""
"Số lượng tối đa panel danh mục mỗi hàng accordion. Khi số danh mục vượt quá "
"con số này, các hàng mới sẽ được tạo ra bên dưới."

msgid "Panel height"
msgstr "Chiều cao bảng"

msgid ""
"Height of the accordion panels. Larger values create a more dramatic visual "
"effect."
msgstr ""
"Chiều cao của các panel accordion. Giá trị lớn hơn sẽ tạo hiệu ứng thị giác "
"mạnh mẽ hơn."

msgid "Expand ratio"
msgstr "Tỷ lệ mở rộng"

msgid "How much wider the active panel becomes relative to collapsed panels."
msgstr ""
"Độ rộng lớn hơn bao nhiêu của panel đang hoạt động so với các panel đã thu "
"gọn."

msgid "Transition speed"
msgstr "Tốc độ chuyển tiếp"

msgid "Duration in milliseconds for panel expand and collapse animations."
msgstr ""
"Thời gian (tính bằng mili giây) cho các hiệu ứng mở rộng và thu gọn panel."

msgid "Overlay style"
msgstr "Phong cách lớp phủ"

msgid "How the category name and info are displayed over the panel image."
msgstr "Cách hiển thị tên danh mục và thông tin trên hình ảnh panel."

msgid "Mobile layout"
msgstr "Bố cục di động"

msgid ""
"How panels are displayed on mobile devices. Stack shows them vertically; "
"grid uses a compact grid."
msgstr ""
"Cách hiển thị các panel trên thiết bị di động. Stack hiển thị chúng theo "
"chiều dọc; grid sử dụng lưới gọn gàng."

msgid "Show product count per category"
msgstr "Hiển thị số lượng sản phẩm theo danh mục"

msgid "Display the number of products in each category panel."
msgstr "Hiển thị số lượng sản phẩm trong mỗi panel danh mục."

msgid ""
"All checkout steps on one page with collapsible sections. Steps collapse "
"after completion, showing a summary. Great for general-purpose stores."
msgstr ""
"Tất cả các bước thanh toán trên một trang với các phần có thể thu gọn. Các "
"bước sẽ thu gọn sau khi hoàn thành, hiển thị tóm tắt. Lý tưởng cho các cửa "
"hàng đa mục đích."

msgid ""
"One step per screen with a progress bar at top. Clean, focused input with "
"smooth transitions. Ideal for mobile-first stores and impulse purchases."
msgstr ""
"Một bước cho mỗi màn hình với thanh tiến trình ở trên. Nhập liệu sạch sẽ, "
"tập trung với chuyển đổi mượt. Lý tưởng cho các cửa hàng ưu tiên di động và "
"mua sắm bốc đồng."

msgid ""
"All checkout fields visible at once in a two-column layout. No collapsing or "
"stepping. Perfect for B2B, repeat buyers, and digital products."
msgstr ""
"Tất cả các trường thanh toán hiển thị cùng lúc trong bố cục hai cột. Không "
"thu gọn hoặc bước. Hoàn hảo cho B2B, khách hàng quay lại và sản phẩm kỹ "
"thuật số."

msgid ""
"Streamlined checkout for returning customers with saved addresses and "
"payment methods. Falls back to another template for new customers."
msgstr ""
"Quy trình thanh toán được tối ưu cho khách hàng quay lại với địa chỉ và "
"phương thức thanh toán đã lưu. Quay về mẫu khác cho khách hàng mới."

msgid ""
"Classic responsive grid of product cards with configurable columns. The most "
"versatile layout for general-purpose stores."
msgstr ""
"Lưới sản phẩm đáp ứng cổ điển với các cột có thể cấu hình. Bố cục linh hoạt "
"nhất cho các cửa hàng đa dụng."

msgid ""
"Product rows with image and details side by side. Great for categories where "
"customers need to compare specs at a glance."
msgstr ""
"Hàng sản phẩm với hình ảnh và chi tiết hiển thị song song. Lý tưởng cho các "
"danh mục mà khách hàng cần so sánh thông số một cách nhanh chóng."

msgid ""
"Horizontal product slider with navigation arrows and dot indicators. Ideal "
"for curated collections and featured selections."
msgstr ""
"Thanh trượt sản phẩm ngang với mũi tên điều hướng và chỉ báo chấm. Lý tưởng "
"cho các bộ sưu tập được chọn lọc và các lựa chọn nổi bật."

msgid ""
"Pinterest-style staggered grid that adapts to varying image heights. Best "
"for visual products like fashion, art, and photography."
msgstr ""
"Lưới staggered kiểu Pinterest thích ứng với độ cao hình ảnh khác nhau. Lý "
"tưởng cho các sản phẩm mang tính thị giác như thời trang, nghệ thuật và "
"nhiếp ảnh."

msgid ""
"Large hero spotlight for top products with a supporting grid below. Perfect "
"for categories with standout items or new arrivals."
msgstr ""
"Đèn flash hero lớn cho các sản phẩm hàng đầu với lưới hỗ trợ bên dưới. Lý "
"tưởng cho các danh mục có sản phẩm nổi bật hoặc mới ra mắt."

msgid ""
"Interactive horizontal image panels for browsing categories. Each panel "
"expands on hover to reveal the category. Best for 3-8 categories."
msgstr ""
"Các panel hình ảnh ngang tương tác để duyệt danh mục. Mỗi panel sẽ mở rộng "
"khi di chuột để hiển thị danh mục. Lý tưởng cho 3-8 danh mục."

msgid ""
"Gallery left, product info right. The familiar two-column layout used by "
"major retailers. Tabs below for details, specs, and reviews."
msgstr ""
"Gallery bên trái, thông tin sản phẩm bên phải. Bố cục quen thuộc hai cột "
"được các nhà bán lẻ lớn sử dụng. Các tab bên dưới cho chi tiết, thông số kỹ "
"thuật và đánh giá."

msgid ""
"Large hero gallery spanning the full width, with product info centered "
"below. Editorial feel that emphasizes product imagery. Great for lifestyle "
"and luxury brands."
msgstr ""
"Gallery hero lớn trải dài toàn bộ chiều rộng, với thông tin sản phẩm được "
"căn giữa phía dưới. Cảm giác như một ấn phẩm nhấn mạnh hình ảnh sản phẩm. Lý "
"tưởng cho thương hiệu lối sống và cao cấp."

msgid ""
"Gallery-heavy 60/40 layout with a sticky info sidebar. Shows more images by "
"default. Ideal for jewelry, furniture, art, and handmade products."
msgstr ""
"Bố cục 60/40 nặng gallery với thanh bên thông tin dính. Hiển thị nhiều hình "
"ảnh hơn theo mặc định. Lý tưởng cho trang sức, nội thất, nghệ thuật và sản "
"phẩm thủ công."

msgid ""
"Optimized for digital products with feature lists, instant delivery badges, "
"license info, and no shipping-related UI. Perfect for software, ebooks, and "
"courses."
msgstr ""
"Được tối ưu cho sản phẩm kỹ thuật số với danh sách tính năng, nhãn giao hàng "
"tức thì, thông tin giấy phép và không có giao diện liên quan đến vận chuyển. "
"Hoàn hảo cho phần mềm, sách điện tử và khóa học."

msgid "Designer"
msgstr "Thiết kế"

msgid ""
"Full-width design editor with compact product info bar. Optimized for "
"customizable products where the visual editor is the primary interaction."
msgstr ""
"Trình chỉnh sửa thiết kế toàn màn hình với thanh thông tin sản phẩm gọn "
"gàng. Được tối ưu cho các sản phẩm có thể tùy chỉnh, nơi trình chỉnh sửa "
"trực quan là phương thức tương tác chính."

msgid ""
"Full-width featured image at top, article body below with sidebar. "
"Traditional blog layout with categories, tags, and subscribe."
msgstr ""
"Hình ảnh nổi bật chiếm toàn bộ chiều rộng ở trên cùng, phần nội dung bài "
"viết phía dưới với thanh bên. Giao diện blog truyền thống với các danh mục, "
"thẻ và chức năng đăng ký."

msgid ""
"Clean centered reading experience with no sidebar. Focus on typography and "
"content with comfortable reading width."
msgstr ""
"Trải nghiệm đọc trung tâm, sạch sẽ không có thanh bên. Tập trung vào kiểu "
"chữ và nội dung với chiều rộng đọc thoải mái."

msgid ""
"Large hero image, author bio section, and editorial feel with sidebar. Great "
"for long-form content and storytelling."
msgstr ""
"Hình ảnh hero lớn, phần thông tin tác giả và cảm giác biên tập với thanh "
"bên. Lý tưởng cho nội dung dài và kể chuyện."

msgid ""
"Edge-to-edge featured image hero with wide content area and no sidebar. "
"Immersive layout for visual storytelling."
msgstr ""
"Ảnh nổi bật từ mép này đến mép kia với khu vực nội dung rộng và không thanh "
"bên. Bố cục đắm chìm cho kể chuyện trực quan."

msgid ""
"Card-based responsive grid with featured images, titles, and excerpts. "
"Classic blog homepage layout."
msgstr ""
"Lưới đáp ứng dựa trên thẻ với hình ảnh nổi bật, tiêu đề và các đoạn trích. "
"Bố cục trang chủ blog cổ điển."

msgid ""
"Full-width article rows with image on left and text on right. Scannable "
"format for content-heavy blogs."
msgstr ""
"Dòng bài viết chiếm toàn bộ chiều rộng với hình ảnh bên trái và văn bản bên "
"phải. Định dạng dễ quét cho các blog có nội dung dày đặc."

msgid ""
"Featured post hero at top with mixed grid and list layout below. Editorial "
"magazine look and feel."
msgstr ""
"Hình ảnh nổi bật ở trên cùng với bố cục lưới và danh sách pha trộn bên dưới. "
"Phong cách như một tạp chí biên tập."

msgid ""
"Title-and-date list with no images. Clean, text-focused index page for blogs "
"focused on writing."
msgstr ""
"Danh sách tiêu đề và ngày tháng không có hình ảnh. Trang chỉ mục sạch sẽ, "
"tập trung vào văn bản cho blog tập trung vào viết lách."

msgid "Show sidebar"
msgstr "Hiển thị thanh bên"

msgid "Display sidebar with search, categories, tags, and subscribe."
msgstr "Hiển thị thanh bên với tính năng tìm kiếm, danh mục, thẻ và đăng ký."

msgid "Show author"
msgstr "Hiển thị tác giả"

msgid "Display the post author name and avatar."
msgstr "Hiển thị tên và hình đại diện của tác giả bài viết."

msgid "Show share buttons"
msgstr "Hiển thị nút chia sẻ"

msgid "Display social sharing buttons after the article."
msgstr "Hiển thị nút chia sẻ xã hội sau bài viết."

msgid "Show related posts"
msgstr "Hiển thị bài viết liên quan"

msgid "Display related articles after the post content."
msgstr "Hiển thị các bài viết liên quan sau nội dung bài viết."

msgid "Show subscribe CTA"
msgstr "Hiển thị lời kêu gọi đăng ký"

msgid "Display a subscribe call-to-action after the article."
msgstr "Hiển thị lời kêu gọi đăng ký sau bài viết."

msgid "Display the post author name."
msgstr "Hiển thị tên tác giả bài viết."

msgid "Content width"
msgstr "Chiều rộng nội dung"

msgid "Maximum width of the article content."
msgstr "Chiều rộng tối đa của nội dung bài viết."

msgid "Show author bio"
msgstr "Hiển thị tiểu sử tác giả"

msgid "Display full author biography section below the article."
msgstr "Hiển thị phần tiểu sử đầy đủ của tác giả dưới bài viết."

msgid "Grid columns"
msgstr "Cột lưới"

msgid "Number of columns in the blog post grid."
msgstr "Số cột trong lưới bài viết blog."

msgid "Show excerpt"
msgstr "Hiển thị tóm tắt"

msgid "Display post excerpt below the title."
msgstr "Hiển thị phần trích dẫn bài viết dưới tiêu đề."

msgid "Show date"
msgstr "Hiển thị ngày"

msgid "Display the published date."
msgstr "Hiển thị ngày đăng."

msgid "Show category"
msgstr "Hiển thị danh mục"

msgid "Display the post category badge."
msgstr "Hiển thị nhãn danh mục bài viết."

msgid "Display post excerpt in each row."
msgstr "Hiển thị phần trích dẫn bài viết trong mỗi hàng."

msgid "Show image"
msgstr "Hiển thị hình ảnh"

msgid "Display featured image thumbnail."
msgstr "Hiển thị hình ảnh thu nhỏ nổi bật."

msgid "Show reading time"
msgstr "Hiển thị thời gian đọc"

msgid "Display estimated reading time."
msgstr "Hiển thị thời gian đọc ước tính."

msgid "Featured posts"
msgstr "Bài viết nổi bật"

msgid "Number of featured/hero posts at the top."
msgstr "Số lượng bài viết nổi bật/hero ở trên cùng."

msgid "Display the post category."
msgstr "Hiển thị danh mục bài viết."

msgid "Manage design tokens for consistent styling across your store"
msgstr ""
"Quản lý các token thiết kế để có kiểu dáng nhất quán trên toàn cửa hàng"

