msgid "General"
msgstr "ทั่วไป"

msgid "Autocomplete"
msgstr "การเติมคำอัตโนมัติ"

msgid "Autocomplete Display"
msgstr "การแสดงผลการเติมคำอัตโนมัติ"

msgid "Content Types"
msgstr "ประเภทเนื้อหา"

msgid "Deep Indexing"
msgstr "การจัดทำดัชนีแบบลึก"

msgid "Fuzzy Matching"
msgstr "การจับคู่แบบคลุมเครือ"

msgid "Relevance Weights"
msgstr "น้ำหนักความเกี่ยวข้อง"

msgid ""
"Adjust the relevance weights for different content types. Higher values (up "
"to 2.0) increase importance."
msgstr ""
"ปรับน้ำหนักความเกี่ยวข้องสำหรับประเภทเนื้อหาต่าง ๆ ค่าที่สูงขึ้น (สูงสุด 2.0) จะเพิ่มความสำคัญ"

msgid "Caching"
msgstr "การเก็บแคช"

msgid "Analytics"
msgstr "การวิเคราะห์"

msgid "Pagination"
msgstr "การแบ่งหน้า"

msgid "Basic Information"
msgstr "ข้อมูลพื้นฐาน"

msgid "Content Configuration"
msgstr "การตั้งค่าเนื้อหา"

msgid "Exclusions"
msgstr "รายการที่ไม่ต้องการให้แสดง"

msgid "Metadata"
msgstr "เมตาดาต้า"

msgid "All"
msgstr "ทั้งหมด"

msgid "Scope"
msgstr "ขอบเขต"

msgid "Optionally limit this synonym to a specific language or search engine."
msgstr "จำกัดคำสังเคราะห์นี้ให้ใช้ได้เฉพาะภาษาหรือเครื่องมือค้นหาเฉพาะ (เลือกได้)"

msgid "Synonyms"
msgstr "คำสังเคราะห์"

msgid "Language"
msgstr "ภาษา"

msgid "Redirect"
msgstr "เปลี่ยนเส้นทาง"

msgid "Statistics"
msgstr "สถิติ"

msgid "Redirect URL"
msgstr "URL สำหรับการเปลี่ยนเส้นทาง"

msgid "Text Preview"
msgstr "แสดงตัวอย่างข้อความ"

msgid "Search query"
msgstr "คำค้นหา"

msgid "Language code (e.g., en, es, fr)"
msgstr "รหัสภาษา (เช่น en, es, fr)"

msgid "Search engine slug"
msgstr "ชื่อสั้นสำหรับเครื่องมือค้นหา"

msgid "Max results per type"
msgstr "ผลลัพธ์สูงสุดต่อประเภท"

msgid "Autocomplete search"
msgstr "ค้นหาแบบอัตโนมัติ"

msgid ""
"Fast predictive search suggestions. Returns products, categories, brands, "
"and blog posts."
msgstr ""
"ข้อเสนอการค้นหาที่คาดการณ์ล่วงหน้าอย่างรวดเร็ว คืนผลลัพธ์เป็นสินค้า หมวดหมู่ แบรนด์ และบล็อก"

msgid "Language code"
msgstr "รหัสภาษา"

msgid "Filter by type (product/category/brand/blog_post)"
msgstr "กรองตามประเภท (สินค้า/หมวดหมู่/แบรนด์/บล็อกโพสต์)"

msgid "Filter by category ID"
msgstr "กรองตาม ID หมวดหมู่"

msgid "Filter by brand ID"
msgstr "กรองตาม ID แบรนด์"

msgid "Minimum price"
msgstr "ราคาขั้นต่ำ"

msgid "Maximum price"
msgstr "ราคาสูงสุด"

msgid "Only in-stock items"
msgstr "เฉพาะสินค้าที่มีในสต็อก"

msgid "Sort order (relevance/price_asc/price_desc/newest)"
msgstr "ลำดับการจัดเรียง (ความเกี่ยวข้อง/ราคาต่ำสูง/ราคาสูงต่ำ/ใหม่ที่สุด)"

msgid "Page number"
msgstr "เลขหน้า"

msgid "Results per page"
msgstr "ผลลัพธ์ต่อหน้า"

msgid "Full search results"
msgstr "ผลลัพธ์การค้นหาทั้งหมด"

msgid "Paginated search results with facets and filtering."
msgstr "ผลลัพธ์การค้นหาแบบแบ่งหน้า พร้อมฟิลเตอร์และตัวกรอง"

msgid "Number of days to analyze"
msgstr "จำนวนวันในการวิเคราะห์"

msgid "Max results"
msgstr "ผลลัพธ์สูงสุด"

msgid "Trending searches"
msgstr "การค้นหาที่ได้รับความนิยม"

msgid "Popular search queries over the specified period."
msgstr "คำค้นหาที่นิยมในช่วงเวลาที่กำหนด"

msgid "Search settings"
msgstr "การตั้งค่าการค้นหา"

msgid "Public search configuration for frontend JS."
msgstr "การตั้งค่าการค้นหาสำหรับ frontend JS."

msgid "Track click"
msgstr "ติดตามการคลิก"

msgid "Record a click on a search result for analytics."
msgstr "บันทึกการคลิกผลการค้นหาเพื่อวิเคราะห์ข้อมูล"

msgid "Spelling suggestions"
msgstr "คำแนะนำการสะกด"

msgid "Suggest spelling corrections for misspelled queries."
msgstr "แนะนำการแก้ไขคำที่สะกดผิดสำหรับคำค้นหาที่ผิดพลาด"

msgid "List search engines"
msgstr "รายการเครื่องมือค้นหา"

msgid "Get list of available search engines."
msgstr "ดึงรายการเครื่องมือค้นหาที่พร้อมใช้งาน"

msgid "Search"
msgstr "ค้นหา"

msgid "Search Enabled"
msgstr "เปิดใช้งานการค้นหา"

msgid "Enable or disable search functionality globally"
msgstr "เปิดหรือปิดฟังก์ชันค้นหาทั่วระบบ"

msgid "Minimum Query Length"
msgstr "ความยาวขั้นต่ำของคำค้นหา"

msgid "Minimum number of characters required to trigger search"
msgstr "จำนวนตัวอักษรขั้นต่ำที่จำเป็นในการเริ่มต้นการค้นหา"

msgid "Autocomplete Enabled"
msgstr "เปิดใช้งานการเติมคำอัตโนมัติ"

msgid "Show predictive search suggestions as user types"
msgstr "แสดงคำแนะนำการค้นหาที่คาดการณ์ได้ขณะผู้ใช้พิมพ์"

msgid "Autocomplete Max Results"
msgstr "จำนวนผลลัพธ์สูงสุดของการเติมคำอัตโนมัติ"

msgid "Maximum number of suggestions per content type"
msgstr "จำนวนคำแนะนำสูงสุดต่อประเภทเนื้อหา"

msgid "Autocomplete Debounce (ms)"
msgstr "การเลื่อนการตอบสนอง (ms)"

msgid "Delay in milliseconds before triggering autocomplete"
msgstr "ช่วงเวลาในการรอ (มิลลิวินาที) ก่อนที่จะเริ่มต้นการแนะนำอัตโนมัติ"

msgid "Show Thumbnails"
msgstr "แสดงภาพย่อ"

msgid "Display product/content thumbnails in search results"
msgstr "แสดงรูปภาพย่อของสินค้า/เนื้อหาในผลลัพธ์การค้นหา"

msgid "Show Product Thumbnail"
msgstr "แสดงภาพย่อของสินค้า"

msgid "Display product images in autocomplete dropdown"
msgstr "แสดงรูปภาพของสินค้าในรายการแนะนำอัตโนมัติ"

msgid "Show Product Description"
msgstr "แสดงคำอธิบายสินค้า"

msgid "Display short description in autocomplete dropdown"
msgstr "แสดงคำอธิบายสั้น ๆ ในรายการแนะนำอัตโนมัติ"

msgid "Show Product Price"
msgstr "แสดงราคาสินค้า"

msgid "Display price in autocomplete dropdown"
msgstr "แสดงราคาในรายการเติมคำอัตโนมัติ"

msgid "Show Product SKU"
msgstr "แสดง SKU ของสินค้า"

msgid "Display SKU in autocomplete dropdown"
msgstr "แสดง SKU ในรายการเติมคำอัตโนมัติ"

msgid "Show Product Stock Status"
msgstr "แสดงสถานะสต็อกสินค้า"

msgid "Display stock availability badge in autocomplete dropdown"
msgstr "แสดงป้ายสถานะสต็อกในรายการแนะนำอัตโนมัติ"

msgid "Show Blog Featured Image"
msgstr "แสดงภาพหลักของบล็อก"

msgid "Display featured image in blog post autocomplete results"
msgstr "แสดงรูปภาพหลักในผลลัพธ์การแนะนำอัตโนมัติของโพสต์บล็อก"

msgid "Show Blog Excerpt"
msgstr "แสดงสรุปบทความบล็อก"

msgid "Display excerpt in blog post autocomplete results"
msgstr "แสดงเนื้อหาสั้น ๆ ในผลลัพธ์การแนะนำอัตโนมัติของโพสต์บล็อก"

msgid "Blog Excerpt Length"
msgstr "ความยาวสรุปบทความบล็อก"

msgid "Maximum characters to show for blog excerpts"
msgstr "จำนวนตัวอักษรสูงสุดที่แสดงในเนื้อหาสั้น ๆ ของบล็อก"

msgid "Show Category Thumbnail"
msgstr "แสดงภาพย่อของหมวดหมู่"

msgid "Display category image in autocomplete dropdown"
msgstr "แสดงรูปภาพของหมวดหมู่ในรายการแนะนำอัตโนมัติ"

msgid "Show Category Product Count"
msgstr "แสดงจำนวนสินค้าในหมวดหมู่"

msgid "Display product count in category autocomplete results"
msgstr "แสดงจำนวนสินค้าในผลลัพธ์การแนะนำอัตโนมัติของหมวดหมู่"

msgid "Show Brand Logo"
msgstr "แสดงโลโก้แบรนด์"

msgid "Display brand logo in autocomplete dropdown"
msgstr "แสดงโลโก้แบรนด์ในรายการแนะนำอัตโนมัติ"

msgid "Show Brand Product Count"
msgstr "แสดงจำนวนสินค้าของแบรนด์"

msgid "Display product count in brand autocomplete results"
msgstr "แสดงจำนวนสินค้าในผลลัพธ์การแนะนำอัตโนมัติของแบรนด์"

msgid "Search Products"
msgstr "ค้นหาสินค้า"

msgid "Include products in search results"
msgstr "รวมสินค้าในผลลัพธ์การค้นหา"

msgid "Search Categories"
msgstr "ค้นหาหมวดหมู่"

msgid "Include categories in search results"
msgstr "รวมหมวดหมู่ในผลลัพธ์การค้นหา"

msgid "Search Brands"
msgstr "ค้นหาแบรนด์"

msgid "Include brands in search results"
msgstr "รวมแบรนด์ในผลลัพธ์การค้นหา"

msgid "Search Blog Posts"
msgstr "ค้นหาบทความบล็อก"

msgid "Include blog posts in search results"
msgstr "รวมโพสต์บล็อกในผลลัพธ์การค้นหา"

msgid "Index SKUs"
msgstr "จัดทำดัชนี SKU"

msgid "Include product SKUs in search"
msgstr "รวม SKU ของสินค้าในการค้นหา"

msgid "Index Attributes"
msgstr "จัดทำดัชนีคุณสมบัติ"

msgid "Include product attributes (color, size, etc.) in search"
msgstr "รวมคุณสมบัติของสินค้า (สี, ขนาด, ฯลฯ) ในการค้นหา"

msgid "Index Custom Fields"
msgstr "จัดทำดัชนีฟิลด์เฉพาะ"

msgid "Include custom product fields in search"
msgstr "รวมฟิลด์สินค้าแบบกำหนดเองในการค้นหา"

msgid "Index Reviews"
msgstr "จัดทำดัชนีรีวิว"

msgid "Include product review content in search"
msgstr "รวมเนื้อหาของรีวิวสินค้าในการค้นหา"

msgid "Index Documents"
msgstr "จัดทำดัชนีเอกสาร"

msgid "Index text content from digital asset documents (PDFs, Office files)"
msgstr "ดัชนีเนื้อหาข้อความจากเอกสารสินทรัพย์ดิจิทัล (PDF, เอกสาร Office)"

msgid "Fuzzy Matching Enabled"
msgstr "เปิดใช้งานการจับคู่แบบคลุมเครือ"

msgid "Enable typo tolerance in search queries"
msgstr "เปิดใช้งานการจัดการความผิดพลาดในการพิมพ์ในคำค้นหา"

msgid "Fuzzy Threshold"
msgstr "ค่าความคลุมเครือ"

msgid "Similarity threshold for fuzzy matching (0-1, higher = stricter)"
msgstr "ระดับความคล้ายคลึงสำหรับการจับคู่แบบคลุมเครือ (0-1, ค่าที่สูงขึ้น = แม่นยำยิ่งขึ้น)"

msgid "Fuzzy Max Edits"
msgstr "จำนวนการแก้ไขสูงสุด"

msgid "Maximum character edits allowed for fuzzy matching"
msgstr "จำนวนการแก้ไขตัวอักษรสูงสุดที่อนุญาตสำหรับการจับคู่แบบคลุมเครือ"

msgid "Name Weight"
msgstr "น้ำหนักชื่อ"

msgid "Relevance weight for product/item names"
msgstr "น้ำหนักความเกี่ยวข้องสำหรับชื่อสินค้า/รายการ"

msgid "SKU Weight"
msgstr "น้ำหนัก SKU"

msgid "Relevance weight for SKUs"
msgstr "น้ำหนักความเกี่ยวข้องสำหรับ SKU"

msgid "Description Weight"
msgstr "น้ำหนักคำอธิบาย"

msgid "Relevance weight for descriptions"
msgstr "น้ำหนักความเกี่ยวข้องสำหรับคำอธิบาย"

msgid "Attributes Weight"
msgstr "น้ำหนักคุณสมบัติ"

msgid "Relevance weight for product attributes and custom fields"
msgstr "น้ำหนักความเกี่ยวข้องสำหรับคุณสมบัติของสินค้าและฟิลด์แบบกำหนดเอง"

msgid "Reviews Weight"
msgstr "น้ำหนักรีวิว"

msgid "Relevance weight for review content"
msgstr "น้ำหนักความเกี่ยวข้องสำหรับเนื้อหาการรีวิว"

msgid "Categories Weight"
msgstr "น้ำหนักหมวดหมู่"

msgid "Relevance weight for category names"
msgstr "น้ำหนักความเกี่ยวข้องสำหรับชื่อหมวดหมู่"

msgid "Brands Weight"
msgstr "น้ำหนักแบรนด์"

msgid "Relevance weight for brand names"
msgstr "น้ำหนักความเกี่ยวข้องสำหรับชื่อแบรนด์"

msgid "Blog Posts Weight"
msgstr "น้ำหนักโพสต์บล็อก"

msgid "Relevance weight for blog post content"
msgstr "น้ำหนักความเกี่ยวข้องสำหรับเนื้อหาของโพสต์บล็อก"

msgid "Autocomplete Cache TTL"
msgstr "ระยะเวลาชั่วคราวสำหรับแคชการแนะนำอัตโนมัติ"

msgid "Time to live for autocomplete cache in seconds"
msgstr "ระยะเวลาการเก็บแคชการแนะนำอัตโนมัติ (ในวินาที)"

msgid "Results Cache TTL"
msgstr "ระยะเวลาชั่วคราวสำหรับแคชผลลัพธ์"

msgid "Time to live for full search results cache in seconds"
msgstr "ระยะเวลาการเก็บแคชผลลัพธ์การค้นหาทั้งหมด (ในวินาที)"

msgid "Track Search Queries"
msgstr "ติดตามคำค้นหา"

msgid "Store search queries for analytics and trending searches"
msgstr "บันทึกคำค้นหาเพื่อวิเคราะห์และค้นหาที่กำลังเป็นที่นิยม"

msgid "Track Clicks"
msgstr "ติดตามการคลิก"

msgid "Track clicks on search results for analytics"
msgstr "บันทึกการคลิกผลลัพธ์การค้นหาเพื่อวิเคราะห์"

msgid "Track Zero Results"
msgstr "ติดตามผลลัพธ์ศูนย์"

msgid "Flag and track queries that return no results"
msgstr "ติดตามและบันทึกคำค้นหาที่ไม่ได้ผลลัพธ์"

msgid "Results Per Page"
msgstr "จำนวนผลลัพธ์ต่อหน้า"

msgid "Number of results to display per page"
msgstr "จำนวนผลลัพธ์ที่แสดงต่อหน้า"

msgid "Created At"
msgstr "สร้างเมื่อ"

msgid "Updated At"
msgstr "อัปเดตเมื่อ"

msgid "Search Settings"
msgstr "การตั้งค่าการค้นหา"

msgid "Name"
msgstr "ชื่อ"

msgid "Engine name (e.g., \"Shop Search\", \"Blog Search\")"
msgstr "ชื่อเครื่องมือค้นหา (เช่น \"Shop Search\", \"Blog Search\")"

msgid "Slug"
msgstr "Slug"

msgid "URL-safe identifier"
msgstr "ตัวระบุที่ปลอดภัยสำหรับ URL"

msgid "Active"
msgstr "ใช้งานอยู่"

msgid "Enable or disable this search engine"
msgstr "เปิดหรือปิดเครื่องมือค้นหาตัวนี้"

msgid ""
"List of searchable content types for this engine (e.g., [\"product\", "
"\"category\"])"
msgstr ""
"รายการประเภทเนื้อหาที่สามารถค้นหาได้สำหรับเครื่องมือค้นหาตัวนี้ (เช่น [\"product\", "
"\"category\"])"

msgid "Weight Overrides"
msgstr "การกำหนดน้ำหนักใหม่"

msgid "Engine-specific weight adjustments (e.g., {\"weight_name\": 2.0})"
msgstr "การปรับน้ำหนักที่เฉพาะเจาะจงต่อเครื่องมือค้นหา (เช่น {\"weight_name\": 2.0})"

msgid "Excluded Categories"
msgstr "หมวดหมู่ที่ถูกยกเว้น"

msgid "Categories to exclude from this engine"
msgstr "หมวดหมู่ที่ต้องการยกเว้นจากเครื่องมือค้นหาตัวนี้"

msgid "Excluded Brands"
msgstr "แบรนด์ที่ถูกยกเว้น"

msgid "Brands to exclude from this engine"
msgstr "แบรนด์ที่ต้องการยกเว้นจากเครื่องมือค้นหาตัวนี้"

msgid "Search Engine"
msgstr "เครื่องมือค้นหา"

msgid "Search Engines"
msgstr "เครื่องมือค้นหา"

msgid "Term"
msgstr "คำ"

msgid "Original search term"
msgstr "คำค้นหาเดิม"

msgid "List of equivalent terms (e.g., [\"sweater\", \"pullover\"])"
msgstr "รายการคำที่เทียบเท่ากัน (เช่น [\"sweater\", \"pullover\"])"

msgid "Bidirectional"
msgstr "สองทาง"

msgid "Apply mapping both ways (e.g., jumper ↔ sweater)"
msgstr "ใช้การจับคู่ในทั้งสองทิศทาง (เช่น jumper ↔ sweater)"

msgid "Language code (e.g., \"en\", \"es\"). Leave blank for all languages."
msgstr "รหัสภาษา (เช่น \"en\", \"es\"). ทิ้งว่างเพื่อใช้กับทุกภาษา"

msgid "Apply to specific engine only. Leave blank for all engines."
