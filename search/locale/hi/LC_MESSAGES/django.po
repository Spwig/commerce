msgstr "प्रति प्रकार अधिकतम परिणाम"

msgid "Autocomplete search"
msgstr "ऑटोकम्प्लीट खोज"

msgid ""
"Fast predictive search suggestions. Returns products, categories, brands, "
"and blog posts."
msgstr "त्वरित पूर्वानुमानित खोज सुझाव। उत्पाद, श्रेणियां, ब्रैंड और ब्लॉग पोस्ट लौटाता है।"

msgid "Language code"
msgstr "भाषा कोड"

msgid "Filter by type (product/category/brand/blog_post)"
msgstr "प्रकार द्वारा फ़िल्टर करें (उत्पाद/श्रेणी/ब्रांड/ब्लॉग_पोस्ट)"

msgid "Filter by category ID"
msgstr "श्रेणी ID द्वारा फ़िल्टर करें"

msgid "Filter by brand ID"
msgstr "ब्रांड ID द्वारा फ़िल्टर करें"

msgid "Minimum price"
msgstr "न्यूनतम कीमत"

msgid "Maximum price"
msgstr "अधिकतम कीमत"

msgid "Only in-stock items"
msgstr "केवल स्टॉक में वाली वस्तुएं"

msgid "Sort order (relevance/price_asc/price_desc/newest)"
msgstr "सॉर्ट क्रम (संबंधित/कीमत_आरोही/कीमत_अवरोही/नवीनतम)"

