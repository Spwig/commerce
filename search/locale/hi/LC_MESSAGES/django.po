msgstr "पृष्ठ संख्या"

msgid "Results per page"
msgstr "पृष्ठ पर परिणाम"

msgid "Full search results"
msgstr "पूरे खोज परिणाम"

msgid "Paginated search results with facets and filtering."
msgstr "पृष्ठभूमि और फ़िल्टर के साथ खोज परिणाम।"

msgid "Number of days to analyze"
msgstr "विश्लेषण के लिए दिनों की संख्या"

msgid "Max results"
msgstr "अधिकतम परिणाम"

msgid "Trending searches"
msgstr "लोकप्रिय खोजें"

msgid "Popular search queries over the specified period."
msgstr "निर्दिष्ट अवधि के दौरान लोकप्रिय खोज प्रश्न।"

msgid "Search settings"
msgstr "खोज सेटिंग्स"

msgid "Public search configuration for frontend JS."
msgstr "फ्रंटएंड JS के लिए सार्वजनिक खोज विन्यास।"

msgid "Track click"
msgstr "क्लिक ट्रैक करें"

