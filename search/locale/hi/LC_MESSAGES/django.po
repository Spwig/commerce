msgstr "एनालिटिक्स के लिए खोज परिणाम पर क्लिक रिकॉर्ड करें।"

msgid "Spelling suggestions"
msgstr "लेखन सुझाव"

msgid "Suggest spelling corrections for misspelled queries."
msgstr "गलत लिखे गए प्रश्नों के लिए लेखन सुधार की सुचना दें।"

msgid "List search engines"
msgstr "खोज इंजनों की सूची"

msgid "Get list of available search engines."
msgstr "उपलब्ध खोज इंजनों की सूची प्राप्त करें।"

msgid "Search"
msgstr "खोज"

msgid "Search Enabled"
msgstr "खोज सक्षम"

msgid "Enable or disable search functionality globally"
msgstr "खोज कार्यक्षमता को समग्र रूप से चालू या बंद करें"

msgid "Minimum Query Length"
msgstr "न्यूनतम प्रश्न लंबाई"

msgid "Minimum number of characters required to trigger search"
msgstr "खोज को ट्रिगर करने के लिए आवश्यक न्यूनतम करैक्टर की संख्या"

msgid "Autocomplete Enabled"
msgstr "ऑटोकम्प्लीट सक्षम"

msgid "Show predictive search suggestions as user types"
msgstr "उपयोगकर्ता द्वारा टाइप करते समय पूर्वानुमानित खोज सुझाव दिखाएं"

msgid "Autocomplete Max Results"
msgstr "ऑटोकम्प्लीट अधिकतम परिणाम"

msgid "Maximum number of suggestions per content type"
msgstr "सामग्री प्रकार प्रति अधिकतम सुझाव की संख्या"

msgid "Autocomplete Debounce (ms)"
msgstr "ऑटोकम्प्लीट डीबाउंस (मिलीसेकंड)"

msgid "Delay in milliseconds before triggering autocomplete"
msgstr "ऑटोकम्प्लीट ट्रिगर करने से पहले मिलीसेकंड में विलंब"

msgid "Show Thumbnails"
msgstr "थंबनेल दिखाएं"

msgid "Display product/content thumbnails in search results"
msgstr "खोज परिणामों में उत्पाद/सामग्री थंबनेल दिखाएं"

msgid "Show Product Thumbnail"
msgstr "उत्पाद थंबनेल दिखाएं"

msgid "Display product images in autocomplete dropdown"
msgstr "ऑटोकम्प्लीट ड्रॉपडाउन में उत्पाद छवियाँ दिखाएं"

msgid "Show Product Description"
msgstr "उत्पाद विवरण दिखाएं"

msgid "Display short description in autocomplete dropdown"
msgstr "ऑटोकम्प्लीट ड्रॉपडाउन में छोटा विवरण दिखाएं"

msgid "Show Product Price"
msgstr "उत्पाद मूल्य दिखाएं"

msgid "Display price in autocomplete dropdown"
msgstr "ऑटोकम्प्लीट ड्रॉपडाउन में मूल्य प्रदर्शित करें"

msgid "Show Product SKU"
msgstr "उत्पाद SKU दिखाएं"

msgid "Display SKU in autocomplete dropdown"
msgstr "ऑटोकम्प्लीट ड्रॉपडाउन में SKU प्रदर्शित करें"

msgid "Show Product Stock Status"
msgstr "उत्पाद स्टॉक स्थिति दिखाएं"

msgid "Display stock availability badge in autocomplete dropdown"
msgstr "ऑटोकम्प्लीट ड्रॉपडाउन में स्टॉक उपलब्धता बैज दिखाएं"

msgid "Show Blog Featured Image"
msgstr "ब्लॉग विशेष छवि दिखाएं"

msgid "Display featured image in blog post autocomplete results"
msgstr "ब्लॉग पोस्ट ऑटोकम्प्लीट परिणामों में चयनित छवि दिखाएं"

msgid "Show Blog Excerpt"
msgstr "ब्लॉग अवतरण दिखाएं"

msgid "Display excerpt in blog post autocomplete results"
msgstr "ब्लॉग पोस्ट ऑटोकम्प्लीट परिणामों में अवतरण दिखाएं"

msgid "Blog Excerpt Length"
msgstr "ब्लॉग अवतरण लंबाई"

msgid "Maximum characters to show for blog excerpts"
msgstr "ब्लॉग अवतरण के लिए दिखाए जाने वाले अधिकतम करैक्टर"

msgid "Show Category Thumbnail"
msgstr "श्रेणी थंबनेल दिखाएं"

msgid "Display category image in autocomplete dropdown"
msgstr "ऑटोकम्प्लीट ड्रॉपडाउन में श्रेणी छवि दिखाएं"

msgid "Show Category Product Count"
msgstr "श्रेणी उत्पाद गिनती दिखाएं"

msgid "Display product count in category autocomplete results"
msgstr "श्रेणी ऑटोकम्प्लीट परिणामों में उत्पाद की संख्या दिखाएं"

msgid "Show Brand Logo"
msgstr "ब्रांड लोगो दिखाएं"

msgid "Display brand logo in autocomplete dropdown"
msgstr "ऑटोकम्प्लीट ड्रॉपडाउन में ब्रांड लोगो दिखाएं"

msgid "Show Brand Product Count"
msgstr "ब्रांड उत्पाद गिनती दिखाएं"

msgid "Display product count in brand autocomplete results"
msgstr "ब्रांड ऑटोकम्प्लीट परिणामों में उत्पाद की संख्या दिखाएं"

msgid "Search Products"
msgstr "उत्पाद खोजें"

msgid "Include products in search results"
msgstr "खोज परिणाम में उत्पाद शामिल करें"

msgid "Search Categories"
msgstr "श्रेणी खोजें"

msgid "Include categories in search results"
msgstr "खोज परिणाम में श्रेणी शामिल करें"

msgid "Search Brands"
msgstr "ब्रांड खोजें"

msgid "Include brands in search results"
msgstr "खोज परिणाम में ब्रांड शामिल करें"

msgid "Search Blog Posts"
msgstr "ब्लॉग पोस्ट खोजें"

msgid "Include blog posts in search results"
msgstr "खोज परिणामों में ब्लॉग पोस्ट शामिल करें"

msgid "Index SKUs"
msgstr "SKU अनुक्रमित करें"

msgid "Include product SKUs in search"
msgstr "खोज में उत्पाद SKU शामिल करें"

msgid "Index Attributes"
msgstr "गुण अनुक्रमित करें"

msgid "Include product attributes (color, size, etc.) in search"
msgstr "खोज में उत्पाद गुण (रंग, आकार आदि) शामिल करें"

msgid "Index Custom Fields"
msgstr "कस्टम फील्ड अनुक्रमित करें"

msgid "Include custom product fields in search"
msgstr "खोज में विशेष उत्पाद क्षेत्र शामिल करें"

msgid "Index Reviews"
msgstr "समीक्षा अनुक्रमित करें"

msgid "Include product review content in search"
msgstr "खोज में उत्पाद समीक्षा सामग्री शामिल करें"

msgid "Index Documents"
msgstr "दस्तावेज अनुक्रमित करें"

msgid "Index text content from digital asset documents (PDFs, Office files)"
msgstr "डिजिटल संपत्ति दस्तावेजों (पीडीएफ, ऑफिस फाइल) से टेक्स्ट सामग्री के अनुक्रमण करें"

msgid "Fuzzy Matching Enabled"
msgstr "फ्यूज़ी मैचिंग सक्षम"

msgid "Enable typo tolerance in search queries"
msgstr "खोज प्रश्नों में टाइपो टॉलरेंस चालू करें"

msgid "Fuzzy Threshold"
msgstr "फ्यूज़ी अंतर के लिए सीमा"

msgid "Similarity threshold for fuzzy matching (0-1, higher = stricter)"
msgstr "फ्यूज़ी मैचिंग के लिए समानता थ्रेशोल्ड (0-1, उच्च = कड़ा)"

msgid "Fuzzy Max Edits"
msgstr "फ्यूज़ी अधिकतम संपादन"

msgid "Maximum character edits allowed for fuzzy matching"
msgstr "फ्यूज़ी मैचिंग के लिए अनुमत करैक्टर एडिट की अधिकतम संख्या"

msgid "Name Weight"
msgstr "नाम भार"

msgid "Relevance weight for product/item names"
msgstr "उत्पाद/आइटम नामों के लिए संबंधित भार"

msgid "SKU Weight"
msgstr "SKU भार"

msgid "Relevance weight for SKUs"
msgstr "SKUs के लिए संबंधित भार"

msgid "Description Weight"
msgstr "विवरण भार"

msgid "Relevance weight for descriptions"
msgstr "विवरणों के लिए संबंधित भार"

msgid "Attributes Weight"
msgstr "विशेषताएं भार"

msgid "Relevance weight for product attributes and custom fields"
msgstr "उत्पाद गुण और विशेष क्षेत्रों के लिए प्रासंगिकता वजन"

msgid "Reviews Weight"
msgstr "समीक्षा भार"

msgid "Relevance weight for review content"
msgstr "समीक्षा सामग्री के लिए संबंधित भार"

msgid "Categories Weight"
msgstr "श्रेणियाँ भार"

msgid "Relevance weight for category names"
msgstr "श्रेणी नामों के लिए संबंधित भार"

msgid "Brands Weight"
msgstr "ब्रांड भार"

msgid "Relevance weight for brand names"
msgstr "ब्रांड नामों के लिए संबंधित भार"

msgid "Blog Posts Weight"
msgstr "ब्लॉग पोस्ट भार"

msgid "Relevance weight for blog post content"
msgstr "ब्लॉग पोस्ट सामग्री के लिए प्रासंगिकता वजन"

msgid "Autocomplete Cache TTL"
msgstr "स्वचालित पूर्णता कैश TTL"

msgid "Time to live for autocomplete cache in seconds"
msgstr "ऑटोकम्प्लीट कैश के लिए सेकंड में लाइफ टाइम"

msgid "Results Cache TTL"
msgstr "परिणाम कैश TTL"

msgid "Time to live for full search results cache in seconds"
msgstr "पूर्ण खोज परिणाम कैश के लिए सेकंड में लाइफ टाइम"

msgid "Track Search Queries"
msgstr "खोज प्रश्न ट्रैक करें"

msgid "Store search queries for analytics and trending searches"
msgstr "खोज प्रश्नों को विश्लेषण और लोकप्रिय खोजों के लिए संग्रहित करें"

msgid "Track Clicks"
msgstr "क्लिक ट्रैक करें"

msgid "Track clicks on search results for analytics"
msgstr "विश्लेषण के लिए खोज परिणामों पर क्लिक के ट्रैक करें"

msgid "Track Zero Results"
msgstr "शून्य परिणाम ट्रैक करें"

msgid "Flag and track queries that return no results"
msgstr "कोई परिणाम नहीं लौटाने वाले प्रश्नों को चिह्नित करें और ट्रैक करें"

msgid "Results Per Page"
msgstr "प्रति पृष्ठ परिणाम"

msgid "Number of results to display per page"
msgstr "प्रति पृष्ठ दिखाए जाने वाले परिणामों की संख्या"

msgid "Created At"
msgstr "बनाया गया"

msgid "Updated At"
msgstr "अपडेट कर दिया गया"

msgid "Search Settings"
msgstr "खोज सेटिंग्स"

msgid "Name"
msgstr "नाम"

msgid "Engine name (e.g., \"Shop Search\", \"Blog Search\")"
msgstr "इंजन का नाम (उदा., \"शॉप खोज\", \"ब्लॉग खोज\")"

msgid "Slug"
msgstr "स्लग"

msgid "URL-safe identifier"
msgstr "URL-सुरक्षित पहचानकर्ता"

msgid "Active"
msgstr "सक्रिय"

msgid "Enable or disable this search engine"
msgstr "इस खोज इंजन को चालू या बंद करें"

msgid ""
"List of searchable content types for this engine (e.g., [\"product\", "
"\"category\"])"
msgstr "इस इंजन के लिए खोज सामग्री प्रकारों की सूची (उदा., [\"उत्पाद\", \"श्रेणी\"])"

msgid "Weight Overrides"
msgstr "भार ओवरराइड"

msgid "Engine-specific weight adjustments (e.g., {\"weight_name\": 2.0})"
msgstr "इंजन विशिष्ट वजन अनुकूलन (उदा., {\"वजन_नाम\": 2.0})"

msgid "Excluded Categories"
msgstr "अपवाद श्रेणियाँ"

msgid "Categories to exclude from this engine"
msgstr "इस इंजन से बाहर करने वाली श्रेणियाँ"

msgid "Excluded Brands"
msgstr "अपवाद ब्रांड"

msgid "Brands to exclude from this engine"
msgstr "इस इंजन से बाहर करने वाले ब्रांड"

msgid "Search Engine"
msgstr "खोज इंजन"

msgid "Search Engines"
msgstr "खोज इंजन"

msgid "Term"
msgstr "शब्द"

msgid "Original search term"
msgstr "मूल खोज शब्द"

msgid "List of equivalent terms (e.g., [\"sweater\", \"pullover\"])"
msgstr "समकक्ष शब्दों की सूची (उदा., [\"स्वेटर\", \"पुलओवर\"])"

msgid "Bidirectional"
msgstr "द्विदिश"

msgid "Apply mapping both ways (e.g., jumper ↔ sweater)"
msgstr "दोनों तरफ मैपिंग लागू करें (उदा., जंपर ↔ स्वेटर)"

msgid "Language code (e.g., \"en\", \"es\"). Leave blank for all languages."
msgstr "भाषा कोड (उदा., \"en\", \"es\"). सभी भाषाओं के लिए खाली छोड़ दें।"

msgid "Apply to specific engine only. Leave blank for all engines."
msgstr "केवल विशिष्ट इंजन के लिए लागू करें। सभी इंजनों के लिए खाली छोड़ दें।"

msgid "Synonym"
msgstr "समानार्थी"

msgid "Exact Match"
msgstr "ठीक मिलान"

msgid "Contains"
msgstr "शामिल करता है"

msgid "Starts With"
msgstr "से शुरू होता है"

msgid "Regular Expression"
msgstr "नियमित अभिव्यक्ति"

msgid "Temporary (302)"
msgstr "अस्थायी (302)"

msgid "Permanent (301)"
msgstr "स्थायी (301)"

msgid "Search Term"
