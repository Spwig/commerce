msgstr "商品"

msgid "Categories"
msgstr "分類"

msgid "Brands"
msgstr "品牌"

msgid "Blog Posts"
msgstr "部落格文章"

msgid "Relevance weight for product attributes"
msgstr "產品屬性相關性權重"

msgid "Engine name is required."
msgstr "引擎名稱為必填項目。"

msgid "An engine with this slug already exists."
msgstr "已存在使用此 slug 的引擎。"

msgid "Please complete Step 1 first."
msgstr "請先完成步驟 1。"

msgid "Please complete the wizard steps."
msgstr "請完成向導步驟。"

