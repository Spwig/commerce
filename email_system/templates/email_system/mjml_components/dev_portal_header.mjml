{# Developer Portal Header Component #}
{# Usage: {% include 'email_system/mjml_components/dev_portal_header.mjml' %} #}
{# Provides a dark branded header for all developer portal emails #}

<mj-section background-color="#1e293b" padding="28px 30px">
  <mj-column>
    <mj-text
      font-size="20px"
      font-weight="700"
      color="#ffffff"
      letter-spacing="0.5px"
    >
      <img src="{{ shop_url }}/static/email_system/img/spwig-favicon.png" alt="" width="22" height="22" style="vertical-align: middle; margin-right: 10px; display: inline-block;" />
      Spwig Developer Portal
    </mj-text>
  </mj-column>
</mj-section>
