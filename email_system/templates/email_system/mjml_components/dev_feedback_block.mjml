{# Developer Feedback Block Component #}
{# Usage: {% include 'email_system/mjml_components/dev_feedback_block.mjml' with label="FEEDBACK" message=review_notes %} #}
{# Styled amber block for displaying rejection reasons, review notes, suspension reasons #}

<mj-section background-color="#fef3c7" padding="16px 24px" border-radius="8px">
  <mj-column>
    <mj-text
      font-size="11px"
      font-weight="700"
      color="#92400e"
      letter-spacing="0.5px"
      text-transform="uppercase"
      padding-bottom="6px"
    >
      {{ label|default:"FEEDBACK" }}
    </mj-text>
    <mj-text
      font-size="14px"
      color="#78350f"
      line-height="22px"
    >
      {{ message }}
    </mj-text>
  </mj-column>
</mj-section>
