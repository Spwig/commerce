msgid ""
"Cannot edit order - already shipped. Please create a return/refund instead."
msgstr ""
"Không thể chỉnh sửa đơn hàng - đã được giao hàng. Vui lòng tạo yêu cầu hoàn "
"tiền/thanh toán lại thay vào đó."

msgid ""
"Cannot edit order - already delivered. Please create a return/refund instead."
msgstr ""
"Không thể chỉnh sửa đơn hàng - đã được giao hàng. Vui lòng tạo yêu cầu hoàn "
"tiền/thanh toán lại thay vào đó."

msgid "Cannot edit cancelled order. Please create a new order instead."
msgstr ""
"Không thể chỉnh sửa đơn hàng đã hủy. Vui lòng tạo đơn hàng mới thay vào đó."

