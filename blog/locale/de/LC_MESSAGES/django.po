msgstr "Neuer Blogbeitrag"

msgid "Read Full Post"
msgstr "Den vollständigen Beitrag lesen"

msgid "You received this email because you subscribed to our blog."
msgstr ""
"Sie erhalten diese E-Mail, da Sie sich für unseren Blog angemeldet haben."

msgid "Read the full post"
msgstr "Den vollständigen Beitrag lesen"

msgid "Weekly Blog Digest"
msgstr "Wöchentlicher Blog-Auszug"

msgid "Your Weekly Blog Digest"
msgstr "Ihr wöchentlicher Blog-Auszug"

msgid "Here's what you missed this week"
msgstr "Hier sind die Inhalte, die Sie diese Woche verpasst haben"

msgid ""
"You received this email because you subscribed to our weekly blog digest."
msgstr ""
"Sie erhalten diese E-Mail, da Sie sich für unseren wöchentlichen Blog-Digest "
"angemeldet haben."

#, python-format
msgid "Managing preferences for %(email)s"
msgstr "Verwalten der Einstellungen für %(email)s"

#, python-format
msgid ""
"Your email %(email)s has been verified. You'll now receive notifications "
"about new blog posts."
msgstr ""
"Ihre E-Mail %(email)s wurde bestätigt. Sie erhalten jetzt Benachrichtigungen "
"zu neuen Blogbeiträgen."

#, python-format
msgid "Tag: %(name)s"
msgstr "Schlagwort: %(name)s"

#, python-format
msgid "Posts tagged: %(name)s"
msgstr "Beiträge mit dem Schlagwort: %(name)s"

#, python-format
msgid "Posts tagged \"%(name)s\""
msgstr "Beiträge mit dem Schlagwort \"%(name)s\""

#, python-format
msgid "Are you sure you want to unsubscribe %(email)s from blog notifications?"
msgstr ""
"Sind Sie sicher, dass Sie %(email)s von Blog-Benachrichtigungen abmelden "
"möchten?"

#, python-format
msgid ""
"%(email)s has been removed from our mailing list. You will no longer receive "
"blog notifications."
msgstr ""
"%(email)s wurde von unserer Mailingliste entfernt. Sie erhalten keine Blog-"
"Benachrichtigungen mehr."

msgid "Please select a provider."
msgstr "Bitte wählen Sie einen Anbieter aus."

msgid "Invalid provider selected."
msgstr "Ungültiger Anbieter ausgewählt."

msgid "Please select a provider first."
msgstr "Bitte wählen Sie zuerst einen Anbieter aus."

msgid "Provider not found."
msgstr "Anbieter nicht gefunden."

msgid "OAuth state mismatch. Please try again."
msgstr "OAuth-Zustand nicht korrekt. Bitte erneut versuchen."

#, python-brace-format
msgid "OAuth error: {error}"
msgstr "OAuth-Fehler: {error}"

msgid "No authorization code received."
msgstr "Kein Autorisierungscode erhalten."

msgid "Failed to obtain access token."
msgstr "Es ist nicht möglich, den Zugriffstoken zu erhalten."

#, python-brace-format
msgid "Failed to complete OAuth: {error}"
msgstr "Fehlschlag bei der OAuth-Vervollständigung: {error}"

msgid "Please complete OAuth first."
msgstr "Bitte führen Sie die OAuth-Komplettierung zuerst durch."

msgid "No accounts found. Please check your permissions."
msgstr "Keine Accounts gefunden. Bitte Ihre Berechtigungen überprüfen."

msgid "Please select an account."
msgstr "Bitte wählen Sie ein Konto aus."

msgid "Please complete the authorization flow first."
msgstr "Bitte führen Sie den Autorisierungsprozess zuerst durch."

msgid "Please enter an account name."
msgstr "Bitte geben Sie einen Kontonamen ein."

msgid "Please fill in all required fields."
msgstr "Bitte füllen Sie alle erforderlichen Felder aus."

