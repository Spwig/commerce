msgid "Multilingual tag names"
msgstr "Многоязычные имена меток"

msgid "Original ID from source platform (e.g. WordPress tag ID)"
msgstr "Оригинальный ID из исходной платформы (например, ID тега WordPress)"

msgid "Migration job that imported this tag"
msgstr "Задача миграции, которая импортировала этот тег"

