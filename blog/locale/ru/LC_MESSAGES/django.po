msgid "Override the site-wide blog post template for this post."
msgstr ""
"Переопределить шаблон поста блога на уровне всего сайта для этого поста."

msgid "Brief summary for listings and social sharing (primary language)"
msgstr ""
"Краткое описание для списков и социального взаимодействия (основной язык)"

msgid "Full post content with rich text formatting (primary language)"
msgstr "Полный контент поста с форматированием богатого текста (основной язык)"

msgid "Use Page Builder for custom layout instead of simple content"
msgstr ""
"Использовать Page Builder для кастомного макета вместо простого контента"

msgid "Page containing the post content layout"
msgstr "Страница, содержащая макет содержимого поста"

msgid "Featured image from media library"
msgstr "Изображение из медиатеки"

msgid "Open Graph image for social sharing (defaults to featured image)"
msgstr ""
"Изображение Open Graph для социального взаимодействия (по умолчанию "
"используется изображение, выделенное как главное)"

msgid "Multilingual content (title, excerpt, content, SEO)"
msgstr "Многоязычный контент (заголовок, выдержка, основной текст, SEO)"

msgid "Schedule post to be published at this time"
msgstr "Запланировать публикацию поста на это время"

msgid "Pinned posts appear at the top of listings"
msgstr "Закрепленные посты появляются в верхней части списка"

msgid "Estimated reading time (auto-calculated)"
msgstr "Предполагаемое время чтения (автоматически рассчитано)"

msgid "Send notification to subscribers when published"
msgstr "Отправить уведомление подписчикам при публикации"

msgid "Custom message for social shares (optional)"
msgstr ""
"Персонализированное сообщение для социальных разделяемых ссылок "
"(необязательное)"

msgid "Original ID from source platform (e.g. WordPress post ID)"
msgstr "Оригинальный ID из исходной платформы (например, ID поста WordPress)"

msgid "Migration job that imported this post"
msgstr "Задача миграции, которая импортировала этот пост"

