msgstr "即時"

msgid "Weekly Digest"
msgstr "週間ダイジェスト"

msgid "Monthly Digest"
msgstr "月間ダイジェスト"

msgid "Pending Verification"
msgstr "確認待ち"

msgid "Verified"
msgstr "確認済み"

