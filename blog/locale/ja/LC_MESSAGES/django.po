msgstr "失敗"

msgid "Skipped"
msgstr "スキップ"

msgid "When to post (null = immediately on publish)"
msgstr "投稿するタイミング（null = 投稿時にすぐに公開）"

msgid "Blog Post Auto Share"
msgstr "ブログ記事自動共有"

msgid "Blog Post Auto Shares"
msgstr "ブログ記事自動共有設定"

msgid "Include full content in RSS (False = excerpt only)"
msgstr "RSSに全文を含めるか（False = 要約のみ）"

msgid "Day of week for weekly digest (0=Sunday, 1=Monday, ...)"
msgstr "週間ダイジェストの曜日（0=日曜日, 1=月曜日, ...）"

msgid "Hour (UTC) to send weekly digest"
msgstr "週間ダイジェストを送信する時間（UTC）"

msgid "Day of month for monthly digest"
msgstr "月間ダイジェストの日付"

msgid "Hour (UTC) to send monthly digest"
msgstr "月間ダイジェストを送信する時間（UTC）"

msgid "Blog Settings"
