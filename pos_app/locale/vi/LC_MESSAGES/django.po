"Component package from upgrade server. Null for built-in manual provider."
msgstr ""
"Gói thành phần từ máy chủ nâng cấp. Trống cho nhà cung cấp thủ công tích hợp."

msgid "Credentials"
msgstr "Thông tin xác thực"

msgid "Encrypted API credentials. Use set_credentials() to update safely."
msgstr ""
"Thông tin xác thực API được mã hóa. Sử dụng set_credentials() để cập nhật an "
"toàn."

msgid "Provider Settings"
msgstr "Cài đặt nhà cung cấp"

msgid "Non-secret provider config, e.g. Stripe location ID."
msgstr "Cấu hình nhà cung cấp không bí mật, ví dụ: ID vị trí Stripe."

