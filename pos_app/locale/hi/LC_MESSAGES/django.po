msgstr "टर्मिनल (दूरसंचार) को अनलॉक करें"

#, python-format
msgid ""
"Remote unlock signal sent to %d terminal(s). They will unlock within a few "
"seconds."
msgstr "%d टर्मिनल के लिए दूरस्थ अनलॉक सिग्नल भेजा गया। वे कुछ सेकंड में अनलॉक हो जाएंगे।"

msgid "Regional Settings"
msgstr "क्षेत्रीय सेटिंग"

msgid ""
"Settings applied to all stores in this group. Blank = inherit from site "
"default."
msgstr "इस समूह में सभी दुकानों पर लागू सेटिंग। खाली = साइट के डिफ़ॉल्ट से विरासत लें।"

msgid "Advanced"
msgstr "उन्नत"

msgid "Additional group-level settings as JSON."
msgstr "JSON के रूप में अतिरिक्त समूह-स्तर सेटिंग।"

msgid "Metadata"
msgstr "मेटाडेटा"

msgid "Stores"
