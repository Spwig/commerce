msgstr "(साइट डिफ़ॉल्ट)"

msgid "Currency"
msgstr "मुद्रा"

msgid "Component"
msgstr "संघटक"

msgid ""
"Component package from upgrade server. Null for built-in manual provider."
msgstr "अपग्रेड सर्वर से घटक पैकेज। बिल्ट-इन मैनुअल प्रदाता के लिए खाली।"

msgid "Credentials"
msgstr "ज्ञान"

msgid "Encrypted API credentials. Use set_credentials() to update safely."
msgstr ""
"एन्क्रिप्टेड API एक्रेडेंटियल्स। सुरक्षित अपडेट करने के लिए set_credentials() का उपयोग करें।"

msgid "Provider Settings"
msgstr "प्रदाता सेटिंग"

msgid "Non-secret provider config, e.g. Stripe location ID."
msgstr "गैर-रहस्य प्रदाता विन्यास, उदाहरण के लिए Stripe स्थान का ID।"

msgid "Connection Health"
msgstr "कनेक्शन स्वास्थ्य"

msgid "Timestamps"
msgstr "टाइमस्टैंप"

msgid "Test connection"
msgstr "कनेक्शन परीक्षण करें"

msgid "connected"
msgstr "जुड़ा हुआ"

