msgstr "(По умолчанию для сайта)"

msgid "Currency"
msgstr "Валюта"

msgid "Component"
msgstr "Компонент"

msgid ""
"Component package from upgrade server. Null for built-in manual provider."
msgstr ""
"Пакет компонентов с сервера обновления. Null для встроенного ручного "
"провайдера."

msgid "Credentials"
msgstr "Учетные данные"

msgid "Encrypted API credentials. Use set_credentials() to update safely."
msgstr ""
"Шифрованные учетные данные API. Используйте set_credentials() для "
"безопасного обновления."

msgid "Provider Settings"
msgstr "Настройки поставщика"

msgid "Non-secret provider config, e.g. Stripe location ID."
msgstr ""
"Неконфиденциальная настройка провайдера, например, идентификатор "
"расположения Stripe."

msgid "Connection Health"
msgstr "Состояние подключения"

msgid "Timestamps"
msgstr "Временные метки"

msgid "Test connection"
msgstr "Проверить соединение"

