msgstr "идентификатор считывателя поставщика"

msgid "Reader ID from the provider, e.g. \"tmr_xxx\" for Stripe"
msgstr ""
"Идентификатор считывателя от поставщика, например, \"tmr_xxx\" для Stripe"

msgid "label"
msgstr "метка"

msgid "Friendly name, e.g. \"Front Counter Reader\""
msgstr "Дружественное имя, например, \"Считыватель на фронтовом прилавке\""

msgid "reader type"
msgstr "тип считывателя"

msgid "Device type, e.g. \"bbpos_wisepos_e\", \"stripe_s700\""
msgstr "Тип устройства, например, \"bbpos_wisepos_e\", \"stripe_s700\""

