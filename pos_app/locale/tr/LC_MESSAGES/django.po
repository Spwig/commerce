msgstr "para birimi"

msgid ""
"Currency for stores in this group (e.g. NZD, SGD). Blank = site default."
msgstr ""
"Bu gruptaki mağazalar için para birimi (örneğin NZD, SGD). Boş bırakılırsa, "
"site varsayılanı."

msgid "language"
msgstr "dil"

msgid "Default language for stores in this group. Blank = site default."
msgstr ""
"Bu gruptaki mağazalar için varsayılan dil. Boş bırakılırsa, site varsayılanı."

msgid "timezone"
msgstr "saat dilimi"

