msgid "terminal name"
msgstr "terminal adı"

msgid "Friendly name for this terminal, e.g. \"Front Register\""
msgstr "Bu terminal için dostane isim, örneğin \"Front Register\""

msgid "Unique identifier for this terminal"
msgstr "Bu terminal için benzersiz tanımlayıcı"

