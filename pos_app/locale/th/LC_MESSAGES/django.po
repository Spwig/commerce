msgid ""
"Your credentials are encrypted using AES-256 before being stored. They are "
"never exposed in logs or admin interfaces."
msgstr ""
"ข้อมูลการรับรองของคุณถูกเข้ารหัสโดยใช้ AES-256 ก่อนที่จะถูกจัดเก็บ "
"ข้อมูลเหล่านี้จะไม่เคยปรากฏในบันทึกหรืออินเทอร์เฟซผู้ดูแลระบบ"

msgid "Test Connection"
msgstr "ทดสอบการเชื่อมต่อ"

#, python-format
msgid "Verifying your connection to %(name)s."
msgstr "กำลังตรวจสอบการเชื่อมต่อกับ %(name)s"

msgid "Connection Successful!"
msgstr "การเชื่อมต่อสำเร็จ!"

msgid "Connection Failed"
msgstr "การเชื่อมต่อไม่สำเร็จ"

msgid "Testing Connection..."
msgstr "กำลังทดสอบการเชื่อมต่อ..."

msgid "Please wait while we verify your credentials."
msgstr "กรุณารอสักครู่ขณะที่เรากำลังตรวจสอบข้อมูลการรับรองของคุณ"

msgid "API credentials verified"
msgstr "ข้อมูลการเข้าถึง API ได้รับการยืนยันแล้ว"

msgid "Account access confirmed"
msgstr "การเข้าถึงบัญชีได้รับการยืนยันแล้ว"

msgid "Retry Test"
msgstr "ลองทดสอบอีกครั้ง"

msgid "Update Credentials"
msgstr "อัปเดตข้อมูลการเข้าถึง"

msgid "Unable to connect. Please check your credentials."
msgstr "ไม่สามารถเชื่อมต่อได้ กรุณาตรวจสอบข้อมูลการรับรองของคุณ"

msgid "An unexpected error occurred. Please try again."
msgstr "เกิดข้อผิดพลาดที่ไม่คาดคิด กรุณาลองอีกครั้ง"

msgid "Configure & Save"
msgstr "ตั้งค่าและบันทึก"

msgid "Configure the manual entry provider for your store."
msgstr "ตั้งค่าผู้ให้บริการสำหรับการกรอกข้อมูลด้วยตนเองสำหรับร้านค้าของคุณ"

#, python-format
msgid "Review and finalize your %(name)s configuration."
msgstr "ตรวจสอบและตั้งค่า %(name)s ของคุณให้สมบูรณ์"

msgid "This name will appear in the admin interface and terminal selection."
msgstr "ชื่อนี้จะปรากฏในอินเทอร์เฟซผู้ดูแลระบบและหน้าเลือกอุปกรณ์"

msgid "About Manual Entry"
msgstr "เกี่ยวกับการป้อนข้อมูลด้วยตนเอง"

msgid ""
"The manual entry provider is for standalone terminals that process cards "
"independently. After each terminal transaction, you'll enter the card "
"details (brand, last 4 digits) manually in the POS app."
msgstr ""
"ผู้ให้บริการสำหรับการกรอกข้อมูลด้วยตนเองเป็นสำหรับอุปกรณ์ที่ทำงานเป็นอิสระและสามารถประมวลผลการชำระเงินด้วยบัตรได้เอง "
"หลังจากแต่ละธุรกรรมของอุปกรณ์ คุณจะต้องกรอกข้อมูลบัตร (แบรนด์, 4 หลักสุดท้าย) "
"ด้วยตนเองในแอป POS"

msgid "Ready to Connect"
msgstr "พร้อมสำหรับการเชื่อมต่อ"

#, python-format
msgid ""
"Your %(name)s account is verified and ready. Click \"Save & Connect\" to "
"complete the setup."
msgstr ""
"บัญชี %(name)s ของคุณได้รับการตรวจสอบแล้วและพร้อมใช้งาน คลิก \"บันทึกและเชื่อมต่อ\" "
"เพื่อสร้างการตั้งค่าให้สมบูรณ์"

msgid "Save & Connect"
msgstr "บันทึกและเชื่อมต่อ"

