msgstr "نقطة البيع"

msgid "group name"
msgstr "اسم المجموعة"

msgid "e.g. \"NZ Stores\", \"Singapore Region\""
msgstr "مثلاً: \"متاجر نيوزيلندا\"، \"منطقة سنغافورة\""

msgid "group code"
msgstr "كود المجموعة"

msgid "Short unique code e.g. \"NZ\", \"SG\""
msgstr "رمز قصير فريد، مثال: \"NZ\"، \"SG\""

msgid "currency"
msgstr "العملة"

msgid ""
"Currency for stores in this group (e.g. NZD, SGD). Blank = site default."
msgstr ""
"العملة للمتاجر في هذه المجموعة (مثلاً NZD، SGD). فارغ = الافتراضات العامة "
"للموقع."

msgid "language"
msgstr "اللغة"

msgid "Default language for stores in this group. Blank = site default."
msgstr ""
"اللغة الافتراضية للمتاجر في هذه المجموعة. فارغ = الافتراضات العامة للموقع."

msgid "timezone"
msgstr "المنطقة الزمنية"

msgid "Timezone for reports (e.g. Pacific/Auckland). Blank = site default."
msgstr ""
"المنطقة الزمنية للتقارير (مثلاً Pacific/Auckland). فارغ = الافتراضات العامة "
"للموقع."

msgid "additional settings"
msgstr "الإعدادات الإضافية"

msgid "sort order"
msgstr "ترتيب الفرز"

msgid "Lower numbers appear first in lists."
msgstr "تظهر الأرقام الأصغر أولاً في القوائم."

