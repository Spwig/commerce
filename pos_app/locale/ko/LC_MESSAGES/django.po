msgstr "공급업체에서의 리더 ID 예: Stripe의 경우 \"tmr_xxx\""

msgid "label"
msgstr "레이블"

msgid "Friendly name, e.g. \"Front Counter Reader\""
msgstr "친근한 이름 예: \"Front Counter Reader\""

msgid "reader type"
msgstr "리더 유형"

msgid "Device type, e.g. \"bbpos_wisepos_e\", \"stripe_s700\""
msgstr "기기 유형, 예: \"bbpos_wisepos_e\", \"stripe_s700\""

msgid "serial number"
msgstr "시리얼 번호"

msgid "IP address"
msgstr "IP 주소"

msgid "status"
msgstr "상태"

msgid "last seen"
msgstr "마지막 확인 시간"

msgid "custom splash screen"
msgstr "사용자 정의 스플래시 화면"

msgid ""
"Upload a custom splash screen image. Leave blank to auto-generate from site "
"logo."
msgstr ""
"사용자 정의 스플래시 화면 이미지를 업로드합니다. 사이트 로고에서 자동으로 생"
"성하려면 빈 항목을 남겨두세요."

msgid "Stripe file ID"
msgstr "Stripe 파일 ID"

