msgid "Save & Finish"
msgstr "저장 및 완료"

msgid "Save & Add Another"
msgstr "저장 및 추가"

msgid "Select Terminal Provider"
msgstr "단말기 제공업체 선택"

msgid ""
"Choose a payment terminal provider to accept card payments at the point of "
"sale."
msgstr "판매 시 카드 결제를 수락할 수 있는 결제 단말기 제공업체를 선택하세요."

