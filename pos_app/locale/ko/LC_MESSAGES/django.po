msgstr "설치 지침"

#, python-format
msgid "Follow these steps to set up %(name)s for your store."
msgstr "가맹점의 %(name)s 설정을 위해 다음 단계를 따르세요."

msgid "Don't have an account?"
msgstr "계정이 없으십니까?"

#, python-format
msgid "Create a %(name)s account to get started."
msgstr "시작하려면 %(name)s 계정을 만드세요."

msgid "Sign Up"
msgstr "회원가입"

msgid "I've completed setup"
msgstr "설치를 완료했습니다"

msgid "Enter Credentials"
msgstr "자격 증명 입력"

#, python-format
msgid "Enter your %(name)s API credentials to connect your account."
msgstr "계정을 연결하려면 %(name)s API 자격 증명을 입력하세요."

msgid "Display Name"
msgstr "표시 이름"

msgid "A friendly name for this connection (shown in admin)."
msgstr "이 연결에 대한 친근한 이름입니다(관리자에서 표시됨)."

msgid "API Credentials"
msgstr "API 자격 증명"

msgid "These credentials are encrypted and stored securely."
msgstr "이 자격 증명은 암호화되어 안전하게 저장됩니다."

msgid "Security Notice"
msgstr "보안 공지"

msgid ""
"Your credentials are encrypted using AES-256 before being stored. They are "
"never exposed in logs or admin interfaces."
msgstr ""
"자격 증명은 저장되기 전에 AES-256으로 암호화됩니다. 로그 또는 관리자 인터페이"
"스에서는 절대 노출되지 않습니다."

msgid "Test Connection"
msgstr "연결 테스트"

#, python-format
msgid "Verifying your connection to %(name)s."
msgstr "%(name)s에 대한 연결을 확인 중입니다."

msgid "Connection Successful!"
msgstr "연결 성공!"

msgid "Connection Failed"
msgstr "연결 실패"

msgid "Testing Connection..."
msgstr "연결 테스트 중..."

msgid "Please wait while we verify your credentials."
msgstr "자격 증명을 확인하는 중입니다. 잠시 기다려 주세요."

msgid "API credentials verified"
msgstr "API 인증 정보 확인됨"

msgid "Account access confirmed"
msgstr "계정 접근 확인됨"

