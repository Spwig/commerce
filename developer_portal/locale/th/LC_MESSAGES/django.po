msgstr "การตรวจสอบอัตโนมัติผ่านแล้ว"

#, python-format
msgid ""
"%(type)s \"%(name)s\" v%(version)s submitted successfully. It will be "
"reviewed by our team."
msgstr ""
"%(type)s \"%(name)s\" v%(version)s ได้รับการส่งข้อมูลสำเร็จแล้ว "
"ทีมของเราจะตรวจสอบข้อมูลนี้"

msgid "Logo upload failed. Please try JPG or PNG format."
msgstr "การอัปโหลดโลโก้ล้มเหลว กรุณาลองใช้รูปแบบ JPG หรือ PNG"

msgid "Invalid logo file. Please use JPG, PNG, or WebP."
msgstr "ไฟล์โลโก้ไม่ถูกต้อง กรุณาใช้ JPG, PNG หรือ WebP"

msgid "Profile updated successfully."
msgstr "การอัปเดตโปรไฟล์สำเร็จ"

msgid "API key regenerated. Your new key is shown below."
msgstr "สร้างคีย์ API ใหม่เรียบร้อยแล้ว คีย์ใหม่ของคุณแสดงอยู่ด้านล่าง"

msgid "Response text is required."
msgstr "จำเป็นต้องระบุข้อความตอบกลับ"

msgid "Response must be under 2000 characters."
msgstr "ข้อความตอบกลับต้องไม่เกิน 2000 ตัวอักษร"

msgid "You have already claimed your free developer license."
msgstr "คุณได้รับใบอนุญาตพัฒนาฟรีแล้ว"

msgid "Company or organization name is required."
msgstr "จำเป็นต้องระบุชื่อบริษัทหรือองค์กร"

msgid "Country is required."
msgstr "จำเป็นต้องระบุประเทศ"

msgid "Free developer license"
msgstr "ใบอนุญาตสำหรับนักพัฒนาแบบฟรี"

msgid ""
"Your free developer license has been provisioned! Use the setup token below "
"to activate your Spwig installation."
msgstr ""
"ใบอนุญาตสำหรับการพัฒนาฟรีของคุณได้ถูกจัดเตรียมแล้ว! "
"กรุณาใช้โทเค็นตั้งค่าด้านล่างเพื่อเปิดใช้งานการติดตั้ง Spwig ของคุณ"

msgid ""
"Could not provision your license at this time. Please try again later or "
"contact support."
msgstr "ไม่สามารถจัดเตรียมใบอนุญาตของคุณในขณะนี้ กรุณาลองอีกครั้งในภายหลังหรือติดต่อฝ่ายสนับสนุน"

#, python-format
msgid "Failed to create cart: %(msg)s"
msgstr "ไม่สามารถสร้างตะกร้าสินค้า: %(msg)s"

msgid "Payment is not configured. Please contact support."
msgstr "การชำระเงินยังไม่ได้รับการตั้งค่า กรุณาติดต่อฝ่ายสนับสนุน"

#, python-format
msgid "Payment initialization failed: %(msg)s"
msgstr "การเริ่มต้นการชำระเงินล้มเหลว: %(msg)s"

msgid "This license has not been provisioned yet."
msgstr "ใบอนุญาตนี้ยังไม่ได้รับการจัดเตรียม"

msgid "Setup token regenerated successfully."
msgstr "โทเคนการตั้งค่าถูกสร้างใหม่สำเร็จ"

msgid "Could not regenerate the setup token. Please try again later."
msgstr "ไม่สามารถสร้างโทเค็นตั้งค่าใหม่ได้ กรุณาลองอีกครั้งในภายหลัง"

