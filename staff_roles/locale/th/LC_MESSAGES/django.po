msgstr "สิทธิ์ผู้ดูแลระบบ"

msgid "POS Permissions"
msgstr "สิทธิ์ POS"

msgid "Role Settings"
msgstr "การตั้งค่าบทบาท"

msgid "Display Name"
msgstr "ชื่อแสดงผล"

msgid "e.g. Store Manager"
msgstr "เช่น ผู้จัดการร้านค้า"

msgid "Sort Order"
msgstr "ลำดับการจัดเรียง"

msgid "What is this role for?"
msgstr "บทบาทนี้ใช้สำหรับอะไร?"

msgid "Appearance"
msgstr "ลักษณะ"

msgid "Icon"
msgstr "ไอคอน"

msgid "Badge Color"
msgstr "สีชื่อสถานะ"

