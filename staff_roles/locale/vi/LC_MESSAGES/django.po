msgstr "Vai trò nhân viên"

msgid "POS Access"
msgstr "Truy cập POS"

msgid "Can use the POS system"
msgstr "Có thể sử dụng hệ thống POS"

msgid "Manual Discounts"
msgstr "Giảm giá thủ công"

msgid "Can apply manual line-item or cart-level discounts"
msgstr "Có thể áp dụng giảm giá theo mục hoặc theo giỏ hàng thủ công"

msgid "Maximum Discount %"
msgstr "Tỷ lệ giảm giá tối đa %"

msgid "Maximum manual discount percentage allowed (0-100)"
msgstr "Tỷ lệ giảm giá thủ công tối đa cho phép (0-100)"

