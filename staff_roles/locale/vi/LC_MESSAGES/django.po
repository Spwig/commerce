msgid "Product Catalog"
msgstr "Bộ sưu tập sản phẩm"

msgid ""
"Products, categories, brands, attributes, stock, digital assets, and 3D "
"configurator"
msgstr ""
"Sản phẩm, danh mục, thương hiệu, thuộc tính, tồn kho, tài sản kỹ thuật số và"
" máy cấu hình 3D"

msgid "Orders & Fulfillment"
msgstr "Đơn hàng & Giao hàng"

msgid "Orders, refunds, returns, shipments, and shipping configuration"
msgstr "Đơn hàng, hoàn tiền, hoàn trả, giao hàng và cấu hình giao hàng"

msgid "Customers"
msgstr "Khách hàng"

msgid "Customer profiles, segments, analytics, and messages"
msgstr "Hồ sơ khách hàng, phân khúc, phân tích và tin nhắn"

msgid "Content & Pages"
msgstr "Nội dung & Trang"

msgid "Pages, blog posts, announcements, and forms"
msgstr "Trang, bài đăng blog, thông báo và biểu mẫu"

msgid "Design & Theme"
msgstr "Thiết kế & Chủ đề"

msgid "Themes, header/footer, branding, and design tokens"
msgstr "Chủ đề, tiêu đề/chân trang, thương hiệu và token thiết kế"

msgid "Marketing & Promotions"
msgstr "Tiếp thị & Khuyến mãi"

msgid ""
"Promotions, vouchers, affiliate, loyalty, referrals, product feeds, and SEO "
"generation"
msgstr ""
"Khuyến mãi, phiếu giảm giá, đại lý, chương trình khách hàng thân thiết, giới"
" thiệu, nguồn cấp sản phẩm và tạo SEO"

msgid "Media Library"
msgstr "Thư viện phương tiện"

msgid "Images, videos, and other media assets"
msgstr "Hình ảnh, video và các tài sản phương tiện khác"

msgid "Communications"
msgstr "Giao tiếp"

msgid "Email accounts, SMS/WhatsApp providers, templates, and delivery logs"
msgstr "Tài khoản email, nhà cung cấp SMS/WhatsApp, mẫu và nhật ký giao hàng"

msgid "Payments & Billing"
msgstr "Thanh toán & Hóa đơn"

msgid "Payment providers, transactions, subscriptions, and payouts"
msgstr "Các nhà cung cấp thanh toán, giao dịch, đăng ký và thanh toán"

msgid "Search"
msgstr "Tìm kiếm"

msgid "Search settings, synonyms, redirects, and analytics"
msgstr "Cài đặt tìm kiếm, từ đồng nghĩa, chuyển hướng và phân tích"

msgid "Store Settings"
msgstr "Cài đặt cửa hàng"

msgid "Site settings, geolocation, business rules, and webhooks"
msgstr "Cài đặt trang web, định vị địa lý, quy tắc kinh doanh và webhook"

msgid "POS Management"
msgstr "Quản lý POS"

msgid "POS terminal configuration and shift management"
msgstr "Cấu hình máy POS và quản lý ca làm việc"

msgid "Users & Roles"
msgstr "Người dùng & Vai trò"

msgid "Staff user accounts, roles, and API tokens"
msgstr "Tài khoản người dùng nhân viên, vai trò và token API"

msgid "Translation Service"
msgstr "Dịch vụ dịch thuật"

msgid "Translation providers, AI models, and translation metadata"
msgstr "Các nhà cung cấp dịch thuật, mô hình AI và siêu dữ liệu dịch thuật"

msgid "Custom Fields"
msgstr "Trường tùy chỉnh"

msgid "Custom field groups and definitions for extending platform objects"
msgstr "Nhóm trường tùy chỉnh và định nghĩa để mở rộng các đối tượng nền tảng"

msgid "System & Updates"
msgstr "Hệ thống và Cập nhật"

msgid ""
"Component registry, update channels, version tracking, and platform updates"
msgstr ""
"Bộ đăng ký thành phần, kênh cập nhật, theo dõi phiên bản và cập nhật nền "
"tảng"

