msgstr "Ghi đè giá"

msgid "Can override product prices at the register"
msgstr "Có thể ghi đè giá sản phẩm tại quầy thanh toán"

msgid "Process Refunds"
msgstr "Xử lý hoàn tiền"

msgid "Can process refunds on POS orders"
msgstr "Có thể xử lý hoàn tiền cho đơn hàng POS"

msgid "Void Orders"
msgstr "Hủy đơn hàng"

msgid "Can void POS orders from the current shift"
msgstr "Có thể hủy đơn hàng POS từ ca làm việc hiện tại"

msgid "Issue Gift Cards"
msgstr "Phát hành thẻ quà tặng"

msgid "Can issue new gift cards at the register"
msgstr "Có thể phát hành thẻ quà tặng mới tại quầy thanh toán"

msgid "Check Gift Card Balance"
msgstr "Kiểm tra số dư thẻ quà tặng"

msgid "Can look up gift card balances"
msgstr "Có thể tra cứu số dư thẻ quà tặng"

msgid "Cash Management"
msgstr "Quản lý tiền mặt"

msgid "Can perform cash-in and cash-out operations"
msgstr "Có thể thực hiện các giao dịch tiền mặt (nhập và rút tiền)"

msgid "Open Cash Drawer"
msgstr "Mở hộp đựng tiền"

msgid "Can open the cash drawer without a sale"
msgstr "Có thể mở ngăn kéo tiền mà không có giao dịch bán hàng"

msgid "Close Shifts"
msgstr "Đóng ca"

msgid "Can close shifts and perform cash reconciliation"
msgstr "Có thể đóng ca làm việc và thực hiện đối chiếu tiền mặt"

msgid "View POS Reports"
msgstr "Xem báo cáo POS"

msgid "Can view shift reports and sales summaries"
msgstr "Có thể xem báo cáo ca làm việc và tổng kết doanh thu"

msgid "Stock Adjustments"
msgstr "Điều chỉnh tồn kho"

msgid "Can adjust stock levels (receive, damage, recount, return)"
msgstr ""
"Có thể điều chỉnh mức tồn kho (nhận hàng, hư hỏng, kiểm đếm lại, trả hàng)"

