msgid "Product Catalog"
msgstr "فهرس المنتجات"

msgid ""
"Products, categories, brands, attributes, stock, digital assets, and 3D "
"configurator"
msgstr ""
"المنتجات، والتصنيفات، والعلامات التجارية، والخصائص، والمخزون، والأصول "
"الرقمية، والمُكوِّن ثلاثي الأبعاد"

msgid "Orders & Fulfillment"
msgstr "الطلبات والتوزيع"

msgid "Orders, refunds, returns, shipments, and shipping configuration"
msgstr "الطلبات، والاستبدالات، والمرتجعات، والشحنات، وإعدادات الشحن"

msgid "Customers"
msgstr "العملاء"

msgid "Customer profiles, segments, analytics, and messages"
msgstr "الملفات الشخصية للعملاء، والشرائح، والتحليلات، والرسائل"

msgid "Content & Pages"
msgstr "المحتوى والصفحات"

