msgstr "الthemes، والheader/footer، والbranding، والdesign tokens"

msgid "Marketing & Promotions"
msgstr "التسويق والترويج"

msgid ""
"Promotions, vouchers, affiliate, loyalty, referrals, product feeds, and SEO "
"generation"
msgstr ""
"العروض الترويجية، والقسائم، والشراكات، والولاء، والإحالات، وخلاصات المنتجات،"
" وتوليد تحسين محركات البحث"

msgid "Media Library"
msgstr "مكتبة الوسائط"

msgid "Images, videos, and other media assets"
msgstr "الصور، والفيديوهات، والصولات الإعلامية الأخرى"

msgid "Communications"
msgstr "الاتصالات"

msgid "Email accounts, SMS/WhatsApp providers, templates, and delivery logs"
msgstr ""
"حسابات البريد الإلكتروني، ومزودي الرسائل القصيرة/واتساب، والقوالب، وسجلات "
"التسليم"

msgid "Payments & Billing"
msgstr "الدفعات والفواتير"

msgid "Payment providers, transactions, subscriptions, and payouts"
msgstr "مزودي الدفع، والمعاملات، والاشتراكات، والدفعات"

msgid "Search"
msgstr "البحث"

msgid "Search settings, synonyms, redirects, and analytics"
msgstr "إعدادات البحث، والمرادفات، والتحويلات، والتحليلات"

msgid "Store Settings"
msgstr "إعدادات المتجر"

msgid "Site settings, geolocation, business rules, and webhooks"
msgstr "إعدادات الموقع، والتحديد الجغرافي، وقواعد العمل، والإشعارات التلقائية"

msgid "POS Management"
msgstr "إدارة نقاط البيع"

msgid "POS terminal configuration and shift management"
msgstr "إعدادات محطة نقاط البيع، وإدارة الورش"

msgid "Users & Roles"
msgstr "المستخدمين والأدوار"

msgid "Staff user accounts, roles, and API tokens"
msgstr "حسابات المستخدمين التابعين للإدارة، والأدوار، ورموز API"

msgid "Translation Service"
msgstr "خدمة الترجمة"

msgid "Translation providers, AI models, and translation metadata"
msgstr "مزودي الترجمة، ونماذج الذكاء الاصطناعي، وبيانات الترجمة الوصفية"

msgid "Custom Fields"
msgstr "الحقول المخصصة"

msgid "Custom field groups and definitions for extending platform objects"
msgstr "مجموعات الحقول المخصصة والتعريفات لتوسيع كائنات المنصة"

msgid "System & Updates"
msgstr "النظام والتحديثات"

msgid ""
"Component registry, update channels, version tracking, and platform updates"
msgstr "سجل المكونات، وقنوات التحديث، وتتبع الإصدارات، وتحديثات المنصة"

