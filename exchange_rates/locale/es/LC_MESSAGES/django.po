#, python-format
msgid ""
"\n"
"        Enter your API credentials for %(provider)s. These will be securely "
"encrypted and stored.\n"
"        "
msgstr ""
"\n"
"        Ingrese sus credenciales de API para %(provider)s. Estas se "
"encriptarán y almacenarán de forma segura.\n"
"        "

msgid "Don't have an account yet?"
msgstr "¿No tienes una cuenta aún?"

