"\n"
"        Antes de ingresar las credenciales, revise estos pasos de "
"configuración para %(provider)s.\n"
"        "

msgid "Setup Instructions Not Available"
msgstr "No están disponibles las instrucciones de configuración"

#, python-format
msgid ""
"\n"
"                    Setup instructions are not available for this version of "
"%(provider)s.\n"
"                    Please contact support for assistance or check for an "
"updated version.\n"
"                    "
msgstr ""
"\n"
"                    No están disponibles instrucciones de configuración para "
"esta versión de %(provider)s. Por favor, contacte al soporte para obtener "
