msgstr "{} penyedia dalam antrian untuk sinkronisasi"

msgid "{} provider(s) deleted"
msgstr "{} penyedia dihapus"

msgid "Unknown action: {}"
msgstr "Aksi tidak diketahui: {}"

msgid "An error occurred while performing the bulk action."
msgstr "Terjadi kesalahan saat melakukan aksi batch."

