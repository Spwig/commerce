msgid "Toggle manual rate active status"
msgstr "Aktifkan status tingkat manual"

msgid ""
"Toggle the active/inactive status of a manual exchange rate. When "
"deactivated, the system falls back to provider rates."
msgstr ""
"Ubah status aktif/tidak aktif dari tingkat pertukaran manual. Ketika "
"dinonaktifkan, sistem akan kembali ke tingkat penyedia."

msgid "Status toggled successfully"
msgstr "Status berhasil diaktifkan"

msgid "Rate {} successfully"
msgstr "Kurs {} berhasil"

