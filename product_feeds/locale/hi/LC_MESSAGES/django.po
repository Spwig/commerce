"                    वर्तमान में: %(counter)s प्रदाता उपलब्ध\n"
"                "

msgid "Update Available"
msgstr "अपडेट उपलब्ध है"

msgid "Installed"
msgstr "इंस्टॉल किया गया"

msgid "Available"
msgstr "उपलब्ध"

msgid "Push Feed"
msgstr "फीड धकेलें"

msgid "Hosted Feed"
msgstr "मेजबान फीड"

msgid "XML"
msgstr "XML"

msgid "CSV"
msgstr "CSV"

msgid "API Sync"
msgstr "API सिंक"

msgid "Inventory"
msgstr "स्टॉक"

msgid "Update"
msgstr "अपडेट करें"

msgid "Configure"
msgstr "सेट करें"

msgid "Install"
msgstr "इंस्टॉल करें"

msgid "View Details"
msgstr "विवरण देखें"

msgid "Learn More"
msgstr "अधिक जानें"

msgid "No Providers Available"
msgstr "कोई प्रदाता उपलब्ध नहीं"

msgid ""
"No product feed providers are currently available. Please check your update "
"server connection or contact support."
msgstr ""
"वर्तमान में कोई उत्पाद फीड प्रदाता उपलब्ध नहीं है। कृपया अपने अपडेट सर्वर कनेक्शन की जांच "
"करें या समर्थन से संपर्क करें।"

msgid "Installing provider..."
msgstr "प्रदाता इंस्टॉल कर रहा है..."

msgid "Connect Product Feed Provider"
msgstr "उत्पाद फीड प्रदाता को जोड़ें"

msgid ""
"Follow these steps to connect your product feed provider and start syncing "
"products"
msgstr ""
"अपने उत्पाद फीड प्रदाता को कनेक्ट करने और उत्पादों को सिंक करने के लिए इन चरणों का पालन "
"करें"

msgid "Select Provider"
msgstr "प्रदाता चुनें"

msgid "Setup Instructions"
msgstr "स्थापना निर्देश"

msgid "Configure Feed"
msgstr "फीड कॉन्फ़िगर करें"

msgid "Test & Save"
msgstr "परीक्षण और सहेजें"

msgid "Select a Product Feed Provider"
msgstr "एक उत्पाद फीड प्रदाता चुनें"

msgid "Choose the product feed provider you want to connect to your store."
msgstr ""
"अपने स्टोर के लिए कनेक्ट करने के लिए आपके द्वारा चुने गए उत्पाद फीड प्रदाता का चयन करें।"

msgid "JSON"
msgstr "JSON"

msgid "API Push"
msgstr "API धकेलें"

msgid "Real-time"
msgstr "वास्तविक समय"

msgid "No product feed provider components are currently installed."
msgstr "वर्तमान में कोई उत्पाद फीड प्रदाता घटक इंस्टॉल नहीं है।"

msgid ""
"Please download and install product feed provider components from the "
"component registry."
msgstr "कृपया घटक रजिस्ट्री से उत्पाद फीड प्रदाता घटक डाउनलोड और इंस्टॉल करें।"

msgid "Cancel"
msgstr "रद्द करें"

msgid "Next"
msgstr "अगला"

#, python-format
msgid ""
"\n"
"        Before entering credentials, review these setup steps for "
"%(provider)s.\n"
"        "
msgstr ""
"\n"
"        %(provider)s के लिए इन स्थापना चरणों की जांच करें।"
"%(provider)s के लिए इन स्थापना चरणों की जांच करें।\n"
"        "

msgid "Setup Instructions Not Available"
msgstr "स्थापना निर्देश उपलब्ध नहीं हैं"

#, python-format
msgid ""
"\n"
"                    Setup instructions are not available for this version of "
"%(provider)s.\n"
"                    Please contact support for assistance or check for an "
"updated version.\n"
"                    "
msgstr ""
"\n"
"                    %(provider)s के इस संस्करण के लिए स्थापना निर्देश उपलब्ध नहीं हैं। कृपया सहायता के लिए समर्थन से संपर्क करें या एक अपडेटेड संस्करण की जांच करें।\n"
"                    "

msgid "Back"
msgstr "पीछे"

msgid "Continue to Configuration"
msgstr "कॉन्फ़िगरेशन तक जारी रखें"

msgid "Configure Feed Settings"
msgstr "फीड सेटिंग्स कॉन्फ़िगर करें"

#, python-format
msgid ""
"\n"
"        Enter your API credentials and configure feed settings for "
"%(provider)s.\n"
"        "
msgstr ""
"\n"
"        अपने API एक्रेडेंटियल्स दर्ज करें और %(provider)s के लिए फीड सेटिंग्स कॉन्फ़िगर करें।"
"अपने API एक्रेडेंटियल्स दर्ज करें और %(provider)s के लिए फीड सेटिंग्स कॉन्फ़िगर करें।\n"
"        "

msgid "Don't have an account yet?"
msgstr "अभी तक खाता नहीं है?"

msgid "You'll need an account to get API credentials."
msgstr "आपको API प्रमाणपत्र प्राप्त करने के लिए एक खाता चाहिए।"

msgid "Sign up here"
msgstr "यहां रजिस्टर करें"

msgid "Feed Name"
msgstr "फीड का नाम"

msgid "e.g., Google Shopping - US, Meta Catalog - Main"
msgstr "उदाहरण के लिए, Google Shopping - US, Meta Catalog - Main"

msgid "Give this feed a descriptive name to identify it in your dashboard."
msgstr "अपने डैशबोर्ड में इसे पहचानने के लिए इस फीड के लिए एक विवरणात्मक नाम दें।"

msgid "API Credentials"
msgstr "API प्रमाणपत्र"

msgid "Select..."
msgstr "चुनें..."

msgid "No credential fields configured for this provider."
msgstr "इस प्रदाता के लिए कोई प्रमाणपत्र क्षेत्र निर्धारित नहीं है।"

msgid "Feed Settings"
msgstr "फीड सेटिंग्स"

msgid "Sync Interval"
msgstr "सिंक अंतराल"

msgid "Hourly"
msgstr "तीन घंटे के बराबर"

msgid "Daily"
msgstr "दैनिक"

msgid "Weekly"
msgstr "हफ्ते में"

msgid "How often to automatically sync your product feed to this provider."
msgstr "इस प्रदाता के लिए अपने उत्पाद फीड को कितनी बार स्वचालित रूप से सिंक करें।"

msgid "The format to generate your product feed in."
msgstr "अपने उत्पाद फीड को जनरेट करने के लिए फॉर्मेट।"

msgid "Enable this feed"
msgstr "इस फीड को एनेबल करें"

msgid "Uncheck to disable automatic syncing for this feed."
msgstr "इस फीड के लिए स्वचालित सिंक को अक्षम करने के लिए अनचेक करें।"

msgid ""
"Your credentials will be encrypted using AES-256 encryption before being "
"stored in the database."
msgstr ""
"आपके प्रमाणपत्रों को डेटाबेस में संग्रहित करने से पहले AES-256 एन्क्रिप्शन का उपयोग करके "
"एन्क्रिप्ट किया जाएगा।"

msgid "Test Connection"
msgstr "कनेक्शन परीक्षण करें"

#, python-format
msgid ""
"\n"
"        Test the connection to %(provider)s to verify your credentials are "
"correct.\n"
"        "
msgstr ""
"\n"
"        %(provider)s के कनेक्शन का परीक्षण करें ताकि आपके लॉगिन विवरण सही हैं या नहीं।"
"%(provider)s के कनेक्शन का परीक्षण करें ताकि आपके लॉगिन विवरण सही हैं या नहीं।\n"
"        "

msgid "Testing connection..."
msgstr "कनेक्शन का परीक्षण कर रहा है..."

msgid "Please wait while we verify your credentials."
msgstr "कृपया प्रतीक्षा करें जब तक हम आपके प्रमाणपत्रों की जांच करते हैं।"

msgid "Click to test the connection with your entered credentials."
msgstr "अपने प्रविष्ट प्रमाणपत्रों के साथ कनेक्शन का परीक्षण करने के लिए क्लिक करें।"

msgid "Connection Successful!"
msgstr "कनेक्शन सफल!"

msgid "Connection Details"
msgstr "कनेक्शन विवरण"

msgid "Feed Preview"
msgstr "फीड पूर्वावलोकन"

msgid "Here's a preview of what your product feed will look like:"
msgstr "यहां आपके उत्पाद फीड के रूप में क्या दिखाई देगा उसकी एक पूर्व दृश्य है:"

msgid "Categories"
msgstr "श्रेणियाँ"

msgid "Format"
msgstr "फॉर्मेट"

msgid "Save & Finish"
msgstr "सहेजें और समाप्त करें"

msgid "Your credentials were verified successfully."
msgstr "आपके अधिकार पत्र सफलतापूर्वक सत्यापित कर दिए गए हैं।"

msgid "Connection Failed"
msgstr "कनेक्शन विफल"

msgid "Could not connect to the provider API."
msgstr "प्रदाता API से कनेक्ट करने में विफल रहा।"

msgid "An unexpected error occurred."
msgstr "अप्रत्याशित त्रुटि हुई।"

msgid "Saving..."
msgstr "सहेज रहा है..."

msgid "Failed to save feed provider account."
msgstr "फीड प्रदाता खाता बचाने में विफल रहा।"

msgid "An error occurred while saving."
msgstr "सहेजते समय एक त्रुटि हुई।"

msgid "Connect Product Feed Provider - Select Provider"
msgstr "उत्पाद फीड प्रदाता कनेक्ट करें - प्रदाता चुनें"

msgid "Please select a provider."
msgstr "कृपया एक प्रदाता चुनें।"

msgid "Invalid provider selected."
msgstr "अमान्य प्रदाता चुना गया है।"

msgid "Please select a provider first."
msgstr "कृपया पहले एक प्रदाता चुनें।"

#, python-format
msgid "Setup instructions not found for %(provider)s. Please contact support."
msgstr "%(provider)s के लिए स्थापना निर्देश नहीं मिले। कृपया समर्थन से संपर्क करें।"

#, python-format
msgid "Error loading provider: %(error)s"
msgstr "प्रदाता लोड करने में त्रुटि: %(error)s"

msgid "Connect Product Feed Provider - Setup Instructions"
msgstr "उत्पाद फीड प्रदाता कनेक्ट करें - स्थापना निर्देश"

msgid "Could not load provider configuration."
msgstr "प्रदाता के सेटअप को लोड करने में विफल रहा।"

msgid "Connect Product Feed Provider - Configure Feed"
msgstr "उत्पाद फीड प्रदाता कनेक्ट करें - फीड सेटिंग करें"

msgid "Error loading provider configuration."
msgstr "प्रदाता के सेटअप को लोड करते समय त्रुटि हुई।"

#, python-format
msgid "%(field)s is required."
msgstr "%(field)s आवश्यक है।"

msgid "Feed Name is required."
msgstr "फीड का नाम आवश्यक है।"

msgid "Please complete previous steps first."
msgstr "कृपया पहले पिछले चरण पूरा करें।"

msgid "Provider not found."
msgstr "प्रदाता नहीं मिला।"

msgid "Connect Product Feed Provider - Test Connection"
msgstr "उत्पाद फीड प्रदाता कनेक्ट करें - कनेक्शन परीक्षण करें"

msgid "Provider implementation not found."
msgstr "प्रदाता के लेआउट को नहीं मिला।"

msgid "Site not configured."
msgstr "साइट कॉन्फ़िगर नहीं की गई है।"

msgid "Connection test failed"
msgstr "कनेक्शन परीक्षण विफल"

msgid "Product feed provider connected successfully!"
msgstr "उत्पाद फीड प्रदाता सफलतापूर्वक जुड़ गया!"

msgid "Feed sync started"
msgstr "फीड सिंक शुरू हो गया"

msgid "No feed available"
msgstr "कोई फीड उपलब्ध नहीं है"

msgid "enabled"
msgstr "सक्रिय"

msgid "disabled"
msgstr "असक्रिय"

msgid "Provider is already installed. Configure it now."
msgstr "प्रदाता पहले से ही इंस्टॉल है। अब इसे निर्माण करें।"

msgid "Provider not found on update server."
msgstr "अपडेट सर्वर पर प्रदाता नहीं मिला।"

msgid "Could not determine provider version."
msgstr "प्रदाता के वर्जन का पता लगाया नहीं जा सका।"

#, python-format
msgid "Failed to download provider: %(error)s"
msgstr "प्रदाता डाउनलोड करने में विफल: %(error)s"

#, python-format
msgid "Failed to install provider: %(error)s"
msgstr "प्रदाता इंस्टॉल करने में विफल: %(error)s"

#, python-format
msgid "Provider \"%(name)s\" installed successfully! Configure it now."
msgstr "प्रदाता \"%(name)s\" सफलतापूर्वक इंस्टॉल कर दिया गया! अब इसे सेट करें।"

msgid "Provider not installed."
msgstr "प्रदाता इंस्टॉल नहीं किया गया।"

#, python-format
msgid "Could not connect to update server: %(error)s"
msgstr "अपडेट सर्वर से कनेक्ट नहीं कर सका: %(error)s"

msgid "Could not determine latest version."
msgstr "नवीनतम संस्करण निर्धारित नहीं किया जा सका।"

#, python-format
msgid "Provider \"%(name)s\" is already up to date (v%(version)s)."
msgstr "प्रदाता \"%(name)s\" पहले से ही अप-टू-डेट है (v%(version)s)"

#, python-format
msgid "Failed to download update: %(error)s"
msgstr "अपडेट डाउनलोड करने में विफल रहे: %(error)s"

#, python-format
msgid "Failed to install update: %(error)s"
msgstr "अपडेट इंस्टॉल करने में विफल रहे: %(error)s"

#, python-format
msgid "Provider \"%(name)s\" updated successfully to v%(version)s!"
msgstr "प्रदाता \"%(name)s\" को सफलतापूर्वक v%(version)s तक अपडेट कर दिया गया!"
