msgstr "Priority Mail®"

msgid "Priority Mail Express®"
msgstr "Priority Mail Express®"

msgid "Parcel Select®"
msgstr "Parcel Select®"

msgid "Parcel Select Lightweight®"
msgstr "Parcel Select Lightweight®"

