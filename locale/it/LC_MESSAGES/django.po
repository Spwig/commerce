msgstr "Sistema di Pagamento Enterprise (EPS)"

msgid "For high-volume shippers"
msgstr "Per spedizionieri ad alto volume"

msgid "Permit Account"
msgstr "Account Permesso"

msgid "For bulk mail"
msgstr "Per posta in grandi quantità"

msgid "Postage Meter"
msgstr "Metro di Spesa"

msgid "For PC Postage meters"
msgstr "Per metro di spesa per PC"

