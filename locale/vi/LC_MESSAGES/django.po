msgstr "Định dạng phản hồi từ API theo dõi của FedEx không mong đợi: %(error)s"

msgid "FedEx REST API does not support webhooks. Use polling instead."
msgstr "API REST của FedEx không hỗ trợ webhooks. Sử dụng polling thay vào đó."

msgid "FedEx Ground"
msgstr "FedEx Ground"

msgid "FedEx Home Delivery"
msgstr "FedEx Giao hàng tại nhà"

msgid "FedEx Express Saver"
msgstr "FedEx Express Saver"

msgid "FedEx 2Day"
msgstr "FedEx 2 Ngày"

msgid "FedEx 2Day AM"
msgstr "FedEx 2 Ngày (Sáng)"

msgid "FedEx Standard Overnight"
msgstr "FedEx Chuẩn Giao hàng qua đêm"

msgid "FedEx Priority Overnight"
msgstr "FedEx Ưu tiên Giao hàng qua đêm"

msgid "FedEx First Overnight"
msgstr "FedEx Đầu tiên Giao hàng qua đêm"

msgid "FedEx International Economy"
msgstr "FedEx Quốc tế Kinh tế"

msgid "FedEx International Priority"
msgstr "FedEx Quốc tế Ưu tiên"

msgid "FedEx International First"
msgstr "FedEx Quốc tế Đầu tiên"

msgid "FedEx International Ground"
msgstr "FedEx Quốc tế Ground"

msgid "FedEx Europe First"
msgstr "FedEx Châu Âu Đầu tiên"

msgid "FedEx SmartPost"
msgstr "FedEx SmartPost"

msgid "FedEx Freight Economy"
msgstr "FedEx Hàng hóa Kinh tế"

msgid "FedEx Freight Priority"
msgstr "FedEx Hàng hóa Ưu tiên"

msgid "FedEx 1Day Freight"
msgstr "FedEx 1 Ngày Hàng hóa"

msgid "FedEx 2Day Freight"
msgstr "FedEx 2 Ngày Hàng hóa"

msgid "FedEx 3Day Freight"
msgstr "FedEx 3 Ngày Hàng hóa"

msgid "Getting Your FedEx API Credentials"
msgstr "Được FedEx API Credentials"

msgid ""
"Follow these steps to set up your FedEx developer account and obtain API "
"credentials"
msgstr ""
"Thực hiện các bước sau để thiết lập tài khoản phát triển của bạn trên FedEx "
"và lấy thông tin xác thực API"

msgid "Create a FedEx Developer Account"
msgstr "Tạo tài khoản nhà phát triển FedEx"

msgid ""
"Visit the FedEx Developer Portal and sign up for a free developer account."
msgstr ""
"Truy cập Trang cổng phát triển của FedEx và đăng ký tài khoản phát triển "
"miễn phí."

msgid "Open FedEx Developer Portal"
msgstr "Mở Cổng thông tin nhà phát triển FedEx"

msgid "You'll need a valid email address and basic business information."
msgstr "Bạn sẽ cần một địa chỉ email hợp lệ và thông tin kinh doanh cơ bản."

msgid "Create a New Project"
msgstr "Tạo Dự án mới"

msgid "Click 'Create New Project' or navigate to 'My Projects'"
msgstr "Nhấp vào 'Tạo Dự án mới' hoặc điều hướng đến 'Dự án của tôi'"

msgid ""
"Give your project a descriptive name (e.g., 'My Store Shipping Integration')"
msgstr ""
"Đặt tên mô tả cho dự án của bạn (ví dụ: 'Tích hợp giao hàng Cửa hàng của "
"tôi')"

msgid "Select the APIs you need (at minimum: Ship, Track, Rates)"
msgstr "Chọn các API bạn cần (ít nhất: Ship, Track, Rates)"

msgid "Accept the terms of service"
msgstr "Chấp nhận điều khoản dịch vụ"

msgid "Generate API Credentials"
msgstr "Tạo thông tin xác thực API"

msgid "In your project dashboard:"
msgstr "Trên bảng điều khiển dự án của bạn:"

msgid "Navigate to 'API Credentials' or 'Keys & Secrets'"
msgstr "Điều hướng đến 'Thông tin xác thực API' hoặc 'Khóa & Bí mật'"

msgid "Click 'Generate New Credentials' or 'Create API Key'"
msgstr "Nhấp vào 'Tạo Thông tin xác thực mới' hoặc 'Tạo Khóa API'"

msgid "You will receive an API Key (Client ID) and API Secret (Client Secret)"
msgstr "Bạn sẽ nhận được một API Key (Client ID) và API Secret (Client Secret)"

msgid "Copy both values immediately - you'll need them in the next step"
msgstr ""
"Sao chép cả hai giá trị ngay lập tức - bạn sẽ cần chúng trong bước tiếp theo"

msgid "Important!"
msgstr "Quan trọng!"

msgid ""
"FedEx will only show your API Secret once. Make sure to save it securely "
"before closing the page."
msgstr ""
"FedEx chỉ hiển thị API Secret của bạn một lần. Đảm bảo lưu trữ nó an toàn "
"trước khi đóng trang."

msgid "Choose Your Environment"
msgstr "Chọn Môi trường của bạn"

msgid "FedEx provides two environments for API integration:"
msgstr "FedEx cung cấp hai môi trường cho tích hợp API:"

msgid "Test Environment"
msgstr "Môi trường kiểm thử"

msgid ""
"Use this for development and testing. It allows you to simulate shipments "
"without creating real labels or charges. Recommended for initial setup."
msgstr ""
"Sử dụng môi trường này cho phát triển và kiểm tra. Nó cho phép bạn mô phỏng "
"các đơn hàng mà không tạo nhãn giao hàng thực tế hoặc phí. Được khuyến khích "
"sử dụng cho thiết lập ban đầu."

msgid "Production Environment"
msgstr "Môi trường sản xuất"

msgid ""
"Use this for live shipments with real tracking numbers and charges. Requires "
"account approval from FedEx."
msgstr ""
"Sử dụng môi trường này cho các đơn hàng thực tế với số theo dõi và phí thật. "
"Yêu cầu phê duyệt tài khoản từ FedEx."

msgid ""
"Start with the Test environment to verify your integration works correctly "
"before switching to Production."
msgstr ""
"Bắt đầu với môi trường Test để xác minh tích hợp của bạn hoạt động đúng "
"trước khi chuyển sang Production."

msgid "Gather Your Account Information"
msgstr "Thu thập Thông tin Tài khoản của bạn"

msgid "You will also need your FedEx account number. This can be found:"
msgstr "Bạn cũng cần số tài khoản FedEx của mình. Bạn có thể tìm thấy nó ở:"

msgid "On your FedEx invoices"
msgstr "Trên các hóa đơn FedEx của bạn"

msgid "In your FedEx account dashboard (fedex.com)"
msgstr "Trên bảng điều khiển tài khoản FedEx của bạn (fedex.com)"

msgid "By contacting FedEx customer service"
msgstr "Bằng cách liên hệ với dịch vụ khách hàng của FedEx"

msgid ""
"Your account number is required for generating shipping labels and accessing "
"certain features."
msgstr ""
"Số tài khoản của bạn là bắt buộc để tạo nhãn giao hàng và truy cập một số "
"tính năng."

msgid "FedEx Developer Support"
msgstr "Hỗ trợ kỹ thuật cho nhà phát triển FedEx"

msgid "Check the"
msgstr "Kiểm tra"

msgid "FedEx API Reference"
msgstr "Tài liệu tham khảo API FedEx"

msgid "Contact FedEx Developer Support at"
msgstr "Liên hệ Hỗ trợ kỹ thuật cho nhà phát triển FedEx tại"

msgid "FedEx Developer account created"
msgstr "Tài khoản nhà phát triển FedEx đã được tạo"

msgid "Project created in the developer portal"
msgstr "Dự án đã được tạo trong cổng phát triển"

msgid "API Key (Client ID) copied and ready"
msgstr "API Key (Client ID) đã sao chép và sẵn sàng"

msgid "API Secret (Client Secret) copied and ready"
msgstr "API Secret (Client Secret) đã sao chép và sẵn sàng"

msgid "Decided on Test vs Production environment"
msgstr "Đã quyết định môi trường Test vs. Production"

msgid "FedEx account number available (if applicable)"
msgstr "Số tài khoản FedEx có sẵn (nếu áp dụng)"

msgid "NinjaVan"
msgstr "NinjaVan"

msgid "Client ID from NinjaVan Dashboard > Settings > IT Settings"
msgstr "Client ID từ Bảng điều khiển NinjaVan > Cài đặt > Cài đặt IT"

msgid "Client Secret from NinjaVan Dashboard > Settings > IT Settings"
msgstr "Bí mật khách hàng từ Bảng điều khiển NinjaVan > Cài đặt > Cài đặt IT"

msgid "Country"
msgstr "Quốc gia"

msgid "Country of your NinjaVan account"
msgstr "Quốc gia của tài khoản NinjaVan của bạn"

msgid "Use sandbox for testing, production after passing integration audit"
msgstr ""
"Sử dụng môi trường sandbox để kiểm tra, sản xuất sau khi vượt qua kiểm toán "
"tích hợp"

msgid "OAuth not completed. Please authorize your NinjaVan account."
msgstr "OAuth chưa hoàn tất. Vui lòng xác thực tài khoản NinjaVan của bạn."

msgid "Authentication failed. Please re-authorize your NinjaVan account."
msgstr "Xác thực thất bại. Vui lòng xác thực lại tài khoản NinjaVan của bạn."

#, python-brace-format
msgid "Connection failed: {error}"
msgstr "Kết nối thất bại: {error}"

msgid "Order cancelled successfully"
msgstr "Đơn hàng đã được hủy thành công"

msgid "Setting Up Your NinjaVan Integration"
msgstr "Cài đặt Tích hợp NinjaVan của bạn"

msgid ""
"NinjaVan uses OAuth 2.0 for secure authentication. Follow these steps to "
"connect your NinjaVan account."
msgstr ""
"NinjaVan sử dụng OAuth 2.0 để xác thực an toàn. Hãy làm theo các bước sau để "
"kết nối tài khoản NinjaVan của bạn."

msgid "Important Differences from Traditional Integrations:"
msgstr "Sự khác biệt quan trọng so với các tích hợp truyền thống:"

msgid ""
"NinjaVan Plugin APIs use OAuth 2.0 - you'll log into your NinjaVan Dashboard "
"to grant permissions"
msgstr ""
"APIs Plugin của NinjaVan sử dụng OAuth 2.0 - bạn sẽ đăng nhập vào Bảng điều "
"khiển NinjaVan để cấp quyền"

msgid "No rate calculation - you already have pricing in your NinjaVan account"
msgstr "Không tính giá - bạn đã có giá cả trong tài khoản NinjaVan của bạn"

msgid "Production access requires passing NinjaVan's integration audit"
msgstr "Truy cập sản xuất yêu cầu vượt qua kiểm toán tích hợp của NinjaVan"

msgid "Introduction to NinjaVan Plugin API"
msgstr "Giới thiệu về API Plugin NinjaVan"

msgid ""
"NinjaVan's Plugin API allows you to create orders, generate shipping labels, "
"and receive real-time tracking updates via webhooks."
msgstr ""
"API Plugin của NinjaVan cho phép bạn tạo đơn hàng, tạo nhãn vận chuyển và "
"nhận cập nhật theo dõi thời gian thực thông qua webhooks."

msgid "Supported Countries:"
msgstr "Các quốc gia được hỗ trợ:"

msgid "View API Documentation"
msgstr "Xem Tài liệu API"

msgid "Prerequisites"
msgstr "Yêu cầu tiên quyết"

msgid "Required:"
msgstr "Yêu cầu:"

msgid ""
"You must have a NinjaVan Postpaid Pro account to use the Plugin APIs. Other "
"account types are not supported."
msgstr ""
"Bạn phải có tài khoản Postpaid Pro của NinjaVan để sử dụng APIs Plugin. Các "
"loại tài khoản khác không được hỗ trợ."

msgid "Before continuing, ensure you have:"
msgstr "Trước khi tiếp tục, đảm bảo bạn đã có:"

msgid "An active NinjaVan Postpaid Pro account"
msgstr "Tài khoản Postpaid Pro của NinjaVan đang hoạt động"

msgid "Access to NinjaVan Dashboard"
msgstr "Truy cập vào Bảng điều khiển NinjaVan"

msgid "Sandbox"
msgstr "Môi trường Sandbox"

msgid "Production"
msgstr "Môi trường Sản xuất"

msgid "Your shop domain must use HTTPS (required for OAuth and webhooks)"
msgstr ""
"Tên miền cửa hàng của bạn phải sử dụng HTTPS (yêu cầu cho OAuth và webhooks)"

msgid "Generate Client ID & Client Secret"
msgstr "Tạo Client ID & Client Secret"

msgid "To obtain your OAuth credentials:"
msgstr "Để nhận thông tin xác thực OAuth của bạn:"

msgid "Log into your NinjaVan Dashboard"
msgstr "Đăng nhập vào Bảng điều khiển NinjaVan của bạn"

msgid "Sandbox:"
msgstr "Môi trường Sandbox:"

msgid "Production:"
msgstr "Môi trường Sản xuất:"

msgid "Settings > IT Settings"
msgstr "Cài đặt > Cài đặt IT"

msgid "REGENERATE CLIENT ID & KEY"
msgstr "TẠO LẠI ID & KHÓA KHÁCH HÀNG"

msgid "Copy the"
msgstr "Sao chép"

msgid "Save Your Client Secret!"
msgstr "Lưu Bí mật Khách hàng của bạn!"

msgid ""
"NinjaVan will only show the Client Secret once. Save it securely before "
"closing the page."
msgstr ""
"NinjaVan chỉ hiển thị Client Secret một lần. Hãy lưu trữ nó an toàn trước "
"khi đóng trang."

msgid "You'll need to provide these credentials when configuring the provider:"
msgstr ""
"Bạn sẽ cần cung cấp các thông tin xác thực này khi cấu hình nhà cung cấp:"

msgid "From NinjaVan Dashboard > Settings > IT Settings"
msgstr "Từ Bảng điều khiển NinjaVan > Cài đặt > Cài đặt IT"

msgid "Shown only once after generation"
msgstr "Chỉ hiển thị một lần sau khi tạo"

msgid "Country Code"
msgstr "Mã quốc gia"

msgid "Select the country where your NinjaVan account is registered"
msgstr "Chọn quốc gia nơi tài khoản NinjaVan của bạn đã đăng ký"

msgid "Choose Sandbox for testing or Production for live shipments"
msgstr "Chọn Sandbox để kiểm tra hoặc Production cho vận chuyển trực tiếp"

msgid "Register Your Redirect URI with NinjaVan"
msgstr "Đăng ký Redirect URI của bạn với NinjaVan"

msgid ""
"Before you can complete OAuth authorization, you must email NinjaVan to "
"register your redirect URI:"
msgstr ""
"Trước khi bạn hoàn tất xác thực OAuth, bạn phải gửi email cho NinjaVan để "
"đăng ký Redirect URI của bạn:"

msgid "Your OAuth Redirect URI:"
msgstr "URI chuyển hướng OAuth của bạn:"

msgid "Email the following information to:"
msgstr "Gửi thông tin sau qua email đến:"

msgid "Subject:"
msgstr "Tiêu đề:"

msgid "Body:"
msgstr "Nội dung:"

msgid ""
"NinjaVan typically responds within 1-2 business days with sandbox "
"credentials. Continue to the next step once you receive confirmation."
msgstr ""
"NinjaVan thường phản hồi trong vòng 1-2 ngày làm việc với thông tin xác thực "
"sandbox. Tiếp tục đến bước tiếp theo sau khi bạn nhận được xác nhận."

msgid "Connect to NinjaVan via OAuth"
msgstr "Kết nối với NinjaVan qua OAuth"

msgid ""
"Once NinjaVan has registered your redirect URI, you can complete the OAuth "
"authorization:"
msgstr ""
"Sau khi NinjaVan đã đăng ký Redirect URI của bạn, bạn có thể hoàn tất xác "
"thực OAuth:"

msgid "Connect to NinjaVan"
msgstr "Kết nối với NinjaVan"

msgid "button (provided after entering credentials)"
msgstr "nút (sẽ được cung cấp sau khi nhập thông tin xác thực)"

msgid "You'll be redirected to the NinjaVan Dashboard login page"
msgstr "Bạn sẽ được chuyển hướng đến trang đăng nhập Bảng điều khiển NinjaVan"

msgid "Log in with your NinjaVan account credentials"
msgstr "Đăng nhập bằng thông tin xác thực tài khoản NinjaVan của bạn"

msgid "Review the requested permissions and click"
msgstr "Xem xét các quyền được yêu cầu và nhấp"

msgid "Authorize"
msgstr "Xác thực"

msgid "You'll be redirected back to your shop with an authorization code"
msgstr "Bạn sẽ được chuyển hướng trở lại cửa hàng của bạn với mã xác thực"

msgid ""
"The system will automatically exchange the code for access and refresh tokens"
msgstr "Hệ thống sẽ tự động đổi mã này thành mã truy cập và mã làm mới"

msgid "Security Note:"
msgstr "Lưu ý về bảo mật:"

msgid ""
"Your tokens are encrypted and stored securely. They are automatically "
"refreshed 5 minutes before expiry."
msgstr ""
"Các mã của bạn được mã hóa và lưu trữ an toàn. Chúng sẽ được làm mới tự động "
"5 phút trước khi hết hạn."

msgid "Required OAuth Scopes:"
msgstr "Phạm vi OAuth cần thiết:"

msgid "Create delivery orders"
msgstr "Tạo đơn giao hàng"

msgid "Cancel pending orders"
msgstr "Hủy đơn hàng đang chờ"

msgid "Generate waybill/labels"
msgstr "Tạo vận đơn/ nhãn"

msgid "Fetch service settings"
msgstr "Lấy cài đặt dịch vụ"

msgid "List webhook subscriptions"
msgstr "Liệt kê các đăng ký webhook"

msgid "Create webhook subscriptions"
msgstr "Tạo đăng ký webhook"

msgid "Remove webhook subscriptions"
msgstr "Xóa đăng ký webhook"

msgid "Webhook Configuration"
msgstr "Cấu hình Webhook"

msgid ""
"Webhooks are automatically configured when you connect your NinjaVan account."
msgstr ""
"Webhooks được cấu hình tự động khi bạn kết nối tài khoản NinjaVan của mình."

msgid "Your Webhook Endpoint:"
msgstr "Điểm cuối webhook của bạn:"

msgid "Subscribed Events:"
msgstr "Sự kiện đã đăng ký:"

msgid "Order created and ready for pickup"
msgstr "Đơn hàng đã được tạo và sẵn sàng để nhận"

msgid "Shipment temporarily held"
msgstr "Giao hàng tạm dừng"

msgid "Package is in transit"
msgstr "Gói hàng đang được vận chuyển"

msgid "Package out for delivery"
msgstr "Gói hàng đang được giao"

msgid "Successfully delivered"
msgstr "Giao hàng thành công"

msgid "Delivery attempt failed"
msgstr "Lần giao hàng thất bại"

msgid "Order cancelled"
msgstr "Đơn hàng đã hủy"

msgid "Package returned"
msgstr "Gói hàng được trả lại"

msgid "Webhook Security:"
msgstr "Bảo mật webhook:"

msgid ""
"All webhooks are verified using HMAC-SHA256 signatures. Invalid signatures "
"are automatically rejected."
msgstr ""
"Tất cả webhooks được xác minh bằng chữ ký HMAC-SHA256. Các chữ ký không hợp "
"lệ sẽ bị từ chối tự động."

msgid ""
"After OAuth authorization, the system will automatically test your "
"connection by fetching your shipper settings."
msgstr ""
"Sau khi xác thực OAuth, hệ thống sẽ tự động kiểm tra kết nối của bạn bằng "
"cách lấy cài đặt người vận chuyển của bạn."

msgid "Connection test will verify:"
msgstr "Kiểm tra kết nối sẽ xác minh:"

msgid "OAuth tokens are valid"
msgstr "Token OAuth hợp lệ"

msgid "API endpoints are accessible"
msgstr "Điểm cuối API có thể truy cập"

msgid "Your NinjaVan account settings are retrievable"
msgstr "Cài đặt tài khoản NinjaVan của bạn có thể được truy xuất"

msgid "Webhook subscriptions are active"
msgstr "Đăng ký webhook đang hoạt động"

msgid "Information displayed:"
msgstr "Thông tin được hiển thị:"

msgid "Available service types (Standard, Return, Marketplace, etc.)"
msgstr "Các loại dịch vụ có sẵn (Standard, Return, Marketplace, v.v.)"

msgid "Service levels configured in your account"
msgstr "Các cấp độ dịch vụ được cấu hình trong tài khoản của bạn"

msgid "Your tracking prefix(es)"
msgstr "Tiền tố theo dõi của bạn"

msgid "Pickup and delivery settings"
msgstr "Cài đặt thu và giao hàng"

msgid "Success!"
msgstr "Thành công!"

msgid ""
"If the connection test passes, you're ready to start creating orders in "
"sandbox."
msgstr ""
"Nếu kiểm tra kết nối thành công, bạn đã sẵn sàng để bắt đầu tạo đơn hàng "
"trong môi trường sandbox."

msgid "Integration Audit (Required for Production)"
msgstr "Kiểm toán tích hợp (Yêu cầu cho môi trường sản xuất)"

msgid "Production Access Requires Audit:"
msgstr "Truy cập sản xuất yêu cầu kiểm toán:"

msgid ""
"Before NinjaVan grants production access, you must pass their integration "
"audit by submitting test orders."
msgstr ""
"Trước khi NinjaVan cấp quyền truy cập sản xuất, bạn phải vượt qua kiểm toán "
"tích hợp của họ bằng cách gửi các đơn hàng kiểm tra."

msgid "Audit Requirements:"
msgstr "Yêu cầu kiểm toán:"

msgid ""
"Create at least 3 test orders using your integrated UI (not Postman or "
"direct API calls)"
msgstr ""
"Tạo ít nhất 3 đơn hàng kiểm tra bằng giao diện tích hợp của bạn (không phải "
"Postman hoặc gọi API trực tiếp)"

msgid "Test orders must include:"
msgstr "Đơn hàng kiểm tra phải bao gồm:"

msgid "Accurate addresses with valid postal codes"
msgstr "Địa chỉ chính xác với mã bưu chính hợp lệ"

msgid "Valid phone numbers and email addresses"
msgstr "Số điện thoại và địa chỉ email hợp lệ"

msgid "Proper package dimensions and weight"
msgstr "Kích thước và trọng lượng gói hàng hợp lệ"

msgid "Submit your test orders via the audit link provided by NinjaVan"
msgstr ""
"Gửi các đơn hàng kiểm tra của bạn qua liên kết kiểm toán được cung cấp bởi "
"NinjaVan"

msgid "Wait for NinjaVan QA team to review (typically 3-5 business days)"
msgstr "Chờ đội ngũ QA của NinjaVan xem xét (thường mất 3-5 ngày làm việc)"

msgid "Audit Focus Areas:"
msgstr "Khu vực tập trung kiểm toán:"

msgid "OAuth login flow, token handling, and disconnection cleanup"
msgstr "Quy trình đăng nhập OAuth, xử lý mã và dọn dẹp khi ngắt kết nối"

msgid "Webhook APIs:"
msgstr "API webhook:"

msgid "Subscription timing and webhook event processing"
msgstr "Thời gian đăng ký và xử lý sự kiện webhook"

msgid "Error Handling:"
msgstr "Xử lý lỗi:"

msgid "Proper handling of success (200) and failure (400, 401, 5xx) responses"
msgstr "Xử lý đúng các phản hồi thành công (200) và thất bại (400, 401, 5xx)"

msgid "Token Refresh:"
msgstr "Làm mới token:"

msgid "Automatic refresh 5 minutes before expiry or on 401 errors"
msgstr "Làm mới tự động 5 phút trước khi hết hạn hoặc khi xảy ra lỗi 401"

msgid ""
"Once approved, you'll need to regenerate your tokens for production and "
"reconfigure the provider with production credentials."
