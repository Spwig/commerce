msgstr "Tài liệu tham khảo API UPS"

msgid "Contact UPS Developer Support at"
msgstr "Liên hệ hỗ trợ nhà phát triển UPS tại"

msgid "For general UPS account questions, call"
msgstr "Để hỏi về tài khoản UPS chung, vui lòng gọi"

