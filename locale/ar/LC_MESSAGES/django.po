msgstr "التسليم الأرضي القياسي (2-9 أيام عمل)"

msgid "Expedited Parcel"
msgstr "الحزمة السريعة"

msgid "Faster ground service (1-7 business days)"
msgstr "خدمة أرضية أسرع (1-7 أيام عمل)"

msgid "Xpresspost"
msgstr "Xpresspost"

msgid "Next-day to 2-day delivery with tracking"
msgstr "التسليم في يوم واحد إلى يومين مع تتبع"

msgid "Priority"
msgstr "الأولوية"

msgid "Overnight to most Canadian destinations"
msgstr "overnight إلى معظم الوجهات الكندية"

msgid "USA Services"
msgstr "خدمات الولايات المتحدة"

msgid "Expedited Parcel USA"
msgstr "الحزمة السريعة (الولايات المتحدة الأمريكية)"

msgid "Ground service to USA (4-7 business days)"
msgstr "خدمة أرضية إلى الولايات المتحدة (4-7 أيام عمل)"

msgid "Xpresspost USA"
msgstr "Xpresspost (الولايات المتحدة الأمريكية)"

msgid "Fast air service to USA (2-3 business days)"
msgstr "خدمة جوية سريعة إلى الولايات المتحدة (2-3 أيام عمل)"

msgid "Xpresspost International"
msgstr "Xpresspost الدولي"

msgid "Fast air service to 65+ countries (4-7 business days)"
msgstr "خدمة جوية سريعة إلى 65+ دولة (4-7 أيام عمل)"

msgid "International Parcel Air"
msgstr "الحزمة الدولية بالطائرة"

msgid "Air service to worldwide destinations (6-12 business days)"
msgstr "خدمة جوية إلى وجهات عالمية (6-12 يوم عمل)"

msgid "International Parcel Surface"
msgstr "الحزمة الدولية بالطريق"

msgid "Surface service (4-12 weeks, varies by destination)"
msgstr "خدمة سطحية (4-12 أسبوع، يختلف حسب الوجهة)"

msgid ""
"All services are available to both Contract and Non-Contract customers, but "
"Contract customers receive discounted rates."
msgstr ""
"جميع الخدمات متاحة لعملاء العقد وعملاء غير العقد، لكن عملاء العقد يحصلون على "
"أسعار مخفضة."

msgid "Configure Shipping Options"
msgstr "قم بتكوين خيارات الشحن"

