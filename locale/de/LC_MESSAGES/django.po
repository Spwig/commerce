msgstr "Versicherungsdeckung für Paketinhalte"

msgid "Amount in CAD"
msgstr "Betrag in CAD"

msgid "Collect on Delivery"
msgstr "Bei Lieferung einnehmen"

msgid "Collect payment on delivery"
msgstr "Bezahlung bei Lieferung einnehmen"

msgid "Amount to collect"
msgstr "Betrag zum Einnehmen"

msgid "Deliver to Post Office"
msgstr "Zur Postfiliale liefern"

