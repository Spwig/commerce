msgstr ""
"Nachdem Sie Ihre Anmeldeinformationen eingegeben haben, testen Sie die "
"Verbindung, um sicherzustellen, dass alles korrekt funktioniert."

msgid "Enter all required credentials"
msgstr "Geben Sie alle erforderlichen Anmeldeinformationen ein"

msgid "Choose your environment (Development or Production)"
msgstr "Wählen Sie Ihre Umgebung (Entwicklung oder Produktion)"

msgid "Click 'Test Connection'"
msgstr "Klicken Sie auf 'Verbindung testen'"

msgid "Wait for the validation to complete"
msgstr "Warten Sie, bis die Validierung abgeschlossen ist"

msgid "Connection Successful"
msgstr "Verbindung erfolgreich"

msgid "Your credentials are valid and the API is accessible."
msgstr "Ihre Anmeldeinformationen sind gültig und die API ist zugänglich."

msgid "Authentication Failed"
msgstr "Authentifizierung fehlgeschlagen"

