msgid "Data Binding"
msgstr "ربط البيانات"

msgid "Select which model this element will display data from."
msgstr "حدد النموذج الذي سيعرض هذا العنصر البيانات منه."

msgid "Appearance"
msgstr "المظهر"

msgid "Status"
msgstr "الحالة"

msgid "Timestamps"
msgstr "الوقت الزمني"

msgid "None (Static)"
msgstr "لا شيء (ثابت)"

msgid "Target Model"
msgstr "نموذج الهدف"

msgid "Icon"
msgstr "الأيقونة"

