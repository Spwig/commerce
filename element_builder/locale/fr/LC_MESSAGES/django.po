msgid "Data Binding"
msgstr "Binding des données"

msgid "Select which model this element will display data from."
msgstr "Sélectionnez le modèle dont cet élément affichera les données."

msgid "Appearance"
msgstr "Apparence"

msgid "Status"
msgstr "Statut"

msgid "Timestamps"
msgstr "Horodatages"

