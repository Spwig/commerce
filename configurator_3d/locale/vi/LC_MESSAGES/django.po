msgstr "Tên nút đồ họa cảnh từ cây nút đã được phân tích."

msgid "Action Data"
msgstr "Dữ liệu hành động"

msgid "Action-specific payload (color, texture URLs, GLB URL, visibility)."
msgstr ""
"Gói tải trọng cụ thể cho hành động (màu sắc, URL chất liệu, URL GLB, tính "
"năng hiển thị)."

msgid "Sort Order"
msgstr "Thứ tự sắp xếp"

msgid "Node Mapping"
msgstr "Ánh xạ nút"

