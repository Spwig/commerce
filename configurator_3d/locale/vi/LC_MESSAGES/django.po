msgstr "Nút mô hình cơ bản nào cần thay thế."

msgid "Node Data"
msgstr "Dữ liệu nút"

msgid "Parsed node names from this GLB."
msgstr "Tên các nút đã được phân tích từ tệp GLB này."

msgid "Geometry Asset"
msgstr "Tài sản hình học"

