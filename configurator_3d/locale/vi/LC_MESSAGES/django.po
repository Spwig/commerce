msgstr "Để đen nếu không muốn ánh sáng phát quang."

msgid "Emissive Strength"
msgstr "Độ mạnh phát quang"

msgid "Values above 1.0 create bloom glow when bloom is enabled."
msgstr ""
"Các giá trị trên 1.0 sẽ tạo hiệu ứng ánh sáng tỏa ra khi hiệu ứng bloom được "
"bật."

msgid "Base Color Texture"
msgstr "Màu cơ bản của chất liệu"

msgid "Visible"
msgstr "Khả kiến"

