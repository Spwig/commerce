msgid "Visibility"
msgstr "Tính khả kiến"

msgid "Scene Config"
msgstr "Cấu hình cảnh"

msgid "Slot Option"
msgstr "Tùy chọn khe"

msgid "Action Type"
msgstr "Loại hành động"

