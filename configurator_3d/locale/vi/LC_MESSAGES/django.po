msgstr "Không có mô hình nào được chọn"

msgid "Select GLB File"
msgstr "Chọn tệp GLB"

msgid ""
"Upload a GLB file from the Media Library. The scene graph will be parsed "
"automatically."
msgstr ""
"Tải lên tệp GLB từ Thư viện phương tiện. Đồ họa cảnh sẽ được phân tích tự "
"động."

msgid "Scene Graph"
msgstr "Đồ họa cảnh"

msgid "Parse a GLB to see the scene graph."
msgstr "Phân tích tệp GLB để xem đồ họa cảnh."

msgid "Viewer Settings"
msgstr "Cài đặt trình xem"

msgid "Solid"
msgstr "Rắn"

msgid "Gradient"
msgstr "Độ dốc"

msgid "No gradient set"
msgstr "Không có độ dốc được thiết lập"

msgid "Edit Gradient"
msgstr "Chỉnh sửa độ dốc"

msgid "Default Camera Position"
msgstr "Vị trí máy ảnh mặc định"

msgid ""
"Rotate and zoom the 3D preview to your preferred angle, then click Capture."
msgstr ""
"Xoay và phóng to xem trước 3D đến góc bạn mong muốn, sau đó nhấp vào Chụp "
"ảnh."

msgid "Save the current camera angle as the default view"
msgstr "Lưu góc máy ảnh hiện tại làm góc nhìn mặc định"

msgid "Capture Current View"
msgstr "Lấy lại góc nhìn hiện tại"

