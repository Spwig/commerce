msgstr "Bản đồ độ nhám"

msgid "Metalness Map"
msgstr "Bản đồ độ kim loại"

msgid "Ambient Occlusion"
msgstr "Bóng môi trường"

msgid "Emissive Map"
msgstr "Bản đồ phát sáng"

msgid "e.g., \"Red Leather\""
msgstr "Ví dụ: \"Da đỏ\""

msgid "Texture Image"
msgstr "Hình ảnh vân"

msgid "Texture Type"
msgstr "Loại vân"

msgid "Texture Asset"
msgstr "Tài sản vân"

msgid "Texture Assets"
msgstr "Các tài sản vân"

