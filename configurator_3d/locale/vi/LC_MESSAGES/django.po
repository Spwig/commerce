msgid "An error occurred while capturing the thumbnail. Please try again."
msgstr "Đã xảy ra lỗi khi chụp ảnh thu nhỏ. Vui lòng thử lại."

msgid "3D Configurator"
msgstr "Cấu hình 3D"

msgid "Product"
msgstr "Sản phẩm"

msgid "Base 3D Model"
msgstr "Mô hình 3D cơ sở"

msgid "The main GLB file containing the assembled 3D model."
msgstr "Tệp GLB chính chứa mô hình 3D đã được lắp ráp."

msgid "Node Tree"
msgstr "Cây nút"

msgid "Parsed scene graph from the GLB file (auto-populated)."
msgstr "Đồ họa cảnh được phân tích từ tệp GLB (tự động điền)."

msgid "Camera Orbit"
msgstr "Quỹ đạo máy ảnh"

msgid "model-viewer camera-orbit attribute."
msgstr "Thuộc tính camera-orbit của model-viewer."

msgid "Camera Target"
msgstr "Điểm đến máy ảnh"

msgid "model-viewer camera-target attribute."
msgstr "Thuộc tính camera-target của model-viewer."

msgid "Environment Image"
msgstr "Hình ảnh môi trường"

msgid "HDR environment map for image-based lighting."
msgstr "Bản đồ môi trường HDR cho chiếu sáng dựa trên hình ảnh."

msgid "Exposure"
msgstr "Độ phơi sáng"

msgid "Shadow Intensity"
msgstr "Độ đậm bóng"

msgid "Shadow Softness"
msgstr "Độ mờ bóng"

msgid "Shadow blur amount. 0 = sharp, 1 = soft."
msgstr "Độ mờ của bóng. 0 = sắc nét, 1 = mờ."

msgid "Tone Mapping"
msgstr "Ánh sáng"

msgid ""
"Color grading algorithm. Commerce = vibrant, Neutral = accurate, ACES = "
"cinematic."
msgstr ""
"Thuật toán phân cấp màu sắc. Commerce = rực rỡ, Neutral = chính xác, ACES = "
"phim ảnh."

msgid "Bloom Strength"
msgstr "Độ mạnh Bloom"

msgid ""
"Glow intensity for emissive materials. 0 = off, 1-5 = subtle to dramatic."
msgstr ""
"Độ sáng của ánh sáng phát quang cho vật liệu phát quang. 0 = tắt, 1-5 = nhẹ "
"đến mạnh mẽ."

msgid "Auto Rotate"
msgstr "Quay tự động"

msgid "AR Enabled"
msgstr "Kích hoạt AR"

msgid "Enable augmented reality viewing on supported devices."
msgstr "Kích hoạt chế độ xem thực tế tăng cường trên các thiết bị được hỗ trợ."

msgid "Background"
msgstr "Nền"

msgid "Solid hex color or CSS gradient."
msgstr "Màu hex rắn hoặc gradient CSS."

msgid "Thumbnail"
msgstr "Ảnh thu nhỏ"

msgid "Preview screenshot captured from the 3D viewer."
msgstr "Hình ảnh chụp màn hình xem trước từ trình xem 3D."

msgid "Enabled"
msgstr "Đã kích hoạt"

msgid "When disabled, the product uses the standard 2D configurator."
msgstr "Khi bị tắt, sản phẩm sẽ sử dụng trình cấu hình 2D tiêu chuẩn."

msgid "3D Scene Configuration"
msgstr "Cấu hình cảnh 3D"

msgid "3D Scene Configurations"
msgstr "Các cấu hình cảnh 3D"

msgid "Material Color"
msgstr "Màu vật liệu"

