msgstr "%(count)s 고객을 업데이트했습니다."

msgid "Cohort calculation completed"
msgstr "코호트 계산이 완료되었습니다"

msgid "Probabilistic calculation completed"
msgstr "확률적 계산이 완료되었습니다"

msgid "LTV calculation task queued for user"
msgstr "사용자에 대한 LTV 계산 작업이 대기열에 추가되었습니다"

msgid "LTV updated successfully"
msgstr "LTV가 성공적으로 업데이트되었습니다"
