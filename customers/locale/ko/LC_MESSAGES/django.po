msgstr "계정 초대가 {}에게 전송되었습니다"

msgid "Failed to send invitation email"
msgstr "초대 이메일 전송 실패"

msgid ""
"Email could not be sent — template may be missing or email preferences "
"blocked delivery"
msgstr ""
"이메일을 보내지 못했습니다 — 템플릿이 누락되었거나 이메일 선호도가 전송을 차"
"단한 것일 수 있습니다"

msgid "Invalid action"
msgstr "잘못된 액션"

msgid "Address set as default"
msgstr "주소가 기본으로 설정되었습니다"

msgid "Address not found"
msgstr "주소를 찾을 수 없습니다"

msgid "Settings saved and LTV calculation started"
msgstr "설정이 저장되었고 LTV 계산이 시작되었습니다"

msgid "Settings saved successfully"
msgstr "설정이 성공적으로 저장되었습니다"

msgid "LTV calculation task queued"
msgstr "LTV 계산 작업이 대기열에 추가되었습니다"

#, python-format
