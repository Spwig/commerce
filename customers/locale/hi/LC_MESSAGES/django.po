msgstr "सेटिंग्स सहेजें"

msgid "Save & Recalculate Now"
msgstr "अब सहेजें और पुनः गणना करें"

msgid "View Cohort Analytics"
msgstr "समूह विश्लेषण देखें"

msgid "Data Quality Notice"
msgstr "डेटा गुणवत्ता सूचना"

msgid "You need at least"
msgstr "आपको कम से कम आवश्यक है"

msgid "repeat customers to use probabilistic methods. You currently have"
msgstr ""
"दोहराए गए ग्राहकों के उपयोग के लिए संभावनात्मक विधियों के लिए। आपके पास वर्तमान में है"

msgid ""
