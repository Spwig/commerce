msgid "Enter client secret (leave blank to keep current)"
msgstr "Nhập mật khẩu máy khách (trống để giữ nguyên mật khẩu hiện tại)"

msgid "Client Secret"
msgstr "Bí mật Client"

msgid ""
"Application/Client secret from your identity provider. Stored encrypted."
msgstr ""
"Mật khẩu ứng dụng/máy khách từ nhà cung cấp danh tính của bạn. Được lưu trữ "
"dưới dạng mã hóa."

msgid ""
"A client secret is currently configured. Leave blank to keep it, or enter a "
"new value to replace it."
msgstr ""
"Hiện tại đã cấu hình mật khẩu máy khách. Trống để giữ nguyên, hoặc nhập giá "
"trị mới để thay thế."

msgid "Provider"
msgstr "Cung cấp"

msgid "OIDC Discovery"
msgstr "Khám phá OIDC"

msgid "OIDC Endpoints"
msgstr "Điểm cuối OIDC"

msgid "Client Credentials"
msgstr "Thông tin xác thực Client"

msgid "Claims Mapping"
msgstr "Ánh xạ Các tuyên bố"

msgid "Role Mapping"
msgstr "Ánh xạ Vai trò"

msgid "Scopes & Behavior"
msgstr "Phạm vi & Hành vi"

msgid "Provider Name"
msgstr "Tên Cung cấp"

msgid ""
"Display name for the SSO button, e.g. 'Microsoft', 'Okta', 'Google "
"Workspace'"
msgstr ""
"Tên hiển thị cho nút SSO, ví dụ: 'Microsoft', 'Okta', 'Google Workspace'"

msgid "OIDC Discovery URL"
msgstr "URL Khám phá OIDC"

#, python-brace-format
msgid ""
"OpenID Connect discovery endpoint (e.g. "
"https://login.microsoftonline.com/{tenant}/v2.0/.well-known/openid-"
"configuration)"
msgstr ""
"Điểm cuối phát hiện OpenID Connect (ví dụ: "
"https://login.microsoftonline.com/{tenant}/v2.0/.well-known/openid-"
"configuration)"

msgid "Authorization Endpoint"
msgstr "Điểm cuối Xác thực"

msgid "Token Endpoint"
msgstr "Điểm cuối Token"

msgid "UserInfo Endpoint"
msgstr "Điểm cuối Thông tin Người dùng"

msgid "JWKS Endpoint"
msgstr "Điểm cuối JWKS"

msgid "End Session Endpoint"
msgstr "Điểm cuối Kết thúc Phiên"

msgid "Used for single sign-out (optional)"
msgstr "Được sử dụng cho đăng xuất duy nhất (tùy chọn)"

msgid "Client ID"
msgstr "ID Client"

msgid "Application/Client ID from your identity provider"
msgstr "ID Ứng dụng/Máy khách từ nhà cung cấp danh tính của bạn"

msgid "Client Secret (Encrypted)"
msgstr "Bí mật Client (Mã hóa)"

msgid "Email Claim"
msgstr "Tuyên bố Email"

msgid "OIDC claim field for user email address"
msgstr "Trường yêu cầu OIDC cho địa chỉ email người dùng"

msgid "First Name Claim"
msgstr "Tuyên bố Tên"

msgid "OIDC claim field for first name"
msgstr "Trường yêu cầu OIDC cho tên"

msgid "Last Name Claim"
msgstr "Trường Tên đệm"

msgid "OIDC claim field for last name"
msgstr "Trường yêu cầu OIDC cho họ"

msgid "Groups Claim"
msgstr "Trường Nhóm"

msgid ""
"OIDC claim field for group memberships (leave blank to disable group "
"mapping)"
msgstr "Trường yêu cầu OIDC cho thành viên nhóm (trống để tắt ánh xạ nhóm)"

msgid "Staff Groups"
msgstr "Nhóm Nhân viên"

msgid "Comma-separated group names or IDs that grant staff status"
msgstr "Tên hoặc ID nhóm được phân tách bằng dấu phẩy để cấp quyền nhân viên"

msgid "Superuser Groups"
msgstr "Nhóm Người dùng Quản trị"

msgid "Comma-separated group names or IDs that grant superuser status"
msgstr "Tên hoặc ID nhóm phân cách bằng dấu phẩy cấp quyền siêu quản trị"

msgid "OIDC Scopes"
msgstr "Phạm vi OIDC"

msgid "Space-separated OIDC scopes to request"
msgstr "Các phạm vi OIDC được yêu cầu, cách nhau bằng dấu cách"

msgid "Auto-Create Users"
msgstr "Tự động tạo người dùng"

msgid ""
"Automatically create a user account when an SSO user signs in for the first "
"time"
msgstr "Tự động tạo tài khoản người dùng khi người dùng SSO đăng nhập lần đầu"

msgid "Restrict to Staff"
msgstr "Hạn chế cho Nhân viên"

msgid ""
"Only allow existing staff users to sign in via SSO. Disable to allow SSO "
"user auto-creation."
msgstr ""
"Chỉ cho phép người dùng nhân viên hiện có đăng nhập qua SSO. Vô hiệu hóa để "
"cho phép tạo tài khoản SSO tự động."

msgid "SSO Provider Configuration"
msgstr "Cấu hình Cung cấp SSO"

msgid "Configured"
msgstr "Đã cấu hình"

msgid "Not Configured"
msgstr "Chưa cấu hình"

msgid "Save and continue editing"
msgstr "Lưu và tiếp tục chỉnh sửa"

msgid "Save"
msgstr "Lưu"

msgid "Please correct the errors below"
msgstr "Vui lòng sửa các lỗi dưới đây"

msgid "Connection"
msgstr "Kết nối"

msgid "Claims & Roles"
msgstr "Trường và Vai trò"

msgid "Advanced"
msgstr "Nâng cao"

msgid "Identity Provider"
msgstr "Cung cấp danh tính"

msgid ""
"Enter the OIDC Discovery URL and click Auto-Discover to populate the "
"endpoint fields automatically."
msgstr ""
"Nhập URL khám phá OIDC và nhấn Auto-Discover để tự động điền các trường điểm"
" cuối."

msgid "Please enter a Discovery URL first."
msgstr "Vui lòng nhập URL khám phá trước."

msgid "Discovering..."
msgstr "Đang khám phá..."

msgid "Discovery failed:"
msgstr "Khám phá thất bại:"

msgid "Discovery successful!"
msgstr "Khám phá thành công!"

msgid "endpoints populated."
msgstr "Đã điền các điểm cuối."

msgid "Discovery request failed:"
msgstr "Yêu cầu khám phá thất bại:"

msgid "Auto-Discover"
msgstr "Khám phá tự động"

msgid "Secret is configured"
msgstr "Bí mật đã được cấu hình"

msgid "No secret configured"
msgstr "Chưa cấu hình bí mật"

msgid "Quick Setup Guide"
msgstr "Hướng dẫn Cài đặt Nhanh"

msgid "Redirect URI"
msgstr "URI Chuyển hướng"

msgid "Microsoft Entra ID:"
msgstr "Microsoft Entra ID:"

msgid "App registrations > New > Web platform > Redirect URI"
msgstr "Đăng ký ứng dụng > Mới > Nền tảng Web > URI chuyển hướng"

msgid "Google Workspace:"
msgstr "Google Workspace:"

msgid ""
"Cloud Console > APIs & Services > Credentials > OAuth 2.0 > Redirect URI"
msgstr ""
"Bảng điều khiển đám mây > APIs & Services > Thông tin xác thực > OAuth 2.0 >"
" URI chuyển hướng"

msgid "Okta:"
msgstr "Okta:"

msgid "Applications > New App > OIDC Web > Sign-in redirect URI"
msgstr "Ứng dụng > Tạo ứng dụng mới > OIDC Web > URI chuyển hướng đăng nhập"

msgid "Map OIDC claims to user fields. The defaults work for most providers."
msgstr ""
"Ánh xạ các yêu cầu OIDC đến các trường người dùng. Các cài đặt mặc định hoạt"
" động với hầu hết nhà cung cấp."

msgid ""
"Map identity provider groups to staff permissions. Enter comma-separated "
"group names or IDs."
msgstr ""
"Ánh xạ các nhóm nhà cung cấp danh tính đến quyền nhân viên. Nhập tên hoặc ID"
" nhóm phân cách bằng dấu phẩy."

msgid ""
"These are auto-populated from the Discovery URL. Only edit manually if "
"needed."
msgstr ""
"Các mục này được tự động điền từ URL Khám phá. Chỉ chỉnh sửa thủ công nếu "
"cần."

msgid "SSO authentication failed. Please try again or use local login."
msgstr ""
"Xác thực SSO thất bại. Vui lòng thử lại hoặc sử dụng đăng nhập cục bộ."
