msgid "Enter client secret (leave blank to keep current)"
msgstr "أدخل سر العميل (اتركه فارغًا للحفاظ على القيمة الحالية)"

msgid "Client Secret"
msgstr "سر العميل"

msgid ""
"Application/Client secret from your identity provider. Stored encrypted."
msgstr "سر التطبيق/العميل من مزود الهوية الخاص بك. يتم تخزينه مشفرًا."

msgid ""
"A client secret is currently configured. Leave blank to keep it, or enter a "
"new value to replace it."
msgstr ""
"يتم تكوين سر العميل حاليًا. اتركه فارغًا للحفاظ عليه، أو أدخل قيمة جديدة "
"لاستبداله."

msgid "Provider"
msgstr "المزود"

msgid "OIDC Discovery"
msgstr "اكتشاف OIDC"

msgid "OIDC Endpoints"
msgstr "نقاط نهاية OIDC"

msgid "Client Credentials"
msgstr "بيانات اعتماد العميل"

msgid "Claims Mapping"
msgstr "خريطة المطالبات"

msgid "Role Mapping"
msgstr "تعيين الأدوار"

msgid "Scopes & Behavior"
msgstr "النطاقات والسلوك"

msgid "Provider Name"
msgstr "اسم المزود"

msgid ""
"Display name for the SSO button, e.g. 'Microsoft', 'Okta', 'Google "
"Workspace'"
msgstr ""
"اسم العرض للمفتاح SSO، على سبيل المثال 'Microsoft'، 'Okta'، 'Google "
"Workspace'"

msgid "OIDC Discovery URL"
msgstr "عنوان URL اكتشاف OIDC"

#, python-brace-format
msgid ""
"OpenID Connect discovery endpoint (e.g. "
"https://login.microsoftonline.com/{tenant}/v2.0/.well-known/openid-"
"configuration)"
msgstr ""
"نقطة اكتشاف OpenID Connect (مثلاً "
"https://login.microsoftonline.com/{tenant}/v2.0/.well-known/openid-"
"configuration)"

msgid "Authorization Endpoint"
msgstr "نقطة التفويض"

msgid "Token Endpoint"
msgstr "نقطة التوكن"

msgid "UserInfo Endpoint"
msgstr "نقطة نهاية معلومات المستخدم"

msgid "JWKS Endpoint"
msgstr "نقطة نهاية JWKS"

msgid "End Session Endpoint"
msgstr "نقطة نهاية جلسة المستخدم"

msgid "Used for single sign-out (optional)"
msgstr "يستخدم لتسجيل الخروج مرة واحدة (اختياري)"

msgid "Client ID"
msgstr "معرّف العميل"

msgid "Application/Client ID from your identity provider"
msgstr "معرّف التطبيق/العميل من مزود الهوية الخاص بك"

msgid "Client Secret (Encrypted)"
msgstr "سر العميل (مُشفّر)"

msgid "Email Claim"
msgstr "ادّعاء البريد الإلكتروني"

msgid "OIDC claim field for user email address"
msgstr "حقل الادّعاء OIDC لعنوان بريد المستخدم"

msgid "First Name Claim"
msgstr "ادّعاء الاسم الأول"

msgid "OIDC claim field for first name"
msgstr "حقل ادعاء OIDC لاسم العائلة"

msgid "Last Name Claim"
msgstr "ادّعاء الاسم الأخير"

msgid "OIDC claim field for last name"
msgstr "حقل ادعاء OIDC لاسم العائلة"

msgid "Groups Claim"
msgstr "ادّعاء المجموعات"

msgid ""
"OIDC claim field for group memberships (leave blank to disable group "
"mapping)"
msgstr ""
"حقل ادعاء OIDC للعضويات في المجموعة (اتركه فارغًا لتعطيل خريطة المجموعة)"

msgid "Staff Groups"
msgstr "مجموعات الموظفين"

msgid "Comma-separated group names or IDs that grant staff status"
msgstr "أسماء مجموعات أو أرقام مفصولة بفواصل تمنح حالة الموظف"

msgid "Superuser Groups"
msgstr "مجموعات المستخدمين الأذن"

msgid "Comma-separated group names or IDs that grant superuser status"
msgstr "أسماء مجموعات أو أرقام مفصولة بفواصل تمنح حالة المستخدم الرئيسي"

msgid "OIDC Scopes"
msgstr " نطاقات OIDC"

msgid "Space-separated OIDC scopes to request"
msgstr " نطاقات OIDC مفصولة بالمسافات لطلبها"

msgid "Auto-Create Users"
msgstr "إنشاء المستخدمين تلقائيًا"

msgid ""
"Automatically create a user account when an SSO user signs in for the first "
"time"
msgstr "إنشاء حساب مستخدم تلقائيًا عندما يسجل مستخدم SSO الدخول لأول مرة"

msgid "Restrict to Staff"
msgstr "تقييد الوصول إلى الموظفين فقط"

msgid ""
"Only allow existing staff users to sign in via SSO. Disable to allow SSO "
"user auto-creation."
msgstr ""
"السماح فقط للمستخدمين الحاليين من الموظفين بالتسجيل الدخول عبر SSO. تعطيل "
"هذا الخيار للسماح بإنشاء مستخدمي SSO تلقائيًا."

msgid "SSO Provider Configuration"
msgstr "إعدادات مزود SSO"

msgid "Configured"
msgstr "تم التكوين"

msgid "Not Configured"
msgstr "غير م 구성"

msgid "Save and continue editing"
msgstr "حفظ والانتقال للتحرير"

msgid "Save"
msgstr "حفظ"

msgid "Please correct the errors below"
msgstr "يرجى تصحيح الأخطاء أدناه"

msgid "Connection"
msgstr "الاتصال"

msgid "Claims & Roles"
msgstr "المطالبات والمهام"

msgid "Advanced"
msgstr "متقدم"

msgid "Identity Provider"
msgstr "مزوّد الهوية"

msgid ""
"Enter the OIDC Discovery URL and click Auto-Discover to populate the "
"endpoint fields automatically."
msgstr ""
"أدخل عنوان URL للكشف عن OIDC وانقر على \"اكتشاف تلقائي\" لملء حقول النهاية "
"تلقائيًا."

msgid "Please enter a Discovery URL first."
msgstr "يرجى إدخال عنوان URL للكشف أولاً."

msgid "Discovering..."
msgstr "جارٍ اكتشاف..."

msgid "Discovery failed:"
msgstr "فشل اكتشاف:"

msgid "Discovery successful!"
msgstr "تم اكتشافه بنجاح!"

msgid "endpoints populated."
msgstr "تم ملء نقاط الوجهة."

msgid "Discovery request failed:"
msgstr "فشل طلب الاكتشاف:"

msgid "Auto-Discover"
msgstr "اكتشاف تلقائي"

msgid "Secret is configured"
msgstr "السر مكوّن"

msgid "No secret configured"
msgstr "لا يوجد سر مكوّن"

msgid "Quick Setup Guide"
msgstr "دليل التكوين السريع"

msgid "Redirect URI"
msgstr "URI التوجيه"

msgid "Microsoft Entra ID:"
msgstr "Microsoft Entra ID:"

msgid "App registrations > New > Web platform > Redirect URI"
msgstr "تسجيلات التطبيق > جديد > منصة الويب > URI التوجيه"

msgid "Google Workspace:"
msgstr "Google Workspace:"

msgid ""
"Cloud Console > APIs & Services > Credentials > OAuth 2.0 > Redirect URI"
msgstr ""
"اللوحة السحابية > واجهات API والخدمات > المصادقة > OAuth 2.0 > URI التوجيه"

msgid "Okta:"
msgstr "Okta:"

msgid "Applications > New App > OIDC Web > Sign-in redirect URI"
msgstr "التطبيقات > تطبيق جديد > OIDC Web > URI التوجيه لتسجيل الدخول"

msgid "Map OIDC claims to user fields. The defaults work for most providers."
msgstr ""
"قم بتعيين ادعاءات OIDC إلى حقول المستخدم. تعمل الافتراضات على معظم مزودي "
"الخدمة."

msgid ""
"Map identity provider groups to staff permissions. Enter comma-separated "
"group names or IDs."
msgstr ""
"قم بتعيين مجموعات مزود الهوية إلى صلاحيات الموظفين. أدخل أسماء المجموعات أو "
"أرقامها المنفصلة بفواصل."

msgid ""
"These are auto-populated from the Discovery URL. Only edit manually if "
"needed."
msgstr ""
"هذه تتم ملؤها تلقائيًا من عنوان URL الاكتشاف. قم بتحريرها يدويًا فقط إذا لزم"
" الأمر."

msgid "SSO authentication failed. Please try again or use local login."
msgstr "فشل 인증 SSO. من فضلك حاول مرة أخرى أو استخدم تسجيل الدخول المحلي."
