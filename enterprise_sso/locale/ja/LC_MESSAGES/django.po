msgid "Enter client secret (leave blank to keep current)"
msgstr "現在設定されているクライアントシークレットを保持する場合は空白のままにし、置き換える場合は新しい値を入力してください。"

msgid "Client Secret"
msgstr "クライアントシークレット"

msgid ""
"Application/Client secret from your identity provider. Stored encrypted."
msgstr "IDプロバイダから取得したアプリケーション/クライアントシークレット。暗号化して保存されます。"

msgid ""
"A client secret is currently configured. Leave blank to keep it, or enter a "
"new value to replace it."
msgstr "現在、クライアントシークレットが設定されています。保持する場合は空白のままにし、置き換える場合は新しい値を入力してください。"

msgid "Provider"
msgstr "プロバイダ"

msgid "OIDC Discovery"
msgstr "OIDC ディスカバリ"

msgid "OIDC Endpoints"
msgstr "OIDC エンドポイント"

msgid "Client Credentials"
msgstr "クライアント資格情報"

msgid "Claims Mapping"
msgstr "クレームマッピング"

msgid "Role Mapping"
msgstr "ロールマッピング"

msgid "Scopes & Behavior"
msgstr "スコープと動作"

msgid "Provider Name"
msgstr "プロバイダ名"

msgid ""
"Display name for the SSO button, e.g. 'Microsoft', 'Okta', 'Google "
"Workspace'"
msgstr "SSOボタンの表示名。例: 'Microsoft', 'Okta', 'Google Workspace'\""

msgid "OIDC Discovery URL"
msgstr "OIDC ディスカバリーURL"

#, python-brace-format
msgid ""
"OpenID Connect discovery endpoint (e.g. "
"https://login.microsoftonline.com/{tenant}/v2.0/.well-known/openid-"
"configuration)"
msgstr ""
"OpenID Connect ディスカバリーエンドポイント（例: "
"https://login.microsoftonline.com/{tenant}/v2.0/.well-known/openid-"
"configuration）"

msgid "Authorization Endpoint"
msgstr "認証エンドポイント"

msgid "Token Endpoint"
msgstr "トークンエンドポイント"

msgid "UserInfo Endpoint"
msgstr "UserInfo エンドポイント"

msgid "JWKS Endpoint"
msgstr "JWKS エンドポイント"

msgid "End Session Endpoint"
msgstr "セッション終了エンドポイント"

msgid "Used for single sign-out (optional)"
msgstr "単一サインアウト用（オプション）"

msgid "Client ID"
msgstr "クライアントID"

msgid "Application/Client ID from your identity provider"
msgstr "IDプロバイダから取得したアプリケーション/クライアントID\""

msgid "Client Secret (Encrypted)"
msgstr "クライアントシークレット（暗号化済み）"

msgid "Email Claim"
msgstr "メールクレーム"

msgid "OIDC claim field for user email address"
msgstr "ユーザーの電子メールアドレス用のOIDCクレームフィールド\""

msgid "First Name Claim"
msgstr "名前クレーム"

msgid "OIDC claim field for first name"
msgstr "OIDCのクレームフィールド（名前）"

msgid "Last Name Claim"
msgstr "姓クレーム"

msgid "OIDC claim field for last name"
msgstr "OIDCのクレームフィールド（姓）"

msgid "Groups Claim"
msgstr "グループクレーム"

msgid ""
"OIDC claim field for group memberships (leave blank to disable group "
"mapping)"
msgstr "OIDCのクレームフィールド（グループメンバーシップ）（空欄にするとグループマッピングを無効にします）"

msgid "Staff Groups"
msgstr "スタッフグループ"

msgid "Comma-separated group names or IDs that grant staff status"
msgstr "スタッフステータスを付与するグループ名またはID（カンマで区切ってください）"

msgid "Superuser Groups"
msgstr "スーパーユーザーグループ"

msgid "Comma-separated group names or IDs that grant superuser status"
msgstr "スーパーユーザーのステータスを付与するグループ名またはID（カンマで区切ってください）"

msgid "OIDC Scopes"
msgstr "OIDC スコープ"

msgid "Space-separated OIDC scopes to request"
msgstr "要求する OIDC スコープ（スペースで区切る）"

msgid "Auto-Create Users"
msgstr "ユーザーを自動作成"

msgid ""
"Automatically create a user account when an SSO user signs in for the first "
"time"
msgstr "SSOユーザーが初めてサインインしたときに自動的にユーザー アカウントを作成"

msgid "Restrict to Staff"
msgstr "スタッフに限定"

msgid ""
"Only allow existing staff users to sign in via SSO. Disable to allow SSO "
"user auto-creation."
msgstr "既存のスタッフユーザーのみがSSOを通じてサインインできるようにしてください。SSOユーザーの自動作成を許可するには、無効にしてください。"

msgid "SSO Provider Configuration"
msgstr "SSO プロバイダ設定"

msgid "Configured"
msgstr "設定済み"

msgid "Not Configured"
msgstr "未設定"

msgid "Save and continue editing"
msgstr "保存して編集を続ける"

msgid "Save"
msgstr "保存"

msgid "Please correct the errors below"
msgstr "以下のエラーを修正してください"

msgid "Connection"
msgstr "接続"

msgid "Claims & Roles"
msgstr "クレームとロール"

msgid "Advanced"
msgstr "高度な設定"

msgid "Identity Provider"
msgstr "IDプロバイダー"

msgid ""
"Enter the OIDC Discovery URL and click Auto-Discover to populate the "
"endpoint fields automatically."
msgstr "OIDC Discovery URLを入力し、自動検出をクリックしてエンドポイントフィールドを自動的に埋め込むことができます。"

msgid "Please enter a Discovery URL first."
msgstr "最初にDiscovery URLを入力してください。"

msgid "Discovering..."
msgstr "検出中..."

msgid "Discovery failed:"
msgstr "検出失敗:"

msgid "Discovery successful!"
msgstr "検出成功！"

msgid "endpoints populated."
msgstr "エンドポイントが設定されました。"

msgid "Discovery request failed:"
msgstr "検出リクエストに失敗しました:"

msgid "Auto-Discover"
msgstr "オート検出"

msgid "Secret is configured"
msgstr "シークレットが設定されています"

msgid "No secret configured"
msgstr "シークレットが設定されていません"

msgid "Quick Setup Guide"
msgstr "クイックセットアップガイド"

msgid "Redirect URI"
msgstr "リダイレクトURI"

msgid "Microsoft Entra ID:"
msgstr "Microsoft Entra ID:"

msgid "App registrations > New > Web platform > Redirect URI"
msgstr "アプリケーション登録 > 新規 > ウェブプラットフォーム > リダイレクトURI"

msgid "Google Workspace:"
msgstr "Google Workspace:"

msgid ""
"Cloud Console > APIs & Services > Credentials > OAuth 2.0 > Redirect URI"
msgstr "クラウドコンソール > APIs & Services > 認証情報 > OAuth 2.0 > リダイレクトURI"

msgid "Okta:"
msgstr "Okta:"

msgid "Applications > New App > OIDC Web > Sign-in redirect URI"
msgstr "アプリケーション > 新規アプリ > OIDC Web > サインインリダイレクトURI"

msgid "Map OIDC claims to user fields. The defaults work for most providers."
msgstr "OIDCのクレームをユーザーのフィールドにマッピングします。デフォルトの設定はほとんどのプロバイダで動作します。"

msgid ""
"Map identity provider groups to staff permissions. Enter comma-separated "
"group names or IDs."
msgstr "認証プロバイダのグループをスタッフの権限にマッピングします。コンマで区切られたグループ名またはIDを入力してください。"

msgid ""
"These are auto-populated from the Discovery URL. Only edit manually if "
"needed."
msgstr "これらはDiscovery URLから自動で埋め込まれます。必要に応じてのみ手動で編集してください。"

msgid "SSO authentication failed. Please try again or use local login."
msgstr "SSO認証に失敗しました。再度お試しください、またはローカルログインをご利用ください。"
