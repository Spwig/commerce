msgid "Enter client secret (leave blank to keep current)"
msgstr ""
"Masukkan kunci klien (biarkan kosong untuk mempertahankan yang saat ini)"

msgid "Client Secret"
msgstr "Kunci Klien"

msgid ""
"Application/Client secret from your identity provider. Stored encrypted."
msgstr ""
"Kunci klien dari penyedia identitas Anda. Disimpan dalam bentuk terenkripsi."

msgid ""
"A client secret is currently configured. Leave blank to keep it, or enter a "
"new value to replace it."
msgstr ""
"Saat ini telah dikonfigurasi kunci klien. Biarkan kosong untuk "
"mempertahankannya, atau masukkan nilai baru untuk menggantinya."

msgid "Provider"
msgstr "Pemulai"

msgid "OIDC Discovery"
msgstr "OIDC Penemuan"

msgid "OIDC Endpoints"
msgstr "OIDC Titik Akhir"

msgid "Client Credentials"
msgstr "Kredensial Klien"

msgid "Claims Mapping"
msgstr "Pemetaan Klaim"

msgid "Role Mapping"
msgstr "Pemetaan Peran"

msgid "Scopes & Behavior"
msgstr "Cakupan & Perilaku"

msgid "Provider Name"
msgstr "Nama Pemulai"

msgid ""
"Display name for the SSO button, e.g. 'Microsoft', 'Okta', 'Google "
"Workspace'"
msgstr ""
"Nama tampilan untuk tombol SSO, misalnya 'Microsoft', 'Okta', 'Google "
"Workspace'"

msgid "OIDC Discovery URL"
msgstr "URL Penemuan OIDC"

#, python-brace-format
msgid ""
"OpenID Connect discovery endpoint (e.g. "
"https://login.microsoftonline.com/{tenant}/v2.0/.well-known/openid-"
"configuration)"
msgstr ""
"Titik akhir penemuan OpenID Connect (contoh: "
"https://login.microsoftonline.com/{tenant}/v2.0/.well-known/openid-"
"configuration)"

msgid "Authorization Endpoint"
msgstr "Titik Akhir Otorisasi"

msgid "Token Endpoint"
msgstr "Titik Akhir Token"

msgid "UserInfo Endpoint"
msgstr "Titik Akhir Info Pengguna"

msgid "JWKS Endpoint"
msgstr "Titik Akhir JWKS"

msgid "End Session Endpoint"
msgstr "Titik Akhir Akhir Sesi"

msgid "Used for single sign-out (optional)"
msgstr "Digunakan untuk sign-out tunggal (opsional)"

msgid "Client ID"
msgstr "ID Klien"

msgid "Application/Client ID from your identity provider"
msgstr "ID Aplikasi/Klien dari penyedia identitas Anda"

msgid "Client Secret (Encrypted)"
msgstr "Kunci Klien (Dienskripsi)"

msgid "Email Claim"
msgstr "Klaim Email"

msgid "OIDC claim field for user email address"
msgstr "Bidang klaim OIDC untuk alamat email pengguna"

msgid "First Name Claim"
msgstr "Klaim Nama Depan"

msgid "OIDC claim field for first name"
msgstr "Bidang klaim OIDC untuk nama depan"

msgid "Last Name Claim"
msgstr "Klaim Nama Belakang"

msgid "OIDC claim field for last name"
msgstr "Bidang klaim OIDC untuk nama belakang"

msgid "Groups Claim"
msgstr "Klaim Grup"

msgid ""
"OIDC claim field for group memberships (leave blank to disable group "
"mapping)"
msgstr ""
"Bidang klaim OIDC untuk keanggotaan kelompok (biarkan kosong untuk "
"menonaktifkan peta kelompok)"

msgid "Staff Groups"
msgstr "Grup Staf"

msgid "Comma-separated group names or IDs that grant staff status"
msgstr ""
"Nama atau ID kelompok yang dipisahkan oleh koma yang memberikan status staf"

msgid "Superuser Groups"
msgstr "Grup Superuser"

msgid "Comma-separated group names or IDs that grant superuser status"
msgstr ""
"Nama atau ID kelompok yang dipisahkan dengan koma yang memberikan status "
"superuser"

msgid "OIDC Scopes"
msgstr "Cakupan OIDC"

msgid "Space-separated OIDC scopes to request"
msgstr "Cakupan OIDC yang dipisahkan oleh spasi untuk diminta"

msgid "Auto-Create Users"
msgstr "Buat Pengguna Otomatis"

msgid ""
"Automatically create a user account when an SSO user signs in for the first "
"time"
msgstr ""
"Buat akun pengguna secara otomatis saat pengguna SSO masuk untuk pertama "
"kalinya"

msgid "Restrict to Staff"
msgstr "Batasi ke Staf"

msgid ""
"Only allow existing staff users to sign in via SSO. Disable to allow SSO "
"user auto-creation."
msgstr ""
"Hanya izinkan pengguna staf yang sudah ada untuk masuk melalui SSO. "
"Nonaktifkan untuk mengizinkan pembuatan otomatis pengguna SSO."

msgid "SSO Provider Configuration"
msgstr "Konfigurasi Pemimpin SSO"

msgid "Configured"
msgstr "Dikonfigurasi"

msgid "Not Configured"
msgstr "Tidak Dikonfigurasi"

msgid "Save and continue editing"
msgstr "Simpan dan lanjutkan mengedit"

msgid "Save"
msgstr "Simpan"

msgid "Please correct the errors below"
msgstr "Silakan perbaiki kesalahan di bawah ini"

msgid "Connection"
msgstr "Koneksi"

msgid "Claims & Roles"
msgstr "Klaim & Peran"

msgid "Advanced"
msgstr "Maju"

msgid "Identity Provider"
msgstr "Pemimpin Identitas"

msgid ""
"Enter the OIDC Discovery URL and click Auto-Discover to populate the "
"endpoint fields automatically."
msgstr ""
"Masukkan URL OIDC Discovery dan klik Auto-Discover untuk mengisi bidang "
"ujung secara otomatis."

msgid "Please enter a Discovery URL first."
msgstr "Silakan masukkan URL Discovery terlebih dahulu."

msgid "Discovering..."
msgstr "Mendiscovery..."

msgid "Discovery failed:"
msgstr "Discovery gagal:"

msgid "Discovery successful!"
msgstr "Penemuan berhasil!"

msgid "endpoints populated."
msgstr "endpoint diisi."

msgid "Discovery request failed:"
msgstr "Permintaan penemuan gagal:"

msgid "Auto-Discover"
msgstr "Auto-Discover"

msgid "Secret is configured"
msgstr "Rahasia telah dikonfigurasi"

msgid "No secret configured"
msgstr "Tidak ada rahasia yang dikonfigurasi"

msgid "Quick Setup Guide"
msgstr "Panduan Pengaturan Cepat"

msgid "Redirect URI"
msgstr "URI Redirect"

msgid "Microsoft Entra ID:"
msgstr "Microsoft Entra ID:"

msgid "App registrations > New > Web platform > Redirect URI"
msgstr "Pendaftaran aplikasi > Baru > Platform web > Redirect URI"

msgid "Google Workspace:"
msgstr "Google Workspace:"

msgid ""
"Cloud Console > APIs & Services > Credentials > OAuth 2.0 > Redirect URI"
msgstr "Konsol Cloud > APIs & Layanan > Kredensial > OAuth 2.0 > Redirect URI"

msgid "Okta:"
msgstr "Okta:"

msgid "Applications > New App > OIDC Web > Sign-in redirect URI"
msgstr "Aplikasi > Aplikasi Baru > OIDC Web > Redirect URI masuk"

msgid "Map OIDC claims to user fields. The defaults work for most providers."
msgstr ""
"Petakan klaim OIDC ke bidang pengguna. Pengaturan default berfungsi untuk "
"sebagian besar penyedia."

msgid ""
"Map identity provider groups to staff permissions. Enter comma-separated "
"group names or IDs."
msgstr ""
"Petakan kelompok penyedia identitas ke izin staf. Masukkan nama atau ID "
"kelompok yang dipisahkan dengan koma."

msgid ""
"These are auto-populated from the Discovery URL. Only edit manually if "
"needed."
msgstr ""
"Ini diisi secara otomatis dari URL Discovery. Hanya ubah secara manual jika "
"diperlukan."

msgid "SSO authentication failed. Please try again or use local login."
msgstr "Autentikasi SSO gagal. Silakan coba lagi atau gunakan login lokal."
