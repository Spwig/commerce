msgid "Enter client secret (leave blank to keep current)"
msgstr "Insira o segredo do cliente (deixe em branco para manter o atual)"

msgid "Client Secret"
msgstr "Segredo do Cliente"

msgid ""
"Application/Client secret from your identity provider. Stored encrypted."
msgstr ""
"Segredo do aplicativo/cliente do seu provedor de identidade. Armazenado "
"criptografado."

msgid ""
"A client secret is currently configured. Leave blank to keep it, or enter a "
"new value to replace it."
msgstr ""
"Um segredo do cliente está atualmente configurado. Deixe em branco para "
"mantê-lo ou insira um novo valor para substituí-lo."

msgid "Provider"
msgstr "Fornecedor"

msgid "OIDC Discovery"
msgstr "Descoberta OIDC"

msgid "OIDC Endpoints"
msgstr "Pontos de Extremidade OIDC"

msgid "Client Credentials"
msgstr "Credenciais do Cliente"

msgid "Claims Mapping"
msgstr "Mapeamento de Atributos"

msgid "Role Mapping"
msgstr "Mapeamento de Papéis"

msgid "Scopes & Behavior"
msgstr "Escopos & Comportamento"

msgid "Provider Name"
msgstr "Nome do Fornecedor"

msgid ""
"Display name for the SSO button, e.g. 'Microsoft', 'Okta', 'Google "
"Workspace'"
msgstr ""
"Nome de exibição para o botão SSO, por exemplo, 'Microsoft', 'Okta', 'Google"
" Workspace'"

msgid "OIDC Discovery URL"
msgstr "URL de Descoberta OIDC"

#, python-brace-format
msgid ""
"OpenID Connect discovery endpoint (e.g. "
"https://login.microsoftonline.com/{tenant}/v2.0/.well-known/openid-"
"configuration)"
msgstr ""
"Ponto de descoberta do OpenID Connect (ex. "
"https://login.microsoftonline.com/{tenant}/v2.0/.well-known/openid-"
"configuration)"

msgid "Authorization Endpoint"
msgstr "Ponto de Extremidade de Autorização"

msgid "Token Endpoint"
msgstr "Ponto de Extremidade de Token"

msgid "UserInfo Endpoint"
msgstr "Ponto de Extremidade de Informações do Usuário"

msgid "JWKS Endpoint"
msgstr "Ponto de Extremidade JWKS"

msgid "End Session Endpoint"
msgstr "Ponto de Extremidade de Fim de Sessão"

msgid "Used for single sign-out (optional)"
msgstr "Usado para saída única (opcional)"

msgid "Client ID"
msgstr "ID do Cliente"

msgid "Application/Client ID from your identity provider"
msgstr "ID do aplicativo/cliente do seu provedor de identidade"

msgid "Client Secret (Encrypted)"
msgstr "Segredo do Cliente (Criptografado)"

msgid "Email Claim"
msgstr "Atributo de E-mail"

msgid "OIDC claim field for user email address"
msgstr "Campo de reivindicação OIDC para endereço de e-mail do usuário"

msgid "First Name Claim"
msgstr "Atributo de Nome"

msgid "OIDC claim field for first name"
msgstr "Campo de reivindicação OIDC para nome"

msgid "Last Name Claim"
msgstr "Reivindicação de Sobrenome"

msgid "OIDC claim field for last name"
msgstr "Campo de reivindicação OIDC para sobrenome"

msgid "Groups Claim"
msgstr "Reivindicação de Grupos"

msgid ""
"OIDC claim field for group memberships (leave blank to disable group "
"mapping)"
msgstr ""
"Campo de reivindicação OIDC para membros de grupo (deixe em branco para "
"desativar o mapeamento de grupo)"

msgid "Staff Groups"
msgstr "Grupos de Funcionários"

msgid "Comma-separated group names or IDs that grant staff status"
msgstr ""
"Nomes ou IDs de grupo separados por vírgula que concedem status de staff"

msgid "Superuser Groups"
msgstr "Grupos de Superusuários"

msgid "Comma-separated group names or IDs that grant superuser status"
msgstr ""
"Nomes ou IDs de grupo separados por vírgula que concedem o status de "
"superusuário"

msgid "OIDC Scopes"
msgstr "Escopos OIDC"

msgid "Space-separated OIDC scopes to request"
msgstr "Escopos OIDC separados por espaço para solicitar"

msgid "Auto-Create Users"
msgstr "Criar Usuários Automaticamente"

msgid ""
"Automatically create a user account when an SSO user signs in for the first "
"time"
msgstr ""
"Criar automaticamente uma conta de usuário quando um usuário SSO fizer login"
" pela primeira vez"

msgid "Restrict to Staff"
msgstr "Restringir a Funcionários"

msgid ""
"Only allow existing staff users to sign in via SSO. Disable to allow SSO "
"user auto-creation."
msgstr ""
"Permitir apenas usuários de staff existentes fazerem login via SSO. Desative"
" para permitir a criação automática de usuários SSO."

msgid "SSO Provider Configuration"
msgstr "Configuração do Fornecedor SSO"

msgid "Configured"
msgstr "Configurado"

msgid "Not Configured"
msgstr "Não Configurado"

msgid "Save and continue editing"
msgstr "Salvar e continuar editando"

msgid "Save"
msgstr "Salvar"

msgid "Please correct the errors below"
msgstr "Por favor, corrija os erros abaixo"

msgid "Connection"
msgstr "Conexão"

msgid "Claims & Roles"
msgstr "Reivindicações & Papéis"

msgid "Advanced"
msgstr "Avançado"

msgid "Identity Provider"
msgstr "Fornecedor de Identidade"

msgid ""
"Enter the OIDC Discovery URL and click Auto-Discover to populate the "
"endpoint fields automatically."
msgstr ""
"Insira a URL de Descoberta OIDC e clique em Descobrir Automaticamente para "
"preencher automaticamente os campos de endpoint."

msgid "Please enter a Discovery URL first."
msgstr "Por favor, insira uma URL de Descoberta primeiro."

msgid "Discovering..."
msgstr "Descobrindo..."

msgid "Discovery failed:"
msgstr "Falha na descoberta:"

msgid "Discovery successful!"
msgstr "Descoberta bem-sucedida!"

msgid "endpoints populated."
msgstr "pontos de extremidade populados."

msgid "Discovery request failed:"
msgstr "Solicitação de descoberta falhou:"

msgid "Auto-Discover"
msgstr "Auto-descobrir"

msgid "Secret is configured"
msgstr "Segredo está configurado"

msgid "No secret configured"
msgstr "Nenhum segredo configurado"

msgid "Quick Setup Guide"
msgstr "Guia de Configuração Rápida"

msgid "Redirect URI"
msgstr "URI de Redirecionamento"

msgid "Microsoft Entra ID:"
msgstr "Microsoft Entra ID:"

msgid "App registrations > New > Web platform > Redirect URI"
msgstr ""
"Registros de aplicativo > Novo > Plataforma Web > URI de Redirecionamento"

msgid "Google Workspace:"
msgstr "Google Workspace:"

msgid ""
"Cloud Console > APIs & Services > Credentials > OAuth 2.0 > Redirect URI"
msgstr ""
"Console em nuvem > APIs & Serviços > Credenciais > OAuth 2.0 > URI de "
"Redirecionamento"

msgid "Okta:"
msgstr "Okta:"

msgid "Applications > New App > OIDC Web > Sign-in redirect URI"
msgstr ""
"Aplicativos > Novo Aplicativo > OIDC Web > URI de Redirecionamento de Login"

msgid "Map OIDC claims to user fields. The defaults work for most providers."
msgstr ""
"Mapear reivindicações OIDC para campos de usuário. Os padrões funcionam para"
" a maioria dos provedores."

msgid ""
"Map identity provider groups to staff permissions. Enter comma-separated "
"group names or IDs."
msgstr ""
"Mapear grupos do provedor de identidade para permissões de staff. Insira "
"nomes ou IDs de grupo separados por vírgula."

msgid ""
"These are auto-populated from the Discovery URL. Only edit manually if "
"needed."
msgstr ""
"Esses são preenchidos automaticamente a partir da URL de Descoberta. Edite "
"manualmente apenas se necessário."

msgid "SSO authentication failed. Please try again or use local login."
msgstr "Autenticação SSO falhou. Tente novamente ou use o login local."
