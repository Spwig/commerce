msgid "Invalid settings data."
msgstr "잘못된 상태 업데이트입니다."

#, fuzzy
#| msgid "SSO is not enabled or not configured."
msgid "Site settings not configured."
msgstr "SSO가 활성화되지 않았거나 설정되지 않았습니다."

