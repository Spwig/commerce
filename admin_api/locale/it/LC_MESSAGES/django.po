msgid "Update message status"
msgstr "Aggiorna stato del messaggio"

#, python-brace-format
msgid ""
"\n"
"    Update the status of a customer message.\n"
"\n"
"    **Rate Limit:** 300 requests per minute\n"
"\n"
"    **URL Format:** `/messages/{source}/{id}/status/`\n"
"    - `source`: Either 'contact_form' or 'order_note'\n"
"    - `id`: The message ID within that source\n"
"\n"
"    **Status Options:**\n"
"    - read: Mark as read\n"
"    - replied: Mark as replied (contact_form only)\n"
"    - archived: Archive the message (contact_form only)\n"
"\n"
"    Note: OrderNotes only support 'read' status.\n"
"    "
msgstr ""
"\n"
"    Aggiorna lo stato di un messaggio del cliente.\n"
"\n"
"**Limite di richieste:** 300 richieste al minuto\n"
"\n"
"**Formato URL:** `/messages/{source}/{id}/status/`\n"
"- `source`: Sia 'contact_form' che 'order_note'\n"
"- `id`: L'ID del messaggio all'interno di quel source\n"
"\n"
"**Opzioni di stato:**\n"
"- read: Contrassegna come letto\n"
"- replied: Contrassegna come risposto (solo contact_form)\n"
"- archived: Archivia il messaggio (solo contact_form)\n"
"\n"
"Nota: OrderNotes supportano solo lo stato 'read'.\n"
