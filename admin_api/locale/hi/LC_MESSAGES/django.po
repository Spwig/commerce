msgstr "उत्पाद \"%(name)s\" सफलतापूर्वक हटा दिया गया।"

msgid "Bulk create products"
msgstr "बैच उत्पाद बनाएं"

msgid ""
"\n"
"    Create multiple products in a single request. Maximum 100 products per "
"request.\n"
"    Individual failures do not rollback the entire batch.\n"
"\n"
"    **Rate Limit:** 30 requests per minute (sensitive operation)\n"
"    "
msgstr ""
"\n"
"    एक अनुरोध में कई उत्पाद बनाएं। प्रति अनुरोध अधिकतम 100 उत्पाद।\n"
"व्यक्तिगत विफलताएं पूरे बैच को वापस नहीं करती हैं।\n"
"\n"
"**दर बंधन:** 30 अनुरोध प्रति मिनट (संवेदनशील कार्य)\n"
"    "

msgid "Invalid bulk product data."
msgstr "अमान्य बैच उत्पाद डेटा।"

#, python-format
msgid "Created %(created)d product(s). %(errors)d failed."
msgstr "%(created)d उत्पाद(ओं) के बनाया गया। %(errors)d विफल।"

msgid "Bulk update products"
msgstr "बैच उत्पाद अपडेट करें"

msgid ""
"\n"
"    Update multiple products in a single request. Maximum 100 products per "
"request.\n"
"    Each product object must include an `id` field plus the fields to "
"update.\n"
"    Individual failures do not rollback the entire batch.\n"
"\n"
"    **Rate Limit:** 30 requests per minute (sensitive operation)\n"
"    "
msgstr ""
"\n"
"    एक अनुरोध में कई उत्पादों को अपडेट करें। प्रत्येक अनुरोध में अधिकतम 100 उत्पाद हो सकते "
"हैं।\n"
"प्रत्येक उत्पाद ऑब्जेक्ट में `id` फील्ड के साथ अपडेट करने वाले फील्ड शामिल होने चाहिए।\n"
"व्यक्तिगत विफलताएं पूरे बैच को रोलबैक नहीं करती हैं।\n"
"\n"
"**दर सीमा:** 1 मिनट में 30 अनुरोध (संवेदनशील कार्य)\n"
"    "

msgid "Invalid bulk update data."
msgstr "अमान्य बैच अपडेट डेटा।"

