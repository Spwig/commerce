msgid "Only paid orders can be refunded."
msgstr "Hanya pesanan yang telah dibayar yang dapat dikembalikan."

msgid "Invalid refund request."
msgstr "Permintaan pengembalian dana tidak valid."

msgid "Refund initiated successfully."
