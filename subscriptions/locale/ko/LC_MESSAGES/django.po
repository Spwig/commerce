msgstr "티어 정보"

msgid "Billing Configuration"
msgstr "청구서 설정"

msgid "Billing Cycle"
msgstr "청구 주기"

msgid "Add-on Information"
msgstr "추가 정보"

msgid "Pricing"
msgstr "가격"

msgid "Subscription Information"
msgstr "구독 정보"

msgid "Payment Configuration"
msgstr "결제 설정"

msgid "Billing Schedule"
msgstr "청구서 일정"

msgid "Billing History"
msgstr "청구서 내역"

msgid "Cancellation"
msgstr "환불"

msgid "Pause/Resume"
msgstr "일시 중지/재개"

msgid "Plan Changes"
msgstr "플랜 변경"

msgid "ID"
