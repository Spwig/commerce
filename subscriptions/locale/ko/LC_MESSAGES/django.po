#, python-format
msgid ""
"Discount applied to product price when customer subscribes (0 for full "
"price, 10 for 10% off, etc.)"
msgstr "구독 시 제품 가격에 적용되는 할인 (전체 가격: 0, 10% 할인: 10 등)"

msgid "Discount percentage is required (use 0 for no discount)"
msgstr "할인 비율은 필수입니다 (할인 없이 0을 사용하세요)"

msgid "Discount must be between 0% and 100%"
msgstr "할인은 0%에서 100% 사이여야 합니다"

msgid "Plan Information"
msgstr "플랜 정보"

msgid "Pricing Configuration"
msgstr "가격 설정"

msgid "Trial Period"
msgstr "시도 기간"

msgid "Cancellation Policy"
msgstr "취소 정책"

msgid "Plan Change Behavior"
msgstr "플랜 변경 동작"

msgid "Limits & Restrictions"
msgstr "제한 사항"

msgid "Status"
msgstr "상태"

