msgstr "Abonnements"

msgid "Tiered Pricing"
msgstr "Stufige Preisgestaltung"

msgid "Quantity-Based"
msgstr "Auf Basis der Menge"

msgid "Flat Rate"
msgstr "Pauschale"

msgid "Cancel Anytime"
msgstr "Jederzeit stornieren"

msgid "Cancel at Period End"
msgstr "Am Ende des Zeitraums stornieren"

msgid "Minimum Commitment Required"
msgstr "Minimale Verpflichtung erforderlich"

msgid "Plan ID"
msgstr "Plan-ID"

msgid "Unique identifier for this plan"
msgstr "Eindeutige Kennung für diesen Plan"

msgid "Plan Name"
msgstr "Planname"

msgid "Name displayed to customers (e.g., 'Premium Plan', 'Enterprise Plan')"
msgstr ""
"Name, der Kunden angezeigt wird (z. B. 'Premium-Plan', 'Enterprise-Plan')"

msgid "Slug"
msgstr "Slug"

msgid "URL-friendly version of the name"
msgstr "URL-freundliche Version des Namens"

msgid "Description"
msgstr "Beschreibung"

msgid "Detailed description of what this plan includes"
msgstr "Detaillierte Beschreibung, was dieser Plan beinhaltet"

msgid "Translations"
msgstr "Übersetzungen"

msgid "Multilingual content for customer-facing fields (name, description)"
msgstr "Multisprachige Inhalte für kundennahen Felder (Name, Beschreibung)"

msgid "Pricing Model"
msgstr "Preismodell"

msgid "How pricing is structured for this plan"
msgstr "Wie der Preis für diesen Plan strukturiert ist"

msgid "Allow Quantity"
msgstr "Menge erlauben"

msgid "Enable per-seat/per-user pricing (price × quantity)"
msgstr "Pro-Sitz/Pro-Nutzer-Preis ermöglichen (Preis × Menge)"

