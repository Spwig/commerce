msgstr "Thông Tin Gói Đặt"

msgid "Payment Configuration"
msgstr "Cấu Hình Thanh Toán"

msgid "Billing Schedule"
msgstr "Lịch Thanh Toán"

msgid "Billing History"
msgstr "Lịch Sử Thanh Toán"

msgid "Cancellation"
msgstr "Hủy bỏ"

