msgid "Cancel selected subscriptions at period end"
msgstr "Hủy các đăng ký đã chọn tại cuối chu kỳ"

msgid "Pause selected subscriptions"
msgstr "Tạm Dừng Các Gói Đặt Được Chọn"

msgid "Resume selected subscriptions"
msgstr "Tiếp tục các đăng ký đã chọn"

msgid "Billing Breakdown"
msgstr "Chi tiết thanh toán"

msgid "Retry Management"
msgstr "Quản Lý Thử Lại"

