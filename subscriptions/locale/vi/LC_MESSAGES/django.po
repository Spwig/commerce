#, python-format
msgid ""
"Discount applied to product price when customer subscribes (0 for full "
"price, 10 for 10% off, etc.)"
msgstr ""
"Giảm giá áp dụng cho giá sản phẩm khi khách hàng đăng ký (0 cho giá đầy đủ, "
"10 cho giảm 10%, v.v.)"

msgid "Discount percentage is required (use 0 for no discount)"
msgstr "Tỷ lệ giảm giá là bắt buộc (sử dụng 0 nếu không có giảm giá)"

msgid "Discount must be between 0% and 100%"
msgstr "Giảm giá phải nằm giữa 0% và 100%"

msgid "Plan Information"
msgstr "Thông tin gói"

msgid "Pricing Configuration"
msgstr "Cấu Hình Giá"

msgid "Trial Period"
msgstr "Chu kỳ thử nghiệm"

msgid "Cancellation Policy"
msgstr "Chính sách hủy"

msgid "Plan Change Behavior"
msgstr "Hành vi thay đổi gói"

