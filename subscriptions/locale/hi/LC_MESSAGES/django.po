msgstr "मूल्य"

msgid "Subscription Information"
msgstr "सदस्यता जानकारी"

msgid "Payment Configuration"
msgstr "भुगतान सेटअप"

msgid "Billing Schedule"
msgstr "बिलिंग अनुसूची"

msgid "Billing History"
msgstr "बिलिंग इतिहास"

msgid "Cancellation"
msgstr "रद्द करें"

msgid "Pause/Resume"
msgstr "रोक/पुनरारंभ"

msgid "Plan Changes"
