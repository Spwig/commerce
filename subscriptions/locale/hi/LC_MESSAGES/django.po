#, python-format
msgid ""
"Discount applied to product price when customer subscribes (0 for full "
"price, 10 for 10% off, etc.)"
msgstr ""
"ग्राहक द्वारा उपयोग के समय उत्पाद की कीमत पर छूट लागू की गई (पूरी कीमत के लिए 0, 10% "
"छूट के लिए 10, आदि)"

msgid "Discount percentage is required (use 0 for no discount)"
msgstr "डिस्काउंट प्रतिशत आवश्यक है (कोई डिस्काउंट नहीं होने पर 0 का उपयोग करें)"

msgid "Discount must be between 0% and 100%"
msgstr "डिस्काउंट 0% और 100% के बीच होना चाहिए"

msgid "Plan Information"
msgstr "योजना जानकारी"

msgid "Pricing Configuration"
msgstr "मूल्य विन्यास"

msgid "Trial Period"
msgstr "परीक्षण अवधि"

msgid "Cancellation Policy"
msgstr "रद्दीकरण नीति"

msgid "Plan Change Behavior"
msgstr "योजना बदलने का व्यवहार"

msgid "Limits & Restrictions"
msgstr "सीमा और प्रतिबंध"

msgid "Status"
msgstr "स्थिति"

msgid "Provider Integration"
msgstr "प्रोवाइडर एकीकरण"

msgid ""
"Map this plan to provider-specific plan IDs (e.g., {\"stripe\": "
"\"price_xxx\", \"paypal\": \"P-xxx\"})"
