msgstr "Aucun identifiant configuré (fournisseur intégré)"

#, python-format
msgid "Invalid model type: %(type)s. Must be one of: %(valid)s"
msgstr ""
"Type de modèle invalide : %(type)s. Doit être l'un des suivants : %(valid)s"

msgid "Permission denied."
msgstr "Accès refusé."

msgid "Generate SEO content for a single object"
msgstr "Générer du contenu SEO pour un seul objet"

msgid ""
"Generate meta title, meta description, and keywords for a product, category, "
"brand, page, blog post, or blog category. The generated content is "
"automatically saved to the object."
msgstr ""
"Générer le titre meta, la description meta et les mots-clés pour un produit, "
"une catégorie, une marque, une page, un article de blog ou une catégorie de "
"blog. Le contenu généré est automatiquement enregistré dans l'objet."

msgid "Model type: product, category, brand, page, blogpost, or blogcategory"
msgstr ""
"Type de modèle : produit, catégorie, marque, page, article de blog ou "
"catégorie de blog"

msgid "ID of the object to generate SEO for"
msgstr "ID de l'objet pour lequel générer le SEO"

msgid "Invalid model type, provider key, or language code"
msgstr "Type de modèle, clé du fournisseur ou code de langue invalides"

msgid "Permission denied"
msgstr "Accès refusé"

msgid "Object not found"
msgstr "Objet non trouvé"

msgid "Generation failed or unexpected error"
msgstr "Échec de la génération ou erreur inattendue"

msgid "Invalid provider key."
msgstr "Clé de fournisseur invalide."

msgid "Invalid language code."
msgstr "Code de langue invalide."

msgid "Object not found."
msgstr "Objet non trouvé."

msgid "SEO generation failed. Please try again."
msgstr "La génération SEO a échoué. Veuillez réessayer."

msgid "An unexpected error occurred. Please try again."
msgstr "Une erreur inattendue s'est produite. Veuillez réessayer."

msgid "Batch generate SEO for multiple objects"
msgstr "Générer en lot le SEO pour plusieurs objets"

msgid ""
"Generate SEO content for multiple objects at once. Each item specifies a "
"model type and object ID. Results include per-item success/failure and a "
"summary."
msgstr ""
"Générer du contenu SEO pour plusieurs objets à la fois. Chaque élément "
"spécifie un type de modèle et un ID d'objet. Les résultats incluent une "
"indication de succès/échec par élément ainsi qu'un résumé."

msgid "Invalid request body, no items, or invalid provider"
msgstr "Corps de la demande invalide, aucun élément ou fournisseur invalide"

msgid "Unexpected error"
msgstr "Erreur inattendue"

msgid "Invalid request body."
msgstr "Corps de la requête invalide."

msgid "No items provided."
msgstr "Aucun élément fourni."

msgid "Missing model_type or object_id."
msgstr "Manque model_type ou object_id."

msgid "Generation failed for this item."
msgstr "Échec de la génération pour cet élément."

msgid "Check SEO status for an object"
msgstr "Vérifier l'état SEO d'un objet"

msgid ""
"Check whether an object has SEO content, whether it was auto-generated, and "
"return the current meta title and description with their lengths."
msgstr ""
"Vérifier si un objet a du contenu SEO, s'il a été généré automatiquement, et "
"renvoyer le titre meta et la description actuels avec leurs longueurs."

msgid "ID of the object"
msgstr "ID de l'objet"

msgid "Invalid model type"
msgstr "Type de modèle non valide"

msgid "SEO Generator"
msgstr "Générateur SEO"

msgid "Model type to generate SEO for (or \"all\" for all models)"
msgstr ""
"Type de modèle pour lequel générer le SEO (ou \"all\" pour tous les modèles)"

msgid "Number of items to process in each batch (default: 50)"
msgstr "Nombre d'éléments à traiter par lot (par défaut : 50)"

msgid "Only generate SEO for items with seo_auto_generated=True"
msgstr ""
"Générer le SEO uniquement pour les éléments avec seo_auto_generated=True"

msgid ""
"SEO provider to use (default: primary provider, or deterministic if none "
"configured)"
msgstr ""
"Fournisseur SEO à utiliser (par défaut : fournisseur principal, ou "
"déterministe si aucun n'est configuré)"

msgid "Language code for generation (default: site primary language)"
msgstr ""
"Code de langue pour la génération (par défaut : langue principale du site)"

