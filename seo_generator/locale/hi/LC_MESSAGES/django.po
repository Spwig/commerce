msgid "Configure"
msgstr "कॉन्फ़िगर करें"

msgid "Install"
msgstr "इंस्टॉल करें"

msgid "View Details"
msgstr "विवरण देखें"

msgid "Learn More"
msgstr "अधिक जानें"

msgid "No Providers Available"
msgstr "कोई प्रदाता उपलब्ध नहीं है"

msgid ""
"No SEO generation providers are currently available. The built-in "
"deterministic provider is always available without installation."
msgstr ""
"वर्तमान में कोई एसईओ जेनरेशन प्रोवाइडर्स उपलब्ध नहीं हैं। बिल्ट-इन निर्धारक प्रोवाइडर हमेशा "
"बिना इंस्टॉल किए उपलब्ध रहता है।"

msgid "Installing provider..."
msgstr "प्रदाता को इंस्टॉल कर रहे हैं..."

msgid "SEO Providers"
msgstr "एसईओ प्रदाता"

msgid "Manage SEO generation provider integrations"
msgstr "एसईओ उत्पादन प्रदाता इंटीग्रेशन का प्रबंधन करें"

msgid "provider"
msgstr "प्रदाता"

msgid "active"
msgstr "सक्रिय"

msgid "Inactive"
msgstr "असक्रिय"

msgid "No SEO Providers Configured"
msgstr "कोई एसईओ प्रदाता सेट अप नहीं किया गया है"

msgid ""
"The built-in deterministic provider is available by default. Connect "
"additional providers for AI-powered SEO generation."
msgstr ""
"बिल्ट-इन निर्धारक प्रोवाइडर को पूर्वनिर्धारित रूप से उपलब्ध कर दिया गया है। एआई-पावर्ड "
"एसईओ जेनरेशन के लिए अतिरिक्त प्रोवाइडर्स को कनेक्ट करें।"

msgid "Connect Provider"
msgstr "प्रदाता के साथ कनेक्ट करें"

msgid "Connect SEO Provider"
msgstr "एसईओ प्रदाता के साथ कनेक्ट करें"

msgid "Follow these steps to connect your SEO generation provider"
msgstr "अपने SEO उत्पादन प्रदाता को कनेक्ट करने के लिए इन चरणों का पालन करें"

msgid "Select Provider"
msgstr "प्रदाता का चयन करें"

msgid "Setup Instructions"
msgstr "सेटअप निर्देश"

msgid "Enter Credentials"
msgstr "अपना एक्रेडेंशियल दर्ज करें"

msgid "Test Connection"
msgstr "कनेक्शन का परीक्षण करें"

msgid "Select an SEO Provider"
msgstr "एक एसईओ प्रदाता का चयन करें"

msgid "Choose the SEO generation provider you want to connect to your store."
msgstr "अपने स्टोर के लिए कनेक्ट करने वाला SEO उत्पादन प्रदाता चुनें।"

msgid "No SEO provider components are currently installed."
msgstr "वर्तमान में कोई SEO प्रदाता कम्पोनेंट इंस्टॉल नहीं है।"

msgid "Please browse and install SEO provider components from the marketplace."
msgstr "कृपया मार्केटप्लेस से SEO प्रदाता कम्पोनेंट ब्राउज़ और इंस्टॉल करें।"

msgid "Next"
msgstr "अगला"

#, python-format
msgid ""
"\n"
"        Before entering credentials, review these setup steps for "
"%(provider)s.\n"
"        "
msgstr ""
"\n"
"        %(provider)s के लिए इन सेटअप चरणों की जांच करें, क्रेडेंशियल्स दर्ज करने से पहले।"
"%(provider)s के लिए इन सेटअप चरणों की जांच करें, क्रेडेंशियल्स दर्ज करने से पहले।\n"
"        "

msgid "Setup Instructions Not Available"
msgstr "सेटअप निर्देश उपलब्ध नहीं हैं"

#, python-format
msgid ""
"\n"
"                    Setup instructions are not available for this version of "
"%(provider)s.\n"
"                    Please contact support for assistance or check for an "
"updated version.\n"
"                    "
msgstr ""
"\n"
"                    इस %(provider)s के इस संस्करण के लिए सेटअप निर्देश उपलब्ध नहीं हैं। "
"कृपया सहायता के लिए सपोर्ट से संपर्क करें या अपडेटेड संस्करण की जांच करें।\n"
"                    "

msgid "Back"
msgstr "पीछे"

msgid "Continue to Credentials"
msgstr "एक्रेडेंशियल के लिए जारी रहें"

msgid "Enter API Credentials"
msgstr "एपीआई एक्रेडेंशियल दर्ज करें"

#, python-format
msgid ""
"\n"
"        Enter your API credentials for %(provider)s. These will be securely "
"encrypted and stored.\n"
"        "
msgstr ""
"\n"
"        %(provider)s के लिए अपने API एक्रेडिटिवल्स दर्ज करें। ये सुरक्षित रूप से एन्क्रिप्ट "
"करके संग्रहित किए जाएंगे।\n"
"        "

msgid "Don't have an account yet?"
msgstr "अभी तक एक खाता नहीं है?"

msgid "You'll need an account to get API credentials."
msgstr "आपको API एक्रेडिटिवल्स प्राप्त करने के लिए एक खाता चाहिए।"

msgid "Sign up here"
msgstr "यहां रजिस्टर करें"

msgid "API Credentials"
msgstr "एपीआई एक्रेडेंशियल"

msgid "Select..."
msgstr "चुने..."

msgid "No credential fields configured for this provider."
msgstr "इस प्रदाता के लिए कोई एक्रेडिटिवल फील्ड कॉन्फ़िगर नहीं है।"

msgid ""
"Your credentials will be encrypted using AES-256 encryption before being "
"stored in the database."
msgstr ""
"आपके एक्रेडिटिवल्स को डेटाबेस में संग्रहित करने से पहले AES-256 एन्क्रिप्शन का उपयोग करके "
"एन्क्रिप्ट किए जाएंगे।"

#, python-format
msgid ""
"\n"
"        Test the connection to %(provider)s to verify your credentials are "
"correct.\n"
"        "
msgstr ""
"\n"
"        %(provider)s के संबंध में कनेक्शन की जांच करें ताकि आपके क्रेडेंशियल्स सही हों।"
"%(provider)s के संबंध में कनेक्शन की जांच करें ताकि आपके क्रेडेंशियल्स सही हों।\n"
"        "

msgid "Testing connection..."
msgstr "कनेक्शन की जांच कर रहे हैं..."

msgid "Please wait while we verify your credentials."
msgstr "कृपया इंतजार करें जब तक हम आपके एक्रेडिटिवल्स की पुष्टि नहीं करते।"

msgid "Click to test the connection with your entered credentials."
msgstr ""
"अपने द्वारा दर्ज किए गए एक्रेडिटिवल्स के साथ कनेक्शन का परीक्षण करने के लिए क्लिक करें।"

msgid "Connection Successful!"
msgstr "कनेक्शन सफल!"

msgid "Save & Finish"
msgstr "सहेजें और समाप्त करें"

msgid "Your credentials were verified successfully."
msgstr "आपका एक्रेडिटिवल्स सफलतापूर्वक सत्यापित किया गया।"

msgid "Connection Failed"
msgstr "कनेक्शन विफल"

msgid "Could not connect to the provider API."
msgstr "प्रदाता API के साथ कनेक्ट नहीं कर सका।"

msgid "Error"
msgstr "त्रुटि"

msgid "An unexpected error occurred."
msgstr "अप्रत्याशित त्रुटि हुई।"

msgid "Saving..."
msgstr "सहेज रहे हैं..."

msgid "Failed to save provider account."
msgstr "प्रोवाइडर खाता सहेजन में विफल रहा।"

msgid "An error occurred while saving."
msgstr "सहेजते समय एक त्रुटि हुई।"

msgid "Failed to calculate coverage."
msgstr "कवरेज की गणना विफल रही।"

msgid "Failed to refresh coverage."
msgstr "कवरेज को फिर से लोड करने में विफल रहा।"

msgid "Failed to get missing items."
msgstr "लापता आइटम प्राप्त करने में विफल रहे।"

msgid "Invalid content type."
msgstr "अमान्य सामग्री प्रकार।"

msgid "Failed to load items."
msgstr "वस्तुओं को लोड करने में विफल रहा।"

msgid "Provider is already installed. Configure it now."
msgstr "प्रदाता पहले से ही इंस्टॉल किया गया है। अब इसे कॉन्फ़िगर करें।"

msgid "Provider not found on update server."
msgstr "अपडेट सर्वर पर प्रदाता नहीं मिला।"

msgid "Could not determine provider version."
msgstr "प्रोवाइडर के संस्करण का पता नहीं लगा सका।"

#, python-format
msgid "Failed to download provider: %(error)s"
msgstr "प्रोवाइडर के डाउनलोड में विफल रहे: %(error)s"

#, python-format
msgid "Failed to install provider: %(error)s"
msgstr "प्रोवाइडर के इंस्टॉल करने में विफल रहे: %(error)s"

#, python-format
msgid "Provider \"%(name)s\" installed successfully! Configure it now."
msgstr "प्रोवाइडर \"%(name)s\" सफलतापूर्वक इंस्टॉल कर दिया गया है! अब इसका सेटअप करें।"

msgid "An unexpected error occurred during installation."
msgstr "इंस्टॉल के दौरान एक अप्रत्याशित त्रुटि हुई।"

msgid "Provider not installed."
msgstr "प्रोवाइडर इंस्टॉल नहीं किया गया।"

#, python-format
msgid "Could not connect to update server: %(error)s"
msgstr "अपडेट सर्वर से कनेक्शन नहीं हो सका: %(error)s"

msgid "Could not determine latest version."
msgstr "नवीनतम संस्करण का पता नहीं लगा सका।"

#, python-format
msgid "Provider \"%(name)s\" is already up to date (v%(version)s)."
msgstr "प्रोवाइडर \"%(name)s\" पहले से ही अपडेट है (v%(version)s)."

#, python-format
msgid "Failed to download update: %(error)s"
msgstr "अपडेट डाउनलोड करने में विफल रहा: %(error)s"

#, python-format
msgid "Failed to install update: %(error)s"
msgstr "अपडेट को इंस्टॉल करने में विफलता: %(error)s"

#, python-format
msgid "Provider \"%(name)s\" updated successfully to v%(version)s!"
msgstr "प्रोवाइडर \"%(name)s\" को सफलतापूर्वक v%(version)s तक अपडेट कर दिया गया!"

msgid "An unexpected error occurred during the update."
msgstr "अपडेट के दौरान अप्रत्याशित त्रुटि हुई।"

msgid "Connect SEO Provider - Select Provider"
msgstr "एसईओ प्रोवाइडर कनेक्ट करें - प्रोवाइडर चुनें"

msgid "Please select a provider."
msgstr "कृपया एक प्रोवाइडर चुनें।"

msgid "Invalid provider selected."
msgstr "अमान्य प्रोवाइडर चुना गया।"

msgid "Please select a provider first."
msgstr "कृपया पहले एक प्रोवाइडर चुनें।"

#, python-format
msgid "Setup instructions not found for %(provider)s."
msgstr "%(provider)s के लिए सेटअप निर्देश नहीं मिले।"

#, python-format
msgid "Error loading provider: %(error)s"
msgstr "प्रोवाइडर लोड करते समय त्रुटि: %(error)s"

msgid "Connect SEO Provider - Setup Instructions"
msgstr "एसईओ प्रोवाइडर कनेक्ट करें - सेटअप निर्देश"

msgid "Could not load provider configuration."
msgstr "प्रोवाइडर कॉन्फ़िगरेशन लोड करने में विफल रहा।"

msgid "Connect SEO Provider - Enter Credentials"
msgstr "एसईओ प्रोवाइडर कनेक्ट करें - एक्रेडिटिवल्स दर्ज करें"

msgid "Error loading provider configuration."
msgstr "प्रोवाइडर कॉन्फ़िगरेशन लोड करते समय त्रुटि हुई।"

msgid "Please complete previous steps first."
msgstr "कृपया पहले पिछले कदम पूरा करें।"

msgid "Provider not found."
msgstr "प्रोवाइडर नहीं मिला।"

msgid "Connect SEO Provider - Test Connection"
msgstr "एसईओ प्रोवाइडर कनेक्ट करें - कनेक्शन का परीक्षण करें"

msgid "Missing data."
msgstr "अपूर्ण डेटा।"

msgid "Provider implementation not found."
msgstr "प्रोवाइडर के लागू करने वाला नहीं मिला।"

msgid "An error occurred while testing the connection."
msgstr "कनेक्शन के परीक्षण के दौरान एक त्रुटि हुई।"

msgid "Site not configured."
msgstr "साइट कॉन्फ़िगर नहीं की गई है।"

msgid "Connection test failed"
msgstr "कनेक्शन परीक्षण विफल रहा"

msgid "Provider connected successfully!"
msgstr "प्रोवाइडर सफलतापूर्वक जुड़ गया!"

msgid "An error occurred while saving the provider."
msgstr "प्रोवाइडर को सहेजते समय एक त्रुटि हुई।"

msgid "Invalid action."
msgstr "अमान्य कार्रवाई।"
