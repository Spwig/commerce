#, python-format
msgid "Invalid model type: %(type)s. Must be one of: %(valid)s"
msgstr "अमान्य मॉडल प्रकार: %(type)s। यह निम्न में से एक होना चाहिए: %(valid)s"

msgid "Permission denied."
msgstr "अनुमति अस्वीकृत।"

msgid "Generate SEO content for a single object"
msgstr "एक ऑब्जेक्ट के लिए SEO सामग्री उत्पन्न करें"

msgid ""
"Generate meta title, meta description, and keywords for a product, category, "
"brand, page, blog post, or blog category. The generated content is "
"automatically saved to the object."
msgstr ""
"एक उत्पाद, श्रेणी, ब्रांड, पृष्ठ, ब्लॉग पोस्ट या ब्लॉग श्रेणी के लिए मेटा शीर्षक, मेटा विवरण "
"और कीवर्ड्स उत्पन्न करें। उत्पन्न सामग्री ऑब्जेक्ट में स्वचालित रूप से सहेजी जाती है।"

msgid "Model type: product, category, brand, page, blogpost, or blogcategory"
msgstr "मॉडल प्रकार: उत्पाद, श्रेणी, ब्रांड, पृष्ठ, ब्लॉग पोस्ट या ब्लॉग श्रेणी"

msgid "ID of the object to generate SEO for"
msgstr "SEO उत्पन्न करने वाले वस्तु का आईडी"

msgid "Invalid model type, provider key, or language code"
msgstr "अमान्य मॉडल प्रकार, प्रदाता की कुंजी या भाषा कोड"

msgid "Permission denied"
msgstr "अनुमति अस्वीकृत"

