msgid ""
"\n"
"%(type)s (%(count)d items)"
msgstr ""
"\n"
"%(type)s (%(count)d elementi)"

#, python-format
msgid "  Failed %(type)s %(pk)s: %(error)s"
msgstr "Fallito %(type)s %(pk)s: %(error)s"

#, python-format
msgid "  %(type)s: %(success)d successful, %(failed)d failed"
msgstr "%(type)s: %(success)d riusciti, %(failed)d falliti"

msgid "Site"
msgstr "Sito"

msgid "Site this provider account belongs to"
msgstr "Sito a cui appartiene questo account del fornitore"

msgid "Provider Component"
msgstr "Componente Fornitore"

msgid "SEO provider component from update system (null for built-in)"
msgstr ""
"Componente fornitore SEO dal sistema di aggiornamento (null per i "
"predefiniti)"

msgid "Provider Key"
msgstr "Chiave Fornitore"

msgid ""
"Built-in provider key (e.g., 'deterministic'). Used when component is null."
msgstr ""
"Chiave fornitore predefinita (es. 'deterministic'). Utilizzata quando il "
"componente è null."

msgid "Account Name"
msgstr "Nome account"

msgid "Friendly name for this provider account"
msgstr "Nome amichevole per questo account del fornitore"

msgid "Encrypted Credentials"
msgstr "Credenziali crittografate"

msgid "Encrypted API credentials for this provider"
msgstr "Credenziali API crittografate per questo fornitore"

msgid "Active"
msgstr "Attivo"

msgid "Whether this provider account is active"
msgstr "Se questo account del fornitore è attivo"

msgid "Primary Provider"
msgstr "Fornitore principale"

msgid "Use this provider as primary source for SEO generation"
msgstr "Utilizza questo fornitore come fonte primaria per la generazione SEO"

msgid "Priority"
msgstr "Priorità"

msgid "Priority for fallback chain (lower = higher priority)"
msgstr "Priorità per la catena di fallback (minore = priorità maggiore)"

msgid "Provider Settings"
msgstr "Impostazioni Fornitore"

msgid "Provider-specific settings and configuration"
msgstr "Impostazioni e configurazioni specifiche del fornitore"

msgid "SEO Provider Account"
msgstr "Account Fornitore SEO"

msgid "SEO Provider Accounts"
msgstr "Account Fornitori SEO"

msgid "provider_key must be set by subclass"
msgstr "provider_key deve essere impostato da una sottoclasse"

msgid "provider_name must be set by subclass"
msgstr "provider_name deve essere impostato da una sottoclasse"

