msgstr "Nenhuma credencial configurada (fornecedor integrado)"

#, python-format
msgid "Invalid model type: %(type)s. Must be one of: %(valid)s"
msgstr ""
"Tipo de modelo inválido: %(type)s. Deve ser um dos seguintes: %(valid)s"

msgid "Permission denied."
msgstr "Permissão negada."

msgid "Generate SEO content for a single object"
msgstr "Gerar conteúdo de SEO para um único objeto"

msgid ""
"Generate meta title, meta description, and keywords for a product, category, "
"brand, page, blog post, or blog category. The generated content is "
"automatically saved to the object."
msgstr ""
"Gerar título meta, descrição meta e palavras-chave para um produto, "
"categoria, marca, página, post de blog ou categoria de blog. O conteúdo "
"gerado é salvo automaticamente no objeto."

msgid "Model type: product, category, brand, page, blogpost, or blogcategory"
msgstr ""
"Tipo de modelo: produto, categoria, marca, página, postagem de blog ou "
"categoria de blog"

msgid "ID of the object to generate SEO for"
msgstr "ID do objeto para o qual o SEO será gerado"

msgid "Invalid model type, provider key, or language code"
msgstr "Tipo de modelo inválido, chave do provedor ou código de idioma"

msgid "Permission denied"
msgstr "Permissão negada"

msgid "Object not found"
msgstr "Objeto não encontrado"

msgid "Generation failed or unexpected error"
msgstr "Falha na geração ou erro inesperado"

msgid "Invalid provider key."
msgstr "Chave de fornecedor inválida."

msgid "Invalid language code."
msgstr "Código de idioma inválido."

msgid "Object not found."
msgstr "Objeto não encontrado."

msgid "SEO generation failed. Please try again."
msgstr "A geração de SEO falhou. Por favor, tente novamente."

msgid "An unexpected error occurred. Please try again."
msgstr "Ocorreu um erro inesperado. Por favor, tente novamente."

msgid "Batch generate SEO for multiple objects"
msgstr "Gerar SEO em lote para múltiplos objetos"

msgid ""
"Generate SEO content for multiple objects at once. Each item specifies a "
"model type and object ID. Results include per-item success/failure and a "
"summary."
msgstr ""
"Gerar conteúdo SEO para múltiplos objetos de uma só vez. Cada item "
"especifica um tipo de modelo e um ID de objeto. Os resultados incluem "
"sucesso/falha por item e um resumo."

msgid "Invalid request body, no items, or invalid provider"
msgstr "Corpo da solicitação inválido, sem itens ou provedor inválido"

msgid "Unexpected error"
msgstr "Erro inesperado"

msgid "Invalid request body."
msgstr "Corpo da solicitação inválido."

msgid "No items provided."
msgstr "Nenhum item fornecido."

msgid "Missing model_type or object_id."
msgstr "Faltando model_type ou object_id."

msgid "Generation failed for this item."
msgstr "Geração falhou para este item."

msgid "Check SEO status for an object"
msgstr "Verificar status do SEO para um objeto"

msgid ""
"Check whether an object has SEO content, whether it was auto-generated, and "
"return the current meta title and description with their lengths."
msgstr ""
"Verificar se um objeto possui conteúdo SEO, se foi gerado automaticamente e "
"retornar o título meta e descrição atuais com seus comprimentos."

msgid "ID of the object"
msgstr "ID do objeto"

msgid "Invalid model type"
msgstr "Tipo de modelo inválido"

msgid "SEO Generator"
msgstr "Gerador SEO"

msgid "Model type to generate SEO for (or \"all\" for all models)"
msgstr "Tipo de modelo para gerar SEO (ou \"all\" para todos os modelos)"

msgid "Number of items to process in each batch (default: 50)"
msgstr "Número de itens para processar em cada lote (padrão: 50)"

msgid "Only generate SEO for items with seo_auto_generated=True"
msgstr "Gerar SEO apenas para itens com seo_auto_generated=True"

msgid ""
"SEO provider to use (default: primary provider, or deterministic if none "
"configured)"
msgstr ""
"Fornecedor de SEO a ser usado (padrão: fornecedor principal, ou "
"determinístico se nenhum configurado)"

msgid "Language code for generation (default: site primary language)"
msgstr "Código de idioma para geração (padrão: idioma principal do site)"

