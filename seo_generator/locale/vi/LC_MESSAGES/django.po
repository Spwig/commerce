#, python-format
msgid "Invalid model type: %(type)s. Must be one of: %(valid)s"
msgstr "Loại mô hình không hợp lệ: %(type)s. Phải là một trong số: %(valid)s"

msgid "Permission denied."
msgstr "Không có quyền truy cập."

msgid "Generate SEO content for a single object"
msgstr "Tạo nội dung SEO cho một đối tượng"

msgid ""
"Generate meta title, meta description, and keywords for a product, category, "
"brand, page, blog post, or blog category. The generated content is "
"automatically saved to the object."
msgstr ""
"Tự động tạo tiêu đề meta, mô tả meta và từ khóa cho sản phẩm, danh mục, "
"thương hiệu, trang, bài viết blog hoặc danh mục blog. Nội dung được tạo sẽ "
"được lưu tự động vào đối tượng."

msgid "Model type: product, category, brand, page, blogpost, or blogcategory"
msgstr ""
"Loại mô hình: sản phẩm, danh mục, thương hiệu, trang, bài viết blog hoặc "
"danh mục blog"

msgid "ID of the object to generate SEO for"
msgstr "ID của đối tượng để tạo SEO"

msgid "Invalid model type, provider key, or language code"
msgstr "Loại mô hình, khóa nhà cung cấp hoặc mã ngôn ngữ không hợp lệ"

msgid "Permission denied"
msgstr "Từ chối quyền truy cập"

msgid "Object not found"
msgstr "Không tìm thấy đối tượng"

msgid "Generation failed or unexpected error"
msgstr "Thất bại khi tạo hoặc xảy ra lỗi bất ngờ"

msgid "Invalid provider key."
msgstr "Khóa nhà cung cấp không hợp lệ."

msgid "Invalid language code."
msgstr "Mã ngôn ngữ không hợp lệ."

msgid "Object not found."
msgstr "Không tìm thấy đối tượng."

msgid "SEO generation failed. Please try again."
msgstr "Tạo SEO thất bại. Vui lòng thử lại."

msgid "An unexpected error occurred. Please try again."
msgstr "Đã xảy ra lỗi không mong muốn. Vui lòng thử lại."

msgid "Batch generate SEO for multiple objects"
msgstr "Tạo SEO theo lô cho nhiều đối tượng"

msgid ""
"Generate SEO content for multiple objects at once. Each item specifies a "
"model type and object ID. Results include per-item success/failure and a "
"summary."
msgstr ""
"Tạo nội dung SEO cho nhiều đối tượng cùng lúc. Mỗi mục xác định loại mô hình "
"và ID đối tượng. Kết quả bao gồm trạng thái thành công/thất bại cho từng mục "
"và một bản tóm tắt."

msgid "Invalid request body, no items, or invalid provider"
msgstr ""
"Nội dung yêu cầu không hợp lệ, không có mục hoặc nhà cung cấp không hợp lệ"

msgid "Unexpected error"
msgstr "Lỗi bất ngờ"

msgid "Invalid request body."
msgstr "Nội dung yêu cầu không hợp lệ."

msgid "No items provided."
msgstr "Không có mục được cung cấp."

msgid "Missing model_type or object_id."
msgstr "Thiếu model_type hoặc object_id."

msgid "Generation failed for this item."
msgstr "Thất bại khi tạo nội dung cho mục này."

msgid "Check SEO status for an object"
msgstr "Kiểm tra trạng thái SEO cho một đối tượng"

msgid ""
"Check whether an object has SEO content, whether it was auto-generated, and "
"return the current meta title and description with their lengths."
msgstr ""
"Kiểm tra xem đối tượng có nội dung SEO hay không, xem nội dung đó có được "
"tạo tự động hay không, và trả về tiêu đề meta và mô tả hiện tại cùng với độ "
"dài của chúng."

msgid "ID of the object"
msgstr "ID của đối tượng"

msgid "Invalid model type"
msgstr "Loại mô hình không hợp lệ"

msgid "SEO Generator"
msgstr "Trình tạo SEO"

msgid "Model type to generate SEO for (or \"all\" for all models)"
msgstr ""
"Loại mô hình để tạo SEO (hoặc \"all\" để tạo SEO cho tất cả các mô hình)"

msgid "Number of items to process in each batch (default: 50)"
msgstr "Số lượng mục cần xử lý trong mỗi lô (mặc định: 50)"

msgid "Only generate SEO for items with seo_auto_generated=True"
msgstr "Chỉ tạo SEO cho các mục có seo_auto_generated=True"

msgid ""
"SEO provider to use (default: primary provider, or deterministic if none "
"configured)"
msgstr ""
"Cung cấp SEO để sử dụng (mặc định: nhà cung cấp chính, hoặc xác định nếu "
"không có cấu hình nào)"

msgid "Language code for generation (default: site primary language)"
msgstr "Mã ngôn ngữ để tạo (mặc định: ngôn ngữ chính của trang web)"

