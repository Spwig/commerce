#, python-format
msgid "Invalid model type: %(type)s. Must be one of: %(valid)s"
msgstr "Неверный тип модели: %(type)s. Должен быть одним из: %(valid)s"

msgid "Permission denied."
msgstr "Доступ запрещен."

msgid "Generate SEO content for a single object"
msgstr "Создать SEO-контент для одного объекта"

msgid ""
"Generate meta title, meta description, and keywords for a product, category, "
"brand, page, blog post, or blog category. The generated content is "
"automatically saved to the object."
msgstr ""
"Сгенерируйте мета-заголовок, мета-описание и ключевые слова для товара, "
"категории, бренда, страницы, блог-поста или категории блога. Сгенерированный "
"контент автоматически сохраняется в объект."

msgid "Model type: product, category, brand, page, blogpost, or blogcategory"
msgstr ""
"Тип модели: продукт, категория, бренд, страница, блог-пост или категория "
"блога"

msgid "ID of the object to generate SEO for"
msgstr "ID объекта для генерации SEO"

msgid "Invalid model type, provider key, or language code"
msgstr "Неверный тип модели, ключ поставщика или код языка"

msgid "Permission denied"
msgstr "Доступ запрещен"

msgid "Object not found"
msgstr "Объект не найден"

msgid "Generation failed or unexpected error"
msgstr "Не удалось создать или произошла непредвиденная ошибка"

msgid "Invalid provider key."
msgstr "Неверный ключ поставщика."

msgid "Invalid language code."
msgstr "Неверный код языка."

msgid "Object not found."
msgstr "Объект не найден."

msgid "SEO generation failed. Please try again."
msgstr "Генерация SEO не удалась. Пожалуйста, попробуйте еще раз."

msgid "An unexpected error occurred. Please try again."
msgstr "Произошла непредвиденная ошибка. Пожалуйста, попробуйте еще раз."

msgid "Batch generate SEO for multiple objects"
msgstr "Пакетная генерация SEO для нескольких объектов"

msgid ""
"Generate SEO content for multiple objects at once. Each item specifies a "
"model type and object ID. Results include per-item success/failure and a "
"summary."
msgstr ""
"Сгенерируйте SEO-контент для нескольких объектов одновременно. Каждый "
"элемент указывает тип модели и идентификатор объекта. Результаты включают "
"успех/провал по каждому элементу и общий итог."

msgid "Invalid request body, no items, or invalid provider"
msgstr "Неверное тело запроса, отсутствуют элементы или неверный провайдер"

msgid "Unexpected error"
msgstr "Непредвиденная ошибка"

msgid "Invalid request body."
msgstr "Неверное тело запроса."

msgid "No items provided."
msgstr "Предоставленных элементов нет."

msgid "Missing model_type or object_id."
msgstr "Отсутствует model_type или object_id."

msgid "Generation failed for this item."
msgstr "Генерация не удалась для этого элемента."

msgid "Check SEO status for an object"
msgstr "Проверить статус SEO для объекта"

msgid ""
"Check whether an object has SEO content, whether it was auto-generated, and "
"return the current meta title and description with their lengths."
msgstr ""
"Проверьте, имеет ли объект SEO-контент, был ли он автоматически "
"сгенерирован, и получите текущий мета-заголовок и описание вместе с их "
"длиной."

msgid "ID of the object"
msgstr "ID объекта"

msgid "Invalid model type"
msgstr "Недопустимый тип модели"

msgid "SEO Generator"
msgstr "Генератор SEO"

msgid "Model type to generate SEO for (or \"all\" for all models)"
msgstr "Тип модели для генерации SEO (или \"all\" для всех моделей)"

msgid "Number of items to process in each batch (default: 50)"
msgstr ""
"Количество элементов для обработки в каждой пакетной операции (по умолчанию: "
"50)"

msgid "Only generate SEO for items with seo_auto_generated=True"
msgstr "Генерировать SEO только для элементов с seo_auto_generated=True"

msgid ""
"SEO provider to use (default: primary provider, or deterministic if none "
"configured)"
msgstr ""
"Поставщик SEO, который следует использовать (по умолчанию: основной "
"поставщик, или определительный, если не настроен)"

msgid "Language code for generation (default: site primary language)"
msgstr "Код языка для генерации (по умолчанию: основной язык сайта)"

