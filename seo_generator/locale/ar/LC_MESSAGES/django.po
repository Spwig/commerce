msgid "Permission denied."
msgstr "الوصول ممنوع."

msgid "Generate SEO content for a single object"
msgstr "إنشاء محتوى SEO لعنصر واحد"

msgid ""
"Generate meta title, meta description, and keywords for a product, category, "
"brand, page, blog post, or blog category. The generated content is "
"automatically saved to the object."
msgstr ""
"إنشاء عنوان ميتا، ووصف ميتا، و الكلمات المفتاحية لمنتج، فئة، علامة تجارية، "
"صفحة، مقالة مدونة أو فئة مدونة. يتم حفظ المحتوى المنشأ تلقائيًا في الكائن."

msgid "Model type: product, category, brand, page, blogpost, or blogcategory"
msgstr "نوع النموذج: منتج، فئة، علامة تجارية، صفحة، مقالة مدونة، أو فئة مدونة"

msgid "ID of the object to generate SEO for"
msgstr "معرّف الكائن لجénération SEO له"

msgid "Invalid model type, provider key, or language code"
msgstr "نوع النموذج غير صحيح أو مفتاح المزود أو رمز اللغة"

msgid "Permission denied"
msgstr "الوصول مُمنوع"

msgid "Object not found"
msgstr "الكائن غير موجود"

msgid "Generation failed or unexpected error"
msgstr "فشل التوليد أو خطأ غير متوقع"

msgid "Invalid provider key."
msgstr "مفتاح المزود غير صحيح."

msgid "Invalid language code."
msgstr "رمز اللغة غير صحيح."

msgid "Object not found."
msgstr "الكائن غير موجود."

msgid "SEO generation failed. Please try again."
msgstr "فشل إنشاء SEO. يرجى المحاولة مرة أخرى."

msgid "An unexpected error occurred. Please try again."
msgstr "لقد حدث خطأ غير متوقع. يرجى المحاولة مرة أخرى."

msgid "Batch generate SEO for multiple objects"
msgstr "إنشاء SEO دفعة واحدة لعدد من الكائنات"

msgid ""
"Generate SEO content for multiple objects at once. Each item specifies a "
"model type and object ID. Results include per-item success/failure and a "
"summary."
msgstr ""
"إنشاء محتوى SEO للكائنات متعددة مرة واحدة. يحدد كل عنصر نوع نموذج ورقم كائن. "
"تتضمن النتائج نجاح/فشل كل عنصر وموجز."

msgid "Invalid request body, no items, or invalid provider"
msgstr "طلب غير صحيح، لا توجد عناصر، أو مزود غير صحيح"

msgid "Unexpected error"
msgstr "خطأ غير متوقع"

msgid "Invalid request body."
msgstr "محتوى الطلب غير صحيح."

msgid "No items provided."
msgstr "لم يتم تقديم أي عناصر."

msgid "Missing model_type or object_id."
msgstr "نوع النموذج أو معرف الكائن مفقود."

msgid "Generation failed for this item."
msgstr "فشل إنشاء هذا العنصر."

msgid "Check SEO status for an object"
msgstr "تحقق من حالة SEO للكائن"

msgid ""
"Check whether an object has SEO content, whether it was auto-generated, and "
"return the current meta title and description with their lengths."
msgstr ""
"تحقق مما إذا كان الكائن يحتوي على محتوى SEO، وما إذا كان تم توليده تلقائيًا، "
"واحصل على عنوان الميتا ووصفه الحالي مع أطوالهما."

msgid "ID of the object"
msgstr "مُعرف الكائن"

msgid "Invalid model type"
msgstr "نوع النموذج غير صحيح"

msgid "SEO Generator"
msgstr "مُنشئ SEO"

msgid "Model type to generate SEO for (or \"all\" for all models)"
msgstr "نوع النموذج لإنشاء SEO له (أو \"all\" لجميع النماذج)"

msgid "Number of items to process in each batch (default: 50)"
msgstr "عدد العناصر لمعالجة كل دفعة (القيمة الافتراضية: 50)"

msgid "Only generate SEO for items with seo_auto_generated=True"
msgstr "أنشئ SEO فقط للعناصر التي يكون فيها seo_auto_generated=True"

msgid ""
"SEO provider to use (default: primary provider, or deterministic if none "
"configured)"
msgstr ""
"مزوّج SEO للاستخدام (القيمة الافتراضية: المزوّج الأساسي، أو التحديدية إذا لم "
"يتم تكوين أي مزوّج)"

msgid "Language code for generation (default: site primary language)"
msgstr ""
"رمز اللغة للاستخدام في الإنشاء (القيمة الافتراضية: اللغة الأساسية للموقع)"

