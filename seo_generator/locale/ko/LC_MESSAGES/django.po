msgstr "이 제공업체 계정이 활성화되어 있는지 여부"

msgid "Primary Provider"
msgstr "기본 프로바이더"

msgid "Use this provider as primary source for SEO generation"
msgstr "이 제공업체를 SEO 생성의 주요 소스로 사용"

msgid "Priority"
msgstr "우선순위"

msgid "Priority for fallback chain (lower = higher priority)"
msgstr "대체 체인의 우선순위 (작을수록 우선순위가 높음)"

msgid "Provider Settings"
msgstr "프로바이더 설정"

msgid "Provider-specific settings and configuration"
msgstr "프로바이더별 설정 및 구성"

msgid "SEO Provider Account"
msgstr "SEO 프로바이더 계정"

