msgstr "빠른 작업"

#, python-format
msgid "Generate SEO for %(count)s missing items"
msgstr "%(count)s개의 누락된 항목에 대해 SEO를 생성합니다."

msgid "Manage Providers"
msgstr "프로바이더 관리"

