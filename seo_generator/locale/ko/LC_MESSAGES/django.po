msgid ""
"\n"
"Skipping unknown model type: %(type)s"
msgstr ""
"\n"
"알 수 없는 모델 유형 %(type)s를 건너뜁니다"

#, python-format
msgid ""
"\n"
"No %(type)s items to process"
msgstr ""
"\n"
"처리할 %(type)s 항목이 없습니다"

