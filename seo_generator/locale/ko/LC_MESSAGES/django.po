msgstr "업데이트 시스템에서 가져온 SEO 제공업체 구성 요소 (내장된 경우 null)"

msgid "Provider Key"
msgstr "프로바이더 키"

msgid ""
"Built-in provider key (e.g., 'deterministic'). Used when component is null."
msgstr ""
"내장된 제공업체 키 (예: 'deterministic'). 구성 요소가 null일 때 사용됩니다."

msgid "Account Name"
msgstr "계정 이름"

msgid "Friendly name for this provider account"
msgstr "이 제공업체 계정의 친근한 이름"

msgid "Encrypted Credentials"
msgstr "암호화된 자격 증명"

msgid "Encrypted API credentials for this provider"
msgstr "이 제공업체의 암호화된 API 자격 증명"

msgid "Active"
msgstr "활성화됨"

