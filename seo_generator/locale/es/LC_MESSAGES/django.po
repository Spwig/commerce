msgstr "%(type)s: %(success)d exitosos, %(failed)d fallidos"

msgid "Site"
msgstr "Sitio"

msgid "Site this provider account belongs to"
msgstr "Sitio al que pertenece esta cuenta del proveedor"

msgid "Provider Component"
msgstr "Componente del proveedor"

msgid "SEO provider component from update system (null for built-in)"
msgstr ""
"Componente del proveedor de SEO del sistema de actualización (nulo para los "
"integrados)"

msgid "Provider Key"
msgstr "Clave del proveedor"

msgid ""
"Built-in provider key (e.g., 'deterministic'). Used when component is null."
msgstr ""
"Clave del proveedor integrado (p. ej., 'determinístico'). Se usa cuando el "
"componente es nulo."

msgid "Account Name"
msgstr "Nombre de cuenta"

msgid "Friendly name for this provider account"
msgstr "Nombre amigable para esta cuenta del proveedor"

