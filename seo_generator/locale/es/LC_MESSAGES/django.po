msgstr "Credenciales de API encriptadas para este proveedor"

msgid "Active"
msgstr "Activo"

msgid "Whether this provider account is active"
msgstr "Si esta cuenta del proveedor está activa"

msgid "Primary Provider"
msgstr "Proveedor principal"

msgid "Use this provider as primary source for SEO generation"
msgstr "Usar este proveedor como fuente principal para la generación de SEO"

msgid "Priority"
msgstr "Prioridad"

msgid "Priority for fallback chain (lower = higher priority)"
msgstr "Prioridad para la cadena de respaldo (más baja = mayor prioridad)"

msgid "Provider Settings"
msgstr "Configuración del proveedor"

msgid "Provider-specific settings and configuration"
msgstr "Configuración y ajustes específicos del proveedor"

msgid "SEO Provider Account"
msgstr "Cuenta del proveedor SEO"

msgid "SEO Provider Accounts"
msgstr "Cuentas de proveedores SEO"

