#, python-format
msgid "Invalid model type: %(type)s. Must be one of: %(valid)s"
msgstr "Jenis model tidak valid: %(type)s. Harus salah satu dari: %(valid)s"

msgid "Permission denied."
msgstr "Akses ditolak."

msgid "Generate SEO content for a single object"
msgstr "Buat konten SEO untuk satu objek"

msgid ""
"Generate meta title, meta description, and keywords for a product, category, "
"brand, page, blog post, or blog category. The generated content is "
"automatically saved to the object."
msgstr ""
"Buat judul meta, deskripsi meta, dan kata kunci untuk produk, kategori, "
"merek, halaman, posting blog, atau kategori blog. Konten yang dihasilkan "
"secara otomatis disimpan ke objek."

msgid "Model type: product, category, brand, page, blogpost, or blogcategory"
msgstr ""
"Jenis model: produk, kategori, merek, halaman, blogpost, atau blogcategory"

msgid "ID of the object to generate SEO for"
msgstr "ID objek yang akan dihasilkan SEO-nya"

msgid "Invalid model type, provider key, or language code"
msgstr "Jenis model, kunci penyedia, atau kode bahasa tidak valid"

msgid "Permission denied"
msgstr "Akses ditolak"

msgid "Object not found"
msgstr "Objek tidak ditemukan"

msgid "Generation failed or unexpected error"
msgstr "Pembuatan gagal atau terjadi kesalahan tak terduga"

msgid "Invalid provider key."
msgstr "Kunci pemasok tidak valid."

msgid "Invalid language code."
msgstr "Kode bahasa tidak valid."

msgid "Object not found."
msgstr "Objek tidak ditemukan."

msgid "SEO generation failed. Please try again."
msgstr "Penghasilan SEO gagal. Silakan coba lagi."

msgid "An unexpected error occurred. Please try again."
msgstr "Terjadi kesalahan tak terduga. Silakan coba lagi."

msgid "Batch generate SEO for multiple objects"
msgstr "Buat SEO secara batch untuk beberapa objek"

msgid ""
"Generate SEO content for multiple objects at once. Each item specifies a "
"model type and object ID. Results include per-item success/failure and a "
"summary."
msgstr ""
"Buat konten SEO untuk beberapa objek sekaligus. Setiap item menentukan jenis "
"model dan ID objek. Hasilnya mencakup keberhasilan/gagal per-item dan "
"ringkasan."

msgid "Invalid request body, no items, or invalid provider"
msgstr ""
"Badan permintaan tidak valid, tidak ada item, atau penyedia tidak valid"

msgid "Unexpected error"
msgstr "Kesalahan tak terduga"

msgid "Invalid request body."
msgstr "Badan permintaan tidak valid."

msgid "No items provided."
msgstr "Tidak ada item yang disediakan."

msgid "Missing model_type or object_id."
msgstr "model_type atau object_id hilang."

msgid "Generation failed for this item."
msgstr "Pembuatan gagal untuk item ini."

msgid "Check SEO status for an object"
msgstr "Periksa status SEO untuk sebuah objek"

msgid ""
"Check whether an object has SEO content, whether it was auto-generated, and "
"return the current meta title and description with their lengths."
msgstr ""
"Periksa apakah objek memiliki konten SEO, apakah konten tersebut dihasilkan "
"secara otomatis, dan kembalikan judul meta dan deskripsi saat ini beserta "
"panjangnya."

msgid "ID of the object"
msgstr "ID objek"

msgid "Invalid model type"
msgstr "Tipe model tidak valid"

msgid "SEO Generator"
msgstr "Pembuat SEO"

msgid "Model type to generate SEO for (or \"all\" for all models)"
msgstr "Jenis model untuk menghasilkan SEO (atau \"all\" untuk semua model)"

msgid "Number of items to process in each batch (default: 50)"
msgstr "Jumlah item yang diproses dalam setiap batch (default: 50)"

msgid "Only generate SEO for items with seo_auto_generated=True"
msgstr "Hanya hasilkan SEO untuk item dengan seo_auto_generated=True"

msgid ""
"SEO provider to use (default: primary provider, or deterministic if none "
"configured)"
msgstr ""
"Pemedia SEO yang akan digunakan (default: penyedia utama, atau deterministik "
"jika tidak dikonfigurasi)"

msgid "Language code for generation (default: site primary language)"
msgstr "Kode bahasa untuk pembuatan (default: bahasa utama situs)"

