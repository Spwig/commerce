msgstr "Se o número de SMS foi verificado"

msgid "SMS verified at"
msgstr "SMS verificado em"

msgid "Timestamp when SMS number was verified"
msgstr "Carimbo de tempo quando o número de SMS foi verificado"

msgid "SMS verification code"
msgstr "Código de Verificação de SMS"

msgid "6-digit OTP code for SMS verification"
msgstr "Código OTP de 6 dígitos para verificação por SMS"

msgid "SMS verification sent at"
msgstr "Verificação de SMS enviada em"

msgid "When the verification code was sent"
msgstr "Quando o código de verificação foi enviado"

msgid "SMS verification attempts"
msgstr "Tentativas de verificação de SMS"

msgid "Number of failed verification attempts"
msgstr "Número de tentativas de verificação falhadas"

