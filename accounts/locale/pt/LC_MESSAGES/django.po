msgid ""
"Successfully unsubscribed {count} user(s) from all marketing communications."
msgstr ""
"Desinscrito com sucesso {count} usuário(s) de todas as comunicações de "
"marketing."

msgid "Export preferences as CSV"
msgstr "Exportar preferências como CSV"

msgid "Export preferences as JSON (with history)"
msgstr "Exportar preferências como JSON (com histórico)"

msgid "Change Details"
msgstr "Alterar Detalhes"

