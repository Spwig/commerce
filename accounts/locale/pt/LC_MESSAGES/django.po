msgid "Order and shipping notifications via SMS (opt-in required)"
msgstr "Notificações de pedidos e envio por SMS (consentimento necessário)"

msgid "Marketing SMS"
msgstr "SMS de marketing"

msgid "Marketing messages via SMS (opt-in required)"
msgstr "Mensagens de marketing por SMS (consentimento necessário)"

msgid "App preferences"
msgstr "Preferências do app"

msgid ""
"App-specific communication preferences stored as JSON. Example: {\"blog\": "
"{\"enabled\": true, \"frequency\": \"weekly\"}, \"loyalty\": "
"{\"points_earned\": true, \"tier_changes\": true}}"
msgstr ""
"Preferências de comunicação específicas do aplicativo armazenadas como JSON. "
"Exemplo: {\"blog\": {\"enabled\": true, \"frequency\": \"weekly\"}, "
"\"loyalty\": {\"points_earned\": true, \"tier_changes\": true}}"

msgid "Whether marketing email address has been verified via double opt-in"
msgstr ""
"Se o endereço de e-mail de marketing foi verificado por meio de duplo "
"consentimento"

msgid "Email verified at"
msgstr "E-mail verificado em"

msgid "Timestamp when email was verified"
msgstr "Carimbo de data/hora quando o e-mail foi verificado"

