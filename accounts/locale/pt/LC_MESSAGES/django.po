msgstr "Verificar se este é uma conta de cliente empresarial/B2B"

msgid "Master toggle for all email communications"
msgstr "Interruptor mestre para todas as comunicações por e-mail"

msgid "Master toggle for all SMS communications (opt-in required)"
msgstr ""
"Interruptor mestre para todas as comunicações por SMS (consentimento "
