msgstr "Gerät \"{}\" wurde widerrufen."

msgid "Device not found or already revoked."
msgstr "Gerät nicht gefunden oder bereits widerrufen."

msgid "All {} trusted device(s) have been revoked."
msgstr "Alle {} vertrauenswürdigen Gerät(e) wurden widerrufen."

msgid "No trusted devices to revoke."
msgstr "Keine vertrauenswürdigen Geräte zum Widerrufen."

msgid "Verification successful. This device is now trusted."
msgstr ""
"Bestätigung erfolgreich. Dieses Gerät wird nun als vertrauenswürdig "
"angesehen."

msgid "Verification successful."
msgstr "Bestätigung erfolgreich."

msgid "Invalid code. Please try again."
msgstr "Ungültiger Code. Bitte versuchen Sie es erneut."

msgid "Please enter your authentication code."
msgstr "Bitte geben Sie Ihren Authentifizierungscode ein."

msgid "Two-Factor Authentication"
msgstr "Zwei-Faktor-Authentifizierung"

