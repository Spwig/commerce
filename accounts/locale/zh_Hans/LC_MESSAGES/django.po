msgid "Provider Configuration"
msgstr "提供商配置"

msgid "Advanced Settings"
msgstr "高级设置"

msgid "Status"
msgstr "状态"

msgid "Timestamps"
msgstr "时间戳"

msgid "Provider"
msgstr "提供商"

msgid "OAuth Credentials"
msgstr "OAuth 凭证"

msgid ""
"Select OAuth provider. Configure credentials in Social Applications section "
"below."
msgstr "选择 OAuth 提供者。在下方的社会应用程序部分配置凭证。"

msgid "Name shown on customer login button (e.g., \"Sign in with Google\")"
msgstr "显示在客户登录按钮上的名称（例如，“使用 Google 登录”）"

msgid "Show this provider to customers. Provider must be configured first."
msgstr "向客户展示此提供者。提供者必须首先进行配置。"

msgid "Display order (lower numbers appear first)"
msgstr "显示顺序（较小的数字优先显示）"

msgid "Warning: {obj.get_provider_display()} is enabled but not configured. "
msgstr "警告：{obj.get_provider_display()} 已启用但未配置。"

msgid "Provider Information"
msgstr "提供商信息"

msgid ""
"Select the OAuth provider and give it a descriptive name. Make sure to add "
"your site to the Sites list."
msgstr ""
"选择 OAuth 提供者并为其指定一个描述性的名称。确保将您的站点添加到站点列表中。"

msgid ""
"<strong>How to get credentials:</strong><br><ul><li><strong>Google:</strong> "
"Visit <a href=\"https://console.cloud.google.com\" target=\"_blank\">Google "
"Cloud Console</a></li><li><strong>Apple:</strong> Visit <a href=\"https://"
"developer.apple.com\" target=\"_blank\">Apple Developer Portal</a></"
"li><li><strong>Microsoft:</strong> Visit <a href=\"https://portal.azure."
"com\" target=\"_blank\">Azure Portal</a></li></ul>See documentation for "
"detailed setup instructions."
msgstr ""
"<strong>如何获取凭证：</strong><br><ul><li><strong>Google：</strong>访问<a "
"href=\"https://console.cloud.google.com\" target=\"_blank\">Google Cloud "
"Console</a></li><li><strong>Apple：</strong>访问<a href=\"https://developer."
"apple.com\" target=\"_blank\">Apple Developer Portal</a></"
"li><li><strong>Microsoft：</strong>访问<a href=\"https://portal.azure.com\" "
"target=\"_blank\">Azure Portal</a></li></ul>查看文档以获取详细的设置说明。"

msgid "Has Credentials"
msgstr "有凭证"

msgid "Sites"
msgstr "站点"

msgid "Remember to add the Client ID from your OAuth provider."
msgstr "记得添加来自您的 OAuth 提供者的客户端 ID。"

msgid "Remember to add your site to the Sites list!"
msgstr "记得将您的站点添加到站点列表中！"

msgid "Roles"
msgstr "角色"

msgid "2FA Status"
msgstr "双因素认证状态"

msgid "My Profile"
msgstr "我的资料"

msgid "Device \"{}\" has been revoked."
msgstr "设备 \"{}\" 已被撤销。"

msgid "Device not found or already revoked."
msgstr "设备未找到或已被撤销。"

msgid "All {} trusted device(s) have been revoked."
msgstr "{} 所有受信任的设备已被撤销。"

msgid "No trusted devices to revoke."
msgstr "没有可撤销的可信设备。"

msgid "Verification successful. This device is now trusted."
msgstr "验证成功。此设备现在是受信任的。"

msgid "Verification successful."
msgstr "验证成功。"

msgid "Invalid code. Please try again."
msgstr "无效代码。请重试。"

msgid "Please enter your authentication code."
msgstr "请输入您的身份验证代码。"

msgid "Two-Factor Authentication"
msgstr "双因素认证"

msgid "Role"
msgstr "角色"

msgid "Access Type"
msgstr "访问类型"

msgid "Admin Only"
msgstr "仅管理员"

msgid "POS Only"
msgstr "仅收银员"

msgid "Admin & POS"
msgstr "管理员和收银员"

msgid "Enabled"
msgstr "已启用"

msgid "Not Enabled"
msgstr "未启用"

msgid "Account"
msgstr "账户"

msgid "User"
msgstr "用户"

msgid "Email Preferences"
msgstr "电子邮件偏好"

msgid ""
"Email communication settings. Transactional emails (order confirmations, "
"etc.) are always sent regardless of these settings."
msgstr ""
"电子邮件通信设置。事务性电子邮件（订单确认等）无论这些设置如何都会发送。"

msgid "SMS Preferences"
msgstr "短信偏好"

msgid ""
"SMS communication settings. All SMS requires explicit customer opt-in (TCPA "
"compliance)."
msgstr "短信通信设置。所有短信需要客户明确同意（符合TCPA规定）。"

msgid "App-Specific Preferences"
msgstr "应用特定偏好"

msgid ""
"JSON field containing preferences for blog, loyalty, referrals, and "
"affiliate communications."
msgstr "包含博客、忠诚度计划、推荐和联盟营销通信偏好的JSON字段。"

msgid "Consent Tracking (GDPR Compliance)"
msgstr "同意跟踪（GDPR合规）"

msgid ""
"Consent metadata required for GDPR Article 7 compliance. Records when, "
"where, and how customer provided consent."
msgstr "GDPR第7条合规所需的同意元数据。记录客户何时、何地以及如何提供同意。"

msgid "Unsubscribe"
msgstr "退订"

msgid "Unique token for one-click unsubscribe links in marketing emails."
msgstr "用于营销电子邮件中一键退订链接的唯一令牌。"

msgid "Metadata"
msgstr "元数据"

msgid "Email enabled"
msgstr "电子邮件已启用"

msgid "Email disabled"
msgstr "电子邮件已禁用"

msgid "Email"
msgstr "电子邮件"

msgid "SMS enabled"
msgstr "短信已启用"

msgid "SMS disabled"
msgstr "短信已禁用"

msgid "SMS"
msgstr "短信"

msgid "Opted In"
msgstr "已同意"

msgid "Opted Out"
msgstr "已拒绝"

msgid "Marketing"
msgstr "营销"

msgid "Email verified"
msgstr "电子邮件已验证"

msgid "Yes"
msgstr "是"

msgid "No"
msgstr "否"

msgid "SMS verified"
msgstr "短信已验证"

msgid "Verified"
msgstr "已验证"

msgid "Source"
msgstr "来源"

msgid "Mark email as verified"
msgstr "标记电子邮件为已验证"

#, python-brace-format
msgid "Successfully verified email for {count} user(s)."
msgstr "成功验证了 {count} 个用户的电子邮件。"

msgid "Unsubscribe from all marketing"
msgstr "取消所有营销邮件订阅"

#, python-brace-format
msgid ""
"Successfully unsubscribed {count} user(s) from all marketing communications."
msgstr "已成功将 {count} 个用户从所有营销通信中退订。"

msgid "Export preferences as CSV"
msgstr "将偏好设置导出为CSV"

msgid "Export preferences as JSON (with history)"
msgstr "以JSON格式导出偏好（包含历史记录）"

msgid "Change Details"
msgstr "更改详细信息"

msgid "Changes"
msgstr "更改"

msgid "Before and after state of the preference change"
msgstr "偏好更改前后的状态"

msgid "Audit Context"
msgstr "审计上下文"

msgid "Technical details for audit trail"
msgstr "审计记录的技术细节"

msgid "Register new user account"
msgstr "注册新用户账户"

msgid ""
"Create a new customer account with email and password. Returns user profile "
"and authentication token."
msgstr "使用电子邮件和密码创建新客户账户。返回用户资料和认证令牌。"

msgid "Registration successful, user created and logged in"
msgstr "注册成功，用户已创建并登录"

msgid "Invalid registration data or email already exists"
msgstr "注册信息无效或电子邮件已存在"

msgid "Registration successful."
msgstr "注册成功。"

msgid "Registration failed."
msgstr "注册失败。"

msgid "User login"
msgstr "用户登录"

msgid ""
"Authenticate user with email and password. Returns user profile and "
"authentication token for API access."
msgstr "使用电子邮件和密码验证用户。返回用于 API 访问的用户资料和认证令牌。"

msgid "Login successful, returns user data and auth token"
msgstr "登录成功，返回用户数据和认证令牌"

msgid "Invalid credentials or account inactive"
msgstr "凭据无效或账户未激活"

msgid "Login successful."
msgstr "登录成功。"

msgid "Login failed."
msgstr "登录失败。"

msgid "User logout"
msgstr "用户登出"

msgid ""
"Log out the current user and invalidate their authentication token. Requires "
"authentication."
msgstr "注销当前用户并使他们的认证令牌失效。需要认证。"

msgid "Logout successful, token deleted"
msgstr "登出成功，令牌已删除"

msgid "Logout successful."
msgstr "登出成功。"

msgid "Request password reset"
msgstr "请求重置密码"

msgid ""
"Request a password reset email. Sends reset link to email if account exists. "
"Always returns success to prevent email enumeration. Rate limited to 20 "
"requests per hour."
msgstr ""
"请求重置密码邮件。如果账户存在，会将重置链接发送到邮箱。始终返回成功以防止邮"
"箱枚举。每小时请求次数限制为20次。"

msgid "Password reset email sent (if account exists)"
msgstr "已发送密码重置邮件（如果账户存在）"

msgid "Invalid email format"
msgstr "电子邮件格式无效"

msgid "Rate limit exceeded - too many password reset requests"
msgstr "速率限制超出 - 密码重置请求过多"

msgid "Password Reset Request"
msgstr "重置密码请求"

#, python-brace-format
msgid "Click the link to reset your password: {reset_url}"
msgstr "点击链接重置您的密码：{reset_url}"

msgid ""
"If an account with that email exists, a password reset link has been sent."
msgstr "如果存在带有该电子邮件地址的帐户，则已发送密码重置链接。"

msgid "Invalid email address."
msgstr "无效的电子邮件地址。"

msgid "Confirm password reset"
msgstr "确认重置密码"

msgid ""
"Complete password reset process using the token from email. Requires uidb64 "
"and token from reset link."
msgstr ""
"使用电子邮件中的令牌完成密码重置过程。需要从重置链接中获取 uidb64 和令牌。"

msgid "Password successfully reset"
msgstr "密码重置成功"

msgid "Invalid or expired reset token, or invalid password"
msgstr "无效或过期的重置令牌，或密码无效"

msgid "Invalid password reset link."
msgstr "无效的重置密码链接。"

msgid "Password has been reset successfully."
msgstr "密码已成功重置。"

msgid "Password reset failed."
msgstr "重置密码失败。"

msgid "Get user profile"
msgstr "获取用户资料"

msgid ""
"Retrieve the current authenticated user's profile information including "
"name, preferences, and settings."
msgstr "获取当前已认证用户的资料信息，包括姓名、偏好和设置。"

msgid "Update user profile"
msgstr "更新用户资料"

msgid ""
"Update the current user's profile information. Use PUT for full update or "
"PATCH for partial update."
msgstr ""
"更新当前用户的资料信息。使用 PUT 进行完整更新，或使用 PATCH 进行部分更新。"

msgid "Profile updated successfully"
msgstr "资料更新成功"

msgid "Invalid profile data"
msgstr "资料无效"

msgid "Profile updated successfully."
msgstr "资料更新成功。"

msgid "Profile update failed."
msgstr "资料更新失败。"

msgid "Update user preferences"
msgstr "更新用户偏好"

msgid ""
"Update user dashboard preferences including notification settings, display "
"options, and other customization."
msgstr "更新用户仪表板偏好，包括通知设置、显示选项和其他自定义设置。"

msgid "Invalid preference data"
msgstr "无效的偏好数据"

msgid "Preferences updated successfully."
msgstr "偏好设置更新成功。"

msgid "Preferences update failed."
msgstr "偏好设置更新失败。"

msgid "Refresh customer metrics"
msgstr "刷新客户指标"

msgid ""
"Recalculate and update customer metrics including order count, total spent, "
"lifetime value, etc."
msgstr "重新计算并更新客户指标，包括订单数量、总消费额、客户终身价值等。"

msgid "Metrics refreshed successfully"
msgstr "指标刷新成功"

msgid "Metrics refreshed successfully."
msgstr "指标刷新成功。"

msgid "Set address as default"
msgstr "设为默认地址"

msgid "Address created successfully."
msgstr "地址创建成功。"

msgid "Address creation failed."
msgstr "地址创建失败。"

msgid "Address updated successfully."
msgstr "地址更新成功。"

msgid "Address update failed."
msgstr "地址更新失败。"

msgid "Address deleted successfully."
msgstr "地址删除成功。"

msgid "Default address updated."
msgstr "默认地址已更新。"

msgid "List available social login providers"
msgstr "列出可用的社交登录提供商"

msgid ""
"Get list of enabled and configured OAuth social authentication providers "
"(Google, Facebook, etc.) with their login URLs."
msgstr ""
"获取已启用并配置的OAuth社交认证提供商列表（如Google、Facebook等）及其登录"
"URL。"

msgid "List of available social providers"
msgstr "可用社交提供商列表"

msgid "Convert guest user to full account"
msgstr "将访客用户转换为完整账户"

msgid ""
"Convert an authenticated guest user to a full account by setting a password. "
"Only works for guest users (username starts with 'guest_')."
msgstr ""
"通过设置密码将已认证的访客用户转换为完整账户。仅适用于访客用户（用户名"
"以'guest_'开头）。"

msgid "Account created successfully"
msgstr "账户创建成功"

msgid "Invalid request or password"
msgstr "请求或密码无效"

msgid "Not authenticated or not a guest user"
msgstr "未认证或不是访客用户"

msgid "Get account creation context"
msgstr "获取账户创建上下文"

msgid ""
"Get context for account creation UI including custom message and available "
"social auth providers."
msgstr "获取账户创建UI的上下文，包括自定义消息和可用的社交认证提供商。"

msgid "Account creation context"
msgstr "账户创建上下文"

msgid "Get communication preferences"
msgstr "获取沟通偏好"

msgid ""
"Retrieve customer's communication preferences including email, SMS, and app-"
"specific settings (blog, loyalty, referrals, affiliate). Returns preferences "
"grouped by category for easier UI consumption. Requires authentication."
msgstr ""
"检索客户的沟通偏好，包括电子邮件、短信和特定于应用的设置（博客、忠诚度计划、"
"推荐、联盟营销）。按类别分组返回偏好，便于UI使用。需要身份验证。"

msgid "Preferences not found - will be auto-created"
msgstr "未找到偏好设置 - 将自动创建"

msgid "Update single preference"
msgstr "更新单个偏好"

msgid ""
"Update a single communication preference (granular control). Allows enabling/"
"disabling specific message types with optional frequency settings. "
"Transactional messages cannot be disabled. Marketing messages require email "
"verification. Changes are tracked for GDPR compliance. Requires "
"authentication."
msgstr ""
"更新单个沟通偏好（精细控制）。允许启用或禁用特定消息类型，并可选频率设置。交"
"易类消息无法禁用。营销类消息需要电子邮件验证。更改将被记录以符合GDPR合规要"
"求。需要身份验证。"

msgid "Preference updated successfully"
msgstr "偏好更新成功"

msgid "Invalid request or cannot disable locked preference"
msgstr "请求无效或无法禁用锁定的偏好设置"

msgid "Preference updated successfully."
msgstr "偏好设置已成功更新。"

msgid "Bulk update preferences"
msgstr "批量更新偏好"

msgid ""
"Update multiple communication preferences in a single request. More "
"efficient than individual updates when changing multiple settings. All "
"updates are atomic - if any fails, none are applied. Requires authentication."
msgstr ""
"通过单个请求更新多个通信偏好。在更改多个设置时，比单独更新更高效。所有更新都"
"是原子操作 - 如果有任何失败，将不应用任何更改。需要身份验证。"

msgid "All preferences updated successfully"
msgstr "所有偏好更新成功"

msgid "One or more updates failed"
msgstr "一个或多个更新失败"

msgid "Unsubscribe from all communications"
msgstr "取消所有通讯订阅"

msgid ""
"Unsubscribe from all non-transactional communications (email and SMS). "
"Transactional messages (order confirmations, shipping updates) remain "
"enabled. This action is logged for GDPR compliance. Optional reason can be "
"provided for analytics. Requires authentication."
msgstr ""
"取消订阅所有非交易性通信（电子邮件和短信）。交易性消息（订单确认、发货更新）"
"仍将启用。此操作将被记录以符合GDPR规定。可提供可选原因用于分析。需要身份验"
"证。"

msgid "Optional reason for unsubscribing"
msgstr "取消订阅的可选原因"

msgid "Successfully unsubscribed from all communications"
msgstr "已成功取消所有通讯订阅"

msgid "Unsubscribe failed"
msgstr "取消订阅失败"

msgid "You have been unsubscribed from all marketing communications."
msgstr "您已退订所有营销通信。"

msgid "Export Communication Preferences"
msgstr "导出通讯偏好"

msgid ""
"Export all preference data including change history for GDPR Article 15 "
"(Right to Access)"
msgstr "导出所有偏好数据，包括根据GDPR第15条（访问权）的更改历史"

msgid "Send SMS Verification Code"
msgstr "发送短信验证码"

msgid ""
"Send a 6-digit OTP code via SMS for TCPA-compliant double opt-in verification"
msgstr "通过短信发送6位OTP验证码以进行符合TCPA的双重确认验证"

msgid "Phone number in E.164 format (e.g., +1234567890)"
msgstr "E.164格式的电话号码（例如，+1234567890）"

msgid "Invalid request or rate limited"
msgstr "请求无效或请求频率过高"

msgid "Verify SMS Code"
msgstr "验证短信验证码"

msgid ""
"Verify the 6-digit OTP code sent via SMS. Uses constant-time comparison for "
"security."
msgstr "验证通过短信发送的6位OTP验证码。使用恒定时间比较以确保安全。"

msgid "6-digit verification code"
msgstr "6位验证码"

msgid "Phone number being verified"
msgstr "正在验证的手机号"

msgid "Resend SMS Verification Code"
msgstr "重新发送短信验证码"

msgid ""
"Request a new verification code. Clears the old code before sending new one."
msgstr "请求新的验证码。在发送新验证码前会清除旧的验证码。"

msgid "Phone number to send code to"
msgstr "发送验证码的电话号码"

msgid "Accounts"
msgstr "账户"

msgid "General Inquiry"
msgstr "一般咨询"

msgid "Support Request"
msgstr "支持请求"

msgid "Order Related"
msgstr "与订单相关"

msgid "Product Question"
msgstr "产品问题"

msgid "Other"
msgstr "其他"

msgid "Subject"
msgstr "主题"

msgid "What is your message about?"
msgstr "您的消息是关于什么的？"

msgid "Message Type"
msgstr "消息类型"

msgid "Related Order"
msgstr "相关订单"

msgid "No order selected"
msgstr "未选择订单"

msgid "Message"
msgstr "消息"

msgid "Please describe your inquiry in detail..."
msgstr "请详细描述您的问题..."

msgid "Your follow-up message"
msgstr "您的后续消息"

msgid "Type your follow-up message..."
msgstr "输入您的后续消息..."

msgid "Staff Member"
msgstr "员工"

msgid "Staff Members"
msgstr "员工成员"

msgid "Company Name"
msgstr "公司名称"

msgid "Business or company name for B2B customers"
msgstr "面向B2B客户的公司或企业名称"

msgid "Tax ID / VAT Number"
msgstr "税号 / 增值税号码"

msgid "Business tax identification number or VAT registration number"
msgstr "企业税识别号或增值税注册号"

msgid "Business Customer"
msgstr "企业客户"

msgid "Check if this is a business/B2B customer account"
msgstr "检查这是否是企业/B2B客户账户"

msgid "Master toggle for all email communications"
msgstr "所有电子邮件通信的主开关"

msgid "Master toggle for all SMS communications (opt-in required)"
msgstr "所有短信通信的主开关（需要同意）"

msgid "Transactional emails"
msgstr "交易邮件"

msgid "Order confirmations, shipping updates, account security emails"
msgstr "订单确认、发货更新、账户安全邮件"

msgid "Marketing emails"
msgstr "营销邮件"

msgid "Newsletters, promotions, product recommendations (opt-in required)"
msgstr "时事通讯、促销、产品推荐（需要同意）"

msgid "Transactional SMS"
msgstr "交易短信"

msgid "Order and shipping notifications via SMS (opt-in required)"
msgstr "通过短信接收订单和发货通知（需要同意）"

msgid "Marketing SMS"
msgstr "营销短信"

msgid "Marketing messages via SMS (opt-in required)"
msgstr "通过短信接收营销信息（需要同意）"

msgid "App preferences"
msgstr "应用偏好"

msgid ""
"App-specific communication preferences stored as JSON. Example: {\"blog\": "
"{\"enabled\": true, \"frequency\": \"weekly\"}, \"loyalty\": "
"{\"points_earned\": true, \"tier_changes\": true}}"
msgstr ""
"以JSON格式存储的应用特定通信偏好。示例：{\"blog\": {\"enabled\": true, "
"\"frequency\": \"weekly\"}, \"loyalty\": {\"points_earned\": true, "
"\"tier_changes\": true}}"

msgid "Whether marketing email address has been verified via double opt-in"
msgstr "营销电子邮件地址是否通过双重确认验证"

msgid "Email verified at"
msgstr "电子邮件验证时间"

msgid "Timestamp when email was verified"
msgstr "电子邮件验证时间戳"

msgid "Whether SMS number has been verified"
msgstr "短信号码是否已验证"

msgid "SMS verified at"
msgstr "短信验证时间"

msgid "Timestamp when SMS number was verified"
msgstr "短信号码验证的时间戳"

msgid "SMS verification code"
msgstr "短信验证码"

msgid "6-digit OTP code for SMS verification"
msgstr "用于短信验证的6位OTP代码"

msgid "SMS verification sent at"
msgstr "短信验证发送时间"

msgid "When the verification code was sent"
msgstr "验证码发送的时间"

