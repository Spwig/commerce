msgstr "Tên miền cửa hàng của bạn"

msgid "Your store's callback URL (we'll show this in the next step)"
msgstr ""
"URL phản hồi của cửa hàng bạn (chúng tôi sẽ hiển thị điều này trong bước "
"tiếp theo)"

msgid "5-10 minutes to complete the setup"
msgstr "5-10 phút để hoàn thành thiết lập"

