msgstr "Dispositivo \"{}\" revocato."

msgid "Device not found or already revoked."
msgstr "Dispositivo non trovato o già revocato."

msgid "All {} trusted device(s) have been revoked."
msgstr "Tutti i {} dispositivi attendibili sono stati revocati."

msgid "No trusted devices to revoke."
msgstr "Nessun dispositivo attendibile da revocare."

msgid "Verification successful. This device is now trusted."
msgstr "Verifica riuscita. Questo dispositivo è ora attendibile."

msgid "Verification successful."
msgstr "Verifica riuscita."

msgid "Invalid code. Please try again."
msgstr "Codice non valido. Per favore riprova."

