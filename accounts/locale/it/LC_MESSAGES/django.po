msgstr "Account"

msgid "General Inquiry"
msgstr "Domanda generale"

msgid "Support Request"
msgstr "Richiesta di supporto"

msgid "Order Related"
msgstr "Relativo all'ordine"

msgid "Product Question"
msgstr "Domanda sul prodotto"

