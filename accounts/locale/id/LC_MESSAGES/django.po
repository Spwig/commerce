msgstr "Peran"

msgid "2FA Status"
msgstr "Status 2FA"

msgid "My Profile"
msgstr "Profil Saya"

msgid "Device \"{}\" has been revoked."
msgstr "Perangkat \"{}\" telah dibatalkan."

msgid "Device not found or already revoked."
msgstr "Perangkat tidak ditemukan atau sudah dicabut."

msgid "All {} trusted device(s) have been revoked."
msgstr "Semua {} perangkat terpercaya telah dicabut."

msgid "No trusted devices to revoke."
msgstr "Tidak ada perangkat terpercaya yang dapat dibatalkan."

msgid "Verification successful. This device is now trusted."
msgstr "Verifikasi berhasil. Perangkat ini sekarang terpercaya."

msgid "Verification successful."
msgstr "Verifikasi berhasil."

msgid "Invalid code. Please try again."
msgstr "Kode tidak valid. Silakan coba lagi."

msgid "Please enter your authentication code."
msgstr "Silakan masukkan kode autentikasi Anda."

