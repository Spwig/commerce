"Поиск по электронной почте, имени пользователя, действию или IP-адресу..."

msgid "All Time"
msgstr "Всё время"

msgid "Last 90 Days"
msgstr "Последние 90 дней"

msgid "Change Log"
msgstr "Журнал изменений"

msgid "change"
msgstr "Изменить"

msgid "View details"
msgstr "Посмотреть детали"

msgid "No change log entries match your filters."
msgstr "Нет записей в журнале изменений, соответствующих вашим фильтрам."

msgid "This subscription cannot be paused."
msgstr "Эту подписку нельзя приостановить."

msgid "Subscription paused successfully."
msgstr "Подписка успешно приостановлена."

msgid "Failed to pause subscription: {}"
msgstr "Не удалось приостановить подписку: {}"

msgid "This subscription is not paused."
msgstr "Эта подписка не приостановлена."

msgid "Subscription resumed successfully."
msgstr "Подписка успешно возобновлена."

msgid "Failed to resume subscription: {}"
msgstr "Не удалось возобновить подписку: {}"

msgid "This subscription is already canceled."
msgstr "Эта подписка уже отменена."

msgid "Subscription canceled immediately."
msgstr "Подписка немедленно отменена."

msgid "Subscription will be canceled at the end of the current billing period."
msgstr "Подписка будет отменена по окончании текущего периода оплаты."

msgid "Failed to cancel subscription: {}"
msgstr "Не удалось отменить подписку: {}"

msgid "Please select a payment method."
msgstr "Пожалуйста, выберите метод оплаты."

msgid "Invalid payment method selected."
msgstr "Выбран некорректный метод оплаты."

msgid "Payment method updated successfully."
msgstr "Метод оплаты успешно обновлен."

msgid "Failed to update payment method: {}"
msgstr "Не удалось обновить метод оплаты: {}"

msgid ""
"Cannot delete this payment method - it is being used by active subscriptions."
msgstr ""
"Невозможно удалить этот метод оплаты - он используется активными подписками."

msgid "Payment method deleted successfully."
msgstr "Метод оплаты успешно удален."

msgid "Failed to delete payment method: {}"
msgstr "Не удалось удалить метод оплаты: {}"

msgid "Default payment method updated."
msgstr "Установлен новый метод оплаты по умолчанию."

msgid "Please fill in all required fields."
msgstr "Пожалуйста, заполните все обязательные поля."

msgid "Address added successfully."
msgstr "Адрес успешно добавлен."

msgid "Failed to add address: {}"
msgstr "Не удалось добавить адрес: {}"

msgid ""
"Address updated. A new version was created because this address was used in "
"previous orders."
msgstr ""
"Адрес обновлен. Была создана новая версия, так как этот адрес использовался "
"в предыдущих заказах."

msgid "Failed to update address: {}"
msgstr "Не удалось обновить адрес: {}"

msgid "Failed to delete address: {}"
msgstr "Не удалось удалить адрес: {}"

msgid "Failed to update default address: {}"
msgstr "Не удалось обновить основной адрес: {}"

msgid "Failed to update profile: {}"
msgstr "Не удалось обновить профиль: {}"

msgid "This account is already registered."
msgstr "Этот аккаунт уже зарегистрирован."

msgid "Please provide a password."
msgstr "Пожалуйста, укажите пароль."

msgid "Password must be at least 8 characters long."
msgstr "Пароль должен содержать как минимум 8 символов."

msgid "Your account has been activated! Welcome to {}"
msgstr "Ваш аккаунт активирован! Добро пожаловать на {}"

msgid "An error occurred while activating your account. Please try again."
msgstr ""
"Произошла ошибка при активации вашего аккаунта. Пожалуйста, попробуйте еще "
"раз."

msgid ""
"The activation link is invalid or has expired. Please contact support for "
"assistance."
msgstr ""
"Ссылка для активации недействительна или истекла. Пожалуйста, свяжитесь с "
"поддержкой для помощи."

#, python-brace-format
msgid "You have been unsubscribed from {message_type} emails."
msgstr "Вас отписали от электронных писем {message_type}."

msgid "An error occurred. Please try again."
msgstr "Произошла ошибка. Пожалуйста, попробуйте еще раз."

#, python-brace-format
msgid "You have been resubscribed to {message_type} emails."
msgstr "Вас снова подписали на электронные письма {message_type}."

msgid "Invalid unsubscribe link. Please use the link from your email."
msgstr ""
"Недействительная ссылка на отписку. Используйте ссылку из вашего email."

msgid "Your communication preferences have been updated."
msgstr "Ваши предпочтения коммуникации были обновлены."

msgid "Your follow-up message has been sent."
msgstr "Ваше сообщение с последующим обращением было отправлено."

msgid "Your message has been submitted. We will respond shortly."
msgstr "Ваше сообщение было отправлено. Мы ответим в ближайшее время."

msgid "Please enter your email address."
msgstr "Пожалуйста, введите ваш адрес электронной почты."

msgid "Customer"
msgstr "Клиент"

msgid "View Your Orders"
msgstr "Посмотреть свои заказы"

msgid ""
"If we have orders for that email address, we've sent you a link to view them."
msgstr ""
"Если у нас есть заказы на этот адрес электронной почты, мы отправили вам "
"ссылку для их просмотра."

msgid "This link is invalid or has expired."
msgstr "Эта ссылка недействительна или истек срок её действия."

msgid "This account is already registered. Please log in."
msgstr "Этот аккаунт уже зарегистрирован. Пожалуйста, войдите в систему."

msgid "Your account has been created! Welcome!"
msgstr "Ваш аккаунт был создан! Добро пожаловать!"

msgid "This booking cannot be cancelled."
msgstr "Это бронирование нельзя отменить."

msgid "Your booking has been cancelled."
msgstr "Ваше бронирование было отменено."

msgid "Failed to cancel booking: {}"
msgstr "Не удалось отменить бронирование: {}"

msgid "This booking cannot be rescheduled."
msgstr "Это бронирование нельзя переназначить."

msgid "Please provide a date and times."
msgstr "Пожалуйста, укажите дату и время."

msgid "Invalid date or time format."
msgstr "Неверный формат даты или времени."

msgid "Your booking has been rescheduled."
msgstr "Ваше бронирование было переназначено."

msgid "Failed to reschedule booking: {}"
msgstr "Не удалось переназначить бронирование: {}"
