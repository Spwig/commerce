msgstr "प्रश्नों या सहायता के लिए कृपया"

msgid "contact us"
msgstr "हमसे संपर्क करें"

msgid "Manage customer email, SMS, and marketing communication preferences"
msgstr "ग्राहक ई-मेल, एसएमएस और विपणन संचार प्राथमिकताओं का प्रबंधन करें"

