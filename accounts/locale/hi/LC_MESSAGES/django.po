msgid "Provider Configuration"
msgstr "प्रदाता विन्यास"

msgid "Advanced Settings"
msgstr "उन्नत सेटिंग्स"

msgid "Status"
msgstr "स्थिति"

msgid "Timestamps"
msgstr "टाइमस्टैंप"

msgid "Provider"
msgstr "प्रदाता"

msgid "OAuth Credentials"
msgstr "ओएएएच क्रेडेंशियल्स"

msgid ""
"Select OAuth provider. Configure credentials in Social Applications section "
"below."
msgstr "OAuth प्रदाता चुनें। सोशल एप्लिकेशन अनुभाग में नीचे आवास के निर्माण करें।"

msgid "Name shown on customer login button (e.g., \"Sign in with Google\")"
msgstr ""
"ग्राहक लॉगिन बटन पर दिखाया गया नाम (उदाहरण के लिए, \"Google के साथ साइन इन करें\")"

msgid "Show this provider to customers. Provider must be configured first."
msgstr "ग्राहकों के लिए इस प्रदाता को दिखाएं। प्रदाता को पहले निर्माण करना आवश्यक है।"

msgid "Display order (lower numbers appear first)"
msgstr "प्रदर्शन क्रम (कम संख्या पहले दिखाई देती है)"

msgid "Warning: {obj.get_provider_display()} is enabled but not configured. "
msgstr ""
"चेतावनी: {obj.get_provider_display()} एनेबल है लेकिन निर्मित नहीं किया गया है।"

msgid "Provider Information"
msgstr "प्रदाता जानकारी"

msgid ""
"Select the OAuth provider and give it a descriptive name. Make sure to add "
"your site to the Sites list."
msgstr ""
"OAuth प्रदाता का चयन करें और इसे एक विवरणात्मक नाम दें। अपने साइट को साइट्स सूची में "
"जोड़ना सुनिश्चित करें।"

msgid ""
"<strong>How to get credentials:</strong><br><ul><li><strong>Google:</strong> "
"Visit <a href=\"https://console.cloud.google.com\" target=\"_blank\">Google "
"Cloud Console</a></li><li><strong>Apple:</strong> Visit <a href=\"https://"
"developer.apple.com\" target=\"_blank\">Apple Developer Portal</a></"
"li><li><strong>Microsoft:</strong> Visit <a href=\"https://portal.azure."
"com\" target=\"_blank\">Azure Portal</a></li></ul>See documentation for "
"detailed setup instructions."
msgstr ""
"<strong>आवास कैसे प्राप्त करें:</strong><br><ul><li><strong>गूगल:</strong> <a "
"href=\"https://console.cloud.google.com\" target=\"_blank\">गूगल क्लाउड कंसोल</"
"a> जाएं</li><li><strong>एप्पल:</strong> <a href=\"https://developer.apple."
"com\" target=\"_blank\">एप्पल डेवलपर पोर्टल</a> जाएं</li><li><strong>माइक्रोसॉफ्ट:"
"</strong> <a href=\"https://portal.azure.com\" target=\"_blank\">एज़रे पोर्टल</"
"a> जाएं</li></ul>विस्तृत सेटअप निर्देशों के लिए दस्तावेज़ देखें।"

msgid "Has Credentials"
msgstr "क्रेडेंशियल्स हैं"

msgid "Sites"
msgstr "साइट्स"

msgid "Remember to add the Client ID from your OAuth provider."
msgstr "अपने OAuth प्रदाता से Client ID को जोड़ना न भूलें।"

msgid "Remember to add your site to the Sites list!"
msgstr "अपने साइट को साइट्स सूची में जोड़ना न भूलें!"

msgid "Roles"
msgstr "भूमिकाएं"

msgid "2FA Status"
msgstr "2FA स्थिति"

msgid "My Profile"
msgstr "मेरा प्रोफाइल"

msgid "Device \"{}\" has been revoked."
msgstr "उपकरण \"{}\" वापस ले लिया गया है।"

msgid "Device not found or already revoked."
msgstr "उपकरण नहीं मिला या पहले से रद्द कर दिया गया है।"

msgid "All {} trusted device(s) have been revoked."
msgstr "सभी {} विश्वासघाती उपकरणों को रद्द कर दिया गया है।"

msgid "No trusted devices to revoke."
msgstr "कोई भरोसेमंद उपकरण वापस लेने के लिए नहीं है।"

msgid "Verification successful. This device is now trusted."
msgstr "जांच सफल रही। अब यह उपकरण विश्वासघाती है।"

msgid "Verification successful."
msgstr "सत्यापन सफल।"

msgid "Invalid code. Please try again."
msgstr "अमान्य कोड। कृपया पुनः प्रयास करें।"

msgid "Please enter your authentication code."
msgstr "कृपया अपना प्रमाणिकरण कोड दर्ज करें।"

msgid "Two-Factor Authentication"
msgstr "दो-कारक प्रमाणिकरण"

msgid "Role"
msgstr "भूमिका"

msgid "Access Type"
msgstr "पहुँच प्रकार"

msgid "Admin Only"
msgstr "केवल प्रशासक"

msgid "POS Only"
msgstr "केवल पॉज़"

msgid "Admin & POS"
msgstr "प्रशासक एवं पॉज़"

msgid "Enabled"
msgstr "सक्रिय"

msgid "Not Enabled"
msgstr "असक्रिय"

msgid "Account"
msgstr "खाता"

msgid "User"
msgstr "उपयोगकर्ता"

msgid "Email Preferences"
msgstr "ई-मेल प्राथमिकताएं"

msgid ""
"Email communication settings. Transactional emails (order confirmations, "
"etc.) are always sent regardless of these settings."
msgstr ""
"ई-मेल संचार सेटिंग्स। लेनदेन ई-मेल (आर्डर पुष्टि, आदि) हमेशा भेजे जाते हैं, चाहे ये सेटिंग्स क्या "
"हों।"

msgid "SMS Preferences"
msgstr "एसएमएस प्राथमिकताएं"

msgid ""
"SMS communication settings. All SMS requires explicit customer opt-in (TCPA "
"compliance)."
msgstr ""
"एसएमएस संचार सेटिंग। सभी एसएमएस के लिए ग्राहक द्वारा स्पष्ट रूप से सहमति की आवश्यकता "
"होती है (TCPA अनुगमन)"

msgid "App-Specific Preferences"
msgstr "एप्लिकेशन-विशिष्ट प्राथमिकताएं"

msgid ""
"JSON field containing preferences for blog, loyalty, referrals, and "
"affiliate communications."
msgstr ""
"ब्लॉग, लॉयल्टी, रेफरल और अफिलिएट संचार के लिए प्राथमिकताओं के साथ एक JSON क्षेत्र।"

msgid "Consent Tracking (GDPR Compliance)"
msgstr "सहमति ट्रैकिंग (जीडीपीआर पालन)"

msgid ""
"Consent metadata required for GDPR Article 7 compliance. Records when, "
"where, and how customer provided consent."
msgstr ""
"जीडीपीआर अनुच्छेद 7 के अनुपालन के लिए सहमति मेटाडेटा की आवश्यकता है। यह रिकॉर्ड करता है "
"कि ग्राहक ने कब, कहां और कैसे सहमति प्रदान की थी।"

msgid "Unsubscribe"
msgstr "सदस्यता रद्द करें"

msgid "Unique token for one-click unsubscribe links in marketing emails."
msgstr "विपणन ईमेल में एक क्लिक सदस्यता रद्द करें लिंक के लिए एक अद्वितीय टोकन।"

msgid "Metadata"
msgstr "मेटाडेटा"

msgid "Email enabled"
msgstr "ई-मेल योग्य"

msgid "Email disabled"
msgstr "ई-मेल अक्षम"

msgid "Email"
msgstr "ई-मेल"

msgid "SMS enabled"
msgstr "एसएमएस योग्य"

msgid "SMS disabled"
msgstr "एसएमएस अक्षम"

msgid "SMS"
msgstr "एसएमएस"

msgid "Opted In"
msgstr "सहमत"

msgid "Opted Out"
msgstr "असहमत"

msgid "Marketing"
msgstr "विपणन"

msgid "Email verified"
msgstr "ई-मेल सत्यापित"

msgid "Yes"
msgstr "हां"

msgid "No"
msgstr "नहीं"

msgid "SMS verified"
msgstr "एसएमएस सत्यापित"

msgid "Verified"
msgstr "सत्यापित"

msgid "Source"
msgstr "स्रोत"

msgid "Mark email as verified"
msgstr "ईमेल को सत्यापित करें"

#, python-brace-format
msgid "Successfully verified email for {count} user(s)."
msgstr "सफलतापूर्वक {count} उपयोगकर्ता(ओं) के ई-मेल की पुष्टि कर दी गई।"

msgid "Unsubscribe from all marketing"
msgstr "सभी मार्केटिंग से अनसबस्क्राइब करें"

#, python-brace-format
msgid ""
"Successfully unsubscribed {count} user(s) from all marketing communications."
msgstr ""
"{count} उपयोगकर्ता(ओं) को सभी विपणन संचार से सफलतापूर्वक अनसबस्क्राइब कर दिया गया।"

msgid "Export preferences as CSV"
msgstr "पसंदें को CSV के रूप में निर्यत करें"

msgid "Export preferences as JSON (with history)"
msgstr "प्राथमिकताओं को JSON के रूप में निर्यात करें (इतिहास के साथ)"

msgid "Change Details"
msgstr "परिवर्तन विवरण"

msgid "Changes"
msgstr "परिवर्तन"

msgid "Before and after state of the preference change"
msgstr "प्राथमिकता परिवर्तन के पहले और बाद की स्थिति"

msgid "Audit Context"
msgstr "अनुमान बैकग्राउंड"

msgid "Technical details for audit trail"
msgstr "अनुमान ट्रेल के लिए तकनीकी विवरण"

msgid "Register new user account"
msgstr "नए उपयोगकर्ता खाता रजिस्टर करें"

msgid ""
"Create a new customer account with email and password. Returns user profile "
"and authentication token."
msgstr ""
"ईमेल और पासवर्ड के साथ एक नया ग्राहक खाता बनाएं। उपयोगकर्ता प्रोफाइल और प्रमाणीकरण "
"टोकन लौटाता है।"

msgid "Registration successful, user created and logged in"
msgstr "पंजीकरण सफल, उपयोगकर्ता बनाया गया और लॉगिन कर गया"

msgid "Invalid registration data or email already exists"
msgstr "अमान्य पंजीकरण डेटा या ईमेल पहले से मौजूद है"

msgid "Registration successful."
msgstr "रजिस्ट्रेशन सफल।"

msgid "Registration failed."
msgstr "रजिस्ट्रेशन विफल।"

msgid "User login"
msgstr "उपयोगकर्ता लॉगिन"

msgid ""
"Authenticate user with email and password. Returns user profile and "
"authentication token for API access."
msgstr ""
"ईमेल और पासवर्ड के साथ उपयोगकर्ता का प्रमाणीकरण करें। एपीआई पहुंच के लिए उपयोगकर्ता "
"प्रोफाइल और प्रमाणीकरण टोकन लौटाता है।"

msgid "Login successful, returns user data and auth token"
msgstr "लॉगिन सफल, उपयोगकर्ता डेटा और अथॉरिज़ेशन टोकन लौटाता है"

msgid "Invalid credentials or account inactive"
msgstr "अमान्य एकाउंट या अकाउंट अक्रिय"

msgid "Login successful."
msgstr "लॉगिन सफल।"

msgid "Login failed."
msgstr "लॉगिन विफल।"

msgid "User logout"
msgstr "उपयोगकर्ता लॉगआउट"

msgid ""
"Log out the current user and invalidate their authentication token. Requires "
"authentication."
msgstr ""
"वर्तमान उपयोगकर्ता को लॉगआउट करें और उनके अथॉरिज़ेशन टोकन को अमान्य करें। यह अथॉरिज़ेशन "
"की आवश्यकता है।"

msgid "Logout successful, token deleted"
msgstr "लॉगआउट सफल, टोकन हटा दिया गया"

msgid "Logout successful."
msgstr "लॉगआउट सफल।"

msgid "Request password reset"
msgstr "पासवर्ड रीसेट की अनुरोध"

msgid ""
"Request a password reset email. Sends reset link to email if account exists. "
"Always returns success to prevent email enumeration. Rate limited to 20 "
"requests per hour."
msgstr ""
"पासवर्ड रीसेट के लिए ईमेल का अनुरोध करें। अगर खाता मौजूद है तो ईमेल पर रीसेट लिंक भेजता "
"है। हमेशा सफलता लौटाता है ताकि ईमेल के उपयोग के द्वारा जानकारी के उपयोग को रोका जा "
"सके। घंटा प्रति 20 अनुरोध तक दर बंद कर दिया गया है।"

msgid "Password reset email sent (if account exists)"
msgstr "पासवर्ड रीसेट के लिए ईमेल भेजा गया (यदि खाता मौजूद है)"

msgid "Invalid email format"
msgstr "अमान्य ईमेल प्रारूप"

msgid "Rate limit exceeded - too many password reset requests"
msgstr "दर सीमा पार हो गई - बहुत अधिक पासवर्ड रीसेट अनुरोध"

msgid "Password Reset Request"
msgstr "पासवर्ड रीसेट अनुरोध"

#, python-brace-format
msgid "Click the link to reset your password: {reset_url}"
msgstr "पासवर्ड रीसेट करने के लिए लिंक पर क्लिक करें: {reset_url}"

msgid ""
"If an account with that email exists, a password reset link has been sent."
msgstr "यदि उस ईमेल के साथ एक खाता मौजूद है, तो एक पासवर्ड रीसेट लिंक भेज दिया गया है।"

msgid "Invalid email address."
msgstr "अमान्य ईमेल पता।"

msgid "Confirm password reset"
msgstr "पासवर्ड रीसेट करें"

msgid ""
"Complete password reset process using the token from email. Requires uidb64 "
"and token from reset link."
msgstr ""
"ईमेल से प्राप्त टोकन का उपयोग करके पासवर्ड रीसेट प्रक्रिया पूर्ण करें। रीसेट लिंक से uidb64 "
"और टोकन की आवश्यकता होती है।"

msgid "Password successfully reset"
msgstr "पासवर्ड सफलतापूर्वक रीसेट कर दिया गया"

msgid "Invalid or expired reset token, or invalid password"
msgstr "अमान्य या अतीत रीसेट टोकन, या अमान्य पासवर्ड"

msgid "Invalid password reset link."
msgstr "अमान्य पासवर्ड रीसेट लिंक।"

msgid "Password has been reset successfully."
msgstr "पासवर्ड सफलतापूर्वक रीसेट कर दिया गया है।"

msgid "Password reset failed."
msgstr "पासवर्ड रीसेट विफल।"

msgid "Get user profile"
msgstr "उपयोगकर्ता प्रोफाइल प्राप्त करें"

msgid ""
"Retrieve the current authenticated user's profile information including "
"name, preferences, and settings."
msgstr ""
"वर्तमान प्रमाणित उपयोगकर्ता के प्रोफाइल जानकारी जैसे नाम, पसंद और सेटिंग्स को प्राप्त करें।"

msgid "Update user profile"
msgstr "उपयोगकर्ता प्रोफ़ाइल अपडेट करें"

msgid ""
"Update the current user's profile information. Use PUT for full update or "
"PATCH for partial update."
msgstr ""
"वर्तमान उपयोगकर्ता की प्रोफ़ाइल जानकारी अपडेट करें। पूर्ण अपडेट के लिए PUT या आंशिक अपडेट "
"के लिए PATCH का उपयोग करें।"

msgid "Profile updated successfully"
msgstr "प्रोफ़ाइल सफलतापूर्वक अपडेट कर दी गई"

msgid "Invalid profile data"
msgstr "अमान्य प्रोफ़ाइल डेटा"

msgid "Profile updated successfully."
msgstr "प्रोफाइल सफलतापूर्वक अपडेट कर दिया गया है।"

msgid "Profile update failed."
msgstr "प्रोफाइल अपडेट विफल।"

msgid "Update user preferences"
msgstr "उपयोगकर्ता पसंद अपडेट करें"

msgid ""
"Update user dashboard preferences including notification settings, display "
"options, and other customization."
msgstr ""
"उपयोगकर्ता डैशबोर्ड पसंद जैसे सूचना सेटिंग्स, प्रदर्शन विकल्प और अन्य व्यक्तिगतीकरण को अपडेट "
"करें।"

msgid "Invalid preference data"
msgstr "अमान्य पसंद डेटा"

msgid "Preferences updated successfully."
msgstr "प्राथमिकताएं सफलतापूर्वक अपडेट कर दी गई हैं।"

msgid "Preferences update failed."
msgstr "प्राथमिकताएं अपडेट विफल।"

msgid "Refresh customer metrics"
msgstr "ग्राहक मापदंडों को ताज़ा करें"

msgid ""
"Recalculate and update customer metrics including order count, total spent, "
"lifetime value, etc."
msgstr ""
"ग्राहक मापदंडों की पुन: गणना और अपडेट करें जिसमें आदेश की संख्या, कुल खर्च, जीवनकाल मूल्य "
"आदि शामिल हैं।"

msgid "Metrics refreshed successfully"
msgstr "मीट्रिक्स सफलतापूर्वक ताजा कर दिए गए"

msgid "Metrics refreshed successfully."
msgstr "मीट्रिक्स सफलतापूर्वक अपडेट कर दिया गया है।"

msgid "Set address as default"
msgstr "पता को डिफ़ॉल्ट के रूप में सेट करें"

msgid "Address created successfully."
msgstr "पता सफलतापूर्वक बना दिया गया है।"

msgid "Address creation failed."
msgstr "पता बनाना विफल।"

msgid "Address updated successfully."
msgstr "पता सफलतापूर्वक अपडेट कर दिया गया है।"

msgid "Address update failed."
msgstr "पता अपडेट विफल।"

msgid "Address deleted successfully."
msgstr "पता सफलतापूर्वक हटा दिया गया है।"

msgid "Default address updated."
msgstr "डिफ़ॉल्ट पता अपडेट कर दिया गया है।"

msgid "List available social login providers"
msgstr "उपलब्ध सोशल लॉगिन प्रदाताओं की सूची"

msgid ""
"Get list of enabled and configured OAuth social authentication providers "
"(Google, Facebook, etc.) with their login URLs."
msgstr ""
"ओएएएच सोशल प्रमाणिकरण प्रदाताओं (गूगल, फेसबुक, आदि) की सूची प्राप्त करें जो एनेबल और "
"कॉन्फ़िगर किए गए हैं और उनके लॉगिन URL के साथ।"

msgid "List of available social providers"
msgstr "उपलब्ध सोशल प्रदाताओं की सूची"

msgid "Convert guest user to full account"
msgstr "अतिथि उपयोगकर्ता को पूरा खाता में परिवर्तित करें"

msgid ""
"Convert an authenticated guest user to a full account by setting a password. "
"Only works for guest users (username starts with 'guest_')."
msgstr ""
"एक प्रमाणित अतिथि उपयोगकर्ता को एक पूर्ण खाता में परिवर्तित करें एक पासवर्ड सेट करके। "
"केवल अतिथि उपयोगकर्ताओं (यूजरनेम 'guest_' से शुरू होता है) के लिए काम करता है।"

msgid "Account created successfully"
msgstr "खाता सफलतापूर्वक बना"

msgid "Invalid request or password"
msgstr "अमान्य अनुरोध या पासवर्ड"

msgid "Not authenticated or not a guest user"
msgstr "अधिकृत नहीं है या अतिथि उपयोगकर्ता नहीं है"

msgid "Get account creation context"
msgstr "खाता निर्माण के संदर्भ प्राप्त करें"

msgid ""
"Get context for account creation UI including custom message and available "
"social auth providers."
msgstr ""
"खाता बनाने के लिए एक यूआई के लिए कंटेक्स्ट प्राप्त करें जिसमें कस्टम संदेश और उपलब्ध सोशल ऑथ "
"आपूर्तिकर्ता शामिल हैं।"

msgid "Account creation context"
msgstr "खाता बनाने के आधार"

msgid "Get communication preferences"
msgstr "संचार पसंद प्राप्त करें"

msgid ""
"Retrieve customer's communication preferences including email, SMS, and app-"
"specific settings (blog, loyalty, referrals, affiliate). Returns preferences "
"grouped by category for easier UI consumption. Requires authentication."
msgstr ""
"ग्राहक के संचार पसंद जैसे ईमेल, एसएमएस और एप-विशिष्ट सेटिंग (ब्लॉग, लॉयल्टी, रेफरल, "
"अफिलिएट) प्राप्त करें। पसंद को श्रेणी के आधार पर समूहित करके आसान UI उपयोग के लिए "
"लौटाता है। यह अधिकृतीकरण की आवश्यकता है।"

msgid "Preferences not found - will be auto-created"
msgstr "पसंद नहीं मिली - स्वचालित रूप से बनाई जाएगी"

msgid "Update single preference"
msgstr "एकल पसंद अपडेट करें"

msgid ""
"Update a single communication preference (granular control). Allows enabling/"
"disabling specific message types with optional frequency settings. "
"Transactional messages cannot be disabled. Marketing messages require email "
"verification. Changes are tracked for GDPR compliance. Requires "
"authentication."
msgstr ""
"एकल संचार पसंद अपडेट करें (विस्तृत नियंत्रण)। विशिष्ट संदेश प्रकार को सक्रिय/अक्रिय करने की "
"अनुमति देता है, जिसमें आवृत्ति सेटिंग वैकल्पिक है। लेनदेन संदेश अक्रिय नहीं किए जा सकते हैं। "
"बाजार प्रचार संदेशों के लिए ईमेल सत्यापन आवश्यक है। बदलाव GDPR संगतता के लिए ट्रैक किए "
"जाते हैं। यह अधिकृतीकरण की आवश्यकता है।"

msgid "Preference updated successfully"
msgstr "पसंद सफलतापूर्वक अपडेट कर दी गई"

msgid "Invalid request or cannot disable locked preference"
msgstr "अमान्य अनुरोध या बंद पसंद को अक्षम नहीं किया जा सकता"

msgid "Preference updated successfully."
msgstr "प्राथमिकता सफलता से अपडेट कर दी गई।"

msgid "Bulk update preferences"
msgstr "बैच पसंद अपडेट करें"

msgid ""
"Update multiple communication preferences in a single request. More "
"efficient than individual updates when changing multiple settings. All "
"updates are atomic - if any fails, none are applied. Requires authentication."
msgstr ""
"एक अनुरोध में कई संचार पसंद अपडेट करें। कई सेटिंग्स बदलते समय व्यक्तिगत अपडेट की तुलना में "
"अधिक कुशल। सभी अपडेट परमाणु हैं - यदि कोई विफल हो जाता है, तो कोई भी लागू नहीं किया "
"जाता। यह अधिकृतीकरण की आवश्यकता है।"

msgid "All preferences updated successfully"
msgstr "सभी पसंदें सफलतापूर्वक अपडेट कर दी गईं"

msgid "One or more updates failed"
msgstr "एक या अधिक अपडेट विफल रहे"

msgid "Unsubscribe from all communications"
msgstr "सभी संचार से अपसब्सक्राइब करें"

msgid ""
"Unsubscribe from all non-transactional communications (email and SMS). "
"Transactional messages (order confirmations, shipping updates) remain "
"enabled. This action is logged for GDPR compliance. Optional reason can be "
"provided for analytics. Requires authentication."
msgstr ""
"सभी गैर-लेनदेन संचार (ईमेल और एसएमएस) से अपसब्सक्राइब करें। लेनदेन संदेश (आदेश पुष्टि, "
"डिलीवरी अपडेट) अभी भी सक्रिय रहते हैं। यह कार्रवाई GDPR के अनुपालन के लिए लॉग किया "
"जाता है। विश्लेषण के लिए एक वैकल्पिक कारण प्रदान किया जा सकता है। यह अधिकृतीकरण की "
"आवश्यकता है।"

msgid "Optional reason for unsubscribing"
msgstr "अपसबस्क्राइब करने का वैकल्पिक कारण"

msgid "Successfully unsubscribed from all communications"
msgstr "सभी संचार से सफलतापूर्वक अपसब्सक्राइब कर दिया गया"

msgid "Unsubscribe failed"
msgstr "अपसब्सक्राइब विफल रहा"

msgid "You have been unsubscribed from all marketing communications."
msgstr "आप सभी विपणन संचार से सदस्यता रद्द कर दिए गए हैं।"

msgid "Export Communication Preferences"
msgstr "संचार पसंद निर्यात करें"

msgid ""
"Export all preference data including change history for GDPR Article 15 "
"(Right to Access)"
msgstr ""
"GDPR अनुच्छेद 15 (प्रवेश का अधिकार) के लिए सभी पसंद डेटा जिसमें परिवर्तन इतिहास शामिल "
"है, निर्यात करें"

msgid "Send SMS Verification Code"
msgstr "एसएमएस सत्यापन कोड भेजें"

msgid ""
"Send a 6-digit OTP code via SMS for TCPA-compliant double opt-in verification"
msgstr ""
"TCPA-अनुगामी डबल ऑप्ट-इन सत्यापन के लिए एसएमएस के माध्यम से 6 अंकों का ओटीपी कोड भेजें"

msgid "Phone number in E.164 format (e.g., +1234567890)"
msgstr "E.164 प्रारूप में फोन नंबर (उदाहरण के लिए, +1234567890)"

msgid "Invalid request or rate limited"
msgstr "अमान्य अनुरोध या दर बंदी"

msgid "Verify SMS Code"
msgstr "एसएमएस कोड की पुष्टि करें"

msgid ""
"Verify the 6-digit OTP code sent via SMS. Uses constant-time comparison for "
"security."
msgstr ""
"एसएमएस के माध्यम से भेजे गए 6 अंकों के ओटीपी कोड की पुष्टि करें। सुरक्षा के लिए इसमें स्थिर "
"समय तुलना का उपयोग किया जाता है।"

msgid "6-digit verification code"
msgstr "6 अंकों का सत्यापन कोड"

msgid "Phone number being verified"
msgstr "सत्यापित फोन नंबर"

msgid "Resend SMS Verification Code"
msgstr "एसएमएस सत्यापन कोड पुनः भेजें"

msgid ""
"Request a new verification code. Clears the old code before sending new one."
msgstr ""
"एक नया सत्यापन कोड अनुरोध करें। नए कोड भेजे जाने से पहले पुराना कोड खाली कर दिया जाता "
"है।"

msgid "Phone number to send code to"
msgstr "कोड भेजने के लिए फोन नंबर"

