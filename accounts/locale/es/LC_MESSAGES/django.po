msgstr "Cuenta"

msgid "User"
msgstr "Usuario"

msgid "Email Preferences"
msgstr "Preferencias de correo electrónico"

msgid ""
"Email communication settings. Transactional emails (order confirmations, "
"etc.) are always sent regardless of these settings."
msgstr ""
"Configuración de comunicación por correo electrónico. Los correos "
"electrónicos transaccionales (confirmaciones de pedidos, etc.) siempre se "
"envían, independientemente de estas configuraciones."

msgid "SMS Preferences"
msgstr "Preferencias de SMS"

msgid ""
"SMS communication settings. All SMS requires explicit customer opt-in (TCPA "
"compliance)."
msgstr ""
"Configuración de comunicación por SMS. Todos los SMS requieren el "
"consentimiento explícito del cliente (cumplimiento de TCPA)."

msgid "App-Specific Preferences"
msgstr "Preferencias específicas de la aplicación"

msgid ""
"JSON field containing preferences for blog, loyalty, referrals, and "
"affiliate communications."
msgstr ""
"Campo JSON que contiene preferencias para el blog, lealtad, referidos y "
"comunicaciones de afiliados."

msgid "Consent Tracking (GDPR Compliance)"
msgstr "Seguimiento de consentimiento (cumplimiento del GDPR)"

msgid ""
"Consent metadata required for GDPR Article 7 compliance. Records when, "
"where, and how customer provided consent."
msgstr ""
"Metadatos de consentimiento necesarios para el cumplimiento del Artículo 7 "
"del GDPR. Registra cuándo, dónde y cómo el cliente proporcionó su "
"consentimiento."

msgid "Unsubscribe"
msgstr "Darse de baja"

msgid "Unique token for one-click unsubscribe links in marketing emails."
msgstr ""
"Token único para enlaces de desuscripción de un solo clic en correos "
"electrónicos de marketing."

msgid "Metadata"
msgstr "Metadatos"

msgid "Email enabled"
msgstr "Correo electrónico activado"

msgid "Email disabled"
msgstr "Correo electrónico deshabilitado"

