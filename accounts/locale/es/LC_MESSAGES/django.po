msgstr "El dispositivo \"{}\" ha sido revocado."

msgid "Device not found or already revoked."
msgstr "Dispositivo no encontrado o ya revocado."

msgid "All {} trusted device(s) have been revoked."
msgstr "Todos los dispositivos confiables {} han sido revocados."

msgid "No trusted devices to revoke."
msgstr "No hay dispositivos de confianza para revocar."

msgid "Verification successful. This device is now trusted."
msgstr "Verificación exitosa. Este dispositivo ahora es de confianza."

msgid "Verification successful."
msgstr "Verificación exitosa."

msgid "Invalid code. Please try again."
msgstr "Código inválido. Por favor, inténtelo de nuevo."

msgid "Please enter your authentication code."
msgstr "Por favor, ingrese su código de autenticación."

msgid "Two-Factor Authentication"
msgstr "Autenticación en Dos Factores"

msgid "Role"
msgstr "Perfil"

msgid "Access Type"
msgstr "Tipo de Acceso"

