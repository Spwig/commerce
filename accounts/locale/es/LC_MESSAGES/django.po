msgstr "SMS"

msgid "Opted In"
msgstr "Aceptado"

msgid "Opted Out"
msgstr "Rechazado"

msgid "Marketing"
msgstr "Marketing"

msgid "Email verified"
msgstr "Correo electrónico verificado"

