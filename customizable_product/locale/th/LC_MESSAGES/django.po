#, python-format
msgid "Template Editor: %(product)s"
msgstr "ตัวแก้ไขเทมเพลต: %(product)s"

msgid "Customizable Products"
msgstr "สินค้าที่ปรับแต่งได้"

msgid "Canvas Editor"
msgstr "ตัวแก้ไขแคนวาส"

msgid "Simple Form"
msgstr "ฟอร์มแบบง่าย"

msgid "Product"
msgstr "สินค้า"

msgid "Enable Visual Editor"
msgstr "เปิดใช้งานตัวแก้ไขภาพ"

msgid ""
"When enabled, customers see the visual design editor on the product page."
msgstr "เมื่อเปิดใช้งาน ลูกค้าจะเห็นตัวแก้ไขการออกแบบทางภาพบนหน้าสินค้า"

msgid "Editor Mode"
msgstr "โหมดตัวแก้ไข"

msgid ""
"Canvas: full visual editor with Fabric.js. Simple: traditional form fields "
"only."
msgstr "แคนวาส: ตัวแก้ไขภาพทั้งหมดด้วย Fabric.js. แบบง่าย: ฟิลด์ฟอร์มแบบดั้งเดิมเท่านั้น。"

msgid "Allow Image Upload"
msgstr "อนุญาตให้อัปโหลดภาพ"

msgid "Allow customers to upload their own images."
msgstr "อนุญาตให้ลูกค้าอัปโหลดภาพของตนเอง"

msgid "Allow Text"
msgstr "อนุญาตให้ใส่ข้อความ"

msgid "Allow customers to add text elements."
msgstr "อนุญาตให้ลูกค้าเพิ่มองค์ประกอบข้อความ"

msgid "Allow Clipart"
msgstr "อนุญาตให้ใช้คลิปอาร์ต"

msgid "Allow customers to use clipart from the asset library."
msgstr "อนุญาตให้ลูกค้าใช้คลิปอาร์ตจากไลบรารีทรัพยากร"

msgid "Max Uploads Per Surface"
msgstr "จำนวนการอัปโหลดสูงสุดต่อพื้นผิว"

msgid "Maximum number of uploaded images allowed per design surface."
msgstr "จำนวนภาพสูงสุดที่อนุญาตให้อัปโหลดต่อพื้นผิวการออกแบบ"

msgid "Max Upload Size (MB)"
msgstr "ขนาดการอัปโหลดสูงสุด (MB)"

msgid "Allowed Upload Types"
msgstr "ประเภทการอัปโหลดที่อนุญาต"

msgid "File extensions allowed for upload. e.g. [\"jpg\", \"png\", \"svg\"]"
msgstr "นาม拡張子ที่อนุญาตสำหรับการอัปโหลด เช่น [\"jpg\", \"png\", \"svg\"]"

msgid "Base Design Fee"
msgstr "ค่าออกแบบพื้นฐาน"

msgid "Flat fee added when any customization is applied."
msgstr "ค่าธรรมเนียมคงที่ที่เพิ่มขึ้นเมื่อมีการใช้การปรับแต่งใด ๆ"

msgid "Per Surface Fee"
msgstr "ค่าต่อพื้นผิว"

msgid "Additional fee for each design surface used beyond the first."
msgstr "ค่าธรรมเนียมเพิ่มเติมสำหรับแต่ละพื้นผิวการออกแบบที่ใช้เกินจากพื้นผิวแรก"

msgid "Per Upload Fee"
msgstr "ค่าต่อการอัปโหลด"

msgid "Fee charged for each customer-uploaded image."
msgstr "ค่าธรรมเนียมที่เก็บสำหรับแต่ละภาพที่ลูกค้าอัปโหลด"

msgid "Per Text Fee"
msgstr "ค่าต่อข้อความ"

msgid "Fee charged for each text element added."
msgstr "ค่าธรรมเนียมที่เรียกเก็บสำหรับแต่ละองค์ประกอบข้อความที่เพิ่มเข้ามา。"

msgid "Product Design Configuration"
msgstr "การตั้งค่าการออกแบบผลิตภัณฑ์"

msgid "Product Design Configurations"
msgstr "การตั้งค่าการออกแบบผลิตภัณฑ์"

msgid "Millimeters"
msgstr "มิลลิเมตร"

msgid "Inches"
msgstr "นิ้ว"

msgid "Pixels"
msgstr "พิกเซล"

msgid "Design Configuration"
msgstr "การตั้งค่าการออกแบบ"

msgid "e.g. \"Front\", \"Back\", \"Left Sleeve\""
msgstr "\"เช่น \"Front\", \"Back\", \"Left Sleeve\"\""

msgid "Slug"
msgstr "สแลก"

msgid "Sort Order"
msgstr "ลำดับการจัดเรียง"

msgid "Product photo showing this surface/angle."
msgstr "รูปภาพของสินค้าที่แสดงถึงผิว/มุมนี้"

msgid "Dimension Unit"
msgstr "หน่วยของขนาด"

msgid "Design Area Width"
msgstr "ความกว้างของพื้นที่ออกแบบ"

msgid "Width of the printable/designable area."
msgstr "ความกว้างของพื้นที่ที่สามารถพิมพ์/ออกแบบได้。"

msgid "Design Area Height"
msgstr "ความสูงของพื้นที่ออกแบบ"

msgid "Height of the printable/designable area."
msgstr "ความสูงของพื้นที่ที่สามารถพิมพ์/ออกแบบได้。"

msgid "Zone X Position (%)"
msgstr "ตำแหน่ง X ของโซน (%)"

msgid ""
"Horizontal position of design zone on the mockup image, as percentage from "
"left."
msgstr "ตำแหน่งแนวนอนของโซนการออกแบบบนภาพต้นแบบ แสดงเป็นเปอร์เซ็นต์จากด้านซ้าย。"

msgid "Zone Y Position (%)"
msgstr "ตำแหน่ง Y ของโซน (%)"

msgid ""
"Vertical position of design zone on the mockup image, as percentage from top."
msgstr "ตำแหน่งแนวตั้งของโซนการออกแบบบนภาพต้นแบบ แสดงเป็นเปอร์เซ็นต์จากด้านบน"

msgid "Zone Width (%)"
msgstr "\"ความกว้างของโซน (%)\""

msgid "Width of design zone on the mockup image, as percentage of image width."
msgstr "ความกว้างของโซนออกแบบบนภาพต้นแบบ แสดงเป็นเปอร์เซ็นต์ของความกว้างภาพ"

msgid "Zone Height (%)"
msgstr "ความสูงของโซน (%)"

msgid ""
"Height of design zone on the mockup image, as percentage of image height."
msgstr "ความสูงของโซนออกแบบบนภาพต้นแบบ แสดงเป็นเปอร์เซ็นต์ของความสูงภาพ"

msgid "Minimum DPI"
msgstr "DPI ขั้นต่ำ"

msgid "Minimum dots-per-inch for acceptable print quality."
msgstr "จำนวนจุดต่อนิ้วขั้นต่ำที่เหมาะสมสำหรับคุณภาพการพิมพ์"

msgid "Recommended DPI"
msgstr "DPI ที่แนะนำ"

msgid "Recommended dots-per-inch for optimal print quality."
msgstr "ความละเอียดดอทต่อพิซซ่า (dpi) ที่แนะนำสำหรับคุณภาพการพิมพ์ที่ดีที่สุด"

msgid "Bleed (mm)"
msgstr "Bleed (มม.)"

msgid "Extra margin outside design area for printing bleed."
msgstr "ขอบเพิ่มเติมนอกพื้นที่ออกแบบสำหรับการพิมพ์ที่รั่ว"

msgid "Max Colors"
msgstr "จำนวนสีสูงสุด"

msgid ""
"Maximum number of colors allowed (for screen printing). Leave blank for "
"unlimited."
msgstr "จำนวนสีสูงสุดที่อนุญาต (สำหรับการพิมพ์หน้าจอ) ทิ้งไว้ว่างสำหรับไม่จำกัด"

msgid "Background Color"
msgstr "สีพื้นหลัง"

msgid "Default background color for the design canvas."
msgstr "สีพื้นหลังเริ่มต้นสำหรับแคนวาสการออกแบบ"

msgid "Override: allow text on this surface. Blank = inherit from config."
msgstr "ทับ: อนุญาตให้ใส่ข้อความบนพื้นผิวนี้ ปล่อยว่าง = ใช้ค่าจากตั้งค่า"

msgid ""
"Override: allow image uploads on this surface. Blank = inherit from config."
msgstr "ทับ: อนุญาตให้อัปโหลดภาพบนพื้นผิวนี้ ปล่อยว่าง = ใช้ค่าจากตั้งค่า"

msgid "Override: allow clipart on this surface. Blank = inherit from config."
msgstr "ปรับใช้: อนุญาตให้ใช้คลิปอาร์ตบนพื้นผิวนี้ได้ ถ้าว่าง = ใช้ค่าจากตั้งค่าทั่วไป"

msgid "Max Design Elements"
msgstr "จำนวนองค์ประกอบการออกแบบสูงสุด"

msgid "Maximum total design elements on this surface. Blank = no limit."
msgstr "จำนวนสูงสุดขององค์ประกอบการออกแบบบนพื้นผิวนี้ ถ้าว่าง = ไม่มีข้อจำกัด"

