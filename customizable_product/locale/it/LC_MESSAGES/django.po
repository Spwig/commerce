msgstr "Prodotto"

msgid "Enable Visual Editor"
msgstr "Abilita editor visivo"

msgid ""
"When enabled, customers see the visual design editor on the product page."
msgstr ""
"Quando abilitato, i clienti vedranno l'editor di progettazione visiva sulla "
"pagina del prodotto."

msgid "Editor Mode"
msgstr "Modalità editor"

msgid ""
"Canvas: full visual editor with Fabric.js. Simple: traditional form fields "
"only."
msgstr ""
"Canvas: editor visivo completo con Fabric.js. Simple: solo campi di form "
"tradizionali."

msgid "Allow Image Upload"
msgstr "Consenti caricamento immagine"

msgid "Allow customers to upload their own images."
msgstr "Consenti ai clienti di caricare le loro immagini."

msgid "Allow Text"
msgstr "Consenti testo"

msgid "Allow customers to add text elements."
msgstr "Consenti ai clienti di aggiungere elementi di testo."

msgid "Allow Clipart"
msgstr "Consenti clipart"

msgid "Allow customers to use clipart from the asset library."
msgstr "Consenti ai clienti di utilizzare clipart dalla libreria degli asset."

msgid "Max Uploads Per Surface"
msgstr "Massimo caricamenti per superficie"

msgid "Maximum number of uploaded images allowed per design surface."
msgstr ""
"Numero massimo di immagini caricate consentite per superficie di "
"progettazione."

msgid "Max Upload Size (MB)"
msgstr "Dimensione massima caricamento (MB)"

msgid "Allowed Upload Types"
msgstr "Tipi di caricamento consentiti"

msgid "File extensions allowed for upload. e.g. [\"jpg\", \"png\", \"svg\"]"
msgstr ""
"Estensioni di file consentite per il caricamento. ad es. [\"jpg\", \"png\", "
"\"svg\"]"

msgid "Base Design Fee"
msgstr "Tariffa base progettazione"

msgid "Flat fee added when any customization is applied."
msgstr ""
"Tassa aggiuntiva applicata quando viene applicata qualsiasi "
"personalizzazione."

msgid "Per Surface Fee"
msgstr "Tariffa per superficie"

msgid "Additional fee for each design surface used beyond the first."
msgstr ""
"Tariffa aggiuntiva per ciascuna superficie di design utilizzata al di là "
"della prima."

msgid "Per Upload Fee"
msgstr "Tariffa per caricamento"

msgid "Fee charged for each customer-uploaded image."
msgstr "Tariffa addebitata per ciascun'immagine caricata dal cliente."

msgid "Per Text Fee"
msgstr "Tariffa per testo"

msgid "Fee charged for each text element added."
msgstr "Tariffa addebitata per ciascun elemento testuale aggiunto."

msgid "Product Design Configuration"
msgstr "Configurazione del design del prodotto"

msgid "Product Design Configurations"
msgstr "Configurazioni del design del prodotto"

