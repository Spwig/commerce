msgstr "Configurazione del design"

msgid "e.g. \"Front\", \"Back\", \"Left Sleeve\""
msgstr "es. \"Fronte\", \"Retro\", \"Manica sinistra\""

msgid "Slug"
msgstr "Slug"

msgid "Sort Order"
msgstr "Ordine di classificazione"

msgid "Product photo showing this surface/angle."
msgstr "Foto del prodotto che mostra questa superficie/angolazione."

msgid "Dimension Unit"
msgstr "Unità di misura"

msgid "Design Area Width"
msgstr "Larghezza dell'area di stampa/design"

msgid "Width of the printable/designable area."
msgstr "Larghezza dell'area stampabile/designabile."

msgid "Design Area Height"
msgstr "Altezza dell'area di stampa/design"

msgid "Height of the printable/designable area."
msgstr "Altezza dell'area stampabile/designabile."

msgid "Zone X Position (%)"
msgstr "Posizione X della zona (%)"

msgid ""
"Horizontal position of design zone on the mockup image, as percentage from "
"left."
msgstr ""
"Posizione orizzontale della zona di design nell'immagine del mockup, "
"espressa come percentuale dalla sinistra."

msgid "Zone Y Position (%)"
msgstr "Posizione Y della zona (%)"

msgid ""
"Vertical position of design zone on the mockup image, as percentage from top."
msgstr ""
"Posizione verticale della zona di design nell'immagine del mockup, espressa "
"come percentuale dall'alto."

msgid "Zone Width (%)"
msgstr "Larghezza della zona (%)"

msgid "Width of design zone on the mockup image, as percentage of image width."
msgstr ""
"Larghezza della zona di design nell'immagine del mockup, espressa come "
"percentuale della larghezza dell'immagine."

msgid "Zone Height (%)"
msgstr "Altezza zona (%)"

msgid ""
"Height of design zone on the mockup image, as percentage of image height."
msgstr ""
"Altezza della zona di design nell'immagine del mockup, espressa come "
"percentuale dell'altezza dell'immagine."

msgid "Minimum DPI"
msgstr "DPI minimo"

msgid "Minimum dots-per-inch for acceptable print quality."
msgstr ""
"Minimo di punti per pollice accettabile per una qualità di stampa "
"accettabile."

msgid "Recommended DPI"
msgstr "DPI consigliato"

msgid "Recommended dots-per-inch for optimal print quality."
msgstr "Punti per pollice consigliati per una qualità di stampa ottimale."

msgid "Bleed (mm)"
msgstr "Margine di taglio (mm)"

msgid "Extra margin outside design area for printing bleed."
msgstr ""
"Margine aggiuntivo al di fuori dell'area di design per la stampa di bleed."

msgid "Max Colors"
msgstr "Massimo numero di colori"

msgid ""
"Maximum number of colors allowed (for screen printing). Leave blank for "
"unlimited."
msgstr ""
"Numero massimo di colori consentiti (per la stampa su tela). Lasciare vuoto "
"per un limite illimitato."

msgid "Background Color"
msgstr "Colore di sfondo"

msgid "Default background color for the design canvas."
msgstr "Colore di sfondo predefinito per il canvas del design."

msgid "Override: allow text on this surface. Blank = inherit from config."
msgstr ""
"Sovrascrivi: consente il testo su questa superficie. Vuoto = eredita dalle "
"impostazioni."

msgid ""
"Override: allow image uploads on this surface. Blank = inherit from config."
msgstr ""
"Sovrascrivi: consente l'upload di immagini su questa superficie. Vuoto = "
"eredita dalle impostazioni."

msgid "Override: allow clipart on this surface. Blank = inherit from config."
msgstr ""
"Sovrascrivi: consente l'uso di clipart su questa superficie. Vuoto = eredita "
"dalle impostazioni."

msgid "Max Design Elements"
msgstr "Massimo numero di elementi di disegno"

msgid "Maximum total design elements on this surface. Blank = no limit."
msgstr ""
"Numero massimo totale di elementi di design su questa superficie. Vuoto = "
"nessun limite."

