msgid "Enable Visual Editor"
msgstr "Aktifkan Editor Visual"

msgid ""
"When enabled, customers see the visual design editor on the product page."
msgstr ""
"Ketika diaktifkan, pelanggan akan melihat editor desain visual di halaman "
"produk."

msgid "Editor Mode"
msgstr "Mode Editor"

msgid ""
"Canvas: full visual editor with Fabric.js. Simple: traditional form fields "
"only."
msgstr ""
"Canvas: editor visual lengkap dengan Fabric.js. Sederhana: hanya bidang "
"formulir tradisional."

msgid "Allow Image Upload"
msgstr "Izinkan Unggah Gambar"

msgid "Allow customers to upload their own images."
msgstr "Izinkan pelanggan mengunggah gambar mereka sendiri."

msgid "Allow Text"
msgstr "Izinkan Teks"

msgid "Allow customers to add text elements."
msgstr "Izinkan pelanggan menambahkan elemen teks."

msgid "Allow Clipart"
msgstr "Izinkan Clipart"

msgid "Allow customers to use clipart from the asset library."
msgstr "Izinkan pelanggan menggunakan klipart dari perpustakaan aset."

msgid "Max Uploads Per Surface"
msgstr "Maksimal Unggah Per Permukaan"

msgid "Maximum number of uploaded images allowed per design surface."
msgstr "Jumlah maksimum gambar yang diizinkan diunggah per permukaan desain."

msgid "Max Upload Size (MB)"
msgstr "Ukuran Unggah Maksimal (MB)"

msgid "Allowed Upload Types"
msgstr "Jenis Unggah yang Diperbolehkan"

msgid "File extensions allowed for upload. e.g. [\"jpg\", \"png\", \"svg\"]"
msgstr ""
"Ekstensi file yang diizinkan untuk diunggah. Contoh: [\"jpg\", \"png\", "
"\"svg\"]"

msgid "Base Design Fee"
msgstr "Biaya Desain Dasar"

msgid "Flat fee added when any customization is applied."
msgstr ""
"Biaya tetap ditambahkan ketika ada perubahan kustomisasi yang diterapkan."

msgid "Per Surface Fee"
msgstr "Biaya Per Permukaan"

msgid "Additional fee for each design surface used beyond the first."
msgstr ""
"Biaya tambahan untuk setiap permukaan desain yang digunakan selain yang "
"pertama."

msgid "Per Upload Fee"
msgstr "Biaya Per Unggah"

msgid "Fee charged for each customer-uploaded image."
msgstr "Biaya yang dikenakan untuk setiap gambar yang diunggah oleh pelanggan."

msgid "Per Text Fee"
msgstr "Biaya Per Teks"

msgid "Fee charged for each text element added."
msgstr "Biaya yang dikenakan untuk setiap elemen teks yang ditambahkan."

msgid "Product Design Configuration"
msgstr "Konfigurasi Desain Produk"

msgid "Product Design Configurations"
msgstr "Konfigurasi Desain Produk"

