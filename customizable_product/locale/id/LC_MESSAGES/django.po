msgstr "Konfigurasi Desain"

msgid "e.g. \"Front\", \"Back\", \"Left Sleeve\""
msgstr "Contoh: \"Front\", \"Back\", \"Left Sleeve\""

msgid "Slug"
msgstr "Slug"

msgid "Sort Order"
msgstr "Urutan Penyortiran"

msgid "Product photo showing this surface/angle."
msgstr "Foto produk yang menampilkan permukaan/sudut ini."

msgid "Dimension Unit"
msgstr "Satuan Dimensi"

msgid "Design Area Width"
msgstr "Lebar Area Desain"

msgid "Width of the printable/designable area."
msgstr "Lebar area yang dapat dicetak/didesain."

msgid "Design Area Height"
msgstr "Tinggi Area Desain"

msgid "Height of the printable/designable area."
msgstr "Tinggi area yang dapat dicetak/didesain."

msgid "Zone X Position (%)"
msgstr "Posisi X Zona (%)"

msgid ""
"Horizontal position of design zone on the mockup image, as percentage from "
"left."
msgstr ""
"Posisi horizontal zona desain pada gambar mockup, diukur sebagai persentase "
"dari kiri."

msgid "Zone Y Position (%)"
msgstr "Posisi Y Zona (%)"

msgid ""
"Vertical position of design zone on the mockup image, as percentage from top."
msgstr ""
"Posisi vertikal zona desain pada gambar mockup, diukur sebagai persentase "
"dari atas."

msgid "Zone Width (%)"
msgstr "Lebar Zona (%)"

msgid "Width of design zone on the mockup image, as percentage of image width."
msgstr ""
"Lebar zona desain pada gambar mockup, diukur sebagai persentase dari lebar "
"gambar."

msgid "Zone Height (%)"
msgstr "Tinggi Zona (%)"

msgid ""
"Height of design zone on the mockup image, as percentage of image height."
msgstr ""
"Tinggi zona desain pada gambar mockup, diukur sebagai persentase dari tinggi "
"gambar."

msgid "Minimum DPI"
msgstr "DPI Minimum"

msgid "Minimum dots-per-inch for acceptable print quality."
msgstr "Minimum titik per inci untuk kualitas cetak yang dapat diterima."

msgid "Recommended DPI"
msgstr "DPI Direkomendasikan"

msgid "Recommended dots-per-inch for optimal print quality."
msgstr "Rekomendasi titik per inci untuk kualitas cetak optimal."

msgid "Bleed (mm)"
msgstr "Bleed (mm)"

msgid "Extra margin outside design area for printing bleed."
msgstr "Marginal tambahan di luar area desain untuk cetak bleed."

msgid "Max Colors"
msgstr "Maksimum Warna"

msgid ""
"Maximum number of colors allowed (for screen printing). Leave blank for "
"unlimited."
msgstr ""
"Jumlah maksimum warna yang diperbolehkan (untuk pencetakan layar). Biarkan "
"kosong untuk tidak terbatas."

msgid "Background Color"
msgstr "Warna Latar Belakang"

msgid "Default background color for the design canvas."
msgstr "Warna latar belakang default untuk kanvas desain."

msgid "Override: allow text on this surface. Blank = inherit from config."
msgstr ""
"Tutup: izinkan teks pada permukaan ini. Kosong = turunkan dari konfigurasi."

msgid ""
"Override: allow image uploads on this surface. Blank = inherit from config."
msgstr ""
"Tutup: izinkan unggah gambar pada permukaan ini. Kosong = turunkan dari "
"konfigurasi."

msgid "Override: allow clipart on this surface. Blank = inherit from config."
msgstr ""
"Tutup: izinkan clipart pada permukaan ini. Kosong = turunkan dari "
"konfigurasi."

msgid "Max Design Elements"
msgstr "Maksimum Elemen Desain"

msgid "Maximum total design elements on this surface. Blank = no limit."
msgstr ""
"Jumlah maksimum elemen desain pada permukaan ini. Kosong = tidak ada batas."

