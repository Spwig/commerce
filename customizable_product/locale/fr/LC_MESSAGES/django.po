msgid "Enable Visual Editor"
msgstr "Activer l'éditeur visuel"

msgid ""
"When enabled, customers see the visual design editor on the product page."
msgstr ""
"Lorsqu'il est activé, les clients voient l'éditeur de conception visuelle "
"sur la page du produit."

msgid "Editor Mode"
msgstr "Mode d'édition"

msgid ""
"Canvas: full visual editor with Fabric.js. Simple: traditional form fields "
"only."
msgstr ""
"Canvas : éditeur visuel complet avec Fabric.js. Simple : champs de "
"formulaire traditionnels uniquement."

msgid "Allow Image Upload"
msgstr "Autoriser le téléchargement d'image"

msgid "Allow customers to upload their own images."
msgstr "Permettre aux clients de télécharger leurs propres images."

msgid "Allow Text"
msgstr "Autoriser le texte"

msgid "Allow customers to add text elements."
msgstr "Permettre aux clients d'ajouter des éléments de texte."

msgid "Allow Clipart"
msgstr "Autoriser les dessins vectoriels"

msgid "Allow customers to use clipart from the asset library."
msgstr ""
"Permettre aux clients d'utiliser des dessins vectoriels depuis la "
"bibliothèque d'actifs."

msgid "Max Uploads Per Surface"
msgstr "Max téléchargements par surface"

msgid "Maximum number of uploaded images allowed per design surface."
msgstr ""
"Nombre maximum d'images téléchargées autorisées par surface de conception."

msgid "Max Upload Size (MB)"
msgstr "Taille maximale de téléchargement (MB)"

msgid "Allowed Upload Types"
msgstr "Types de téléchargement autorisés"

msgid "File extensions allowed for upload. e.g. [\"jpg\", \"png\", \"svg\"]"
msgstr ""
"Extensions de fichiers autorisées pour le téléchargement. Par exemple "
"[\"jpg\", \"png\", \"svg\"]"

msgid "Base Design Fee"
msgstr "Frais de conception de base"

msgid "Flat fee added when any customization is applied."
msgstr "Frais fixes ajoutés lorsqu'une personnalisation est appliquée."

msgid "Per Surface Fee"
msgstr "Frais par surface"

msgid "Additional fee for each design surface used beyond the first."
msgstr ""
"Frais supplémentaires pour chaque surface de conception utilisée au-delà de "
"la première."

msgid "Per Upload Fee"
msgstr "Frais par upload"

msgid "Fee charged for each customer-uploaded image."
msgstr "Frais facturés pour chaque image téléchargée par le client."

msgid "Per Text Fee"
msgstr "Frais par texte"

msgid "Fee charged for each text element added."
msgstr "Frais facturés pour chaque élément de texte ajouté."

