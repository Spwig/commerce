msgstr "Photo du produit montrant cette surface/angle."

msgid "Dimension Unit"
msgstr "Unité de dimension"

msgid "Design Area Width"
msgstr "Largeur de la zone de conception"

msgid "Width of the printable/designable area."
msgstr "Largeur de la zone imprimable/concevable."

msgid "Design Area Height"
msgstr "Hauteur de la zone de conception"

msgid "Height of the printable/designable area."
msgstr "Hauteur de la zone imprimable/concevable."

msgid "Zone X Position (%)"
msgstr "Position X de la zone (%)"

msgid ""
"Horizontal position of design zone on the mockup image, as percentage from "
"left."
msgstr ""
"Position horizontale de la zone de conception sur l'image de mockup, en "
"pourcentage à partir de la gauche."

msgid "Zone Y Position (%)"
msgstr "Position Y de la zone (%)"

msgid ""
"Vertical position of design zone on the mockup image, as percentage from top."
msgstr ""
"Position verticale de la zone de conception sur l'image de mockup, en "
"pourcentage à partir du haut."

msgid "Zone Width (%)"
msgstr "Largeur de la zone (%)"

msgid "Width of design zone on the mockup image, as percentage of image width."
msgstr ""
"Largeur de la zone de conception sur l'image de mockup, en pourcentage de la "
"largeur de l'image."

msgid "Zone Height (%)"
msgstr "Hauteur de zone (%)"

msgid ""
"Height of design zone on the mockup image, as percentage of image height."
msgstr ""
"Hauteur de la zone de conception sur l'image de mockup, en pourcentage de la "
"hauteur de l'image."

msgid "Minimum DPI"
msgstr "DPI minimum"

msgid "Minimum dots-per-inch for acceptable print quality."
msgstr ""
"Nombre minimum de points par pouce pour une qualité d'impression acceptable."

msgid "Recommended DPI"
msgstr "DPI recommandé"

msgid "Recommended dots-per-inch for optimal print quality."
msgstr ""
"Nombre recommandé de points par pouce pour une qualité d'impression optimale."

msgid "Bleed (mm)"
msgstr "Débordement (mm)"

msgid "Extra margin outside design area for printing bleed."
msgstr ""
"Marge supplémentaire en dehors de la zone de conception pour l'impression de "
"débordement."

msgid "Max Colors"
msgstr "Nombre maximum de couleurs"

msgid ""
"Maximum number of colors allowed (for screen printing). Leave blank for "
"unlimited."
msgstr ""
"Nombre maximum de couleurs autorisées (pour l'impression sur écran). Laissez "
"vide pour une limite illimitée."

msgid "Background Color"
msgstr "Couleur d'arrière-plan"

msgid "Default background color for the design canvas."
msgstr "Couleur d'arrière-plan par défaut pour le canevas de conception."

msgid "Override: allow text on this surface. Blank = inherit from config."
msgstr ""
"Remplacer : autoriser le texte sur cette surface. Vide = hériter de la "
"configuration."

msgid ""
"Override: allow image uploads on this surface. Blank = inherit from config."
msgstr ""
"Remplacer : autoriser le téléchargement d'images sur cette surface. Vide = "
"hériter de la configuration."

msgid "Override: allow clipart on this surface. Blank = inherit from config."
msgstr ""
"Remplacer : autoriser les dessins vectoriels sur cette surface. Vide = "
"hériter de la configuration."

msgid "Max Design Elements"
msgstr "Nombre maximum d'éléments de conception"

msgid "Maximum total design elements on this surface. Blank = no limit."
msgstr ""
"Nombre maximum total d'éléments de conception sur cette surface. Vide = pas "
"de limite."

