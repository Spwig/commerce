msgid "Customizable Products"
msgstr "Özel Ürünler"

msgid "Canvas Editor"
msgstr "Kanvas Düzenleyici"

msgid "Simple Form"
msgstr "Basit Form"

msgid "Product"
msgstr "Ürün"

msgid "Enable Visual Editor"
msgstr "Görsel Düzenleyiciyi Etkinleştir"

msgid ""
"When enabled, customers see the visual design editor on the product page."
msgstr ""
"Etkinleştirildiğinde, müşteriler ürün sayfasında görsel tasarım editörünü "
"görür."

msgid "Editor Mode"
msgstr "Düzenleyici Modu"

msgid ""
"Canvas: full visual editor with Fabric.js. Simple: traditional form fields "
"only."
msgstr ""
"Canvas: Fabric.js ile tam görsel editör. Basit: geleneksel form alanları "
"yalnızca."

msgid "Allow Image Upload"
msgstr "Resim Yükleme İzin Ver"

msgid "Allow customers to upload their own images."
msgstr "Müşterilerin kendi resimlerini yüklemesine izin ver."

msgid "Allow Text"
msgstr "Metin İzin Ver"

msgid "Allow customers to add text elements."
msgstr "Müşterilerin metin öğeleri eklemesine izin ver."

msgid "Allow Clipart"
msgstr "Klipart İzin Ver"

msgid "Allow customers to use clipart from the asset library."
msgstr "Müşterilerin varlık kütüphanesinden klipart kullanmasına izin ver."

msgid "Max Uploads Per Surface"
msgstr "Yüzey Başına Maksimum Yükleme"

msgid "Maximum number of uploaded images allowed per design surface."
msgstr "Bir tasarım yüzeyi başına yüklenebilecek maksimum resim sayısı."

msgid "Max Upload Size (MB)"
msgstr "Maksimum Yükleme Boyutu (MB)"

msgid "Allowed Upload Types"
msgstr "İzin Verilen Yükleme Türleri"

msgid "File extensions allowed for upload. e.g. [\"jpg\", \"png\", \"svg\"]"
msgstr ""
"Yükleme için izin verilen dosya uzantıları. Örnek: [\"jpg\", \"png\", "
"\"svg\"]"

msgid "Base Design Fee"
msgstr "Temel Tasarım Ücreti"

msgid "Flat fee added when any customization is applied."
msgstr "Herhangi bir özelleştirme uygulandığında sabit bir ücret eklenecektir."

msgid "Per Surface Fee"
msgstr "Yüzey Başı Ücret"

msgid "Additional fee for each design surface used beyond the first."
msgstr "İlkten sonra kullanılan her tasarım yüzeyi için ekstra ücret."

msgid "Per Upload Fee"
msgstr "Yükleme Başına Ücret"

msgid "Fee charged for each customer-uploaded image."
msgstr "Müşteri tarafından yüklenecek her resim için ücret."

msgid "Per Text Fee"
msgstr "Metin Başına Ücret"

msgid "Fee charged for each text element added."
msgstr "Eklenen her metin öğesi için ücret."

msgid "Product Design Configuration"
msgstr "Ürün Tasarım Ayarı"

msgid "Product Design Configurations"
msgstr "Ürün Tasarım Ayarları"

msgid "Millimeters"
msgstr "Milimetre"

msgid "Inches"
msgstr "İnç"

msgid "Pixels"
msgstr "Piksel"

msgid "Design Configuration"
msgstr "Tasarım Ayarı"

msgid "e.g. \"Front\", \"Back\", \"Left Sleeve\""
msgstr "Örnek: \"Ön\", \"Arka\", \"Sol Kol\""

msgid "Slug"
msgstr "Slug"

msgid "Sort Order"
msgstr "Sıra Numarası"

msgid "Product photo showing this surface/angle."
msgstr "Bu yüz/çapraz açıyı gösteren ürün fotoğrafı."

msgid "Dimension Unit"
msgstr "Boyut Birimi"

msgid "Design Area Width"
msgstr "Tasarım Alanı Genişliği"

msgid "Width of the printable/designable area."
msgstr "Yazdırılabilir/tasarım yapılabilir alanın genişliği."

msgid "Design Area Height"
msgstr "Tasarım Alanı Yüksekliği"

msgid "Height of the printable/designable area."
msgstr "Yazdırılabilir/tasarım yapılabilir alanın yüksekliği."

msgid "Zone X Position (%)"
msgstr "Zon X Konumu (%)"

msgid ""
"Horizontal position of design zone on the mockup image, as percentage from "
"left."
msgstr ""
"Mockup resminde tasarım alanının yatay konumu, sol taraftan yüzde olarak."

msgid "Zone Y Position (%)"
msgstr "Zon Y Konumu (%)"

msgid ""
"Vertical position of design zone on the mockup image, as percentage from top."
msgstr "Mockup resminde tasarım alanının dikey konumu, üstten yüzde olarak."

msgid "Zone Width (%)"
msgstr "Zon Genişliği (%)"

msgid "Width of design zone on the mockup image, as percentage of image width."
msgstr ""
"Mockup resminde tasarım alanının genişliği, resmin genişliğinin yüzde olarak."

msgid "Zone Height (%)"
msgstr "Bölge Yüksekliği (%)"

msgid ""
"Height of design zone on the mockup image, as percentage of image height."
msgstr ""
"Mockup resminde tasarım alanının yüksekliği, resmin yüksekliğinin yüzde "
"olarak."

msgid "Minimum DPI"
msgstr "Minimim DPI"

msgid "Minimum dots-per-inch for acceptable print quality."
msgstr "Kabul edilebilir baskı kalitesi için minimum dot-per-inch."

msgid "Recommended DPI"
msgstr "Önerilen DPI"

msgid "Recommended dots-per-inch for optimal print quality."
msgstr "Optimal baskı kalitesi için önerilen dot-per-inch."

msgid "Bleed (mm)"
msgstr "Kenar Boşluğu (mm)"

msgid "Extra margin outside design area for printing bleed."
msgstr "Baskı kenar akışı için tasarım alanının dışındaki ekstra marj."

msgid "Max Colors"
msgstr "Maksimum Renk"

msgid ""
"Maximum number of colors allowed (for screen printing). Leave blank for "
"unlimited."
msgstr ""
"Ekran basımı için izin verilen maksimum renk sayısı. Boş bırakın, sınırsız "
"olsun."

msgid "Background Color"
msgstr "Arka Plan Rengi"

msgid "Default background color for the design canvas."
msgstr "Tasarım kanvası için varsayılan arka plan rengi."

msgid "Override: allow text on this surface. Blank = inherit from config."
msgstr ""
"Geçersiz kıl: bu yüzeyde metin izin ver. Boş = yapılandırmadan miras al."

msgid ""
"Override: allow image uploads on this surface. Blank = inherit from config."
msgstr ""
"Geçersiz kıl: bu yüzeyde resim yükleme izin ver. Boş = yapılandırmadan miras "
"al."

msgid "Override: allow clipart on this surface. Blank = inherit from config."
msgstr ""
"Geçersiz kıl: bu yüzeyde klipart izin ver. Boş = yapılandırmadan miras al."

msgid "Max Design Elements"
msgstr "Maksimum Tasarım Elemanları"

msgid "Maximum total design elements on this surface. Blank = no limit."
msgstr ""
"Bu yüzeydeki toplam tasarım öğelerinin maksimum sayısı. Boş bırakın = "
"sınırsız."

