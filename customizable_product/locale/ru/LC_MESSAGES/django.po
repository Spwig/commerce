msgstr "Позиция зоны дизайна (%% на макете)"

#, python-format
msgid "X %%"
msgstr "X %%"

#, python-format
msgid "Y %%"
msgstr "Y %%"

#, python-format
msgid "Width %%"
msgstr "Ширина %%"

