msgstr "Текст"

msgid "Image"
msgstr "Изображение"

msgid "Clipart"
msgstr "Клипарт"

msgid "Template"
msgstr "Шаблон"

msgid "Surface"
msgstr "Поверхность"

msgid "Element Type"
msgstr "Тип элемента"

msgid "Element Data"
msgstr "Данные элемента"

msgid "Fabric.js object properties (position, size, rotation, content)."
msgstr "Свойства объекта Fabric.js (позиция, размер, поворот, содержимое)."

msgid "Lock Position"
msgstr "Закрепить позицию"

msgid "Prevent customers from moving this element."
msgstr "Запретить пользователям перемещать этот элемент."

msgid "Lock Size"
msgstr "Закрепить размер"

msgid "Prevent customers from resizing this element."
msgstr "Запретить пользователям изменять размер этого элемента."

msgid "Lock Content"
msgstr "Закрепить содержимое"

msgid "Prevent customers from editing text or replacing the image."
msgstr "Запретить клиентам редактирование текста или замену изображения."

msgid "Lock Delete"
msgstr "Закрепить удаление"

msgid "Prevent customers from removing this element."
msgstr "Запретить клиентам удаление этого элемента."

msgid "Lock Rotation"
msgstr "Закрепить поворот"

msgid "Prevent customers from rotating this element."
msgstr "Запретить клиентам вращение этого элемента."

msgid "Z-order for layering elements."
msgstr "Порядок Z для наложения элементов."

msgid "Design Template Element"
msgstr "Элемент шаблона дизайна"

msgid "Design Template Elements"
msgstr "Элементы шаблона дизайна"

msgid "Category Name"
msgstr "Имя категории"

msgid "Icon"
msgstr "Иконка"

msgid "CSS icon class (e.g. Font Awesome class)."
msgstr "Класс иконки CSS (например, класс Font Awesome)."

msgid "Clipart Category"
msgstr "Категория клипартов"

msgid "Clipart Categories"
msgstr "Категории клипартов"

msgid "Available to All Products"
msgstr "Доступно для всех продуктов"

msgid "Specific Product Only"
msgstr "Только для конкретного продукта"

msgid "Name"
msgstr "Название"

msgid "Image Asset"
msgstr "Изображение"

msgid "PNG or SVG file for the clipart."
msgstr "Файл PNG или SVG для клипов."

msgid "Scope"
msgstr "Область"

msgid "Only set when scope is 'Specific Product Only'."
msgstr ""
"Устанавливается только когда область действия 'Только конкретный продукт'."

msgid "Tags"
msgstr "Теги"

msgid ""
"Searchable tags for this clipart. e.g. [\"star\", \"decoration\", \"gold\"]"
msgstr ""
"Поисковые теги для этого клип-арта. Например, [\"star\", \"decoration\", "
"\"gold\"]"

msgid "Clipart Asset"
msgstr "Растровый ресурс"

msgid "Clipart Assets"
msgstr "Растровые ресурсы"

msgid "Font Name"
msgstr "Название шрифта"

msgid "Display name shown in the font picker."
msgstr "Отображаемое имя, показываемое в выборке шрифтов."

msgid "Font Family"
msgstr "Семейство шрифтов"

msgid "CSS font-family name used in the editor."
msgstr "Имя шрифта font-family CSS, используемое в редакторе."

msgid "WOFF2 or TTF file for regular weight."
msgstr "Файл WOFF2 или TTF для обычного веса."

msgid "WOFF2 or TTF file for bold weight."
msgstr "Файл WOFF2 или TTF для жирного веса."

msgid "Italic"
msgstr "Курсив"

msgid "WOFF2 or TTF file for italic style."
msgstr "Файл WOFF2 или TTF для курсивного стиля."

msgid "Bold Italic"
msgstr "Жирный курсив"

msgid "WOFF2 or TTF file for bold italic style."
msgstr "Файл WOFF2 или TTF для жирного итальянского стиля."

msgid "System Font"
msgstr "Системный шрифт"

msgid "If true, this font is pre-installed and no file upload is needed."
msgstr "Если true, этот шрифт предустановлен, и загрузка файла не требуется."

msgid "Custom Font"
msgstr "Пользовательский шрифт"

msgid "Custom Fonts"
msgstr "Пользовательские шрифты"

msgid "User"
msgstr "Пользователь"

msgid "Design Name"
msgstr "Имя дизайна"

msgid "Full Fabric.js canvas state per surface."
msgstr "Полное состояние холста Fabric.js для каждой поверхности."

msgid "Thumbnails"
msgstr "Миниатюры"

msgid ""
"Per-surface thumbnail MediaAsset IDs. e.g. {\"front\": 123, \"back\": 456}"
msgstr ""
"Идентификаторы медиа-ресурсов миниатюр по поверхностям. Например, "
"{\"front\": 123, \"back\": 456}"

msgid "Saved Design"
msgstr "Сохранённый дизайн"

msgid "Saved Designs"
msgstr "Сохранённые дизайны"

msgid "Token"
msgstr "Токен"

msgid "Unique reference used by the cart system."
msgstr "Уникальная ссылка, используемая системой корзины."

msgid "Session Key"
msgstr "Ключ сессии"

msgid "Session key for anonymous users."
msgstr "Ключ сессии для анонимных пользователей."

msgid "Per-surface thumbnail MediaAsset IDs."
msgstr "ИД медиа-ресурсов миниатюр по поверхностям."

msgid "Pricing Breakdown"
msgstr "Разбивка по цене"

msgid "Calculated price components for this design."
msgstr "Рассчитанные компоненты цены для этого дизайна."

msgid "Expires At"
msgstr "Истекает к"

msgid "Auto-cleanup after this datetime."
msgstr "Автоматическая очистка после этого времени."

msgid "Design Draft"
msgstr "Черновик дизайна"

msgid "Design Drafts"
msgstr "Черновики дизайна"

msgid "Order Item"
msgstr "Элемент заказа"

msgid "Frozen design state at time of order."
msgstr "Замороженное состояние дизайна на момент заказа."

msgid "Rendered Images"
msgstr "Созданные изображения"

msgid "Per-surface preview MediaAsset IDs. e.g. {\"front\": 123}"
msgstr ""
"Идентификаторы MediaAsset для предварительного просмотра по поверхностям. "
"Например, {\"front\": 123}"

msgid "Fulfillment Files"
msgstr "Файлы выполнения"

msgid "High-resolution composite MediaAsset IDs for printing."
msgstr "Идентификаторы высокоразрешенных составных MediaAsset для печати."

msgid "Rendered"
msgstr "Создано"

msgid "Whether high-resolution fulfillment files have been generated."
msgstr "Были ли сгенерированы файлы высокого разрешения для выполнения заказа."

msgid "Render Completed At"
msgstr "Дата завершения создания"

msgid "Design Snapshot"
msgstr "Снимок дизайна"

msgid "Design Snapshots"
msgstr "Снимки дизайна"

msgid "Design Editor Setup"
msgstr "Настройка редактора дизайна"

msgid "Home"
msgstr "Главная"

msgid "Products"
msgstr "Товары"

msgid "Editor Enabled"
msgstr "Редактор включен"

msgid "Back to Product"
msgstr "Назад к товару"

msgid "Fonts"
msgstr "Шрифты"

msgid "Settings"
msgstr "Настройки"

msgid ""
"Define the designable areas of your product. Each surface represents a face "
"or side where customers can place their designs."
msgstr ""
"Определите участки вашего продукта, которые можно настраивать. Каждая "
"поверхность представляет собой сторону или грань, где клиенты могут "
"размещать свои дизайны."

msgid ""
"Create pre-made designs that customers can start from and customize. "
"Templates can have locked elements that customers cannot change."
msgstr ""
"Создавайте готовые дизайны, с которых клиенты могут начать и настроить их. "
"Шаблоны могут содержать заблокированные элементы, которые клиенты не смогут "
"изменить."

msgid "Clipart Library"
msgstr "Библиотека клипов"

msgid ""
"Manage clipart categories and assets that customers can use in their "
"designs. Clipart can be global (all products) or product-specific."
msgstr ""
"Управляйте категориями и ресурсами клипартов, которые клиенты могут "
"использовать в своих дизайнах. Клипарт может быть глобальным (все продукты) "
"или специфичным для продукта."

msgid "Clipart categories and assets are managed from the admin panel:"
msgstr "Категории и ресурсы клипов управляются через панель администратора:"

msgid "Manage Categories"
msgstr "Управление категориями"

msgid "Manage Assets"
msgstr "Управление ресурсами"

msgid ""
"Upload custom fonts for customers to use when adding text to their designs. "
"WOFF2 or TTF format recommended."
msgstr ""
"Загрузите пользовательские шрифты для использования клиентами при добавлении "
"текста в их дизайны. Рекомендуется использовать формат WOFF2 или TTF."

msgid "Manage Fonts"
msgstr "Управление шрифтами"

msgid "Design Pricing"
msgstr "Ценовая политика дизайна"

msgid ""
"Set pricing rules for customizations. Fees are added on top of the product's "
"base price."
msgstr ""
"Установите правила ценообразования для настройок. Платежи добавляются к "
"базовой цене продукта."

msgid "Fee for each additional surface used beyond the first."
msgstr ""
"Плата за каждый дополнительный используемый поверхность, превышающий первую."

msgid "Fee for each customer-uploaded image."
msgstr "Плата за каждое изображение, загруженное клиентом."

msgid "Per Text Element Fee"
msgstr "Плата за каждый текстовый элемент"

msgid "Fee for each text element added to the design."
msgstr "Плата за каждый добавленный текстовый элемент в дизайн."

msgid "Save Pricing"
msgstr "Сохранить ценовую политику"

msgid "Editor Settings"
msgstr "Настройки редактора"

msgid "Configure the design editor behavior and restrictions."
msgstr "Настройте поведение и ограничения редактора дизайна."

msgid "Canvas Editor (Visual)"
msgstr "Редактор холста (визуальный)"

msgid "Simple Form (Text Fields Only)"
msgstr "Простая форма (только текстовые поля)"

msgid "Allow Text Elements"
msgstr "Разрешить текстовые элементы"

msgid "Allowed File Types"
msgstr "Разрешенные типы файлов"

msgid "Comma-separated list of file extensions."
msgstr "Список расширений файлов, разделенных запятыми."

msgid "Save Settings"
msgstr "Сохранить настройки"

msgid "Close"
msgstr "Закрыть"

msgid "e.g. Front, Back, Left Sleeve"
msgstr "напр. Верх, Низ, Левый рукав"

msgid "e.g. front, back, left-sleeve"
msgstr "напр. front, back, left-sleeve"

msgid "No image selected"
msgstr "Изображение не выбрано"

msgid "Select Image"
msgstr "Выберите изображение"

msgid "Remove"
msgstr "Удалить"

msgid "Design Area Dimensions"
msgstr "Размеры области дизайна"

msgid "Width"
msgstr "Ширина"

msgid "Height"
msgstr "Высота"

msgid "Unit"
msgstr "Единица измерения"

