#, python-format
msgid "Design Editor Setup: %(product)s"
msgstr "Настройка редактора дизайна: %(product)s"

msgid "Invalid JSON"
msgstr "Неверный JSON"

msgid "Media asset not found"
msgstr "Медийный актив не найден"

msgid "No image data provided"
msgstr "Не предоставлены данные изображения"

msgid "Invalid image data"
msgstr "Недопустимые данные изображения"

#, python-format
msgid "Template Editor: %(product)s"
msgstr "Редактор шаблонов: %(product)s"

msgid "Customizable Products"
msgstr "Настраиваемые товары"

msgid "Canvas Editor"
msgstr "Редактор холста"

msgid "Simple Form"
msgstr "Простая форма"

msgid "Product"
msgstr "Товар"

msgid "Enable Visual Editor"
msgstr "Включить визуальный редактор"

msgid ""
"When enabled, customers see the visual design editor on the product page."
msgstr ""
"Когда это включено, клиенты видят визуальный редактор дизайна на странице "
"продукта."

msgid "Editor Mode"
msgstr "Режим редактирования"

msgid ""
"Canvas: full visual editor with Fabric.js. Simple: traditional form fields "
"only."
msgstr ""
"Канвас: полный визуальный редактор с Fabric.js. Простой: только традиционные "
"поля форм."

msgid "Allow Image Upload"
msgstr "Разрешить загрузку изображений"

msgid "Allow customers to upload their own images."
msgstr "Разрешить клиентам загружать свои изображения."

msgid "Allow Text"
msgstr "Разрешить текст"

msgid "Allow customers to add text elements."
msgstr "Разрешить клиентам добавлять текстовые элементы."

msgid "Allow Clipart"
msgstr "Разрешить клипарт"

msgid "Allow customers to use clipart from the asset library."
msgstr "Разрешить клиентам использовать клипарт из библиотеки активов."

msgid "Max Uploads Per Surface"
msgstr "Максимальное количество загрузок на поверхность"

msgid "Maximum number of uploaded images allowed per design surface."
msgstr ""
"Максимальное количество загружаемых изображений на одну поверхность дизайна."

msgid "Max Upload Size (MB)"
msgstr "Максимальный размер загрузки (МБ)"

msgid "Allowed Upload Types"
msgstr "Разрешенные типы загрузки"

msgid "File extensions allowed for upload. e.g. [\"jpg\", \"png\", \"svg\"]"
msgstr ""
"Расширения файлов, разрешенных для загрузки. Например. [\"jpg\", \"png\", "
"\"svg\"]"

msgid "Base Design Fee"
msgstr "Базовая плата за дизайн"

msgid "Flat fee added when any customization is applied."
msgstr "Плоский сбор, взимаемый при применении любой настройки."

msgid "Per Surface Fee"
msgstr "Плата за поверхность"

msgid "Additional fee for each design surface used beyond the first."
msgstr ""
"Дополнительный сбор за каждую используемую поверхность дизайна, превышающую "
"первую."

msgid "Per Upload Fee"
msgstr "Плата за загрузку"

msgid "Fee charged for each customer-uploaded image."
msgstr "Сбор, взимаемый за каждую загруженную клиентом изображение."

msgid "Per Text Fee"
msgstr "Плата за текст"

msgid "Fee charged for each text element added."
msgstr "Плата, взимаемая за каждый добавленный текстовый элемент."

msgid "Product Design Configuration"
msgstr "Настройка дизайна продукта"

msgid "Product Design Configurations"
msgstr "Настройки дизайна продукта"

msgid "Millimeters"
msgstr "Миллиметры"

msgid "Inches"
msgstr "Дюймы"

msgid "Pixels"
msgstr "Пиксели"

msgid "Design Configuration"
msgstr "Настройка дизайна"

msgid "e.g. \"Front\", \"Back\", \"Left Sleeve\""
msgstr "например, \"Front\", \"Back\", \"Left Sleeve\""

msgid "Slug"
msgstr "Слаг"

msgid "Sort Order"
msgstr "Порядок сортировки"

msgid "Product photo showing this surface/angle."
msgstr "Фото продукта, показывающее эту поверхность/угол."

msgid "Dimension Unit"
msgstr "Единица измерения"

msgid "Design Area Width"
msgstr "Ширина зоны дизайна"

msgid "Width of the printable/designable area."
msgstr "Ширина печатаемой/дизайнируемой области."

msgid "Design Area Height"
msgstr "Высота области дизайна"

msgid "Height of the printable/designable area."
msgstr "Высота печатаемой/дизайнируемой области."

msgid "Zone X Position (%)"
msgstr "Позиция зоны X (%)"

msgid ""
"Horizontal position of design zone on the mockup image, as percentage from "
"left."
msgstr ""
"Горизонтальное положение зоны дизайна на изображении макета, указанное в "
"процентах от левого края."

msgid "Zone Y Position (%)"
msgstr "Позиция зоны Y (%)"

msgid ""
"Vertical position of design zone on the mockup image, as percentage from top."
msgstr ""
"Вертикальное положение зоны дизайна на изображении макета, указанное в "
"процентах от верхнего края."

msgid "Zone Width (%)"
msgstr "Ширина зоны (%)"

msgid "Width of design zone on the mockup image, as percentage of image width."
msgstr ""
"Ширина зоны дизайна на изображении макета, как процент от ширины изображения."

msgid "Zone Height (%)"
msgstr "Высота зоны (%)"

msgid ""
"Height of design zone on the mockup image, as percentage of image height."
msgstr ""
"Высота зоны дизайна на изображении макета, как процент от высоты изображения."

msgid "Minimum DPI"
msgstr "Минимальное DPI"

msgid "Minimum dots-per-inch for acceptable print quality."
msgstr "Минимальное количество точек на дюйм для приемлемого качества печати."

msgid "Recommended DPI"
msgstr "Рекомендуемое DPI"

msgid "Recommended dots-per-inch for optimal print quality."
msgstr ""
"Рекомендуемое количество точек на дюйм для оптимального качества печати."

msgid "Bleed (mm)"
msgstr "Обрезка (мм)"

msgid "Extra margin outside design area for printing bleed."
msgstr ""
"Дополнительный отступ за пределами области дизайна для печати с кровью."

msgid "Max Colors"
msgstr "Максимальное количество цветов"

msgid ""
"Maximum number of colors allowed (for screen printing). Leave blank for "
"unlimited."
msgstr ""
"Максимальное количество допустимых цветов (для трафаретной печати). Оставьте "
"поле пустым, чтобы разрешить неограниченное количество цветов."

msgid "Background Color"
msgstr "Цвет фона"

msgid "Default background color for the design canvas."
msgstr "Цвет фона по умолчанию для холста дизайна."

msgid "Override: allow text on this surface. Blank = inherit from config."
msgstr ""
"Переопределить: разрешить текст на этой поверхности. Пустое значение = "
"наследовать от конфигурации."

msgid ""
"Override: allow image uploads on this surface. Blank = inherit from config."
msgstr ""
"Переопределить: разрешить загрузку изображений на эту поверхность. Пустое "
"значение = наследовать от конфигурации."

msgid "Override: allow clipart on this surface. Blank = inherit from config."
msgstr ""
"Переопределить: разрешить использование клипов на этой поверхности. Пусто = "
"наследовать из конфигурации."

msgid "Max Design Elements"
msgstr "Максимальное количество элементов дизайна"

msgid "Maximum total design elements on this surface. Blank = no limit."
msgstr ""
"Максимальное общее количество элементов дизайна на этой поверхности. Пусто = "
"без ограничений."

msgid "Enabled"
msgstr "Включено"

msgid "Product Surface"
msgstr "Поверхность продукта"

msgid "Product Surfaces"
msgstr "Поверхности продукта"

msgid "Template Name"
msgstr "Имя шаблона"

msgid "Description"
msgstr "Описание"

msgid "Category"
msgstr "Категория"

msgid "e.g. \"Birthday\", \"Business\", \"Holiday\""
msgstr "например, \"Birthday\", \"Business\", \"Holiday\""

msgid "Design Data"
msgstr "Дизайн-данные"

msgid "Full Fabric.js canvas state for each surface."
msgstr "Полное состояние холста Fabric.js для каждой поверхности."

msgid "Thumbnail"
msgstr "Миниатюра"

msgid "Active"
msgstr "Активный"

msgid "Design Template"
msgstr "Шаблон дизайна"

