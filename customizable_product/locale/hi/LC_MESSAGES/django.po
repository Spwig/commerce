msgstr "मॉकअप इमेज"

msgid "Design Zone"
msgstr "डिज़ाइन क्षेत्र"

msgid "Save Template"
msgstr "टेम्पलेट सहेजें"

msgid "Delete Template"
msgstr "टेम्पलेट हटाएं"

msgid "Add Template"
msgstr "टेम्पलेट जोड़ें"

msgid "Saved successfully"
msgstr "सफलता से सहेजा गया"

msgid "Are you sure you want to delete this?"
msgstr "क्या आप निश्चित हैं कि आप इसे हटाना चाहते हैं?"

msgid "An error occurred"
msgstr "एक त्रुटि हुई"

#, python-format
msgid "Design Editor Setup: %(product)s"
msgstr "डिज़ाइन एडिटर सेटअप: %(product)s"

msgid "Invalid JSON"
msgstr "अमान्य JSON"

msgid "Media asset not found"
msgstr "मीडिया संसाधन नहीं मिला"

msgid "No image data provided"
msgstr "कोई छवि डेटा प्रदान नहीं किया गया"

msgid "Invalid image data"
msgstr "अमान्य छवि डेटा"

#, python-format
msgid "Template Editor: %(product)s"
msgstr "टेम्पलेट एडिटर: %(product)s"

msgid "Customizable Products"
msgstr "अनुकूलित उत्पाद"

msgid "Canvas Editor"
msgstr "कैन्वास संपादक"

msgid "Simple Form"
msgstr "सरल फॉर्म"

msgid "Product"
msgstr "उत्पाद"

msgid "Enable Visual Editor"
msgstr "दृश्य संपादक को योग्य करें"

msgid ""
"When enabled, customers see the visual design editor on the product page."
msgstr "जब इसे चालू किया जाता है, तो ग्राहक उत्पाद पृष्ठ पर दृश्य डिज़ाइन संपादक देखते हैं।"

msgid "Editor Mode"
msgstr "संपादक मोड"

msgid ""
"Canvas: full visual editor with Fabric.js. Simple: traditional form fields "
"only."
msgstr "कैन्वास: Fabric.js के साथ पूर्ण दृश्य संपादक। सरल: केवल पारंपरिक फॉर्म फील्ड।"

msgid "Allow Image Upload"
msgstr "छवि अपलोड की अनुमति"

msgid "Allow customers to upload their own images."
msgstr "ग्राहकों को अपनी छवियां अपलोड करने की अनुमति दें।"

msgid "Allow Text"
msgstr "टेक्स्ट की अनुमति"

msgid "Allow customers to add text elements."
msgstr "ग्राहकों को पाठ तत्व जोड़ने की अनुमति दें।"

msgid "Allow Clipart"
msgstr "क्लिपआर्ट की अनुमति"

msgid "Allow customers to use clipart from the asset library."
msgstr "ग्राहकों को संसाधन पुस्तकालय से क्लिपआर्ट के उपयोग की अनुमति दें।"

msgid "Max Uploads Per Surface"
msgstr "प्रति सतह अधिकतम अपलोड"

msgid "Maximum number of uploaded images allowed per design surface."
msgstr "डिज़ाइन सतह प्रति अपलोड की गई छवियों की अधिकतम संख्या।"

msgid "Max Upload Size (MB)"
msgstr "अधिकतम अपलोड आकार (एमबी)"

msgid "Allowed Upload Types"
msgstr "अनुमोदित अपलोड प्रकार"

msgid "File extensions allowed for upload. e.g. [\"jpg\", \"png\", \"svg\"]"
msgstr "अपलोड के लिए अनुमत फ़ाइल विस्तार। उदाहरण के लिए [\"jpg\", \"png\", \"svg\"]"

msgid "Base Design Fee"
msgstr "आधार डिज़ाइन शुल्क"

msgid "Flat fee added when any customization is applied."
msgstr "किसी भी व्यक्तिगतकरण के लागू होने पर एक फ्लैट शुल्क जोड़ा जाता है।"

msgid "Per Surface Fee"
msgstr "प्रति सतह शुल्क"

msgid "Additional fee for each design surface used beyond the first."
msgstr "पहले के बाद प्रत्येक डिज़ाइन सतह के उपयोग के लिए अतिरिक्त शुल्क।"

msgid "Per Upload Fee"
msgstr "प्रति अपलोड शुल्क"

msgid "Fee charged for each customer-uploaded image."
msgstr "प्रत्येक ग्राहक-अपलोड किए गए चित्र के लिए शुल्क लगाया जाता है।"

msgid "Per Text Fee"
msgstr "प्रति टेक्स्ट शुल्क"

msgid "Fee charged for each text element added."
msgstr "प्रत्येक टेक्स्ट तत्व जोड़े जाने पर लगाए गए शुल्क।"

msgid "Product Design Configuration"
msgstr "उत्पाद डिज़ाइन सेटिंग"

msgid "Product Design Configurations"
msgstr "उत्पाद डिज़ाइन सेटिंग्स"

msgid "Millimeters"
msgstr "मिलीमीटर"

msgid "Inches"
msgstr "इंच"

msgid "Pixels"
msgstr "पिक्सेल"

msgid "Design Configuration"
msgstr "डिज़ाइन सेटिंग"

msgid "e.g. \"Front\", \"Back\", \"Left Sleeve\""
msgstr "जैसे कि \"Front\", \"Back\", \"Left Sleeve\""

msgid "Slug"
msgstr "स्लग"

msgid "Sort Order"
msgstr "क्रमबद्ध करें"

msgid "Product photo showing this surface/angle."
msgstr "इस सतह/कोण को दिखाने वाला उत्पाद फोटो।"

msgid "Dimension Unit"
msgstr "आयाम इकाई"

msgid "Design Area Width"
msgstr "डिज़ाइन क्षेत्र की चौड़ाई"

msgid "Width of the printable/designable area."
msgstr "मुद्रित/डिज़ाइन करने योग्य क्षेत्र की चौड़ाई।"

msgid "Design Area Height"
msgstr "डिज़ाइन क्षेत्र की ऊंचाई"

msgid "Height of the printable/designable area."
msgstr "मुद्रित/डिज़ाइन करने योग्य क्षेत्र की ऊंचाई।"

msgid "Zone X Position (%)"
msgstr "क्षेत्र X स्थिति (%)"

msgid ""
"Horizontal position of design zone on the mockup image, as percentage from "
"left."
msgstr "मॉकअप छवि पर डिज़ाइन क्षेत्र की क्षैतिज स्थिति, बाएं से प्रतिशत के रूप में।"

msgid "Zone Y Position (%)"
msgstr "क्षेत्र Y स्थिति (%)"

msgid ""
"Vertical position of design zone on the mockup image, as percentage from top."
msgstr "मॉकअप छवि पर डिज़ाइन क्षेत्र की ऊर्ध्वाधर स्थिति, ऊपर से प्रतिशत के रूप में।"

msgid "Zone Width (%)"
msgstr "क्षेत्र चौड़ाई (%)"

msgid "Width of design zone on the mockup image, as percentage of image width."
msgstr "मॉकअप छवि पर डिज़ाइन क्षेत्र की चौड़ाई, छवि की चौड़ाई के प्रतिशत के रूप में।"

msgid "Zone Height (%)"
msgstr "क्षेत्र की ऊंचाई (%)"

msgid ""
"Height of design zone on the mockup image, as percentage of image height."
msgstr "मॉकअप छवि पर डिज़ाइन क्षेत्र की ऊँचाई, छवि की ऊँचाई के प्रतिशत के रूप में।"

msgid "Minimum DPI"
msgstr "न्यूनतम DPI"

msgid "Minimum dots-per-inch for acceptable print quality."
msgstr "अमी छाप की गुणवत्ता के लिए प्रति इंच न्यूनतम डॉट।"

msgid "Recommended DPI"
msgstr "सिफारिश की गई DPI"

msgid "Recommended dots-per-inch for optimal print quality."
msgstr "अप्रिंट की गुणवत्ता के लिए अनुशंसित डॉट्स प्रति इंच।"

msgid "Bleed (mm)"
msgstr "ब्लीड (मिमी)"

msgid "Extra margin outside design area for printing bleed."
msgstr "डिज़ाइन क्षेत्र के बाहर अतिरिक्त किनारा मुद्रण रक्त के लिए।"

msgid "Max Colors"
msgstr "अधिकतम रंग"

msgid ""
"Maximum number of colors allowed (for screen printing). Leave blank for "
"unlimited."
msgstr "स्क्रीन प्रिंटिंग के लिए अनुमत रंगों की अधिकतम संख्या। असीमित के लिए खाली छोड़ें।"

msgid "Background Color"
msgstr "पृष्ठभूमि रंग"

msgid "Default background color for the design canvas."
msgstr "डिज़ाइन कैनवास के लिए डिफ़ॉल्ट पृष्ठभूमि रंग।"

msgid "Override: allow text on this surface. Blank = inherit from config."
msgstr "ओवरराइड: इस सतह पर टेक्स्ट की अनुमति दें। खाली = कॉन्फ़िग से अनुग्रह लें।"

msgid ""
"Override: allow image uploads on this surface. Blank = inherit from config."
msgstr "ओवरराइड: इस सतह पर छवि अपलोड की अनुमति दें। खाली = कॉन्फ़िग से अनुग्रह लें।"

msgid "Override: allow clipart on this surface. Blank = inherit from config."
msgstr "ओवरराइड: इस सतह पर क्लिपआर्ट की अनुमति दें। खाली = सेटिंग से विरासत लें।"

msgid "Max Design Elements"
msgstr "अधिकतम डिज़ाइन तत्व"

msgid "Maximum total design elements on this surface. Blank = no limit."
msgstr "इस सतह पर अधिकतम कुल डिज़ाइन तत्व। खाली = कोई सीमा नहीं।"

msgid "Enabled"
msgstr "सक्षम"

msgid "Product Surface"
msgstr "उत्पाद सतह"

msgid "Product Surfaces"
msgstr "उत्पाद सतहें"

msgid "Template Name"
msgstr "टेम्पलेट नाम"

msgid "Description"
msgstr "विवरण"

msgid "Category"
msgstr "श्रेणी"

msgid "e.g. \"Birthday\", \"Business\", \"Holiday\""
msgstr "जैसे, \"जन्मदिन\", \"व्यवसाय\", \"उत्सव\""

msgid "Design Data"
msgstr "डिज़ाइन डेटा"

msgid "Full Fabric.js canvas state for each surface."
msgstr "प्रत्येक सतह के लिए पूरा Fabric.js कैनवास स्थिति।"

msgid "Thumbnail"
msgstr "थंबनेल"

msgid "Active"
msgstr "सक्रिय"

msgid "Design Template"
msgstr "डिज़ाइन टेम्पलेट"

msgid "Design Templates"
msgstr "डिज़ाइन टेम्पलेट्स"

msgid "Text"
msgstr "पाठ"

msgid "Image"
msgstr "चित्र"

msgid "Clipart"
msgstr "क्लिपआर्ट"

msgid "Template"
msgstr "टेम्पलेट"

msgid "Surface"
msgstr "सतह"

msgid "Element Type"
msgstr "तत्व प्रकार"

msgid "Element Data"
msgstr "तत्व डेटा"

msgid "Fabric.js object properties (position, size, rotation, content)."
msgstr "Fabric.js वस्तु गुण (स्थिति, आकार, घूर्णन, सामग्री)."

msgid "Lock Position"
msgstr "स्थिति बंद करें"

msgid "Prevent customers from moving this element."
msgstr "ग्राहकों को इस तत्व को चलाने से रोकें।"

msgid "Lock Size"
msgstr "आकार बंद करें"

msgid "Prevent customers from resizing this element."
msgstr "ग्राहकों को इस तत्व के आकार को बदलने से रोकें।"

msgid "Lock Content"
msgstr "सामग्री बंद करें"

msgid "Prevent customers from editing text or replacing the image."
msgstr "ग्राहकों को टेक्स्ट को संपादित करने या इमेज को बदलने से रोकें।"

msgid "Lock Delete"
msgstr "हटाएं बंद करें"

msgid "Prevent customers from removing this element."
msgstr "ग्राहकों को इस तत्व को हटाने से रोकें।"

msgid "Lock Rotation"
msgstr "रोटेशन बंद करें"

msgid "Prevent customers from rotating this element."
msgstr "ग्राहकों को इस तत्व को घुमाने से रोकें।"

msgid "Z-order for layering elements."
msgstr "तत्वों के लेयरिंग के लिए Z-क्रम।"

msgid "Design Template Element"
msgstr "डिज़ाइन टेम्पलेट तत्व"

msgid "Design Template Elements"
msgstr "डिज़ाइन टेम्पलेट तत्व"

msgid "Category Name"
msgstr "श्रेणी का नाम"

msgid "Icon"
msgstr "आइकॉन"

msgid "CSS icon class (e.g. Font Awesome class)."
msgstr "CSS आइकन क्लास (उदाहरण के लिए फॉंट अवार्म वर्ग)."

msgid "Clipart Category"
msgstr "क्लिपआर्ट श्रेणी"

msgid "Clipart Categories"
msgstr "क्लिपआर्ट श्रेणियाँ"

msgid "Available to All Products"
msgstr "सभी उत्पादों के लिए उपलब्ध"

msgid "Specific Product Only"
msgstr "केवल विशिष्ट उत्पाद"

msgid "Name"
msgstr "नाम"

msgid "Image Asset"
msgstr "चित्र संसाधन"

msgid "PNG or SVG file for the clipart."
msgstr "क्लिपआर्ट के लिए PNG या SVG फ़ाइल।"

msgid "Scope"
msgstr "सीमा"

msgid "Only set when scope is 'Specific Product Only'."
msgstr "'केवल विशिष्ट उत्पाद' होने पर केवल सेट करें।"

msgid "Tags"
msgstr "टैग"

msgid ""
"Searchable tags for this clipart. e.g. [\"star\", \"decoration\", \"gold\"]"
msgstr "इस क्लिपआर्ट के लिए खोजते टैग। उदा. [\"star\", \"decoration\", \"gold\"]"

msgid "Clipart Asset"
msgstr "क्लिपआर्ट संसाधन"

msgid "Clipart Assets"
msgstr "क्लिपआर्ट संसाधन"

msgid "Font Name"
msgstr "फॉन्ट नाम"

msgid "Display name shown in the font picker."
msgstr "फॉंट पिकर में दिखाया गया नाम।"

msgid "Font Family"
msgstr "फॉन्ट परिवार"

msgid "CSS font-family name used in the editor."
msgstr "संपादक में उपयोग किया गया CSS फॉंट-परिवार नाम।"

msgid "WOFF2 or TTF file for regular weight."
msgstr "सामान्य वजन के लिए WOFF2 या TTF फ़ाइल।"

msgid "WOFF2 or TTF file for bold weight."
msgstr "मोटा वजन के लिए WOFF2 या TTF फ़ाइल।"

msgid "Italic"
msgstr "इतालवी"

msgid "WOFF2 or TTF file for italic style."
msgstr "इतालवी स्टाइल के लिए WOFF2 या TTF फ़ाइल।"

msgid "Bold Italic"
msgstr "मोटा इतालवी"

msgid "WOFF2 or TTF file for bold italic style."
msgstr "वाउफ़ 2 या टीएफ़ फ़ाइल बोल्ड इटैलिक स्टाइल के लिए।"

msgid "System Font"
msgstr "सिस्टम फॉन्ट"

msgid "If true, this font is pre-installed and no file upload is needed."
msgstr ""
"यदि सत्य है, तो यह फ़ॉन्ट पहले से इंस्टॉल किया गया है और कोई फ़ाइल अपलोड आवश्यक नहीं है।"

msgid "Custom Font"
msgstr "कस्टम फॉन्ट"

msgid "Custom Fonts"
msgstr "कस्टम फॉन्ट्स"

msgid "User"
msgstr "उपयोगकर्ता"

msgid "Design Name"
msgstr "डिज़ाइन नाम"

msgid "Full Fabric.js canvas state per surface."
msgstr "प्रत्येक सतह के लिए पूर्ण फैब्रिक.जएस कैन्वास स्थिति।"

msgid "Thumbnails"
msgstr "थंबनेल"

msgid ""
"Per-surface thumbnail MediaAsset IDs. e.g. {\"front\": 123, \"back\": 456}"
msgstr ""
"प्रति-सतह थंबनेल मीडिया संसाधक IDs। उदाहरण के लिए {\"front\": 123, \"back\": 456}"

msgid "Saved Design"
msgstr "सहेजा गया डिज़ाइन"

msgid "Saved Designs"
msgstr "सहेजे गए डिज़ाइन"

msgid "Token"
msgstr "टोकन"

msgid "Unique reference used by the cart system."
msgstr "कार्ट प्रणाली द्वारा उपयोग किया गया अद्वितीय संदर्भ।"

msgid "Session Key"
msgstr "सेशन की"

msgid "Session key for anonymous users."
msgstr "अनामिक उपयोगकर्ताओं के लिए सेशन की कुंजी।"

msgid "Per-surface thumbnail MediaAsset IDs."
msgstr "प्रति-सतह थंबनेल मीडिया संपत्ति IDs।"

msgid "Pricing Breakdown"
msgstr "मूल्य वितरण"

msgid "Calculated price components for this design."
msgstr "इस डिज़ाइन के लिए गणना की गई कीमत घटक।"

msgid "Expires At"
msgstr "मूल्य वितरण"

msgid "Auto-cleanup after this datetime."
msgstr "इस डेटटाइम के बाद स्वचालित सफाई।"

msgid "Design Draft"
msgstr "डिज़ाइन ड्राफ्ट"

msgid "Design Drafts"
msgstr "डिज़ाइन ड्राफ्ट्स"

msgid "Order Item"
msgstr "आदेश आइटम"

msgid "Frozen design state at time of order."
msgstr "आदेश के समय फ्रीज किया गया डिज़ाइन स्थिति।"

msgid "Rendered Images"
msgstr "रेंडर किए गए चित्र"

msgid "Per-surface preview MediaAsset IDs. e.g. {\"front\": 123}"
