msgstr "Dữ liệu hình ảnh không hợp lệ"

#, python-format
msgid "Template Editor: %(product)s"
msgstr "Trình soạn thảo Mẫu: %(product)s"

msgid "Customizable Products"
msgstr "Sản phẩm tùy chỉnh"

msgid "Canvas Editor"
msgstr "Chỉnh sửa khung vẽ"

msgid "Simple Form"
msgstr "Biểu mẫu đơn giản"

msgid "Product"
msgstr "Sản phẩm"

msgid "Enable Visual Editor"
msgstr "Kích hoạt trình chỉnh sửa trực quan"

msgid ""
"When enabled, customers see the visual design editor on the product page."
msgstr ""
"Khi được bật, khách hàng sẽ thấy trình chỉnh sửa thiết kế trực quan trên "
"trang sản phẩm."

msgid "Editor Mode"
msgstr "Chế độ chỉnh sửa"

msgid ""
"Canvas: full visual editor with Fabric.js. Simple: traditional form fields "
"only."
msgstr ""
"Canvas: trình chỉnh sửa trực quan đầy đủ với Fabric.js. Simple: chỉ các "
"trường biểu mẫu truyền thống."

msgid "Allow Image Upload"
msgstr "Cho phép tải lên hình ảnh"

msgid "Allow customers to upload their own images."
msgstr "Cho phép khách hàng tải lên hình ảnh của họ."

msgid "Allow Text"
msgstr "Cho phép văn bản"

msgid "Allow customers to add text elements."
msgstr "Cho phép khách hàng thêm các phần tử văn bản."

msgid "Allow Clipart"
msgstr "Cho phép clipart"

msgid "Allow customers to use clipart from the asset library."
msgstr "Cho phép khách hàng sử dụng hình minh họa từ thư viện tài sản."

msgid "Max Uploads Per Surface"
msgstr "Số lượng tải lên tối đa trên mỗi bề mặt"

msgid "Maximum number of uploaded images allowed per design surface."
msgstr "Số lượng tối đa hình ảnh được phép tải lên cho mỗi bề mặt thiết kế."

msgid "Max Upload Size (MB)"
msgstr "Kích thước tải lên tối đa (MB)"

msgid "Allowed Upload Types"
msgstr "Loại tải lên được phép"

msgid "File extensions allowed for upload. e.g. [\"jpg\", \"png\", \"svg\"]"
msgstr ""
"Các phần mở rộng tệp được phép tải lên. Ví dụ: [\"jpg\", \"png\", \"svg\"]"

msgid "Base Design Fee"
msgstr "Phí thiết kế cơ bản"

msgid "Flat fee added when any customization is applied."
msgstr "Phí cố định được thêm khi áp dụng bất kỳ tùy chỉnh nào."

msgid "Per Surface Fee"
msgstr "Phí theo bề mặt"

msgid "Additional fee for each design surface used beyond the first."
msgstr ""
"Phí phụ thêm cho mỗi bề mặt thiết kế được sử dụng ngoài bề mặt đầu tiên."

msgid "Per Upload Fee"
msgstr "Phí tải lên"

msgid "Fee charged for each customer-uploaded image."
msgstr "Phí được tính cho mỗi hình ảnh được khách hàng tải lên."

msgid "Per Text Fee"
msgstr "Phí văn bản"

msgid "Fee charged for each text element added."
msgstr "Phí được tính cho mỗi phần tử văn bản được thêm vào."

msgid "Product Design Configuration"
msgstr "Cấu hình thiết kế sản phẩm"

msgid "Product Design Configurations"
msgstr "Các cấu hình thiết kế sản phẩm"

msgid "Millimeters"
msgstr "Milimét"

msgid "Inches"
msgstr "Inch"

msgid "Pixels"
msgstr "Đơn vị pixel"

msgid "Design Configuration"
msgstr "Cấu hình thiết kế"

msgid "e.g. \"Front\", \"Back\", \"Left Sleeve\""
msgstr "Ví dụ: \"Front\", \"Back\", \"Left Sleeve\""

msgid "Slug"
msgstr "Slug"

msgid "Sort Order"
msgstr "Thứ tự sắp xếp"

msgid "Product photo showing this surface/angle."
msgstr "Hình ảnh sản phẩm hiển thị mặt/góc này."

msgid "Dimension Unit"
msgstr "Đơn vị kích thước"

msgid "Design Area Width"
msgstr "Chiều rộng khu vực thiết kế"

msgid "Width of the printable/designable area."
msgstr "Chiều rộng của khu vực in/thiết kế được."

msgid "Design Area Height"
msgstr "Chiều cao khu vực thiết kế"

msgid "Height of the printable/designable area."
msgstr "Chiều cao của khu vực in/thiết kế được."

msgid "Zone X Position (%)"
msgstr "Vị trí X của khu vực (%)"

msgid ""
"Horizontal position of design zone on the mockup image, as percentage from "
"left."
msgstr ""
"Vị trí ngang của khu vực thiết kế trên hình ảnh mô phỏng, tính bằng phần "
"trăm từ bên trái."

msgid "Zone Y Position (%)"
msgstr "Vị trí Y của khu vực (%)"

msgid ""
"Vertical position of design zone on the mockup image, as percentage from top."
msgstr ""
"Vị trí dọc của khu vực thiết kế trên hình ảnh mô phỏng, tính bằng phần trăm "
"từ phía trên."

msgid "Zone Width (%)"
msgstr "Chiều rộng khu vực (%)"

msgid "Width of design zone on the mockup image, as percentage of image width."
msgstr ""
"Chiều rộng của khu vực thiết kế trên hình ảnh mô phỏng, tính bằng phần trăm "
"chiều rộng của hình ảnh."

msgid "Zone Height (%)"
msgstr "Chiều cao khu vực (%)"

msgid ""
"Height of design zone on the mockup image, as percentage of image height."
msgstr ""
"Chiều cao của khu vực thiết kế trên hình ảnh mô phỏng, tính bằng phần trăm "
"chiều cao của hình ảnh."

msgid "Minimum DPI"
msgstr "Độ phân giải tối thiểu"

msgid "Minimum dots-per-inch for acceptable print quality."
msgstr "Số lượng điểm mỗi inch tối thiểu để đạt chất lượng in chấp nhận được."

msgid "Recommended DPI"
msgstr "Độ phân giải được khuyến nghị"

msgid "Recommended dots-per-inch for optimal print quality."
msgstr "Số lượng điểm mỗi inch được khuyến nghị để đạt chất lượng in tối ưu."

msgid "Bleed (mm)"
msgstr "Bleed (mm)"

msgid "Extra margin outside design area for printing bleed."
msgstr "Khoảng cách bổ sung bên ngoài khu vực thiết kế để in chảy mực."

msgid "Max Colors"
msgstr "Số màu tối đa"

msgid ""
"Maximum number of colors allowed (for screen printing). Leave blank for "
"unlimited."
msgstr ""
"Số lượng màu tối đa được phép (dành cho in lưới). Để trống để không giới hạn."

msgid "Background Color"
msgstr "Màu nền"

msgid "Default background color for the design canvas."
msgstr "Màu nền mặc định cho khung thiết kế."

msgid "Override: allow text on this surface. Blank = inherit from config."
msgstr ""
"Ghi đè: cho phép thêm văn bản trên bề mặt này. Để trống = kế thừa từ cấu "
"hình."

msgid ""
"Override: allow image uploads on this surface. Blank = inherit from config."
msgstr ""
"Ghi đè: cho phép tải lên hình ảnh trên bề mặt này. Để trống = kế thừa từ cấu "
"hình."

msgid "Override: allow clipart on this surface. Blank = inherit from config."
msgstr ""
"Ghi đè: cho phép thêm hình minh họa trên bề mặt này. Để trống = kế thừa từ "
"cấu hình."

msgid "Max Design Elements"
msgstr "Số phần tử thiết kế tối đa"

msgid "Maximum total design elements on this surface. Blank = no limit."
msgstr ""
"Số lượng phần tử thiết kế tối đa trên bề mặt này. Để trống = không giới hạn."

msgid "Enabled"
msgstr "Bật"

