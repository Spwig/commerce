msgstr "Thiết lập Trình soạn thảo Thiết kế: %(product)s"

msgid "Invalid JSON"
msgstr "JSON không hợp lệ"

msgid "Media asset not found"
msgstr "Không tìm thấy tài nguyên phương tiện"

msgid "No image data provided"
msgstr "Không có dữ liệu hình ảnh được cung cấp"

