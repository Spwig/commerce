msgstr "Tên mẫu"

msgid "Description"
msgstr "Mô tả"

msgid "Category"
msgstr "Danh mục"

msgid "e.g. \"Birthday\", \"Business\", \"Holiday\""
msgstr "Ví dụ: \"Birthday\", \"Business\", \"Holiday\""

msgid "Design Data"
msgstr "Dữ liệu thiết kế"

msgid "Full Fabric.js canvas state for each surface."
msgstr "Trạng thái đầy đủ của khung Fabric.js cho mỗi bề mặt."

