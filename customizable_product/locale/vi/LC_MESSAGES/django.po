msgstr "Văn bản"

msgid "Image"
msgstr "Hình ảnh"

msgid "Clipart"
msgstr "Hình minh họa"

msgid "Template"
msgstr "Mẫu"

msgid "Surface"
msgstr "Bề mặt"

msgid "Element Type"
msgstr "Loại phần tử"

msgid "Element Data"
msgstr "Dữ liệu phần tử"

msgid "Fabric.js object properties (position, size, rotation, content)."
msgstr ""
"Tính chất của đối tượng Fabric.js (vị trí, kích thước, góc xoay, nội dung)."

msgid "Lock Position"
msgstr "Khóa vị trí"

msgid "Prevent customers from moving this element."
msgstr "Ngăn khách hàng di chuyển phần tử này."

msgid "Lock Size"
msgstr "Khóa kích thước"

msgid "Prevent customers from resizing this element."
msgstr "Ngăn khách hàng thay đổi kích thước phần tử này."

msgid "Lock Content"
msgstr "Khóa nội dung"

msgid "Prevent customers from editing text or replacing the image."
msgstr "Ngăn khách hàng chỉnh sửa văn bản hoặc thay thế hình ảnh."

msgid "Lock Delete"
msgstr "Khóa xóa"

msgid "Prevent customers from removing this element."
msgstr "Ngăn khách hàng xóa phần tử này."

msgid "Lock Rotation"
msgstr "Khóa xoay"

msgid "Prevent customers from rotating this element."
msgstr "Ngăn khách hàng xoay phần tử này."

msgid "Z-order for layering elements."
msgstr "Thứ tự Z để xếp tầng các phần tử."

msgid "Design Template Element"
msgstr "Phần tử mẫu thiết kế"

msgid "Design Template Elements"
msgstr "Các phần tử mẫu thiết kế"

msgid "Category Name"
msgstr "Tên danh mục"

msgid "Icon"
msgstr "Biểu tượng"

msgid "CSS icon class (e.g. Font Awesome class)."
msgstr "Lớp biểu tượng CSS (ví dụ: lớp Font Awesome)."

msgid "Clipart Category"
msgstr "Danh mục hình minh họa"

msgid "Clipart Categories"
msgstr "Các danh mục hình minh họa"

msgid "Available to All Products"
msgstr "Có sẵn cho tất cả sản phẩm"

msgid "Specific Product Only"
msgstr "Chỉ dành cho sản phẩm cụ thể"

msgid "Name"
msgstr "Tên"

msgid "Image Asset"
msgstr "Tài nguyên hình ảnh"

msgid "PNG or SVG file for the clipart."
msgstr "Tập tin PNG hoặc SVG cho hình minh họa."

msgid "Scope"
msgstr "Phạm vi"

msgid "Only set when scope is 'Specific Product Only'."
msgstr "Chỉ đặt khi phạm vi là 'Chỉ sản phẩm cụ thể'."

msgid "Tags"
msgstr "Thẻ"

msgid ""
"Searchable tags for this clipart. e.g. [\"star\", \"decoration\", \"gold\"]"
msgstr ""
"Nhãn tìm kiếm cho hình minh họa này. Ví dụ: [\"star\", \"decoration\", "
"\"gold\"]"

msgid "Clipart Asset"
msgstr "Tài nguyên minh họa"

msgid "Clipart Assets"
msgstr "Các tài nguyên minh họa"

msgid "Font Name"
msgstr "Tên phông chữ"

msgid "Display name shown in the font picker."
msgstr "Tên hiển thị trong trình chọn phông chữ."

msgid "Font Family"
msgstr "Gia đình phông chữ"

msgid "CSS font-family name used in the editor."
msgstr "Tên font-family CSS được sử dụng trong trình chỉnh sửa."

msgid "WOFF2 or TTF file for regular weight."
msgstr "Tập tin WOFF2 hoặc TTF cho trọng lượng thường."

msgid "WOFF2 or TTF file for bold weight."
msgstr "Tệp WOFF2 hoặc TTF cho kiểu chữ đậm."

msgid "Italic"
msgstr "Kéo dài"

msgid "WOFF2 or TTF file for italic style."
msgstr "Tệp WOFF2 hoặc TTF cho kiểu chữ nghiêng."

msgid "Bold Italic"
msgstr "Đậm kéo dài"

msgid "WOFF2 or TTF file for bold italic style."
msgstr "Tệp WOFF2 hoặc TTF cho kiểu chữ đậm và nghiêng."

msgid "System Font"
msgstr "Phông chữ hệ thống"

msgid "If true, this font is pre-installed and no file upload is needed."
msgstr "Nếu đúng, font này đã được cài đặt sẵn và không cần tải tệp lên."

msgid "Custom Font"
msgstr "Phông chữ tùy chỉnh"

msgid "Custom Fonts"
msgstr "Các phông chữ tùy chỉnh"

msgid "User"
msgstr "Người dùng"

msgid "Design Name"
msgstr "Tên thiết kế"

msgid "Full Fabric.js canvas state per surface."
msgstr "Trạng thái toàn bộ Fabric.js canvas theo từng bề mặt."

msgid "Thumbnails"
msgstr "Ảnh thu nhỏ"

msgid ""
"Per-surface thumbnail MediaAsset IDs. e.g. {\"front\": 123, \"back\": 456}"
msgstr ""
"ID MediaAsset của ảnh thu nhỏ theo từng bề mặt. Ví dụ: {\"front\": 123, "
"\"back\": 456}"

msgid "Saved Design"
msgstr "Thiết kế đã lưu"

msgid "Saved Designs"
msgstr "Các thiết kế đã lưu"

msgid "Token"
msgstr "Mã thông báo"

msgid "Unique reference used by the cart system."
msgstr "Tham chiếu duy nhất được hệ thống giỏ hàng sử dụng."

msgid "Session Key"
msgstr "Khóa phiên"

msgid "Session key for anonymous users."
msgstr "Khóa phiên cho người dùng ẩn danh."

msgid "Per-surface thumbnail MediaAsset IDs."
msgstr "ID tài sản phương tiện thu nhỏ theo bề mặt."

msgid "Pricing Breakdown"
msgstr "Phân tích giá cả"

msgid "Calculated price components for this design."
msgstr "Các thành phần giá được tính toán cho thiết kế này."

msgid "Expires At"
msgstr "Hết hạn lúc"

msgid "Auto-cleanup after this datetime."
msgstr "Tự động dọn dẹp sau thời điểm này."

msgid "Design Draft"
msgstr "Bản nháp thiết kế"

msgid "Design Drafts"
msgstr "Các bản nháp thiết kế"

msgid "Order Item"
msgstr "Mục đặt hàng"

msgid "Frozen design state at time of order."
msgstr "Trạng thái thiết kế cố định tại thời điểm đặt hàng."

msgid "Rendered Images"
msgstr "Hình ảnh đã render"

msgid "Per-surface preview MediaAsset IDs. e.g. {\"front\": 123}"
msgstr "ID MediaAsset xem trước theo bề mặt. Ví dụ: {\"front\": 123}"

msgid "Fulfillment Files"
msgstr "Tệp giao hàng"

msgid "High-resolution composite MediaAsset IDs for printing."
msgstr "ID MediaAsset độ phân giải cao dùng để in ấn."

msgid "Rendered"
msgstr "Đã render"

msgid "Whether high-resolution fulfillment files have been generated."
msgstr "Liệu các tệp hoàn thành độ phân giải cao đã được tạo chưa."

msgid "Render Completed At"
msgstr "Render hoàn tất lúc"

msgid "Design Snapshot"
msgstr "Ảnh chụp thiết kế"

msgid "Design Snapshots"
msgstr "Các ảnh chụp thiết kế"

msgid "Design Editor Setup"
msgstr "Cài đặt trình chỉnh sửa thiết kế"

msgid "Home"
msgstr "Trang chủ"

msgid "Products"
msgstr "Sản phẩm"

msgid "Editor Enabled"
msgstr "Trình chỉnh sửa được bật"

msgid "Back to Product"
msgstr "Quay lại sản phẩm"

msgid "Fonts"
msgstr "Chữ viết"

msgid "Settings"
msgstr "Cài đặt"

msgid ""
"Define the designable areas of your product. Each surface represents a face "
"or side where customers can place their designs."
msgstr ""
"Xác định các khu vực có thể tùy chỉnh của sản phẩm của bạn. Mỗi bề mặt đại "
"diện cho một mặt hoặc cạnh mà khách hàng có thể đặt thiết kế của họ."

msgid ""
"Create pre-made designs that customers can start from and customize. "
"Templates can have locked elements that customers cannot change."
msgstr ""
"Tạo các thiết kế đã được làm sẵn mà khách hàng có thể bắt đầu và tùy chỉnh. "
"Mẫu có thể chứa các phần tử bị khóa mà khách hàng không thể thay đổi."

msgid "Clipart Library"
msgstr "Thư viện clipart"

msgid ""
"Manage clipart categories and assets that customers can use in their "
"designs. Clipart can be global (all products) or product-specific."
msgstr ""
"Quản lý các danh mục và tài nguyên clipart mà khách hàng có thể sử dụng "
"trong thiết kế của họ. Clipart có thể là toàn cục (tất cả sản phẩm) hoặc cụ "
"thể cho từng sản phẩm."

msgid "Clipart categories and assets are managed from the admin panel:"
msgstr ""
"Các danh mục và tài sản clipart được quản lý từ bảng điều khiển quản trị:"

msgid "Manage Categories"
msgstr "Quản lý danh mục"

msgid "Manage Assets"
msgstr "Quản lý tài sản"

msgid ""
"Upload custom fonts for customers to use when adding text to their designs. "
"WOFF2 or TTF format recommended."
msgstr ""
"Tải lên các font chữ tùy chỉnh để khách hàng sử dụng khi thêm văn bản vào "
"thiết kế của họ. Khuyến nghị định dạng WOFF2 hoặc TTF."

msgid "Manage Fonts"
msgstr "Quản lý phông chữ"

msgid "Design Pricing"
msgstr "Thiết kế giá"

msgid ""
"Set pricing rules for customizations. Fees are added on top of the product's "
"base price."
msgstr ""
"Thiết lập các quy tắc định giá cho tùy chỉnh. Phí sẽ được cộng thêm lên giá "
"cơ bản của sản phẩm."

msgid "Fee for each additional surface used beyond the first."
msgstr "Phí cho mỗi bề mặt bổ sung được sử dụng ngoài bề mặt đầu tiên."

msgid "Fee for each customer-uploaded image."
msgstr "Phí cho mỗi hình ảnh do khách hàng tải lên."

msgid "Per Text Element Fee"
msgstr "Phí theo từng phần tử văn bản"

msgid "Fee for each text element added to the design."
msgstr "Phí cho mỗi phần tử văn bản được thêm vào thiết kế."

msgid "Save Pricing"
msgstr "Lưu giá"

msgid "Editor Settings"
