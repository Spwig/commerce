msgstr "Editor de lienzo"

msgid "Simple Form"
msgstr "Formulario simple"

msgid "Product"
msgstr "Producto"

msgid "Enable Visual Editor"
msgstr "Habilitar editor visual"

msgid ""
"When enabled, customers see the visual design editor on the product page."
msgstr ""
"Cuando está habilitado, los clientes ven el editor de diseño visual en la "
"página del producto."

msgid "Editor Mode"
msgstr "Modo editor"

msgid ""
"Canvas: full visual editor with Fabric.js. Simple: traditional form fields "
"only."
msgstr ""
"Canvas: editor visual completo con Fabric.js. Simple: solo campos de "
"formulario tradicionales."

msgid "Allow Image Upload"
msgstr "Permitir carga de imagen"

msgid "Allow customers to upload their own images."
msgstr "Permitir que los clientes suban sus propias imágenes."

msgid "Allow Text"
msgstr "Permitir texto"

msgid "Allow customers to add text elements."
msgstr "Permitir que los clientes agreguen elementos de texto."

msgid "Allow Clipart"
msgstr "Permitir clipart"

msgid "Allow customers to use clipart from the asset library."
msgstr "Permitir que los clientes usen imágenes de la biblioteca de activos."

msgid "Max Uploads Per Surface"
msgstr "Máximo de cargas por superficie"

msgid "Maximum number of uploaded images allowed per design surface."
msgstr "Número máximo de imágenes subidas permitidas por superficie de diseño."

msgid "Max Upload Size (MB)"
msgstr "Tamaño máximo de carga (MB)"

msgid "Allowed Upload Types"
msgstr "Tipos de carga permitidos"

msgid "File extensions allowed for upload. e.g. [\"jpg\", \"png\", \"svg\"]"
msgstr ""
"Extensiones de archivo permitidas para subir. p. ej. [\"jpg\", \"png\", "
"\"svg\"]"

msgid "Base Design Fee"
msgstr "Tarifa de diseño base"

msgid "Flat fee added when any customization is applied."
msgstr "Tarifa plana agregada cuando se aplica cualquier personalización."

msgid "Per Surface Fee"
msgstr "Tarifa por superficie"

msgid "Additional fee for each design surface used beyond the first."
msgstr ""
"Tarifa adicional por cada superficie de diseño utilizada más allá de la "
"primera."

msgid "Per Upload Fee"
msgstr "Tarifa por subida"

msgid "Fee charged for each customer-uploaded image."
msgstr "Tarifa cobrada por cada imagen subida por el cliente."

msgid "Per Text Fee"
msgstr "Tarifa por texto"

msgid "Fee charged for each text element added."
msgstr "Tarifa cobrada por cada elemento de texto agregado."

msgid "Product Design Configuration"
msgstr "Configuración del diseño del producto"

msgid "Product Design Configurations"
msgstr "Configuraciones de diseño del producto"

msgid "Millimeters"
msgstr "Milímetros"

msgid "Inches"
msgstr "Pulgadas"

msgid "Pixels"
msgstr "Píxeles"

msgid "Design Configuration"
msgstr "Configuración del diseño"

msgid "e.g. \"Front\", \"Back\", \"Left Sleeve\""
msgstr "p. ej. \"Front\", \"Back\", \"Left Sleeve\""

msgid "Slug"
msgstr "Slug"

msgid "Sort Order"
msgstr "Orden de clasificación"

msgid "Product photo showing this surface/angle."
msgstr "Foto del producto que muestra esta superficie/ángulo."

msgid "Dimension Unit"
msgstr "Unidad de dimensión"

msgid "Design Area Width"
msgstr "Ancho del área de diseño"

msgid "Width of the printable/designable area."
msgstr "Ancho del área imprimible/diseñable."

msgid "Design Area Height"
msgstr "Altura del área de diseño"

msgid "Height of the printable/designable area."
msgstr "Altura del área imprimible/diseñable."

msgid "Zone X Position (%)"
msgstr "Posición X de la zona (%)"

msgid ""
"Horizontal position of design zone on the mockup image, as percentage from "
"left."
msgstr ""
"Posición horizontal de la zona de diseño en la imagen de presentación, "
"expresada como porcentaje desde la izquierda."

msgid "Zone Y Position (%)"
msgstr "Posición Y de la zona (%)"

msgid ""
"Vertical position of design zone on the mockup image, as percentage from top."
msgstr ""
"Posición vertical de la zona de diseño en la imagen de presentación, "
"expresada como porcentaje desde la parte superior."

msgid "Zone Width (%)"
msgstr "Ancho de la zona (%)"

msgid "Width of design zone on the mockup image, as percentage of image width."
msgstr ""
"Ancho de la zona de diseño en la imagen de presentación, expresado como "
"porcentaje del ancho de la imagen."

msgid "Zone Height (%)"
msgstr "Altura de la zona (%)"

msgid ""
"Height of design zone on the mockup image, as percentage of image height."
msgstr ""
"Altura de la zona de diseño en la imagen de presentación, expresada como "
"porcentaje de la altura de la imagen."

msgid "Minimum DPI"
msgstr "DPI mínima"

msgid "Minimum dots-per-inch for acceptable print quality."
msgstr "Mínimo de puntos por pulgada para una calidad de impresión aceptable."

msgid "Recommended DPI"
msgstr "DPI recomendada"

msgid "Recommended dots-per-inch for optimal print quality."
msgstr ""
"Recomendado de puntos por pulgada para una calidad de impresión óptima."

msgid "Bleed (mm)"
msgstr "Bleed (mm)"

msgid "Extra margin outside design area for printing bleed."
msgstr ""
"Margen adicional fuera del área de diseño para el sangrado de impresión."

msgid "Max Colors"
msgstr "Máximo de colores"

msgid ""
"Maximum number of colors allowed (for screen printing). Leave blank for "
"unlimited."
msgstr ""
"Número máximo de colores permitidos (para impresión en tela). Dejar en "
"blanco para ilimitado."

msgid "Background Color"
msgstr "Color de fondo"

msgid "Default background color for the design canvas."
msgstr "Color de fondo predeterminado para el lienzo del diseño."

msgid "Override: allow text on this surface. Blank = inherit from config."
msgstr ""
"Sobrescribir: permitir texto en esta superficie. En blanco = heredar de la "
"configuración."

msgid ""
"Override: allow image uploads on this surface. Blank = inherit from config."
msgstr ""
"Sobrescribir: permitir subida de imágenes en esta superficie. En blanco = "
"heredar de la configuración."

msgid "Override: allow clipart on this surface. Blank = inherit from config."
msgstr ""
"Sobrescribir: permitir clipart en esta superficie. En blanco = heredar de la "
"configuración."

msgid "Max Design Elements"
msgstr "Máximo de elementos de diseño"

msgid "Maximum total design elements on this surface. Blank = no limit."
msgstr ""
"Número máximo total de elementos de diseño en esta superficie. En blanco = "
"sin límite."

