msgstr "오류가 발생했습니다"

#, python-format
msgid "Design Editor Setup: %(product)s"
msgstr "디자인 편집기 설정: %(product)s"

msgid "Invalid JSON"
msgstr "잘못된 JSON"

msgid "Media asset not found"
msgstr "미디어 자산을 찾을 수 없습니다"

msgid "No image data provided"
msgstr "이미지 데이터가 제공되지 않았습니다"

msgid "Invalid image data"
msgstr "잘못된 이미지 데이터"

#, python-format
msgid "Template Editor: %(product)s"
msgstr "템플릿 편집기: %(product)s"

msgid "Customizable Products"
msgstr "사용자 정의 제품"

msgid "Canvas Editor"
msgstr "캔버스 편집기"

msgid "Simple Form"
msgstr "간단한 양식"

msgid "Product"
msgstr "제품"

msgid "Enable Visual Editor"
msgstr "시각 편집기 활성화"

msgid ""
"When enabled, customers see the visual design editor on the product page."
msgstr ""
"활성화되면 고객은 상품 페이지에서 시각적 디자인 편집기를 볼 수 있습니다."

msgid "Editor Mode"
msgstr "편집기 모드"

msgid ""
"Canvas: full visual editor with Fabric.js. Simple: traditional form fields "
"only."
msgstr ""
"캔버스: Fabric.js를 사용한 전체 시각 편집기. 간단: 전통적인 폼 필드만 제공."

msgid "Allow Image Upload"
msgstr "이미지 업로드 허용"

msgid "Allow customers to upload their own images."
msgstr "고객이 자신의 이미지를 업로드할 수 있도록 허용."

msgid "Allow Text"
msgstr "텍스트 허용"

msgid "Allow customers to add text elements."
msgstr "고객이 텍스트 요소를 추가할 수 있도록 허용."

msgid "Allow Clipart"
msgstr "클립아트 허용"

msgid "Allow customers to use clipart from the asset library."
msgstr "고객이 자산 라이브러리에서 클립아트를 사용하도록 허용합니다."

msgid "Max Uploads Per Surface"
msgstr "표면당 최대 업로드 수"

msgid "Maximum number of uploaded images allowed per design surface."
msgstr "디자인 표면당 업로드할 수 있는 최대 이미지 수."

msgid "Max Upload Size (MB)"
msgstr "최대 업로드 크기 (MB)"

msgid "Allowed Upload Types"
msgstr "허용된 업로드 유형"

msgid "File extensions allowed for upload. e.g. [\"jpg\", \"png\", \"svg\"]"
msgstr "업로드가 허용되는 파일 확장자입니다. 예: [\"jpg\", \"png\", \"svg\"]"

msgid "Base Design Fee"
msgstr "기본 디자인 요금"

msgid "Flat fee added when any customization is applied."
msgstr "어떤 커스터마이징이 적용될 때마다 추가되는 고정 요금입니다."

msgid "Per Surface Fee"
msgstr "표면당 요금"

msgid "Additional fee for each design surface used beyond the first."
msgstr "첫 번째를 제외한 각 디자인 표면 사용에 대한 추가 요금입니다."

msgid "Per Upload Fee"
msgstr "업로드당 요금"

msgid "Fee charged for each customer-uploaded image."
msgstr "고객이 업로드한 각 이미지에 대해 부과되는 요금입니다."

msgid "Per Text Fee"
msgstr "문자당 요금"

msgid "Fee charged for each text element added."
msgstr "각 텍스트 요소 추가 시 요금이 부과됩니다."

msgid "Product Design Configuration"
msgstr "제품 디자인 구성"

msgid "Product Design Configurations"
msgstr "제품 디자인 구성들"

msgid "Millimeters"
msgstr "밀리미터"

msgid "Inches"
msgstr "인치"

msgid "Pixels"
msgstr "픽셀"

msgid "Design Configuration"
msgstr "디자인 구성"

msgid "e.g. \"Front\", \"Back\", \"Left Sleeve\""
msgstr "예: \"Front\", \"Back\", \"Left Sleeve\""

msgid "Slug"
msgstr "슬러그"

msgid "Sort Order"
msgstr "정렬 순서"

msgid "Product photo showing this surface/angle."
msgstr "이 표면/각도를 보여주는 제품 사진."

msgid "Dimension Unit"
msgstr "차원 단위"

msgid "Design Area Width"
msgstr "디자인 영역 너비"

msgid "Width of the printable/designable area."
msgstr "인쇄/디자인 가능한 영역의 너비。"

msgid "Design Area Height"
msgstr "디자인 영역 높이"

msgid "Height of the printable/designable area."
msgstr "인쇄/디자인 가능한 영역의 높이。"

msgid "Zone X Position (%)"
msgstr "존 X 위치 (%)"

msgid ""
"Horizontal position of design zone on the mockup image, as percentage from "
"left."
msgstr ""
"모ック업 이미지의 디자인 영역의 수평 위치, 왼쪽에서 계산한 백분율로 표시됩니"
"다."

msgid "Zone Y Position (%)"
msgstr "존 Y 위치 (%)"

msgid ""
"Vertical position of design zone on the mockup image, as percentage from top."
msgstr ""
"모ック업 이미지의 디자인 영역의 수직 위치, 상단에서 계산한 백분율로 표시됩니"
"다."

msgid "Zone Width (%)"
msgstr "존 너비 (%)"

msgid "Width of design zone on the mockup image, as percentage of image width."
msgstr "모ック업 이미지에서 디자인 영역의 너비, 이미지 너비의 백분율로 표시."

msgid "Zone Height (%)"
msgstr "존 높이 (%)"

msgid ""
"Height of design zone on the mockup image, as percentage of image height."
msgstr "모ック업 이미지에서 디자인 영역의 높이, 이미지 높이의 백분율로 표시."

msgid "Minimum DPI"
msgstr "최소 DPI"

msgid "Minimum dots-per-inch for acceptable print quality."
msgstr "인쇄 품질에 적합한 최소 도트/인치 수."

msgid "Recommended DPI"
msgstr "권장 DPI"

msgid "Recommended dots-per-inch for optimal print quality."
msgstr "최적의 인쇄 품질을 위해 권장되는 도트수/인치."

msgid "Bleed (mm)"
msgstr "블리드 (mm)"

msgid "Extra margin outside design area for printing bleed."
msgstr "인쇄 베일을 위해 디자인 영역 외부에 추가 여백."

msgid "Max Colors"
msgstr "최대 색상"

msgid ""
"Maximum number of colors allowed (for screen printing). Leave blank for "
"unlimited."
msgstr ""
"스크린 인쇄용으로 허용되는 최대 색상 수. 무제한으로 하려면 빈칸으로 두세요."

msgid "Background Color"
msgstr "배경 색상"

msgid "Default background color for the design canvas."
msgstr "디자인 캔버스의 기본 배경 색상입니다."

msgid "Override: allow text on this surface. Blank = inherit from config."
msgstr ""
"상위 설정에서 대체: 이 표면에 텍스트를 허용합니다. 공백 = 설정에서 상속합니"
"다."

msgid ""
"Override: allow image uploads on this surface. Blank = inherit from config."
msgstr ""
"상위 설정에서 대체: 이 표면에 이미지 업로드를 허용합니다. 공백 = 설정에서 상"
"속합니다."

msgid "Override: allow clipart on this surface. Blank = inherit from config."
msgstr "상위 설정: 이 표면에서 클립아트 사용 허용. 빈 값 = 설정에서 상속."

msgid "Max Design Elements"
msgstr "최대 디자인 요소"

msgid "Maximum total design elements on this surface. Blank = no limit."
msgstr "이 표면의 최대 총 디자인 요소 수. 빈 값 = 제한 없음."

msgid "Enabled"
msgstr "사용됨"

msgid "Product Surface"
msgstr "제품 표면"

msgid "Product Surfaces"
msgstr "제품 표면들"

msgid "Template Name"
msgstr "템플릿 이름"

msgid "Description"
msgstr "설명"

msgid "Category"
msgstr "카테고리"

msgid "e.g. \"Birthday\", \"Business\", \"Holiday\""
msgstr "예: \"생일\", \"비즈니스\", \"휴일\""

msgid "Design Data"
msgstr "디자인 데이터"

msgid "Full Fabric.js canvas state for each surface."
msgstr "각 표면의 전체 Fabric.js 캔버스 상태."

msgid "Thumbnail"
msgstr "미리보기 이미지"

msgid "Active"
msgstr "활성화"

msgid "Design Template"
msgstr "디자인 템플릿"

msgid "Design Templates"
msgstr "디자인 템플릿"

msgid "Text"
msgstr "텍스트"

msgid "Image"
msgstr "이미지"

msgid "Clipart"
msgstr "클립아트"

msgid "Template"
msgstr "템플릿"

msgid "Surface"
msgstr "표면"

msgid "Element Type"
msgstr "요소 유형"

msgid "Element Data"
msgstr "요소 데이터"

msgid "Fabric.js object properties (position, size, rotation, content)."
msgstr "Fabric.js 객체 속성(위치, 크기, 회전, 내용)."

msgid "Lock Position"
msgstr "위치 잠금"

msgid "Prevent customers from moving this element."
msgstr "고객이 이 요소를 이동하지 못하도록 방지합니다."

msgid "Lock Size"
msgstr "크기 잠금"

msgid "Prevent customers from resizing this element."
msgstr "고객이 이 요소를 재설정하지 못하도록 방지합니다."

msgid "Lock Content"
msgstr "내용 잠금"

msgid "Prevent customers from editing text or replacing the image."
msgstr "고객이 텍스트를 편집하거나 이미지를 교체하는 것을 방지합니다."

msgid "Lock Delete"
msgstr "삭제 잠금"

msgid "Prevent customers from removing this element."
msgstr "고객이 이 요소를 제거하는 것을 방지합니다."

msgid "Lock Rotation"
msgstr "회전 고정"

msgid "Prevent customers from rotating this element."
msgstr "고객이 이 요소를 회전시키는 것을 방지합니다."

msgid "Z-order for layering elements."
msgstr "요소 층을 위한 Z-순서."

msgid "Design Template Element"
msgstr "디자인 템플릿 요소"

msgid "Design Template Elements"
msgstr "디자인 템플릿 요소들"

msgid "Category Name"
msgstr "카테고리 이름"

msgid "Icon"
msgstr "아이콘"

msgid "CSS icon class (e.g. Font Awesome class)."
msgstr "CSS 아이콘 클래스 (예: Font Awesome 클래스)."

msgid "Clipart Category"
msgstr "클립아트 카테고리"

msgid "Clipart Categories"
msgstr "클립아트 카테고리"

msgid "Available to All Products"
msgstr "모든 제품에 사용 가능"

msgid "Specific Product Only"
msgstr "특정 제품만"

msgid "Name"
msgstr "이름"

msgid "Image Asset"
msgstr "이미지 자산"

msgid "PNG or SVG file for the clipart."
msgstr "클립아트용 PNG 또는 SVG 파일."

msgid "Scope"
msgstr "범위"

msgid "Only set when scope is 'Specific Product Only'."
msgstr "범위가 '특정 제품만'인 경우에만 설정합니다."

msgid "Tags"
msgstr "태그"

msgid ""
"Searchable tags for this clipart. e.g. [\"star\", \"decoration\", \"gold\"]"
msgstr ""
"이 클립아트에 대한 검색 가능한 태그. 예: [\"star\", \"decoration\", \"gold\"]"

msgid "Clipart Asset"
msgstr "클립아트 자산"

msgid "Clipart Assets"
msgstr "클립아트 자산들"

msgid "Font Name"
msgstr "글꼴 이름"

msgid "Display name shown in the font picker."
msgstr "폰트 선택기에서 표시되는 이름입니다."

msgid "Font Family"
msgstr "글꼴 가족"

msgid "CSS font-family name used in the editor."
msgstr "에디터에서 사용되는 CSS font-family 이름입니다."

msgid "WOFF2 or TTF file for regular weight."
msgstr "일반 글꼴 용 WOFF2 또는 TTF 파일."

msgid "WOFF2 or TTF file for bold weight."
msgstr "볼드 글꼴 용 WOFF2 또는 TTF 파일."

msgid "Italic"
msgstr "강조"

msgid "WOFF2 or TTF file for italic style."
msgstr "이탈릭 스타일 용 WOFF2 또는 TTF 파일."

msgid "Bold Italic"
msgstr "굵은 강조"

msgid "WOFF2 or TTF file for bold italic style."
msgstr "볼드 이탈릭 스타일을 위한 WOFF2 또는 TTF 파일입니다."

msgid "System Font"
msgstr "시스템 폰트"

msgid "If true, this font is pre-installed and no file upload is needed."
msgstr ""
"true일 경우 이 글꼴은 사전에 설치되어 있고 파일 업로드가 필요 없습니다."

msgid "Custom Font"
msgstr "사용자 정의 폰트"

msgid "Custom Fonts"
msgstr "사용자 정의 폰트"

msgid "User"
msgstr "사용자"

msgid "Design Name"
msgstr "디자인 이름"

msgid "Full Fabric.js canvas state per surface."
msgstr "각 표면당 완전한 Fabric.js 캔버스 상태입니다."

msgid "Thumbnails"
msgstr "미리보기"

msgid ""
"Per-surface thumbnail MediaAsset IDs. e.g. {\"front\": 123, \"back\": 456}"
msgstr "표면별 썸네일 MediaAsset ID. 예: {\"front\": 123, \"back\": 456}"

msgid "Saved Design"
msgstr "저장된 디자인"

msgid "Saved Designs"
msgstr "저장된 디자인"

msgid "Token"
msgstr "토큰"

msgid "Unique reference used by the cart system."
msgstr "장바구니 시스템에서 사용하는 고유 참조입니다."

msgid "Session Key"
msgstr "세션 키"

msgid "Session key for anonymous users."
msgstr "익명 사용자를 위한 세션 키."

msgid "Per-surface thumbnail MediaAsset IDs."
msgstr "표면별 썸네일 MediaAsset ID."

msgid "Pricing Breakdown"
msgstr "가격 세부 정보"

msgid "Calculated price components for this design."
msgstr "이 디자인의 계산된 가격 구성 요소입니다."

msgid "Expires At"
msgstr "만료 시간"

msgid "Auto-cleanup after this datetime."
msgstr "이 날짜 및 시간 이후 자동 정리."

msgid "Design Draft"
msgstr "디자인 초안"

msgid "Design Drafts"
msgstr "디자인 초안들"

msgid "Order Item"
msgstr "주문 항목"

msgid "Frozen design state at time of order."
msgstr "주문 시 동결된 디자인 상태입니다."

msgid "Rendered Images"
msgstr "렌더링된 이미지"

msgid "Per-surface preview MediaAsset IDs. e.g. {\"front\": 123}"
msgstr "표면별 미리보기 MediaAsset ID입니다. 예: {\"front\": 123}"

msgid "Fulfillment Files"
msgstr "충족 파일"

msgid "High-resolution composite MediaAsset IDs for printing."
msgstr "인쇄용 고해상도 복합 MediaAsset ID입니다."

msgid "Rendered"
msgstr "렌더링됨"

msgid "Whether high-resolution fulfillment files have been generated."
msgstr "고해상도 완료 파일이 생성되었는지 여부입니다."

msgid "Render Completed At"
msgstr "렌더링 완료 시간"

msgid "Design Snapshot"
msgstr "디자인 스냅샷"

msgid "Design Snapshots"
msgstr "디자인 스냅샷"

msgid "Design Editor Setup"
msgstr "디자인 에디터 설정"

msgid "Home"
msgstr "홈"

msgid "Products"
msgstr "상품"

msgid "Editor Enabled"
msgstr "에디터 활성화"

msgid "Back to Product"
msgstr "상품으로 돌아가기"

msgid "Fonts"
msgstr "폰트"

msgid "Settings"
msgstr "설정"

msgid ""
"Define the designable areas of your product. Each surface represents a face "
"or side where customers can place their designs."
msgstr ""
"제품의 디자인 가능한 영역을 정의하세요. 각 표면은 고객이 디자인을 배치할 수 "
"있는 얼굴 또는 측면을 나타냅니다."

msgid ""
"Create pre-made designs that customers can start from and customize. "
"Templates can have locked elements that customers cannot change."
msgstr ""
"고객이 시작하여 커스터마이징할 수 있는 사전 제작 디자인을 만드세요. 템플릿에"
"는 고객이 변경할 수 없는 고정된 요소가 포함될 수 있습니다."

msgid "Clipart Library"
msgstr "클립아트 라이브러리"

msgid ""
"Manage clipart categories and assets that customers can use in their "
"designs. Clipart can be global (all products) or product-specific."
msgstr ""
"고객이 디자인에 사용할 수 있는 클립아트 카테고리 및 자산을 관리합니다. 클립아"
"트는 전역(모든 제품) 또는 특정 제품에 적용될 수 있습니다."

msgid "Clipart categories and assets are managed from the admin panel:"
msgstr "클립아트 카테고리 및 자산은 관리자 패널에서 관리됩니다:"

msgid "Manage Categories"
msgstr "카테고리 관리"

msgid "Manage Assets"
msgstr "자산 관리"

msgid ""
"Upload custom fonts for customers to use when adding text to their designs. "
"WOFF2 or TTF format recommended."
msgstr ""
"고객이 디자인에 텍스트를 추가할 때 사용할 수 있는 사용자 정의 폰트를 업로드합"
"니다. WOFF2 또는 TTF 형식이 권장됩니다."

msgid "Manage Fonts"
msgstr "폰트 관리"

msgid "Design Pricing"
msgstr "디자인 가격"

msgid ""
"Set pricing rules for customizations. Fees are added on top of the product's "
