msgstr "Configuração de Design"

msgid "e.g. \"Front\", \"Back\", \"Left Sleeve\""
msgstr "ex. \"Frente\", \"Costas\", \"Mangas Esquerda\""

msgid "Slug"
msgstr "Slug"

msgid "Sort Order"
msgstr "Ordem de Classificação"

msgid "Product photo showing this surface/angle."
msgstr "Foto do produto mostrando esta superfície/ângulo."

msgid "Dimension Unit"
msgstr "Unidade de Dimensão"

msgid "Design Area Width"
msgstr "Largura da Área de Design"

msgid "Width of the printable/designable area."
msgstr "Largura da área impressível/designável."

msgid "Design Area Height"
msgstr "Altura da Área de Design"

msgid "Height of the printable/designable area."
msgstr "Altura da área impressível/designável."

msgid "Zone X Position (%)"
msgstr "Posição X da Zona (%)"

msgid ""
"Horizontal position of design zone on the mockup image, as percentage from "
"left."
msgstr ""
"Posição horizontal da zona de design na imagem de mockup, como porcentagem a "
"partir da esquerda."

msgid "Zone Y Position (%)"
msgstr "Posição Y da Zona (%)"

msgid ""
"Vertical position of design zone on the mockup image, as percentage from top."
msgstr ""
"Posição vertical da zona de design na imagem de mockup, como porcentagem a "
"partir do topo."

msgid "Zone Width (%)"
msgstr "Largura da Zona (%)"

msgid "Width of design zone on the mockup image, as percentage of image width."
msgstr ""
"Largura da zona de design na imagem de mockup, como porcentagem da largura "
"da imagem."

msgid "Zone Height (%)"
msgstr "Altura da Zona (%)"

msgid ""
"Height of design zone on the mockup image, as percentage of image height."
msgstr ""
"Altura da zona de design na imagem de mockup, como porcentagem da altura da "
"imagem."

msgid "Minimum DPI"
msgstr "DPI Mínimo"

msgid "Minimum dots-per-inch for acceptable print quality."
msgstr "Mínimo de pontos por polegada para qualidade de impressão aceitável."

msgid "Recommended DPI"
msgstr "DPI Recomendado"

msgid "Recommended dots-per-inch for optimal print quality."
msgstr "Recomendado de pontos por polegada para qualidade de impressão ótima."

msgid "Bleed (mm)"
msgstr "Bleed (mm)"

msgid "Extra margin outside design area for printing bleed."
msgstr "Margem extra fora da área de design para sangria de impressão."

msgid "Max Colors"
msgstr "Máximo de Cores"

msgid ""
"Maximum number of colors allowed (for screen printing). Leave blank for "
"unlimited."
msgstr ""
"Número máximo de cores permitido (para impressão em tela). Deixe em branco "
"para ilimitado."

msgid "Background Color"
msgstr "Cor de Fundo"

msgid "Default background color for the design canvas."
msgstr "Cor de fundo padrão para o canvas de design."

msgid "Override: allow text on this surface. Blank = inherit from config."
msgstr ""
"Substituir: permitir texto nesta superfície. Em branco = herdar da "
"configuração."

msgid ""
"Override: allow image uploads on this surface. Blank = inherit from config."
msgstr ""
"Substituir: permitir upload de imagens nesta superfície. Em branco = herdar "
"da configuração."

msgid "Override: allow clipart on this surface. Blank = inherit from config."
msgstr ""
"Substituir: permitir clipart nesta superfície. Em branco = herdar da "
"configuração."

msgid "Max Design Elements"
msgstr "Máximo de Elementos de Design"

msgid "Maximum total design elements on this surface. Blank = no limit."
msgstr ""
"Máximo de elementos de design totais nesta superfície. Em branco = sem "
"limite."

