msgstr "Produto"

msgid "Enable Visual Editor"
msgstr "Ativar Editor Visual"

msgid ""
"When enabled, customers see the visual design editor on the product page."
msgstr ""
"Quando habilitado, os clientes veem o editor de design visual na página do "
"produto."

msgid "Editor Mode"
msgstr "Modo Editor"

msgid ""
"Canvas: full visual editor with Fabric.js. Simple: traditional form fields "
"only."
msgstr ""
"Canvas: editor visual completo com Fabric.js. Simples: apenas campos de "
"formulário tradicionais."

msgid "Allow Image Upload"
msgstr "Permitir Upload de Imagem"

msgid "Allow customers to upload their own images."
msgstr "Permitir que os clientes carreguem suas próprias imagens."

msgid "Allow Text"
msgstr "Permitir Texto"

msgid "Allow customers to add text elements."
msgstr "Permitir que os clientes adicionem elementos de texto."

msgid "Allow Clipart"
msgstr "Permitir Clipart"

msgid "Allow customers to use clipart from the asset library."
msgstr "Permitir que os clientes usem clipart da biblioteca de ativos."

msgid "Max Uploads Per Surface"
msgstr "Máximo de Uploads por Superfície"

msgid "Maximum number of uploaded images allowed per design surface."
msgstr ""
"Número máximo de imagens carregadas permitidas por superfície de design."

msgid "Max Upload Size (MB)"
msgstr "Tamanho Máximo de Upload (MB)"

msgid "Allowed Upload Types"
msgstr "Tipos de Upload Permitidos"

msgid "File extensions allowed for upload. e.g. [\"jpg\", \"png\", \"svg\"]"
msgstr ""
"Extensões de arquivo permitidas para upload. Exemplo: [\"jpg\", \"png\", "
"\"svg\"]"

msgid "Base Design Fee"
msgstr "Taxa de Design Base"

msgid "Flat fee added when any customization is applied."
msgstr "Taxa fixa adicionada quando qualquer personalização for aplicada."

msgid "Per Surface Fee"
msgstr "Taxa por Superfície"

msgid "Additional fee for each design surface used beyond the first."
msgstr "Taxa adicional para cada superfície de design usada além da primeira."

msgid "Per Upload Fee"
msgstr "Taxa por Upload"

msgid "Fee charged for each customer-uploaded image."
msgstr "Taxa cobrada para cada imagem carregada pelo cliente."

msgid "Per Text Fee"
msgstr "Taxa por Texto"

msgid "Fee charged for each text element added."
msgstr "Taxa cobrada para cada elemento de texto adicionado."

msgid "Product Design Configuration"
msgstr "Configuração de Design do Produto"

msgid "Product Design Configurations"
msgstr "Configurações de Design do Produto"

msgid "Millimeters"
msgstr "Milímetros"

msgid "Inches"
msgstr "Polegadas"

msgid "Pixels"
msgstr "Pixels"

