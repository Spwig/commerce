#, python-format
msgid "Template Editor: %(product)s"
msgstr "محرر النموذج: %(product)s"

msgid "Customizable Products"
msgstr "المنتجات القابلة للتخصيص"

msgid "Canvas Editor"
msgstr "محرر القماش"

msgid "Simple Form"
msgstr "نموذج بسيط"

msgid "Product"
msgstr "منتج"

msgid "Enable Visual Editor"
msgstr "تمكين محرر الرؤية"

msgid ""
"When enabled, customers see the visual design editor on the product page."
msgstr "عند تمكينه، يرى العملاء محرر التصميم البصري على صفحة المنتج."

msgid "Editor Mode"
msgstr "وضع المحرر"

msgid ""
"Canvas: full visual editor with Fabric.js. Simple: traditional form fields "
"only."
msgstr "اللوحة: محرر بصري كامل مع Fabric.js. البسيط: الحقول التقليدية فقط."

msgid "Allow Image Upload"
msgstr "السماح بتحميل الصور"

msgid "Allow customers to upload their own images."
msgstr "السماح للعملاء بتحميل صورهم الخاصة."

msgid "Allow Text"
msgstr "السماح بالنص"

msgid "Allow customers to add text elements."
msgstr "السماح للعملاء بإضافة عناصر نصية."

msgid "Allow Clipart"
msgstr "السماح بالرسوم التوضيحية"

msgid "Allow customers to use clipart from the asset library."
msgstr "مسموح للعملاء استخدام رسوم متحركة من مكتبة الأصول."

msgid "Max Uploads Per Surface"
msgstr "الحد الأقصى للتحميلات لكل سطح"

msgid "Maximum number of uploaded images allowed per design surface."
msgstr "العدد الأقصى للصور المرفوعة المسموح بها لكل سطح تصميم."

msgid "Max Upload Size (MB)"
msgstr "حجم التحميل الأقصى (MB)"

msgid "Allowed Upload Types"
msgstr "أنواع التحميل المسموح بها"

msgid "File extensions allowed for upload. e.g. [\"jpg\", \"png\", \"svg\"]"
msgstr "مُسمَح بامتدادات الملفات للرفع. مثال: [\"jpg\", \"png\", \"svg\"]"

msgid "Base Design Fee"
msgstr "رسوم التصميم الأساسية"

msgid "Flat fee added when any customization is applied."
msgstr "رسوم ثابتة يتم إضافتها عند تطبيق أي تخصيص."

msgid "Per Surface Fee"
msgstr "رسوم لكل سطح"

msgid "Additional fee for each design surface used beyond the first."
msgstr "رسوم إضافية لكل سطح تصميم تم استخدامه بالإضافة إلى الأول."

msgid "Per Upload Fee"
msgstr "رسوم لكل تحميل"

msgid "Fee charged for each customer-uploaded image."
msgstr "رسوم يتم فرضها لكل صورة تم رفعها من قبل العميل."

msgid "Per Text Fee"
msgstr "رسوم لكل نص"

msgid "Fee charged for each text element added."
msgstr "الرسوم المُفروضة لكل عنصر نصي يتم إضافته."

msgid "Product Design Configuration"
msgstr "إعدادات تصميم المنتج"

msgid "Product Design Configurations"
msgstr "إعدادات تصميم المنتجات"

msgid "Millimeters"
msgstr "ميليمتر"

msgid "Inches"
msgstr "بوصة"

msgid "Pixels"
msgstr "بكسل"

msgid "Design Configuration"
msgstr "إعداد التصميم"

msgid "e.g. \"Front\", \"Back\", \"Left Sleeve\""
msgstr "مثلاً: \"الجهة الأمامية\", \"الجهة الخلفية\", \"السleeve اليساري\""

msgid "Slug"
msgstr "الslug"

msgid "Sort Order"
msgstr "ترتيب الفرز"

msgid "Product photo showing this surface/angle."
msgstr "صورة المنتج تُظهر هذا السطح/الزاوية."

msgid "Dimension Unit"
msgstr "وحدة القياس"

msgid "Design Area Width"
msgstr "عرض منطقة التصميم"

msgid "Width of the printable/designable area."
msgstr "عرض المنطقة القابلة للطباعة/التصميم."

msgid "Design Area Height"
msgstr "ارتفاع منطقة التصميم"

msgid "Height of the printable/designable area."
msgstr "ارتفاع المنطقة القابلة للطباعة/التصميم."

msgid "Zone X Position (%)"
msgstr "موضع المنطقة X (%)"

msgid ""
"Horizontal position of design zone on the mockup image, as percentage from "
"left."
msgstr "الموضع الأفقي للمنطقة المصممة في صورة النموذج، كنسبة مئوية من اليسار."

msgid "Zone Y Position (%)"
msgstr "موضع المنطقة Y (%)"

msgid ""
"Vertical position of design zone on the mockup image, as percentage from top."
msgstr "الموضع العمودي للمنطقة المصممة في صورة النموذج، كنسبة مئوية من الأعلى."

msgid "Zone Width (%)"
msgstr "عرض المنطقة (%)"

msgid "Width of design zone on the mockup image, as percentage of image width."
msgstr "عرض منطقة التصميم في صورة النموذج، كنسبة من عرض الصورة."

msgid "Zone Height (%)"
msgstr "ارتفاع المنطقة (%)"

msgid ""
"Height of design zone on the mockup image, as percentage of image height."
msgstr "ارتفاع منطقة التصميم في صورة النموذج، كنسبة من ارتفاع الصورة."

msgid "Minimum DPI"
msgstr "الدقة المطلوبة الدنيا"

msgid "Minimum dots-per-inch for acceptable print quality."
msgstr "الحد الأدنى من النقاط لكل بوصة لجودة طباعة قابلة القبول."

msgid "Recommended DPI"
msgstr "الدقة المقترحة"

msgid "Recommended dots-per-inch for optimal print quality."
msgstr "النقاط لكل بوصة الموصى بها للحصول على جودة طباعة مثلى."

msgid "Bleed (mm)"
msgstr "الانسياب (ملم)"

msgid "Extra margin outside design area for printing bleed."
msgstr "هامش إضافي خارج منطقة التصميم لطباعة التسرب."

msgid "Max Colors"
msgstr "أقصى عدد ألوان"

msgid ""
"Maximum number of colors allowed (for screen printing). Leave blank for "
"unlimited."
msgstr ""
"أقصى عدد من الألوان المسموح به (للطباعة بالشاشة). اتركه فارغًا للعدد غير "
"المحدود."

msgid "Background Color"
msgstr "لون الخلفية"

msgid "Default background color for the design canvas."
msgstr "اللون الافتراضي للخلفية للوحة التصميم."

msgid "Override: allow text on this surface. Blank = inherit from config."
msgstr ""
"التعويض: السماح بكتابة النص على هذا السطح. الفارغ = الوراثة من الإعدادات."

msgid ""
"Override: allow image uploads on this surface. Blank = inherit from config."
msgstr ""
"التعويض: السماح بتحميل الصور على هذا السطح. الفارغ = الوراثة من الإعدادات."

msgid "Override: allow clipart on this surface. Blank = inherit from config."
msgstr ""
"التعويض: السماح بوضع صور كليبات على هذا السطح. الفارغ = الوراثة من الإعدادات."

msgid "Max Design Elements"
msgstr "العناصر التصميمية القصوى"

msgid "Maximum total design elements on this surface. Blank = no limit."
msgstr "الحد الأقصى لإجمالي عناصر التصميم على هذا السطح. الفارغ = لا يوجد حد."

