node_modules/
npm-debug.log
yarn-error.log

# Production - never commit private keys or certs
*.pem
*.key
*.cert
*.crt
# Public keys (e.g. license verification key) are explicitly allowlisted where used
!core/keys/*.pem

# Archive
.archive/

# Celery runtime
celerybeat-schedule

# Keys (root-level .keys/ is private, but core/keys/ ships with codebase)
.keys/
!core/keys/
!core/keys/license-public-key.pem

# Claude Code artifacts (CLAUDE.md is now tracked — public AI/contributor guidance)
.claude/
.claude_code/

