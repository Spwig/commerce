#, python-format
msgid "%(field)s is required."
msgstr "%(field)s은(는) 필수입니다."

#, python-format
msgid "%(field)s must be at least %(min)d characters."
msgstr "%(field)s은(는) 최소 %(min)d자 이상이어야 합니다."

#, python-format
msgid "%(field)s must be at most %(max)d characters."
msgstr "%(field)s은(는) 최대 %(max)d자 이하이어야 합니다."

#, python-format
msgid "%(field)s does not match the required pattern."
msgstr "%(field)s은(는) 필요한 형식과 일치하지 않습니다."

#, python-format
msgid "%(field)s must be a whole number."
msgstr "%(field)s은(는) 정수여야 합니다."

#, python-format
msgid "%(field)s must be at least %(min)s."
msgstr "%(field)s은(는) 최소 %(min)s이어야 합니다."

#, python-format
msgid "%(field)s must be at most %(max)s."
msgstr "%(field)s은(는) 최대 %(max)s이어야 합니다."

#, python-format
msgid "%(field)s must be a valid decimal number."
msgstr "%(field)s은(는) 유효한 소수여야 합니다."

#, python-format
msgid "%(field)s must be a valid date (YYYY-MM-DD)."
msgstr "%(field)s은(는) 유효한 날짜(YYYY-MM-DD)여야 합니다."

#, python-format
msgid "%(field)s must be a valid date and time."
msgstr "%(field)s은(는) 유효한 날짜 및 시간이어야 합니다."

#, python-format
msgid "%(field)s must be a valid URL."
msgstr "%(field)s은(는) 유효한 URL이어야 합니다."

#, python-format
msgid "%(field)s must be a valid email address."
msgstr "%(field)s은(는) 유효한 이메일 주소여야 합니다."

#, python-format
msgid "%(field)s: \"%(value)s\" is not a valid choice."
msgstr "%(field)s: \"%(value)s\"은(는) 유효한 선택이 아닙니다."

#, python-format
msgid "%(field)s must be a list of values."
msgstr "%(field)s은(는) 값의 목록이어야 합니다."

#, python-format
msgid "%(field)s must be a valid hex color (e.g., #FF0000)."
msgstr "%(field)s은(는) 유효한 16진수 색상(e.g., #FF0000)이어야 합니다."

