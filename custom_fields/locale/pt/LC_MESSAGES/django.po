#, python-format
msgid "%(field)s is required."
msgstr "%(field)s é obrigatório."

#, python-format
msgid "%(field)s must be at least %(min)d characters."
msgstr "%(field)s deve ter pelo menos %(min)d caracteres."

#, python-format
msgid "%(field)s must be at most %(max)d characters."
msgstr "%(field)s deve ter no máximo %(max)d caracteres."

#, python-format
msgid "%(field)s does not match the required pattern."
msgstr "%(field)s não corresponde ao padrão exigido."

#, python-format
msgid "%(field)s must be a whole number."
msgstr "%(field)s deve ser um número inteiro."

#, python-format
msgid "%(field)s must be at least %(min)s."
msgstr "%(field)s deve ser pelo menos %(min)s."

#, python-format
msgid "%(field)s must be at most %(max)s."
msgstr "%(field)s deve ser no máximo %(max)s."

#, python-format
msgid "%(field)s must be a valid decimal number."
msgstr "%(field)s deve ser um número decimal válido."

#, python-format
msgid "%(field)s must be a valid date (YYYY-MM-DD)."
msgstr "%(field)s deve ser uma data válida (YYYY-MM-DD)."

#, python-format
msgid "%(field)s must be a valid date and time."
msgstr "%(field)s deve ser uma data e hora válidas."

#, python-format
msgid "%(field)s must be a valid URL."
msgstr "%(field)s deve ser uma URL válida."

#, python-format
msgid "%(field)s must be a valid email address."
msgstr "%(field)s deve ser um endereço de e-mail válido."

#, python-format
msgid "%(field)s: \"%(value)s\" is not a valid choice."
msgstr "%(field)s: \"%(value)s\" não é uma opção válida."

#, python-format
msgid "%(field)s must be a list of values."
msgstr "%(field)s deve ser uma lista de valores."

#, python-format
msgid "%(field)s must be a valid hex color (e.g., #FF0000)."
msgstr "%(field)s deve ser uma cor hexadecimal válida (ex: #FF0000)."

