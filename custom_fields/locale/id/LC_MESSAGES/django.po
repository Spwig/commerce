#, python-format
msgid "%(field)s is required."
msgstr "%(field)s diperlukan."

#, python-format
msgid "%(field)s must be at least %(min)d characters."
msgstr "%(field)s harus memiliki setidaknya %(min)d karakter."

#, python-format
msgid "%(field)s must be at most %(max)d characters."
msgstr "%(field)s harus memiliki maksimal %(max)d karakter."

#, python-format
msgid "%(field)s does not match the required pattern."
msgstr "%(field)s tidak cocok dengan pola yang diperlukan."

#, python-format
