msgstr "%(field)s harus berupa bilangan bulat."

#, python-format
msgid "%(field)s must be at least %(min)s."
msgstr "%(field)s harus setidaknya %(min)s."

#, python-format
msgid "%(field)s must be at most %(max)s."
msgstr "%(field)s harus paling banyak %(max)s."

#, python-format
msgid "%(field)s must be a valid decimal number."
msgstr "%(field)s harus berupa angka desimal yang valid."

#, python-format
msgid "%(field)s must be a valid date (YYYY-MM-DD)."
msgstr "%(field)s harus berupa tanggal yang valid (YYYY-MM-DD)."

#, python-format
msgid "%(field)s must be a valid date and time."
msgstr "%(field)s harus berupa tanggal dan waktu yang valid."

#, python-format
msgid "%(field)s must be a valid URL."
msgstr "%(field)s harus berupa URL yang valid."

#, python-format
msgid "%(field)s must be a valid email address."
msgstr "%(field)s harus berupa alamat email yang valid."

#, python-format
msgid "%(field)s: \"%(value)s\" is not a valid choice."
msgstr "%(field)s: \"%(value)s\" bukan pilihan yang valid."

#, python-format
