#, python-format
msgid "%(field)s is required."
msgstr "%(field)s est obligatoire."

#, python-format
msgid "%(field)s must be at least %(min)d characters."
msgstr "%(field)s doit avoir au moins %(min)d caractères."

#, python-format
msgid "%(field)s must be at most %(max)d characters."
msgstr "%(field)s ne peut pas dépasser %(max)d caractères."

#, python-format
