msgstr "%(field)s ne correspond pas au motif requis."

#, python-format
msgid "%(field)s must be a whole number."
msgstr "%(field)s doit être un nombre entier."

#, python-format
msgid "%(field)s must be at least %(min)s."
msgstr "%(field)s doit être au moins %(min)s."

#, python-format
msgid "%(field)s must be at most %(max)s."
msgstr "%(field)s ne peut pas dépasser %(max)s."

#, python-format
