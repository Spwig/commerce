msgstr "%(field)s doit être une date valide (YYYY-MM-DD)."

#, python-format
msgid "%(field)s must be a valid date and time."
msgstr "%(field)s doit être une date et une heure valides."

#, python-format
msgid "%(field)s must be a valid URL."
msgstr "%(field)s doit être une URL valide."

#, python-format
msgid "%(field)s must be a valid email address."
msgstr "%(field)s doit être une adresse e-mail valide."

#, python-format
msgid "%(field)s: \"%(value)s\" is not a valid choice."
msgstr "%(field)s: \"%(value)s\" n'est pas un choix valide."

#, python-format
msgid "%(field)s must be a list of values."
msgstr "%(field)s doit être une liste de valeurs."

#, python-format
