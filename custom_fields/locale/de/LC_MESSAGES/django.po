msgstr "%(field)s muss eine gültige Dezimalzahl sein."

#, python-format
msgid "%(field)s must be a valid date (YYYY-MM-DD)."
msgstr "%(field)s muss ein gültiges Datum (YYYY-MM-DD) sein."

#, python-format
msgid "%(field)s must be a valid date and time."
msgstr "%(field)s muss ein gültiges Datum und eine Uhrzeit sein."

#, python-format
msgid "%(field)s must be a valid URL."
msgstr "%(field)s muss eine gültige URL sein."

#, python-format
