#, python-format
msgid "%(field)s is required."
msgstr "%(field)s ist erforderlich."

#, python-format
msgid "%(field)s must be at least %(min)d characters."
msgstr "%(field)s muss mindestens %(min)d Zeichen lang sein."

#, python-format
msgid "%(field)s must be at most %(max)d characters."
msgstr "%(field)s darf maximal %(max)d Zeichen haben."

#, python-format
msgid "%(field)s does not match the required pattern."
msgstr "%(field)s stimmt nicht mit dem erforderten Muster überein."

#, python-format
msgid "%(field)s must be a whole number."
msgstr "%(field)s muss eine ganze Zahl sein."

#, python-format
msgid "%(field)s must be at least %(min)s."
