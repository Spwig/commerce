#, python-format
msgid "%(field)s is required."
msgstr "%(field)s обязательно."

#, python-format
msgid "%(field)s must be at least %(min)d characters."
msgstr "%(field)s должен содержать не менее %(min)d символов."

#, python-format
msgid "%(field)s must be at most %(max)d characters."
msgstr "%(field)s должен содержать не более %(max)d символов."

#, python-format
msgid "%(field)s does not match the required pattern."
msgstr "%(field)s не соответствует требуемому шаблону."

#, python-format
msgid "%(field)s must be a whole number."
msgstr "%(field)s должен быть целым числом."

#, python-format
msgid "%(field)s must be at least %(min)s."
msgstr "%(field)s должен быть не меньше %(min)s."

#, python-format
msgid "%(field)s must be at most %(max)s."
msgstr "%(field)s должен быть не больше %(max)s."

#, python-format
msgid "%(field)s must be a valid decimal number."
msgstr "%(field)s должен быть действительным десятичным числом."

#, python-format
msgid "%(field)s must be a valid date (YYYY-MM-DD)."
msgstr "%(field)s должен быть действительной датой (ГГГГ-ММ-ДД)."

#, python-format
msgid "%(field)s must be a valid date and time."
msgstr "%(field)s должен быть действительной датой и временем."

#, python-format
msgid "%(field)s must be a valid URL."
msgstr "%(field)s должен быть действительным URL."

#, python-format
msgid "%(field)s must be a valid email address."
msgstr "%(field)s должен быть действительным адресом электронной почты."

#, python-format
msgid "%(field)s: \"%(value)s\" is not a valid choice."
msgstr "%(field)s: \"%(value)s\" не является допустимым вариантом."

#, python-format
msgid "%(field)s must be a list of values."
msgstr "%(field)s должен быть списком значений."

#, python-format
msgid "%(field)s must be a valid hex color (e.g., #FF0000)."
msgstr ""
"%(field)s должен быть действительным шестнадцатеричным цветом (например, "
"#FF0000)."

