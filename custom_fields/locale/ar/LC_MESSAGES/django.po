#, python-format
msgid "%(field)s is required."
msgstr "%(field)s مطلوب."

#, python-format
msgid "%(field)s must be at least %(min)d characters."
msgstr "يجب أن يكون %(field)s على الأقل %(min)d حرفًا."

#, python-format
msgid "%(field)s must be at most %(max)d characters."
msgstr "يجب أن يكون %(field)s على الأكثر %(max)d حرفًا."

#, python-format
msgid "%(field)s does not match the required pattern."
msgstr "لا يتطابق %(field)s مع النمط المطلوب."

#, python-format
msgid "%(field)s must be a whole number."
msgstr "يجب أن يكون %(field)s عددًا صحيحًا."

#, python-format
msgid "%(field)s must be at least %(min)s."
msgstr "يجب أن يكون %(field)s على الأقل %(min)s."

#, python-format
msgid "%(field)s must be at most %(max)s."
msgstr "يجب أن يكون %(field)s على الأكثر %(max)s."

#, python-format
msgid "%(field)s must be a valid decimal number."
msgstr "يجب أن يكون %(field)s عددًا عشريًا صحيحًا."

#, python-format
msgid "%(field)s must be a valid date (YYYY-MM-DD)."
msgstr "يجب أن يكون %(field)s تاريخًا صحيحًا (YYYY-MM-DD)."

#, python-format
msgid "%(field)s must be a valid date and time."
msgstr "يجب أن يكون %(field)s تاريخًا ووقتًا صحيحين."

#, python-format
msgid "%(field)s must be a valid URL."
msgstr "يجب أن يكون %(field)s رابطًا صحيحًا."

#, python-format
msgid "%(field)s must be a valid email address."
msgstr "يجب أن يكون %(field)s عنوان بريد إلكتروني صحيحًا."

#, python-format
msgid "%(field)s: \"%(value)s\" is not a valid choice."
msgstr "%(field)s: \"%(value)s\" ليس خيارًا صحيحًا."

#, python-format
msgid "%(field)s must be a list of values."
msgstr "يجب أن يكون %(field)s قائمة بالقيم."

#, python-format
msgid "%(field)s must be a valid hex color (e.g., #FF0000)."
msgstr "يجب أن يكون %(field)s لونًا سداسي الأ_digits صحيحًا (مثلاً، #FF0000)."

