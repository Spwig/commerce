msgid ""
"Type-specific validation. Text: {\"min_length\": 0, \"max_length\": 500, "
"\"regex\": \"...\"}. Number: {\"min\": 0, \"max\": 9999}. Select: "
"{\"choices\": [{\"value\": \"sm\", \"label\": \"Small\"}, ...]}"
msgstr ""
"التحقق المحدد حسب النوع. النص: {\"min_length\": 0, \"max_length\": 500, "
"\"regex\": \"...\"}. الرقم: {\"min\": 0, \"max\": 9999}. الاختيار: "
"{\"choices\": [{\"value\": \"sm\", \"label\": \"صغير\"}, ...]}"

