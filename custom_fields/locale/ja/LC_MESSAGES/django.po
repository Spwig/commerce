#, python-format
msgid "%(field)s is required."
msgstr "%(field)s は必須です。"

#, python-format
msgid "%(field)s must be at least %(min)d characters."
msgstr "%(field)s は少なくとも %(min)d 文字でなければなりません。"

#, python-format
msgid "%(field)s must be at most %(max)d characters."
msgstr "%(field)s は最大 %(max)d 文字でなければなりません。"

#, python-format
msgid "%(field)s does not match the required pattern."
msgstr "%(field)s は必要なパターンに一致していません。"

#, python-format
msgid "%(field)s must be a whole number."
msgstr "%(field)s は整数でなければなりません。"

#, python-format
msgid "%(field)s must be at least %(min)s."
msgstr "%(field)s は少なくとも %(min)s でなければなりません。"

#, python-format
msgid "%(field)s must be at most %(max)s."
msgstr "%(field)s は最大 %(max)s でなければなりません。"

#, python-format
msgid "%(field)s must be a valid decimal number."
msgstr "%(field)s は有効な小数でなければなりません。"

#, python-format
msgid "%(field)s must be a valid date (YYYY-MM-DD)."
msgstr "%(field)s は有効な日付 (YYYY-MM-DD) でなければなりません。"

#, python-format
msgid "%(field)s must be a valid date and time."
msgstr "%(field)s は有効な日時でなければなりません。"

#, python-format
msgid "%(field)s must be a valid URL."
msgstr "%(field)s は有効な URL でなければなりません。"

#, python-format
msgid "%(field)s must be a valid email address."
msgstr "%(field)s は有効なメールアドレスでなければなりません。"

#, python-format
msgid "%(field)s: \"%(value)s\" is not a valid choice."
msgstr "%(field)s: \"%(value)s\" は有効な選択肢ではありません。"

#, python-format
msgid "%(field)s must be a list of values."
msgstr "%(field)s は値のリストでなければなりません。"

#, python-format
msgid "%(field)s must be a valid hex color (e.g., #FF0000)."
msgstr "%(field)s は有効な16進色 (例: #FF0000) でなければなりません。"

