#, python-format
msgid "%(field)s is required."
msgstr "%(field)s es obligatorio."

#, python-format
msgid "%(field)s must be at least %(min)d characters."
msgstr "%(field)s debe tener al menos %(min)d caracteres."

#, python-format
msgid "%(field)s must be at most %(max)d characters."
msgstr "%(field)s debe tener como máximo %(max)d caracteres."

#, python-format
msgid "%(field)s does not match the required pattern."
msgstr "%(field)s no coincide con el patrón requerido."

#, python-format
msgid "%(field)s must be a whole number."
msgstr "%(field)s debe ser un número entero."

#, python-format
msgid "%(field)s must be at least %(min)s."
msgstr "%(field)s debe ser al menos %(min)s."

#, python-format
msgid "%(field)s must be at most %(max)s."
msgstr "%(field)s debe ser como máximo %(max)s."

#, python-format
msgid "%(field)s must be a valid decimal number."
msgstr "%(field)s debe ser un número decimal válido."

#, python-format
msgid "%(field)s must be a valid date (YYYY-MM-DD)."
msgstr "%(field)s debe ser una fecha válida (AAAA-MM-DD)."

#, python-format
msgid "%(field)s must be a valid date and time."
msgstr "%(field)s debe ser una fecha y hora válidas."

#, python-format
msgid "%(field)s must be a valid URL."
msgstr "%(field)s debe ser una URL válida."

#, python-format
msgid "%(field)s must be a valid email address."
msgstr "%(field)s debe ser una dirección de correo electrónico válida."

#, python-format
msgid "%(field)s: \"%(value)s\" is not a valid choice."
msgstr "%(field)s: \"%(value)s\" no es una opción válida."

#, python-format
msgid "%(field)s must be a list of values."
msgstr "%(field)s debe ser una lista de valores."

#, python-format
msgid "%(field)s must be a valid hex color (e.g., #FF0000)."
msgstr "%(field)s debe ser un color hexadecimal válido (p. ej., #FF0000)."

