#, python-format
msgid "%(field)s is required."
msgstr "%(field)s là bắt buộc."

#, python-format
msgid "%(field)s must be at least %(min)d characters."
msgstr "%(field)s phải dài ít nhất %(min)d ký tự."

#, python-format
msgid "%(field)s must be at most %(max)d characters."
msgstr "%(field)s phải dài tối đa %(max)d ký tự."

#, python-format
msgid "%(field)s does not match the required pattern."
msgstr "%(field)s không khớp với mẫu yêu cầu."

#, python-format
msgid "%(field)s must be a whole number."
msgstr "%(field)s phải là một số nguyên."

#, python-format
msgid "%(field)s must be at least %(min)s."
msgstr "%(field)s phải ít nhất là %(min)s."

#, python-format
msgid "%(field)s must be at most %(max)s."
msgstr "%(field)s phải tối đa là %(max)s."

#, python-format
msgid "%(field)s must be a valid decimal number."
msgstr "%(field)s phải là một số thập phân hợp lệ."

#, python-format
msgid "%(field)s must be a valid date (YYYY-MM-DD)."
msgstr "%(field)s phải là một ngày hợp lệ (YYYY-MM-DD)."

#, python-format
msgid "%(field)s must be a valid date and time."
msgstr "%(field)s phải là một ngày và giờ hợp lệ."

#, python-format
msgid "%(field)s must be a valid URL."
msgstr "%(field)s phải là một URL hợp lệ."

#, python-format
msgid "%(field)s must be a valid email address."
msgstr "%(field)s phải là một địa chỉ email hợp lệ."

#, python-format
msgid "%(field)s: \"%(value)s\" is not a valid choice."
msgstr "%(field)s: \"%(value)s\" không phải là lựa chọn hợp lệ."

#, python-format
msgid "%(field)s must be a list of values."
msgstr "%(field)s phải là danh sách các giá trị."

#, python-format
msgid "%(field)s must be a valid hex color (e.g., #FF0000)."
msgstr "%(field)s phải là một mã màu hex hợp lệ (ví dụ: #FF0000)."

