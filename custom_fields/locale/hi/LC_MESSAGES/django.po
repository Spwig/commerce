#, python-format
msgid "%(field)s is required."
msgstr "%(field)s आवश्यक है।"

#, python-format
msgid "%(field)s must be at least %(min)d characters."
msgstr "%(field)s कम से कम %(min)d अक्षर होना चाहिए।"

#, python-format
msgid "%(field)s must be at most %(max)d characters."
msgstr "%(field)s अधिकतम %(max)d अक्षर होना चाहिए।"

#, python-format
msgid "%(field)s does not match the required pattern."
msgstr "%(field)s आवश्यक पैटर्न के साथ मेल नहीं खाता है।"

#, python-format
msgid "%(field)s must be a whole number."
msgstr "%(field)s एक पूर्ण संख्या होनी चाहिए।"

#, python-format
msgid "%(field)s must be at least %(min)s."
msgstr "%(field)s कम से कम %(min)s होना चाहिए।"

#, python-format
msgid "%(field)s must be at most %(max)s."
msgstr "%(field)s अधिकतम %(max)s होना चाहिए।"

#, python-format
msgid "%(field)s must be a valid decimal number."
msgstr "%(field)s एक वैध दशमलव संख्या होनी चाहिए।"

#, python-format
msgid "%(field)s must be a valid date (YYYY-MM-DD)."
msgstr "%(field)s एक वैध तारीख (YYYY-MM-DD) होनी चाहिए।"

#, python-format
msgid "%(field)s must be a valid date and time."
msgstr "%(field)s एक वैध तारीख और समय होना चाहिए।"

#, python-format
msgid "%(field)s must be a valid URL."
msgstr "%(field)s एक वैध URL होना चाहिए।"

#, python-format
msgid "%(field)s must be a valid email address."
msgstr "%(field)s एक वैध ईमेल पता होना चाहिए।"

#, python-format
msgid "%(field)s: \"%(value)s\" is not a valid choice."
msgstr "%(field)s: \"%(value)s\" एक वैध विकल्प नहीं है।"

#, python-format
msgid "%(field)s must be a list of values."
msgstr "%(field)s मानों की सूची होनी चाहिए।"

#, python-format
msgid "%(field)s must be a valid hex color (e.g., #FF0000)."
msgstr "%(field)s एक वैध हेक्स कलर (जैसे, #FF0000) होना चाहिए।"

