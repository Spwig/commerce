"Dữ liệu sau đây đã được nhập trước khi xảy ra lỗi (tất cả đã được hoàn tác):"

msgid "Try Again"
msgstr "Thử lại"

msgid ""
"You can start a new migration with the same settings or adjust your "
"configuration."
msgstr ""
"Bạn có thể bắt đầu một lần di chuyển dữ liệu mới với cùng các cài đặt hoặc "
"điều chỉnh cấu hình của bạn."

msgid "Adjust Settings"
msgstr "Điều chỉnh cài đặt"

msgid "Review your imported data"
msgstr "Xem xét dữ liệu đã nhập của bạn"

msgid ""
"Check your products, customers, and orders to ensure everything imported "
"correctly."
msgstr ""
"Kiểm tra sản phẩm, khách hàng và đơn hàng của bạn để đảm bảo mọi thứ đã được "
"nhập đúng."

msgid "View Products"
msgstr "Xem sản phẩm"

msgid "View Customers"
msgstr "Xem khách hàng"

msgid "View Orders"
msgstr "Xem đơn hàng"

msgid "Configure your store settings"
msgstr "Cấu hình cài đặt cửa hàng của bạn"

msgid "Review and adjust shipping, tax, and payment settings for your store."
msgstr ""
"Xem xét và điều chỉnh các cài đặt vận chuyển, thuế và thanh toán cho cửa "
"hàng của bạn."

msgid "Test your checkout process"
msgstr "Kiểm tra quy trình thanh toán của bạn"

msgid "Place a test order to ensure everything works correctly."
msgstr "Đặt một đơn hàng kiểm tra để đảm bảo mọi thứ hoạt động đúng."

msgid "Update your DNS settings"
msgstr "Cập nhật cài đặt DNS của bạn"

msgid "When you're ready to go live, point your domain to this platform."
msgstr ""
"Khi bạn đã sẵn sàng để chính thức vận hành, hãy hướng tên miền của bạn đến "
"nền tảng này."

msgid "Review the error logs"
msgstr "Xem lại nhật ký lỗi"

msgid "Understand what went wrong during the migration"
msgstr "Hiểu rõ điều gì đã sai trong quá trình di chuyển dữ liệu"

msgid "Check your source data"
msgstr "Kiểm tra dữ liệu nguồn của bạn"

msgid "Ensure your data is valid and accessible"
msgstr "Đảm bảo dữ liệu của bạn hợp lệ và có thể truy cập được"

msgid "Contact support"
msgstr "Liên hệ hỗ trợ"

msgid "If you need help, our team is here to assist"
msgstr "Nếu bạn cần sự giúp đỡ, đội ngũ của chúng tôi sẵn sàng hỗ trợ"

msgid "Download Report"
msgstr "Tải xuống Báo cáo"

msgid "Download a detailed report of this migration for your records."
msgstr "Tải xuống báo cáo chi tiết về lần di chuyển dữ liệu này để lưu trữ."

msgid "Download PDF"
msgstr "Tải xuống PDF"

msgid "Download CSV"
msgstr "Tải xuống CSV"

msgid "Download Logs"
msgstr "Tải xuống Nhật ký"

msgid "Start Another Migration"
msgstr "Bắt đầu Di chuyển khác"

