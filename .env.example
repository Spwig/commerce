# =============================================================================
# Spwig E-commerce Platform - Environment Configuration
# =============================================================================
# Copy this file to .env and fill in your values.
# IMPORTANT: Never commit .env with real credentials to version control.
# =============================================================================

# Django Settings
DJANGO_SECRET_KEY=your-secret-key-change-in-production
DEBUG=True
DJANGO_ALLOWED_HOSTS=localhost,127.0.0.1
DJANGO_CSRF_TRUSTED_ORIGINS=http://localhost:8000,http://127.0.0.1:8000

# Database
DB_NAME=shop_db
DB_USER=shop_user
DB_PASSWORD=changeme
DB_HOST=localhost
DB_PORT=5432

# Redis
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_DB=0

# Email Settings
EMAIL_BACKEND=django.core.mail.backends.console.EmailBackend
# EMAIL_HOST=smtp.gmail.com
# EMAIL_PORT=587
# EMAIL_USE_TLS=True
# EMAIL_HOST_USER=
# EMAIL_HOST_PASSWORD=

# Email Encryption Key (for encrypting provider credentials at rest)
# Generate with: python -c "from cryptography.fernet import Fernet; print(Fernet.generate_key().decode())"
EMAIL_ENCRYPTION_KEY=

# AWS S3 (optional, for media storage)
USE_S3=False
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_STORAGE_BUCKET_NAME=
AWS_S3_REGION_NAME=us-east-1

# Sentry (optional, for error tracking)
SENTRY_DSN=

# Superuser (for Docker initial setup)
DJANGO_SUPERUSER_USERNAME=admin
DJANGO_SUPERUSER_EMAIL=admin@example.com
DJANGO_SUPERUSER_PASSWORD=changeme

# Docker ports
WEB_PORT=8000
NGINX_PORT=80

# =============================================================================
# PLATFORM SERVICES - Automatically configured by license server
# =============================================================================
# The following secrets are automatically issued by the Spwig license server
# when your installation registers. They are stored in the database and
# do NOT need to be configured in this file.
#
# - GeoIP Service JWT Secret (for IP geolocation)
# - Push Notification Service JWT Secret (for mobile app notifications)
# - SSO/Community Service JWT Secret (for community forum integration)
#
# If you need to override these for development, uncomment and set:
# GEOIP_JWT_SECRET_KEY=your-dev-secret
# PUSH_JWT_SECRET_KEY=your-dev-secret
# SSO_REGISTRATION_SECRET=your-dev-secret
# =============================================================================

# Spwig Platform Services (defaults - typically no need to change)
# PUSH_SERVICE_URL=https://push.spwig.com  # Push notification service
# GEOIP_SERVICE_URL=https://geoip.spwig.com  # GeoIP location service

# Community / Discourse Integration (optional)
COMMUNITY_ENABLED=False
SSO_BROKER_URL=https://sso.spwig.com
COMMUNITY_URL=https://community.spwig.com

# Update Server Configuration
UPDATE_SERVER_URL=https://updates.spwig.com
