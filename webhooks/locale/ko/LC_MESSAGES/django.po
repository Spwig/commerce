msgid "Fired when a refund is initiated"
msgstr "환불이 시작될 때 발생합니다"

msgid "Fired when a refund is completed"
msgstr "환불이 완료될 때 발생합니다"

msgid "Fired when a refund fails"
msgstr "환불이 실패할 때 발생"

msgid "Fired when a shipment is created"
msgstr "발송이 생성될 때 발생합니다"

msgid "Fired when a shipment is dispatched"
msgstr "발송이 배송 처리될 때 발생합니다"

msgid "Fired when a shipment is in transit"
msgstr "발송이 운송 중일 때 발생합니다"

msgid "Fired when a shipment is out for delivery"
msgstr "발송이 배송 준비 중일 때 발생합니다"

msgid "Fired when a shipment is delivered"
msgstr "발송이 배송 완료될 때 발생합니다"

msgid "Fired when a shipment delivery fails"
msgstr "발송 배송이 실패할 때 발생합니다"

msgid "Fired when a shipment is returned"
msgstr "발송이 반품될 때 발생합니다"

msgid "Fired when shipment tracking information is updated"
msgstr "발송 추적 정보가 업데이트될 때 발생합니다"

msgid "Fired when product stock falls below threshold"
msgstr "제품 재고가 임계값 이하로 떨어질 때 발생합니다"

msgid "Fired when a product goes out of stock"
msgstr "제품이 품절 상태가 될 때 발생합니다"

msgid "Fired when a product is restocked"
msgstr "제품이 재고가 다시 충전될 때 발생합니다"

msgid "Fired when inventory is manually adjusted"
msgstr "재고가 수동으로 조정될 때 발생합니다"

msgid "Fired when a new product is created"
msgstr "새로운 제품이 생성될 때 발생합니다"

msgid "Fired when product details are updated"
msgstr "제품 정보가 업데이트될 때 발생합니다"

msgid "Fired when a product is deleted"
msgstr "제품이 삭제될 때 발생합니다"

msgid "Fired when a product is published"
msgstr "제품이 게시될 때 발생합니다"

msgid "Fired when a product is unpublished"
msgstr "제품이 게시되지 않을 때 발생합니다"

msgid "Fired when a new customer registers"
msgstr "새로운 고객이 등록될 때 발생합니다"

msgid "Fired when customer profile is updated"
msgstr "고객 프로필이 업데이트될 때 발생합니다"

msgid "Fired when a customer account is deleted"
msgstr "고객 계정이 삭제될 때 발생합니다"

msgid "Fired when a new subscription is created"
msgstr "새로운 구독이 생성될 때 발생합니다"

msgid "Fired when a subscription is activated"
msgstr "구독이 활성화될 때 발생합니다"

msgid "Fired when a subscription is renewed"
msgstr "구독이 갱신될 때 발생합니다"

msgid "Fired when a subscription is cancelled"
msgstr "구독이 취소될 때 발생합니다"

msgid "Fired when a subscription expires"
msgstr "구독이 만료될 때 발생"

msgid "Fired when a subscription is paused"
msgstr "구독이 일시 중지될 때 발생합니다"

msgid "Fired when a paused subscription is resumed"
msgstr "일시 중지된 구독이 재개될 때 발생합니다"

msgid "Fired when a subscription payment fails"
msgstr "구독 결제가 실패할 때 발생합니다"

msgid "Fired when a cart is abandoned (after configurable delay)"
msgstr "장바구니가 포기될 때 발생합니다 (설정 가능한 지연 시간 후)"

msgid "Fired when an abandoned cart is recovered"
msgstr "포기된 장바구니가 복구될 때 발생합니다"

msgid "Fired when a translation job completes successfully"
msgstr "번역 작업이 성공적으로 완료될 때 발생합니다"

msgid "Fired when a translation job fails"
msgstr "번역 작업이 실패할 때 발생합니다"

msgid "name"
msgstr "이름"

msgid "A friendly name to identify this webhook endpoint"
msgstr "이 웹훅 엔드포인트를 식별하기 위한 친근한 이름"

msgid "The URL that will receive webhook POST requests"
msgstr "웹훅 POST 요청을 수신할 URL"

msgid "secret"
msgstr "비밀"

msgid "Secret key used for HMAC signature verification"
msgstr "HMAC 서명 검증에 사용되는 비밀 키"

msgid "active"
msgstr "활성"

msgid "Whether this endpoint is currently receiving webhooks"
msgstr "이 엔드포인트가 현재 웹훅을 수신하는지 여부"

msgid "subscribed events"
msgstr "구독된 이벤트"

msgid "List of event types this endpoint is subscribed to"
msgstr "이 엔드포인트가 구독한 이벤트 유형 목록"

msgid "max retries"
msgstr "최대 재시도 횟수"

msgid "Maximum number of retry attempts for failed deliveries"
msgstr "실패한 배송에 대한 최대 재시도 횟수"

msgid "timeout (seconds)"
msgstr "타임아웃 (초)"

msgid "Timeout in seconds for webhook requests"
msgstr "웹훅 요청에 대한 초 단위 타임아웃"

msgid "description"
msgstr "설명"

msgid "Optional description of this webhook endpoint"
msgstr "이 웹훅 엔드포인트의 선택적 설명"

msgid "created at"
msgstr "작성 시간"

msgid "updated at"
msgstr "수정 시간"

msgid "last triggered"
msgstr "마지막으로 트리거됨"

msgid "When this endpoint last received a webhook"
msgstr "이 엔드포인트가 마지막으로 웹훅을 받은 시간"

msgid "consecutive failures"
msgstr "연속 실패"

msgid "Number of consecutive failed delivery attempts"
msgstr "연속으로 실패한 전송 시도 횟수"

msgid "disabled by failures"
msgstr "실패로 인해 비활성화됨"

msgid "Whether this endpoint was auto-disabled due to failures"
msgstr "이 엔드포인트가 실패로 인해 자동으로 비활성화되었는지 여부"

msgid "webhook endpoint"
msgstr "웹훅 엔드포인트"

msgid "webhook endpoints"
msgstr "웹훅 엔드포인트들"

msgid "Pending"
msgstr "대기 중"

msgid "endpoint"
msgstr "엔드포인트"

msgid "event type"
msgstr "이벤트 유형"

msgid "The type of event that triggered this delivery"
msgstr "이 전송을 트리거한 이벤트 유형"

msgid "payload"
