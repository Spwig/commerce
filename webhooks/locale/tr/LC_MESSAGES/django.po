msgstr "Doğrulama için HMAC-SHA256 imzası"

msgid "The event type"
msgstr "Olay türü"

msgid "Unique delivery identifier (UUID)"
msgstr "Benzersiz teslimat tanımlayıcısı (UUID)"

msgid "Unix timestamp when sent"
msgstr "Gönderilme zamanı (Unix zaman damgası)"

msgid "Content type"
msgstr "İçerik türü"

