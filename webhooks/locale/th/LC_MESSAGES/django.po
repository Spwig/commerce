msgid "Basic"
msgstr "พื้นฐาน"

msgid "Event Subscriptions"
msgstr "การสมัครรับข่าวสารเหตุการณ์"

msgid ""
"Select the events this endpoint should receive. Use [\"*\"] to receive all "
"events."
msgstr "เลือกเหตุการณ์ที่ปลายทางนี้ควรรับ. ใช้ [\"*\"] เพื่อรับเหตุการณ์ทั้งหมด"

msgid "Configuration"
msgstr "การตั้งค่า"

msgid "Security"
msgstr "ความปลอดภัย"

msgid ""
"The secret is used to sign webhook payloads. Use the API to rotate the "
"secret if needed."
msgstr "คีย์ลับถูกใช้เพื่อลงนาม payload ของ webhook. ใช้ API เพื่อเปลี่ยนคีย์ลับ หากจำเป็น"

msgid "Health & Status"
msgstr "สุขภาพและสถานะ"

msgid "Timestamps"
msgstr "เวลาที่บันทึก"

msgid "URL"
msgstr "URL"

msgid "Disabled due to consecutive failures"
msgstr "ปิดใช้งานเนื่องจากความล้มเหลวต่อเนื่อง"

msgid "Disabled"
msgstr "ปิดใช้งาน"

msgid "Active"
msgstr "ใช้งานอยู่"

msgid "Inactive"
msgstr "ไม่ได้ใช้งาน"

msgid "Status"
msgstr "สถานะ"

msgid "None"
msgstr "ไม่มี"

msgid "All events"
msgstr "เหตุการณ์ทั้งหมด"

msgid "events"
msgstr "เหตุการณ์"

msgid "Subscribed Events"
msgstr "เหตุการณ์ที่สมัครรับข่าวสาร"

msgid "Unhealthy"
msgstr "ไม่สุขภาพดี"

msgid "Degraded"
msgstr "ลดลง"

msgid "Healthy"
msgstr "สุขภาพดี"

msgid "Health"
msgstr "สุขภาพ"

msgid "Never"
msgstr "ไม่มีการตั้งค่า"

msgid "Recently"
msgstr "ไม่นานมานี้"

msgid "hours"
msgstr "ชั่วโมง"

msgid "ago"
msgstr "ก่อน"

msgid "days"
msgstr "วัน"

msgid "Last Triggered"
msgstr "สุดท้ายที่ถูกกระตุ้น"

msgid "Use API to view or rotate"
msgstr "ใช้ API เพื่อดูหรือเปลี่ยนคีย์ลับ"

msgid "Secret"
msgstr "รหัสลับ"

msgid "Total"
msgstr "รวม"

msgid "Success"
msgstr "สำเร็จ"

msgid "Failed"
msgstr "ล้มเหลว"

msgid "Retrying"
msgstr "กำลังลองอีกครั้ง"

msgid "Success Rate"
msgstr "อัตราความสำเร็จ"

msgid "Avg Response"
msgstr "การตอบสนองเฉลี่ย"

msgid "Delivery Stats (24h)"
msgstr "สถิติการจัดส่ง (24 ชม.)"

msgid "Enable selected endpoints"
msgstr "เปิดใช้งานปลายทางที่เลือก"

#, python-format
msgid "%d endpoint(s) enabled."
msgstr "%d จุดปลายทางเปิดใช้งานแล้ว。"

msgid "Disable selected endpoints"
msgstr "ปิดใช้งานปลายทางที่เลือก"

#, python-format
msgid "%d endpoint(s) disabled."
msgstr "%d จุดปลายทางถูกปิดใช้งาน。"

msgid "Reset failure count"
msgstr "รีเซ็ตจำนวนความล้มเหลว"

#, python-format
msgid "%d endpoint(s) reset."
msgstr "%d จุดปลายทางได้รับการรีเซ็ต。"

msgid "Payload"
msgstr "ข้อมูลที่ส่ง"

msgid "Response"
msgstr "การตอบกลับ"

msgid "Error Details"
msgstr "รายละเอียดข้อผิดพลาด"

msgid "Retry Information"
msgstr "ข้อมูลการลองอีกครั้ง"

msgid "ID"
msgstr "ID"

msgid "Endpoint"
msgstr "จุดปลาย"

msgid "Time"
msgstr "เวลา"

msgid "Response Body"
msgstr "เนื้อหาการตอบกลับ"

msgid "Retry selected deliveries"
msgstr "ลองจัดส่งที่เลือกอีกครั้ง"

#, python-format
msgid "%d delivery(ies) queued for retry."
msgstr "%d การส่งข้อมูลถูกจัดคิวสำหรับการลองอีกครั้ง。"

msgid "List webhook endpoints"
msgstr "รายการปลายทาง webhook"

msgid "Get all configured webhook endpoints for this store."
msgstr "ดึงข้อมูลปลายทางเวิร์กฮุคที่ตั้งค่าไว้สำหรับร้านค้านี้ทั้งหมด"

msgid "Create webhook endpoint"
msgstr "สร้างปลายทาง webhook"

msgid ""
"Create a new webhook endpoint.\n"
"\n"
"        The secret will be auto-generated and returned in the response.\n"
"        **Store the secret securely** - it will only be shown once.\n"
"\n"
"        Example events: `order.created`, `order.shipped`, `payment.received`"
msgstr ""
"สร้างปลายทาง webhook ใหม่\n"
"\n"
"คีย์ลับจะถูกสร้างอัตโนมัติและคืนค่าในผลลัพธ์\n"
"**เก็บคีย์ลับไว้ในที่ปลอดภัย** - มันจะแสดงเพียงครั้งเดียวเท่านั้น\n"
"\n"
"ตัวอย่างเหตุการณ์: `order.created`, `order.shipped`, `payment.received`"

msgid "Validation error"
msgstr "ข้อผิดพลาดในการตรวจสอบ"

msgid "Get webhook endpoint"
msgstr "รับปลายทางเวิร์กฮุก"

msgid "Get details of a specific webhook endpoint."
msgstr "ดูรายละเอียดของปลายทาง webhook ที่กำหนด"

msgid "Endpoint not found"
msgstr "ไม่พบปลายทาง"

msgid "Update webhook endpoint"
msgstr "อัปเดตปลายทางเวิร์กฮุก"

msgid "Update an existing webhook endpoint."
msgstr "อัปเดตปลายทางเวิร์กฮุกที่มีอยู่แล้ว"

msgid "Delete webhook endpoint"
msgstr "ลบปลายทางเวิร์กฮุก"

msgid "Delete a webhook endpoint. All delivery logs will also be deleted."
msgstr "ลบปลายทางเวิร์กฮุค บันทึกการส่งข้อมูลทั้งหมดจะถูกลบไปด้วย"

msgid "Endpoint deleted"
msgstr "ลบปลายทางแล้ว"

msgid "Test webhook endpoint"
msgstr "ทดสอบปลายทางเว็บฮูค"

msgid ""
"Send a test webhook to verify the endpoint configuration.\n"
"\n"
"    This sends a `test.webhook` event with sample data to verify\n"
"    that the endpoint is reachable and properly configured."
msgstr ""
"ส่ง webhook ทดสอบเพื่อตรวจสอบการตั้งค่าปลายทาง\n"
"\n"
"การดำเนินการนี้จะส่งเหตุการณ์ `test.webhook` พร้อมข้อมูลตัวอย่างเพื่อตรวจสอบ\n"
"ว่าปลายทางสามารถเข้าถึงได้และตั้งค่าอย่างถูกต้อง"

msgid "Rotate webhook secret"
msgstr "หมุนเวียนคีย์ลับเว็บฮูค"

msgid ""
"Generate a new secret for a webhook endpoint.\n"
"\n"
"    The new secret will be returned in the response. **Store it securely** "
"-\n"
"    it will not be shown again. You will need to update your webhook\n"
"    receiver to use the new secret."
msgstr ""
"สร้างคีย์ลับใหม่สำหรับปลายทาง webhook\n"
"\n"
"คีย์ลับใหม่จะถูกคืนค่าในผลลัพธ์ **เก็บไว้อย่างปลอดภัย** -\n"
"จะไม่แสดงอีกครั้ง คุณจะต้องอัปเดตตัวรับ webhook\n"
"ให้ใช้คีย์ลับใหม่นี้"

msgid "Reset endpoint failures"
msgstr "รีเซ็ตความล้มเหลวของปลายทาง"

msgid ""
"Reset the failure count for a webhook endpoint.\n"
"\n"
"    This re-enables an endpoint that was auto-disabled due to\n"
"    consecutive failures."
msgstr ""
"รีเซ็ตจำนวนความล้มเหลวของปลายทาง webhook\n"
"\n"
"สิ่งนี้จะเปิดใช้งานปลายทางอีกครั้งที่ถูกปิดใช้งานโดยอัตโนมัติเนื่องจาก\n"
"ความล้มเหลวติดต่อกัน"

msgid "List webhook deliveries"
msgstr "รายการการส่งเว็บฮูค"

msgid "Get webhook delivery logs with optional filtering."
msgstr "ดึงบันทึกการส่งเวิร์กฮุคพร้อมการกรองข้อมูลแบบเลือกได้"

msgid "Filter by endpoint UUID"
msgstr "กรองตาม UUID ของปลายทาง"

msgid "Filter by event type (e.g., order.created)"
msgstr "กรองตามประเภทเหตุการณ์ (เช่น order.created)"

msgid "Filter by delivery status"
msgstr "กรองตามสถานะการจัดส่ง"

msgid "Number of results to return (default 50, max 200)"
msgstr "จำนวนผลลัพธ์ที่ต้องการ (ค่าเริ่มต้น 50, สูงสุด 200)"

msgid "Get webhook delivery"
msgstr "รับการส่งเว็บฮูค"

msgid "Get details of a specific webhook delivery including the full payload."
msgstr "ดูรายละเอียดการส่ง webhook ที่เฉพาะเจาะจง รวมถึงข้อมูลทั้งหมด"

msgid "Delivery not found"
msgstr "ไม่พบการจัดส่ง"

msgid "Retry webhook delivery"
msgstr "ลองส่ง webhook อีกครั้ง"

msgid ""
"Manually retry a failed webhook delivery.\n"
"\n"
"    This queues the delivery for immediate retry, regardless of\n"
"    the scheduled retry time."
msgstr ""
"ลองส่ง webhook ที่ล้มเหลวอีกครั้งด้วยตนเอง\n"
"\n"
"การดำเนินการนี้จะเพิ่มการส่งเข้าคิวเพื่อให้ลองอีกครั้งทันที โดยไม่คำนึงถึง\n"
"เวลาที่กำหนดไว้สำหรับการลองอีกครั้ง"

msgid "Cannot retry this delivery"
msgstr "ไม่สามารถลองส่งอีกครั้งได้"

msgid "List webhook event types"
msgstr "รายการประเภทเหตุการณ์ webhook"

msgid ""
"Get all available webhook event types.\n"
"\n"
"    Returns a list of events that can be subscribed to when\n"
"    creating a webhook endpoint."
msgstr ""
"ดึงประเภทเหตุการณ์ webhook ทั้งหมดที่มีอยู่\n"
"\n"
"คืนรายการเหตุการณ์ที่สามารถสมัครรับการแจ้งเตือนได้เมื่อ\n"
"สร้างปลายทาง webhook"

msgid "Get webhook documentation"
msgstr "ดูเอกสาร webhook"

msgid ""
"Get comprehensive documentation for webhook integration.\n"
"\n"
"    Returns all available event types, payload schemas, signature "
"verification\n"
"    instructions, and code examples for integrating with the webhook "
"system.\n"
"\n"
"    This endpoint is publicly accessible to allow external developers to\n"
"    understand webhook payloads without authentication."
msgstr ""
"รับเอกสารประกอบการใช้งาน webhook integration อย่างครบวงจร\n"
"\n"
"ส่งกลับประเภทเหตุการณ์ทั้งหมด โครงสร้างข้อมูล payload การตรวจสอบลายเซ็น\n"
"คำแนะนำ และตัวอย่างโค้ดสำหรับการเชื่อมต่อกับระบบ webhook\n"
"\n"
"ปลายทางนี้สามารถเข้าถึงได้โดยไม่ต้องใช้การยืนยันตัวตน เพื่อให้ผู้พัฒนาภายนอกสามารถ\n"
"เข้าใจ payload ของ webhook ได้โดยไม่ต้องผ่านการตรวจสอบความถูกต้อง"

msgid "Get webhook endpoint stats"
msgstr "ดูสถิติปลายทาง webhook"

msgid "Get delivery statistics for a webhook endpoint."
msgstr "ดูสถิติการส่งข้อมูลของปลายทาง webhook"

msgid "Webhooks"
msgstr "เวิร์กโฮก"

msgid "Fired when a new order is placed"
msgstr "เกิดขึ้นเมื่อมีการสั่งซื้อใหม่"

msgid "Fired when payment for an order is confirmed"
msgstr "เกิดขึ้นเมื่อการชำระเงินสำหรับการสั่งซื้อถูกยืนยัน"

msgid "Fired when an order is cancelled"
msgstr "เกิดขึ้นเมื่อการสั่งซื้อถูกยกเลิก"

msgid "Fired when all items in an order are shipped"
msgstr "เกิดขึ้นเมื่อสินค้าทั้งหมดในรายการสั่งซื้อถูกจัดส่ง"

msgid "Fired when some items in an order are shipped"
msgstr "เกิดขึ้นเมื่อสินค้าบางส่วนในรายการสั่งซื้อถูกจัดส่ง"

msgid "Fired when order status changes"
msgstr "ถูกกระตุ้นเมื่อสถานะคำสั่งซื้อเปลี่ยน"

msgid "Fired when a note is added to an order"
msgstr "เกิดขึ้นเมื่อมีการเพิ่มหมายเหตุในรายการสั่งซื้อ"

msgid "Fired when a payment is received"
msgstr "เกิดขึ้นเมื่อได้รับการชำระเงิน"

msgid "Fired when a payment attempt fails"
msgstr "เกิดขึ้นเมื่อการพยายามชำระเงินล้มเหลว"

msgid "Fired when a payment is pending confirmation"
msgstr "เกิดขึ้นเมื่อการชำระเงินรอการยืนยัน"

msgid "Fired when a refund is initiated"
msgstr "เกิดขึ้นเมื่อเริ่มต้นการคืนเงิน"

msgid "Fired when a refund is completed"
msgstr "เกิดขึ้นเมื่อการคืนเงินเสร็จสิ้น"

msgid "Fired when a refund fails"
msgstr "ถูกกระตุ้นเมื่อการคืนเงินล้มเหลว"

msgid "Fired when a shipment is created"
msgstr "เกิดขึ้นเมื่อสร้างการจัดส่ง"

msgid "Fired when a shipment is dispatched"
msgstr "เกิดขึ้นเมื่อส่งการจัดส่ง"

msgid "Fired when a shipment is in transit"
msgstr "เกิดขึ้นเมื่อการจัดส่งอยู่ระหว่างการขนส่ง"

msgid "Fired when a shipment is out for delivery"
msgstr "เกิดขึ้นเมื่อการจัดส่งพร้อมส่งแล้ว"

msgid "Fired when a shipment is delivered"
msgstr "เกิดขึ้นเมื่อการจัดส่งถูกส่งถึงมือผู้รับ"

msgid "Fired when a shipment delivery fails"
msgstr "เกิดขึ้นเมื่อการจัดส่งล้มเหลว"

msgid "Fired when a shipment is returned"
msgstr "เกิดขึ้นเมื่อการจัดส่งถูกคืน"

msgid "Fired when shipment tracking information is updated"
msgstr "เกิดขึ้นเมื่อข้อมูลการติดตามการจัดส่งถูกอัปเดต"

msgid "Fired when product stock falls below threshold"
msgstr "เกิดขึ้นเมื่อสต็อกสินค้าต่ำกว่าระดับที่กำหนด"

msgid "Fired when a product goes out of stock"
msgstr "เกิดขึ้นเมื่อสินค้าหมดสต็อก"

msgid "Fired when a product is restocked"
msgstr "เกิดขึ้นเมื่อสินค้ามีสต็อกใหม่"

msgid "Fired when inventory is manually adjusted"
msgstr "เกิดขึ้นเมื่อสต็อกถูกปรับเปลี่ยนด้วยตนเอง"

msgid "Fired when a new product is created"
msgstr "เกิดขึ้นเมื่อสร้างสินค้าใหม่"

msgid "Fired when product details are updated"
msgstr "เกิดขึ้นเมื่อรายละเอียดสินค้าถูกอัปเดต"

msgid "Fired when a product is deleted"
msgstr "เกิดขึ้นเมื่อสินค้าถูกลบ"

msgid "Fired when a product is published"
msgstr "เกิดขึ้นเมื่อสินค้าถูกเผยแพร่"

msgid "Fired when a product is unpublished"
msgstr "เกิดขึ้นเมื่อสินค้าถูกยกเลิกการเผยแพร่"

msgid "Fired when a new customer registers"
msgstr "เกิดขึ้นเมื่อผู้ซื้อใหม่ลงทะเบียน"

msgid "Fired when customer profile is updated"
msgstr "เกิดขึ้นเมื่อโปรไฟล์ของลูกค้าถูกอัปเดต"

msgid "Fired when a customer account is deleted"
msgstr "เกิดขึ้นเมื่อบัญชีลูกค้าถูกลบ"

msgid "Fired when a new subscription is created"
msgstr "เกิดขึ้นเมื่อสร้างการสมัครสมาชิกใหม่"

msgid "Fired when a subscription is activated"
msgstr "เกิดขึ้นเมื่อการสมัครสมาชิกถูกเปิดใช้งาน"

msgid "Fired when a subscription is renewed"
msgstr "เกิดขึ้นเมื่อการสมัครสมาชิกถูกต่ออายุ"

msgid "Fired when a subscription is cancelled"
msgstr "เกิดขึ้นเมื่อการสมัครสมาชิกถูกยกเลิก"

msgid "Fired when a subscription expires"
msgstr "ถูกกระตุ้นเมื่อการสมัครสมาชิกหมดอายุ"

msgid "Fired when a subscription is paused"
msgstr "เกิดขึ้นเมื่อการสมัครสมาชิกถูกระงับ"

msgid "Fired when a paused subscription is resumed"
msgstr "เกิดขึ้นเมื่อการสมัครสมาชิกที่ถูกระงับได้รับการเปิดใช้งานใหม่"

msgid "Fired when a subscription payment fails"
msgstr "เกิดขึ้นเมื่อการชำระเงินสำหรับการสมัครสมาชิกล้มเหลว"

msgid "Fired when a cart is abandoned (after configurable delay)"
msgstr "เกิดขึ้นเมื่อตะกร้าถูกทิ้ง (หลังจากช่วงเวลาที่กำหนดได้)"

msgid "Fired when an abandoned cart is recovered"
msgstr "เกิดขึ้นเมื่อตะกร้าที่ถูกทิ้งได้รับการกู้คืน"

msgid "Fired when a translation job completes successfully"
msgstr "ถูกเรียกใช้เมื่องานแปลเสร็จสมบูรณ์สำเร็จ"

msgid "Fired when a translation job fails"
msgstr "ถูกเรียกใช้เมื่องานแปลล้มเหลว"

msgid "name"
msgstr "ชื่อ"

msgid "A friendly name to identify this webhook endpoint"
msgstr "ชื่อที่เป็นมิตรเพื่อระบุปลายทาง webhook นี้"

msgid "The URL that will receive webhook POST requests"
msgstr "URL ที่จะได้รับคำขอ POST จาก webhook"

