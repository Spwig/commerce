msgstr "Nama titik akhir diperlukan"

msgid "Webhook URL is required"
msgstr "URL webhook diperlukan"

msgid "URL must start with http:// or https://"
msgstr "URL harus dimulai dengan http:// atau https://"

msgid "Please select at least one event"
msgstr "Silakan pilih setidaknya satu acara"

msgid "None selected"
msgstr "Tidak ada yang dipilih"

