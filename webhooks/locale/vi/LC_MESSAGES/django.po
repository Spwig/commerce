msgid "Retry Schedule:"
msgstr "Lịch trình thử lại:"

msgid ""
"Failed deliveries are retried with exponential backoff: 1 minute, 2 minutes, "
"4 minutes, 8 minutes, etc."
msgstr ""
"Các lần giao hàng thất bại sẽ được thử lại với cơ chế tăng dần thời gian "
"chờ: 1 phút, 2 phút, 4 phút, 8 phút, v.v."

msgid "Timeout Settings"
msgstr "Cài đặt thời gian chờ"

