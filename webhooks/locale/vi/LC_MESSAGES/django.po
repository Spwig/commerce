msgid "Fired when an abandoned cart is recovered"
msgstr "Kích hoạt khi một giỏ hàng bị bỏ qua được phục hồi"

msgid "Fired when a translation job completes successfully"
msgstr "Được kích hoạt khi công việc dịch thuật hoàn thành thành công"

msgid "Fired when a translation job fails"
msgstr "Được kích hoạt khi công việc dịch thuật thất bại"

