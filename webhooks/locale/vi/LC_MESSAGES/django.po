msgstr "2 phút"

msgid "4 minutes"
msgstr "4 phút"

msgid "8 minutes"
msgstr "8 phút"

msgid "Important Notes"
msgstr "Lưu ý quan trọng"

msgid "Webhooks are considered successful if they return a 2xx status code."
msgstr "Webhook được coi là thành công nếu chúng trả về mã trạng thái 2xx."

msgid "Your endpoint should respond within 30 seconds."
msgstr "Đầu tận điểm của bạn nên phản hồi trong vòng 30 giây."

msgid "After 5 failed attempts, the delivery is marked as failed."
msgstr "Sau 5 lần thất bại, lần giao hàng được đánh dấu là thất bại."

msgid "After 10 consecutive failures, the endpoint is automatically disabled."
msgstr "Sau 10 lần thất bại liên tiếp, đầu tận điểm sẽ bị tắt tự động."

