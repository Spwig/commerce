msgid "Basic"
msgstr "मूल"

msgid "Event Subscriptions"
msgstr "इवेंट सब्सक्रिप्शन्स"

msgid ""
"Select the events this endpoint should receive. Use [\"*\"] to receive all "
"events."
msgstr ""
"इस अंत मानक द्वारा प्राप्त किए जाने वाले ईवेंट्स का चयन करें। सभी ईवेंट्स प्राप्त करने के लिए "
"[\"*\"] का उपयोग करें।"

msgid "Configuration"
msgstr "संfiguration"

msgid "Security"
msgstr "सुरक्षा"

msgid ""
"The secret is used to sign webhook payloads. Use the API to rotate the "
"secret if needed."
msgstr ""
"गुप्त रखरखा वेबहॉक लोड को हस्ताक्षर करने के लिए उपयोग किया जाता है। यदि आवश्यक हो तो "
"एपीआई का उपयोग करके गुप्त रखरखा बदलें।"

msgid "Health & Status"
msgstr "स्वास्थ्य और स्थिति"

msgid "Timestamps"
msgstr "टाइमस्टैंप"

msgid "URL"
msgstr "URL"

msgid "Disabled due to consecutive failures"
msgstr "क्रमागत विफलताओं के कारण अक्षम"

msgid "Disabled"
msgstr "अक्षम"

msgid "Active"
msgstr "सक्रिय"

msgid "Inactive"
msgstr "असक्रिय"

msgid "Status"
msgstr "स्थिति"

msgid "None"
msgstr "कोई नहीं"

msgid "All events"
msgstr "सभी इवेंट्स"

msgid "events"
msgstr "इवेंट्स"

msgid "Subscribed Events"
msgstr "सब्सक्राइब किए गए इवेंट्स"

msgid "Unhealthy"
msgstr "अस्वास्थ्यकर"

msgid "Degraded"
msgstr "हानि"

msgid "Healthy"
msgstr "स्वास्थ्यकर"

msgid "Health"
msgstr "स्वास्थ्य"

msgid "Never"
msgstr "कभी नहीं"

msgid "Recently"
msgstr "हालिया"

msgid "hours"
msgstr "घंटे"

msgid "ago"
msgstr "पहले"

msgid "days"
msgstr "दिन"

msgid "Last Triggered"
msgstr "अंतिम ट्रिगर किया गया"

msgid "Use API to view or rotate"
msgstr "देखें या बदलें के लिए एपीआई का उपयोग करें"

msgid "Secret"
msgstr "गुप्त"

msgid "Total"
msgstr "कुल"

msgid "Success"
msgstr "सफलता"

msgid "Failed"
msgstr "विफल"

msgid "Retrying"
msgstr "पुनः प्रयास कर रहा है"

msgid "Success Rate"
msgstr "सफलता दर"

msgid "Avg Response"
msgstr "औसत प्रतिक्रिया"

msgid "Delivery Stats (24h)"
msgstr "वितरण स्टैट्स (24h)"

msgid "Enable selected endpoints"
msgstr "चयनित अंत मार्गों को सक्रिय करें"

#, python-format
msgid "%d endpoint(s) enabled."
msgstr "%d अंत मार्ग सक्रिय कर दिए गए।"

msgid "Disable selected endpoints"
msgstr "चयनित अंत मार्गों को अक्षम करें"

#, python-format
msgid "%d endpoint(s) disabled."
msgstr "%d अंत मार्ग असक्रिय कर दिए गए।"

msgid "Reset failure count"
msgstr "विफलता के गिनती को रीसेट करें"

#, python-format
msgid "%d endpoint(s) reset."
msgstr "%d अंत मार्ग रीसेट कर दिए गए।"

msgid "Payload"
msgstr "पेलोड"

msgid "Response"
msgstr "प्रतिक्रिया"

msgid "Error Details"
msgstr "त्रुटि विवरण"

msgid "Retry Information"
msgstr "पुनर्प्रयास जानकारी"

msgid "ID"
msgstr "आईडी"

msgid "Endpoint"
msgstr "अंत-बिंदु"

msgid "Time"
msgstr "समय"

msgid "Response Body"
msgstr "प्रतिक्रिया शरीर"

msgid "Retry selected deliveries"
msgstr "चयनित वितरणों को पुनर्प्रयास करें"

#, python-format
msgid "%d delivery(ies) queued for retry."
msgstr "%d डिलीवरी(एस) पुन: प्रयास के लिए पंक्ति में हैं।"

msgid "List webhook endpoints"
msgstr "वेबहुक अंत बिंदु सूची"

msgid "Get all configured webhook endpoints for this store."
msgstr "इस स्टोर के लिए सभी सेट किए गए वेबहुक एंडपॉइंट प्राप्त करें।"

msgid "Create webhook endpoint"
msgstr "वेबहुक अंत बिंदु बनाएं"

msgid ""
"Create a new webhook endpoint.\n"
"\n"
"        The secret will be auto-generated and returned in the response.\n"
"        **Store the secret securely** - it will only be shown once.\n"
"\n"
"        Example events: `order.created`, `order.shipped`, `payment.received`"
msgstr ""
"एक नया webhook एंडपॉइंट बनाएं।\n"
"\n"
"सीक्रेट स्वचालित रूप से उत्पन्न किया जाएगा और प्रतिक्रिया में लौटाया जाएगा।\n"
"**सीक्रेट को सुरक्षित रूप से संग्रहित करें** - यह केवल एक बार दिखाया जाएगा।\n"
"\n"
"उदाहरण ईवेंट: `order.created`, `order.shipped`, `payment.received`"

msgid "Validation error"
msgstr "वैधता त्रुटि"

msgid "Get webhook endpoint"
msgstr "वेबहुक एंडपॉइंट प्राप्त करें"

msgid "Get details of a specific webhook endpoint."
msgstr "एक विशिष्ट webhook एंडपॉइंट के विवरण प्राप्त करें।"

msgid "Endpoint not found"
msgstr "एंडपॉइंट नहीं मिला"

msgid "Update webhook endpoint"
msgstr "वेबहुक एंडपॉइंट अपडेट करें"

msgid "Update an existing webhook endpoint."
msgstr "एक मौजूदा वेबहुक एंडपॉइंट को अपडेट करें।"

msgid "Delete webhook endpoint"
msgstr "वेबहुक एंडपॉइंट हटाएं"

msgid "Delete a webhook endpoint. All delivery logs will also be deleted."
msgstr "एक वेबहुक एंडपॉइंट हटाएं। सभी डिलीवरी लॉग भी हटा दिए जाएंगे।"

msgid "Endpoint deleted"
msgstr "एंडपॉइंट हटा दिया गया"

msgid "Test webhook endpoint"
msgstr "वेबहॉक अंत बिंदु का परीक्षण करें"

msgid ""
"Send a test webhook to verify the endpoint configuration.\n"
"\n"
"    This sends a `test.webhook` event with sample data to verify\n"
"    that the endpoint is reachable and properly configured."
msgstr ""
"एंडपॉइंट विन्यास की जांच करने के लिए एक परीक्षण webhook भेजें।\n"
"\n"
"यह एक `test.webhook` ईवेंट भेजता है जिसमें नमूना डेटा होता है ताकि जांच की जा सके\n"
"कि एंडपॉइंट पहुंच योग्य है और सही ढंग से विन्यासित है।"

msgid "Rotate webhook secret"
msgstr "वेबहॉक गुप्त रखें के घूर्णन करें"

msgid ""
"Generate a new secret for a webhook endpoint.\n"
"\n"
"    The new secret will be returned in the response. **Store it securely** "
"-\n"
"    it will not be shown again. You will need to update your webhook\n"
"    receiver to use the new secret."
msgstr ""
"एक वेबहॉक एंडपॉइंट के लिए एक नया सीक्रेट जनरेट करें।\n"
"\n"
"नया सीक्रेट प्रतिक्रिया में लौटाया जाएगा। **इसे सुरक्षित रूप से संग्रहित करें** -\n"
"इसे पुनः दिखाया नहीं जाएगा। आपको अपने वेबहॉक रिसीवर को अपडेट करने की आवश्यकता होगी\n"
"नए सीक्रेट का उपयोग करने के लिए।"

msgid "Reset endpoint failures"
msgstr "अंत बिंदु विफलताओं को रीसेट करें"

msgid ""
"Reset the failure count for a webhook endpoint.\n"
"\n"
"    This re-enables an endpoint that was auto-disabled due to\n"
"    consecutive failures."
msgstr ""
"एक वेबहॉक एंडपॉइंट के लिए विफलता की गिनती रीसेट करें।\n"
"\n"
"यह एक ऐसे एंडपॉइंट को पुनः तैयार कर देगा जो क्रमागत विफलताओं के कारण स्वचालित रूप से "
"अक्षम कर दिया गया था।"

msgid "List webhook deliveries"
msgstr "वेबहॉक डिलीवरी की सूची"

msgid "Get webhook delivery logs with optional filtering."
msgstr "वैकल्पिक फ़िल्टरिंग के साथ वेबहुक डिलीवरी लॉग प्राप्त करें।"

msgid "Filter by endpoint UUID"
msgstr "अंत बिंदु UUID द्वारा छानें"

msgid "Filter by event type (e.g., order.created)"
msgstr "इवेंट प्रकार द्वारा फ़िल्टर करें (उदा., order.created)"

msgid "Filter by delivery status"
msgstr "वितरण स्थिति के अनुसार फ़िल्टर करें"

msgid "Number of results to return (default 50, max 200)"
msgstr "वापस करने के लिए परिणामों की संख्या (डिफ़ॉल्ट 50, अधिकतम 200)"

msgid "Get webhook delivery"
msgstr "वेबहॉक डिलीवरी प्राप्त करें"

msgid "Get details of a specific webhook delivery including the full payload."
msgstr "एक विशिष्ट webhook डिलीवरी के विवरण प्राप्त करें, जिसमें पूरा पेलोड शामिल है।"

msgid "Delivery not found"
msgstr "डिलीवरी नहीं मिली"

msgid "Retry webhook delivery"
msgstr "वेबहुक डिलीवरी को फिर से प्रयास करें"

msgid ""
"Manually retry a failed webhook delivery.\n"
"\n"
"    This queues the delivery for immediate retry, regardless of\n"
"    the scheduled retry time."
msgstr ""
"एक विफल webhook डिलीवरी को मनमाने ढंग से दोबारा प्रयास करें।\n"
"\n"
"यह डिलीवरी को तुरंत दोबारा प्रयास के लिए क्यू में रखता है, भले ही\n"
"निर्धारित दोबारा प्रयास समय के बिना।"

msgid "Cannot retry this delivery"
msgstr "इस वितरण को फिर से प्रयास नहीं किया जा सकता"

msgid "List webhook event types"
msgstr "वेबहुक ईवेंट प्रकारों की सूची"

msgid ""
"Get all available webhook event types.\n"
"\n"
"    Returns a list of events that can be subscribed to when\n"
"    creating a webhook endpoint."
msgstr ""
"सभी उपलब्ध webhook इवेंट प्रकार प्राप्त करें।\n"
"\n"
"एक webhook एंडपॉइंट बनाते समय सदस्यता ले सकने वाले\n"
"इवेंटों की सूची लौटाता है।"

msgid "Get webhook documentation"
msgstr "वेबहुक दस्तावेज प्राप्त करें"

msgid ""
"Get comprehensive documentation for webhook integration.\n"
"\n"
"    Returns all available event types, payload schemas, signature "
"verification\n"
"    instructions, and code examples for integrating with the webhook "
"system.\n"
"\n"
"    This endpoint is publicly accessible to allow external developers to\n"
"    understand webhook payloads without authentication."
msgstr ""
"वेबहॉक एंटीग्रेशन के लिए व्यापक दस्तावेज़ प्राप्त करें।\n"
"\n"
"सभी उपलब्ध इवेंट प्रकार, पेलोड स्कीमा, साइनचर वेरिफिकेशन\n"
"निर्देशों और वेबहॉक सिस्टम के साथ एंटीग्रेशन के लिए कोड उदाहरण लौटाता है।\n"
"\n"
"यह एंडपॉइंट बिना प्रमाणीकरण के बाहरी विकासकर्ताओं के लिए वेबहॉक पेलोड को समझने की "
"अनुमति देने के लिए सार्वजनिक रूप से पहुंच योग्य है।"

msgid "Get webhook endpoint stats"
msgstr "वेबहुक एंडपॉइंट स्टैट्स प्राप्त करें"

msgid "Get delivery statistics for a webhook endpoint."
msgstr "एक webhook एंडपॉइंट के डिलीवरी सांख्यिकी प्राप्त करें।"

msgid "Webhooks"
msgstr "वेबहॉक्स"

msgid "Fired when a new order is placed"
msgstr "जब एक नई आदेश रखी जाती है तो चलाया जाता है"

msgid "Fired when payment for an order is confirmed"
msgstr "जब एक आदेश के भुगतान की पुष्टि की जाती है तो चलाया जाता है"

msgid "Fired when an order is cancelled"
msgstr "जब एक आदेश रद्द कर दिया जाता है तो चलाया जाता है"

msgid "Fired when all items in an order are shipped"
msgstr "जब एक आदेश में सभी आइटम भेजे जाते हैं तो चलाया जाता है"

msgid "Fired when some items in an order are shipped"
msgstr "जब एक आदेश में कुछ आइटम भेजे जाते हैं तो चलाया जाता है"

msgid "Fired when order status changes"
msgstr "जब आदेश की स्थिति बदलती है तो फायर करें"

msgid "Fired when a note is added to an order"
msgstr "जब एक आदेश में एक नोट जोड़ा जाता है तो चलाया जाता है"

msgid "Fired when a payment is received"
msgstr "जब एक भुगतान प्राप्त किया जाता है तो चलाया जाता है"

msgid "Fired when a payment attempt fails"
msgstr "जब एक भुगतान प्रयास विफल हो जाता है तो चलाया जाता है"

msgid "Fired when a payment is pending confirmation"
msgstr "जब एक भुगतान पुष्टि के लिए अपेक्षा कर रहा है तो चलाया जाता है"

msgid "Fired when a refund is initiated"
msgstr "जब एक रिफंड प्रारंभ किया जाता है तो चलाया जाता है"

msgid "Fired when a refund is completed"
msgstr "जब एक रिफंड पूरा कर दिया जाता है तो चलाया जाता है"

msgid "Fired when a refund fails"
msgstr "जब वापसी विफल होती है तो फायर करें"

msgid "Fired when a shipment is created"
msgstr "जब एक भेजे गए आइटम की रचना की जाती है तो चलाया जाता है"

msgid "Fired when a shipment is dispatched"
msgstr "जब एक भेजे गए आइटम के भेजे जाने के लिए भेज दिया जाता है तो चलाया जाता है"

msgid "Fired when a shipment is in transit"
msgstr "जब एक भेजे गए आइटम के भेजे जाने के लिए ट्रांसिट में है तो चलाया जाता है"

msgid "Fired when a shipment is out for delivery"
msgstr "जब एक भेजे गए आइटम के डिलीवरी के लिए बाहर है तो चलाया जाता है"

msgid "Fired when a shipment is delivered"
msgstr "जब एक भेजे गए आइटम के डिलीवरी कर दिया गया है तो चलाया जाता है"

msgid "Fired when a shipment delivery fails"
msgstr "जब एक भेजे गए आइटम के डिलीवरी विफल हो जाता है तो चलाया जाता है"

msgid "Fired when a shipment is returned"
msgstr "जब एक भेजे गए आइटम के वापस ले लिया जाता है तो चलाया जाता है"

msgid "Fired when shipment tracking information is updated"
msgstr "जब भेजे गए आइटम के ट्रैकिंग जानकारी अपडेट की जाती है तो चलाया जाता है"

msgid "Fired when product stock falls below threshold"
msgstr "जब एक उत्पाद के स्टॉक एक निम्न सीमा के नीचे गिर जाता है तो चलाया जाता है"

msgid "Fired when a product goes out of stock"
msgstr "जब एक उत्पाद स्टॉक से बाहर हो जाता है तो चलाया जाता है"

msgid "Fired when a product is restocked"
msgstr "जब एक उत्पाद फिर से स्टॉक किया जाता है तो चलाया जाता है"

msgid "Fired when inventory is manually adjusted"
msgstr "जब एक इन्वेंटरी के हाथ से समायोजित किया जाता है तो चलाया जाता है"

msgid "Fired when a new product is created"
msgstr "जब एक नया उत्पाद बनाया जाता है तो चलाया जाता है"

msgid "Fired when product details are updated"
msgstr "जब एक उत्पाद के विवरण अपडेट किया जाता है तो चलाया जाता है"

msgid "Fired when a product is deleted"
msgstr "जब एक उत्पाद हटा दिया जाता है तो चलाया जाता है"

msgid "Fired when a product is published"
msgstr "जब एक उत्पाद प्रकाशित किया जाता है तो चलाया जाता है"

msgid "Fired when a product is unpublished"
msgstr "जब एक उत्पाद अप्रकाशित किया जाता है तो चलाया जाता है"

msgid "Fired when a new customer registers"
msgstr "जब एक नए ग्राहक के पंजीकरण करता है तो चलाया जाता है"

msgid "Fired when customer profile is updated"
msgstr "जब एक ग्राहक प्रोफाइल अपडेट किया जाता है तो चलाया जाता है"

msgid "Fired when a customer account is deleted"
msgstr "जब एक ग्राहक खाता हटा दिया जाता है तो चलाया जाता है"

