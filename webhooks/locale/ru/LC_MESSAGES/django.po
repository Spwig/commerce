msgstr "Вызывается при создании нового товара"

msgid "Fired when product details are updated"
msgstr "Вызывается при обновлении деталей товара"

msgid "Fired when a product is deleted"
msgstr "Вызывается при удалении товара"

msgid "Fired when a product is published"
msgstr "Вызывается при публикации товара"

msgid "Fired when a product is unpublished"
msgstr "Вызывается при снятии товара с публикации"

msgid "Fired when a new customer registers"
msgstr "Вызывается при регистрации нового клиента"

msgid "Fired when customer profile is updated"
msgstr "Вызывается при обновлении профиля клиента"

