msgstr "Вызывается при активации подписки"

msgid "Fired when a subscription is renewed"
msgstr "Вызывается при продлении подписки"

msgid "Fired when a subscription is cancelled"
msgstr "Вызывается при отмене подписки"

msgid "Fired when a subscription expires"
msgstr "Вызывается при истечении срока подписки"

msgid "Fired when a subscription is paused"
msgstr "Вызывается при приостановке подписки"

msgid "Fired when a paused subscription is resumed"
msgstr "Вызывается при возобновлении приостановленной подписки"

msgid "Fired when a subscription payment fails"
msgstr "Вызывается при неудачном платеже по подписке"

msgid "Fired when a cart is abandoned (after configurable delay)"
msgstr "Вызывается при оставленной корзине (после настраиваемого задерживания)"

msgid "Fired when an abandoned cart is recovered"
msgstr "Вызывается при восстановлении оставленной корзины"

msgid "Fired when a translation job completes successfully"
msgstr "Срабатывает, когда задание перевода успешно завершено"

msgid "Fired when a translation job fails"
msgstr "Срабатывает, когда задание перевода завершается неудачно"

