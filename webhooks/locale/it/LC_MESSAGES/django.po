msgstr "1 minuto"

msgid "2 minutes"
msgstr "2 minuti"

msgid "4 minutes"
msgstr "4 minuti"

msgid "8 minutes"
msgstr "8 minuti"

msgid "Important Notes"
msgstr "Note importanti"

msgid "Webhooks are considered successful if they return a 2xx status code."
msgstr ""
"I webhook vengono considerati riusciti se restituiscono un codice di stato "
"2xx."

msgid "Your endpoint should respond within 30 seconds."
msgstr "Il tuo endpoint dovrebbe rispondere entro 30 secondi."

msgid "After 5 failed attempts, the delivery is marked as failed."
msgstr ""
"Dopo 5 tentativi falliti, la consegna viene contrassegnata come fallita."

msgid "After 10 consecutive failures, the endpoint is automatically disabled."
msgstr ""
"Dopo 10 fallimenti consecutivi, l'endpoint viene disattivato automaticamente."

