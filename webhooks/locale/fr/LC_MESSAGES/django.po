msgstr "En-tête"

msgid "Description"
msgstr "Description"

msgid "Example"
msgstr "Exemple"

msgid "HMAC-SHA256 signature for verification"
msgstr "Signature HMAC-SHA256 pour la vérification"

msgid "The event type"
msgstr "Le type d'événement"

msgid "Unique delivery identifier (UUID)"
msgstr "Identifiant unique de livraison (UUID)"

msgid "Unix timestamp when sent"
msgstr "Horodatage Unix lors de l'envoi"

