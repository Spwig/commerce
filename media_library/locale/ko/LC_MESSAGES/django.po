msgstr ""
"미디어 자산(비디오 및 3D 모델)에 포스터/썸네일 이미지를 설정합니다. "
"multipart form data를 통해 포스터 파일을 업로드합니다. 인증이 필요합니다."

msgid "Poster image set successfully"
msgstr "포스터 이미지가 성공적으로 설정되었습니다"

msgid "No poster file provided"
msgstr "포스터 파일이 제공되지 않았습니다"

msgid "Thumbnails regenerated successfully"
msgstr "미리보기 이미지가 성공적으로 재생성되었습니다"

msgid "Failed to regenerate thumbnails"
msgstr "미리보기 이미지 재생성에 실패했습니다"

msgid "WebP version regenerated successfully"
msgstr "WebP 버전이 성공적으로 재생성되었습니다"

msgid "Failed to generate WebP version"
msgstr "WebP 버전 생성에 실패했습니다"

msgid "Asset is already WebP or has no original file"
msgstr "자산은 이미 WebP이거나 원본 파일이 없습니다."

msgid "Failed to regenerate WebP version"
msgstr "WebP 버전 재생성에 실패했습니다"

msgid "This asset is not a video"
msgstr "이 자산은 비디오가 아닙니다."

msgid "Video file not found"
msgstr "동영상 파일을 찾을 수 없습니다"

msgid "Failed to stream video"
msgstr "동영상 스트리밍에 실패했습니다"

msgid "content_type, object_id, and field_name are required"
msgstr "content_type, object_id 및 field_name이 필요합니다."

msgid "Usage tracked successfully"
msgstr "사용량이 성공적으로 추적되었습니다"

msgid "No valid assets found"
msgstr "유효한 자산이 없습니다"

#, python-brace-format
msgid "Deleted {count} assets successfully"
msgstr "성공적으로 {count}개의 자산을 삭제했습니다"

msgid "Moved {assets.count()} assets successfully"
msgstr "{assets.count()}개의 자산을 성공적으로 이동했습니다"

msgid "Added tags to {assets.count()} assets successfully"
msgstr "{assets.count()} 자산에 태그를 성공적으로 추가했습니다."

msgid "Removed tags from {assets.count()} assets successfully"
msgstr "{assets.count()} 자산에서 태그를 성공적으로 제거했습니다."

msgid "Toggled public status for {assets.count()} assets successfully"
msgstr "{assets.count()} 자산의 공개 상태를 성공적으로 전환했습니다."

#, python-brace-format
msgid "Failed to perform {action}"
msgstr "{action}을 수행하는 데 실패했습니다"

msgid "No assets specified"
msgstr "지정된 자산이 없습니다"

msgid "No deleted assets found"
msgstr "삭제된 자산이 없습니다"

#, python-brace-format
msgid "Restored {count} assets successfully"
msgstr "성공적으로 {count}개의 자산을 복원했습니다"

#, python-brace-format
msgid "Permanently deleted {count} assets"
msgstr "{count}개의 자산을 영구적으로 삭제했습니다"

msgid "Admin permission required"
msgstr "관리자 권한이 필요합니다"

msgid "Recycle bin is already empty"
msgstr "휴지통이 이미 비어 있습니다"

#, python-brace-format
msgid "Permanently deleted {count} assets from recycle bin"
msgstr "휴지통에서 {count}개의 자산을 영구적으로 삭제했습니다"

msgid "List media folders"
msgstr "미디어 폴더 목록"

msgid "Get folder details"
msgstr "폴더 세부 정보 가져오기"

msgid "Create new folder"
msgstr "새 폴더 생성"

msgid "Update folder"
msgstr "폴더 업데이트"

msgid "Partially update folder"
msgstr "폴더 부분 업데이트"

msgid "Delete folder"
msgstr "폴더 삭제"

msgid "Get folder tree structure"
msgstr "폴더 트리 구조 가져오기"

msgid "List tags"
msgstr "태그 목록"

msgid "Get tag details"
msgstr "태그 상세 정보 가져오기"

msgid "Create new tag"
msgstr "새 태그 생성"

msgid "Update tag"
msgstr "태그 업데이트"

msgid "Partially update tag"
msgstr "태그 부분 업데이트"

msgid "Delete tag"
msgstr "태그 삭제"

msgid "Get popular tags"
msgstr "인기 태그 가져오기"

msgid "Track upload progress"
msgstr "업로드 진행 상황 추적"

msgid "POST required"
msgstr "POST가 필요합니다"

msgid "Upload complete"
msgstr "업로드 완료"

msgid "List processing jobs"
msgstr "처리 작업 목록"

msgid "Get job details"
msgstr "작업 세부 정보 가져오기"

msgid "Get active jobs"
msgstr "활성 작업 가져오기"

msgid "Cancel processing job"
msgstr "처리 중인 작업 취소"

msgid "Auto-save media field value"
msgstr "미디어 필드 값 자동 저장"

msgid ""
"Auto-save a MediaAsset ForeignKey field on any whitelisted model. Saves "
"immediately on selection without requiring full form submission. Admin users "
"only. Only whitelisted model.field combinations are allowed."
msgstr ""
"모든 허용된 모델에서 MediaAsset ForeignKey 필드를 자동으로 저장합니다. 전체 "
"폼 제출 없이 선택 시 즉시 저장됩니다. 관리자 사용자만 허용됩니다. 허용된 "
"model.field 조합만 허용됩니다."

msgid "Field saved successfully"
msgstr "필드가 성공적으로 저장되었습니다"

msgid "Missing required parameters or field is not FK to MediaAsset"
msgstr "필수 파라미터가 누락되었거나, 필드가 MediaAsset의 외래 키가 아닙니다."

msgid "Field not whitelisted for auto-save"
msgstr "자동 저장을 위한 필드가 허용 목록에 없습니다"

msgid "Model, field, instance, or media asset not found"
msgstr "모델, 필드, 인스턴스 또는 미디어 자산을 찾을 수 없습니다."

msgid "Missing required parameters: app_label, model_name, pk, field"
msgstr "필요한 매개변수가 누락되었습니다: app_label, model_name, pk, field"

msgid "Field not allowed for auto-save"
msgstr "자동 저장이 허용되지 않은 필드입니다"

msgid "Model not found"
msgstr "모델을 찾을 수 없습니다"

msgid "Field must be ForeignKey to MediaAsset"
msgstr "필드는 MediaAsset에 대한 ForeignKey여야 합니다."

msgid "Field not found on model"
msgstr "모델에서 필드를 찾을 수 없습니다"

msgid "Instance not found"
msgstr "인스턴스를 찾을 수 없습니다"

msgid "Media asset not found"
msgstr "미디어 자산을 찾을 수 없습니다"
