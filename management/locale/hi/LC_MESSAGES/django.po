msgstr "अधिकृत करना विफल रहा: %(error)s"

msgid "Authorization code not received."
msgstr "अधिकृत कोड प्राप्त नहीं किया गया।"

msgid "Session expired. Please start the wizard again."
msgstr "सेशन समाप्त हो गया। कृपया विजार्ड को फिर से शुरू करें।"

msgid "Unknown provider."
msgstr "अज्ञात प्रदाता।"

#, python-format
msgid "Successfully authorized with %(provider)s."
msgstr "%(provider)s के साथ सफलतापूर्वक अधिकृत किया गया।"

msgid "Add Remote Storage — Select Provider"
msgstr "दूरस्थ संग्रहण जोड़ें — प्रदाता चुनें"

msgid "Please select a storage provider."
msgstr "कृपया एक स्टोरेज प्रोवाइडर चुनें।"

msgid "Unknown provider type."
msgstr "अज्ञात प्रदाता प्रकार।"

msgid "Add Remote Storage — Configure"
msgstr "दूरस्थ स्टोरेज जोड़ें — स्थापना"

msgid "Destination name is required."
msgstr "गंतव्य के नाम की आवश्यकता है।"

msgid "Add Remote Storage — Review & Save"
msgstr "दूरस्थ संग्रहण जोड़ें — समीक्षा और सहेजें"

#, python-format
msgid "Remote storage destination \"%(name)s\" created successfully."
msgstr "रिमोट स्टोरेज गंतव्य \"%(name)s\" सफलतापूर्वक बनाया गया।"

msgid "Destination not found."
msgstr "गंतव्य नहीं मिला।"

#, python-format
msgid "Remote storage destination \"%(name)s\" deleted."
msgstr "रिमोट स्टोरेज गंतव्य \"%(name)s\" हटा दिया गया।"

