msgstr "คุณกำลังใช้เวอร์ชันล่าสุดของ Spwig"

msgid "Check Again"
msgstr "ตรวจสอบอีกครั้ง"

msgid "Checks Complete"
msgstr "การตรวจสอบเสร็จสิ้น"

msgid "Passed"
msgstr "ผ่านการตรวจสอบ"

msgid "Please run and pass all pre-flight checks before upgrading."
msgstr "กรุณารันและผ่านการตรวจสอบก่อนอัปเกรดทั้งหมดก่อนอัปเกรด"

msgid ""
"Are you sure you want to start the upgrade? A backup will be created first."
msgstr "คุณแน่ใจหรือไม่ว่าต้องการเริ่มต้นการอัปเกรด? จะสร้างสำเนาสำรองก่อน"

msgid "Failed to start upgrade"
msgstr "ไม่สามารถเริ่มต้นการอัปเกรดได้"

msgid "Upgrade completed successfully! The page will now reload."
msgstr "การอัปเกรดเสร็จสิ้นอย่างสำเร็จ! หน้าจะโหลดใหม่ในทันที"

msgid "Upgrade failed"
msgstr "การอัปเกรดล้มเหลว"

msgid "No updates available. You are running the latest version."
msgstr "ไม่มีการอัปเดตที่พร้อมใช้งาน คุณกำลังใช้เวอร์ชันล่าสุด"

msgid "Invalid request method."
msgstr "วิธีการร้องขอไม่ถูกต้อง"

msgid "No provider selected. Please start the wizard again."
msgstr "ไม่ได้เลือกผู้ให้บริการ กรุณาเริ่มเวิร์ดไวซ์อีกครั้ง"

msgid "Provider does not support OAuth."
msgstr "ผู้ให้บริการไม่รองรับ OAuth."

#, python-format
msgid "%(field)s is required."
msgstr "%(field)s เป็นข้อมูลที่จำเป็น"

#, python-format
msgid "Failed to start authorization: %(error)s"
msgstr "ไม่สามารถเริ่มต้นการยืนยันตัวตนได้: %(error)s"

msgid "Invalid OAuth state. Please try again."
msgstr "สถานะ OAuth ไม่ถูกต้อง กรุณาลองอีกครั้ง"

#, python-format
msgid "Authorization failed: %(error)s"
msgstr "การตรวจสอบสิทธิ์ล้มเหลว: %(error)s"

msgid "Authorization code not received."
msgstr "ไม่ได้รับรหัสการอนุญาต"

msgid "Session expired. Please start the wizard again."
msgstr "เซสชันหมดอายุ กรุณาเริ่มวิザาร์ดอีกครั้ง"

msgid "Unknown provider."
msgstr "ผู้ให้บริการไม่ทราบ"

#, python-format
msgid "Successfully authorized with %(provider)s."
msgstr "ได้รับการยืนยันตัวตนโดย %(provider)s อย่างสำเร็จ。"

msgid "Add Remote Storage — Select Provider"
msgstr "เพิ่มการจัดเก็บระยะไกล — เลือกผู้ให้บริการ"

msgid "Please select a storage provider."
msgstr "กรุณาเลือกผู้ให้บริการจัดเก็บข้อมูล"

msgid "Unknown provider type."
msgstr "ประเภทผู้ให้บริการไม่ทราบ"

msgid "Add Remote Storage — Configure"
msgstr "เพิ่มการจัดเก็บระยะไกล — ตั้งค่า"

msgid "Destination name is required."
msgstr "จำเป็นต้องระบุชื่อปลายทาง"

msgid "Add Remote Storage — Review & Save"
msgstr "เพิ่มการจัดเก็บระยะไกล — ตรวจสอบและบันทึก"

#, python-format
msgid "Remote storage destination \"%(name)s\" created successfully."
msgstr "จุดปลายทางการจัดเก็บระยะไกล \"%(\"name\" ถูกสร้างขึ้นสำเร็จ %(name)s"

msgid "Destination not found."
msgstr "ไม่พบจุดหมายปลายทาง"

#, python-format
msgid "Remote storage destination \"%(name)s\" deleted."
msgstr "จุดปลายทางการจัดเก็บระยะไกล \"%(\"name\" ถูกลบแล้ว %(name)s"

