"アップグレードする前に、すべての事前チェックを実行し、通過してください。"

msgid ""
"Are you sure you want to start the upgrade? A backup will be created first."
msgstr ""
"アップグレードを開始することに確信を持っていますか？まずバックアップが作成さ"
"れます。"

msgid "Failed to start upgrade"
msgstr "アップグレードの開始に失敗しました"

msgid "Upgrade completed successfully! The page will now reload."
msgstr "アップグレードが正常に完了しました！ページが今すぐ再読み込みされます。"

msgid "Upgrade failed"
msgstr "アップグレードに失敗しました"

msgid "No updates available. You are running the latest version."
msgstr "利用可能な更新はありません。最新バージョンを実行しています。"

msgid "Invalid request method."
msgstr "無効なリクエストメソッドです。"

msgid "No provider selected. Please start the wizard again."
msgstr "プロバイダが選択されていません。ウィザードをもう一度開始してください。"

msgid "Provider does not support OAuth."
msgstr "プロバイダーはOAuthをサポートしていません。"

#, python-format
msgid "%(field)s is required."
msgstr "%(field)s は必須です。"

#, python-format
msgid "Failed to start authorization: %(error)s"
msgstr "認証を開始できませんでした: %(error)s"

msgid "Invalid OAuth state. Please try again."
msgstr "OAuthの状態が無効です。もう一度お試しください。"

#, python-format
msgid "Authorization failed: %(error)s"
msgstr "認証に失敗しました: %(error)s"

msgid "Authorization code not received."
msgstr "認証コードが受信されていません。"

msgid "Session expired. Please start the wizard again."
msgstr "セッションが切れました。ウィザードを再開してください。"

msgid "Unknown provider."
msgstr "不明なプロバイダです。"

#, python-format
msgid "Successfully authorized with %(provider)s."
msgstr " %(provider)s と正常に認証されました。"

msgid "Add Remote Storage — Select Provider"
msgstr "リモートストレージを追加 — プロバイダーを選択"

msgid "Please select a storage provider."
msgstr "ストレージプロバイダを選択してください。"

msgid "Unknown provider type."
msgstr "不明なプロバイダタイプです。"

msgid "Add Remote Storage — Configure"
msgstr "リモートストレージを追加 — 設定"

msgid "Destination name is required."
msgstr "宛先名は必須です。"

msgid "Add Remote Storage — Review & Save"
msgstr "リモートストレージを追加 — 確認と保存"

#, python-format
msgid "Remote storage destination \"%(name)s\" created successfully."
msgstr "リモートストレージ先 \"\" が正常に作成されました。 %(name)s"

msgid "Destination not found."
msgstr "宛先が見つかりません。"

#, python-format
msgid "Remote storage destination \"%(name)s\" deleted."
msgstr "リモートストレージ先 \"\" が削除されました。 %(name)s"

