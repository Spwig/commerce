msgstr "النوع"

msgid "System Default URL"
msgstr "عنوان URL الافتراضي لنظام التشغيل"

msgid "No tracking URL"
msgstr "لا يوجد عنوان URL لمتابعة الشحن"

msgid "System Tracking URL"
msgstr "عنوان URL لمتابعة الشحن لنظام التشغيل"

msgid "Effective URL"
msgstr "عنوان URL الفعال"

msgid "No URL configured"
msgstr "لم يتم إعداد عنوان URL"

msgid "Current URL Status"
msgstr "حالة عنوان URL الحالي"

msgid "Dimensions"
msgstr "الأبعاد"

msgid "Internal vs External Dimensions:"
msgstr "الأبعاد الداخلية مقابل الخارجية:"

msgid ""
"• <strong>Internal dimensions</strong> are used for packing algorithm "
"calculations (determining what fits inside)"
msgstr ""
"• <strong>الأبعاد الداخلية</strong> تستخدم في حسابات خوارزمية التعبئة (تحديد "
"ما يناسب داخلها)"

msgid ""
"• <strong>Wall thickness</strong> defines the package material thickness "
"(default 0.5cm for standard cardboard)"
msgstr ""
"• <strong>سُمك الجدار</strong> يحدد سمك مادة العبوة (القيمة الافتراضية 0.5 سم "
"لورق الكرتون القياسي)"

msgid ""
"• <strong>External dimensions</strong> are automatically calculated and sent "
"to shipping carriers for rate calculations"
msgstr ""
"• <strong>الأبعاد الخارجية</strong> تُحسب تلقائيًا وتُرسل إلى ناقلي الشحن "
"لحسابات التسعير"

msgid "Weight Constraints"
msgstr "قيود الوزن"

msgid "Weight values in kilograms"
msgstr "قيم الوزن بالكيلوجرامات"

msgid "Configuration"
msgstr "الإعدادات"

msgid ""
"Package cost and selection priority (higher = preferred for auto-packing)"
msgstr "تكلفة العبوة وأولوية الاختيار (الأعلى تُفضّل في التعبئة التلقائية)"

msgid "Dimensions (L×W×H)"
msgstr "الأبعاد (الطول × العرض × الارتفاع)"

msgid "Volume"
msgstr "الحجم"

msgid "Enter dimensions to calculate volume"
msgstr "أدخل الأبعاد لحساب الحجم"

msgid "Calculated Volume (Internal)"
msgstr "الحجم المحسوب (الداخلي)"

msgid "Enter dimensions and wall thickness to calculate external dimensions"
msgstr "أدخل الأبعاد وسمك الجدار لحساب الأبعاد الخارجية"

msgid "External Dimensions (for carriers)"
msgstr "الأبعاد الخارجية (للنقل)"

msgid "Usage"
msgstr "الاستخدام"

msgid "Provider Information"
msgstr "معلومات المزوّد"

msgid ""
"Component and User cannot be changed after creation for security and audit "
"purposes."
msgstr "لا يمكن تغيير المكون أو المستخدم بعد إنشائهم لأسباب أمنية ومراجعة."

msgid "Connection Health"
msgstr "صحة الاتصال"

msgid ""
"Connection health is automatically updated when you test the connection from "
"the wizard."
msgstr "يتم تحديث صحة الاتصال تلقائياً عند اختبار الاتصال من خلال الدليل."

msgid "Create Provider"
msgstr "إنشاء مزود"

msgid "Please use the Provider Connection Wizard"
msgstr "يرجى استخدام مساعد اتصال المزود"

msgid ""
"For the best experience, please use the <a href=\"/admin/shipping/wizard/"
"step1/\">Provider Connection Wizard</a> to set up new providers."
msgstr ""
"للحصول على أفضل تجربة، يرجى استخدام <a href=\"/admin/shipping/wizard/step1/"
"\">مساعد اتصال المزود</a> لإعداد مزودين جدد."

