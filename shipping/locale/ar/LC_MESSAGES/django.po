msgid "Basic Information"
msgstr "المعلومات الأساسية"

msgid "Branding"
msgstr "الهوية البصرية"

msgid "Logo Attribution:"
msgstr "إسناد الشعار:"

msgid ""
"Carrier logos are trademarks of their respective owners and are used solely "
"for identification and reference purposes. No affiliation or endorsement is "
"implied."
msgstr ""
"شعارات الناقلين هي علامات تجارية تعود لمالكيها وتعتبر مخصصة فقط لغرض التعرف "
"والمرجع. لا يُفترض أي تعاون أو دعم."

msgid "Tracking Configuration"
msgstr "إعدادات المتابعة"

msgid "URL Override System:"
msgstr "نظام استبدال عنوان URL:"

msgid ""
"System carriers come with default tracking URLs. You can override these URLs "
"if needed."
msgstr ""
"تأتي الناقلين النظاميين مع روابط تتبع افتراضية. يمكنك تجاوز هذه الروابط إذا "
"لزم الأمر."

#, python-brace-format
msgid ""
"Use {tracking_number} as the placeholder for the tracking number in your URL."
msgstr ""
"استخدم {tracking_number} كموضع محفوظ للرقم التعقب في عنوان URL الخاص بك."

msgid "Example:"
msgstr "مثال:"

msgid ""
"Your override will be reported to our update server to help improve default "
"URLs for all users."
msgstr ""
"سيتم الإبلاغ عن تجاوزك إلى خادم التحديث الخاص بنا لمساعدتنا في تحسين روابط "
"التتبع الافتراضية لجميع المستخدمين."

msgid "Logo"
msgstr "الشعار"

msgid "No logo uploaded"
msgstr "لم يتم تحميل شعار"

