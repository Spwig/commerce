msgstr "Restrições de peso"

msgid "Weight values in kilograms"
msgstr "Valores de peso em quilogramas"

msgid "Configuration"
msgstr "Configuração"

msgid ""
"Package cost and selection priority (higher = preferred for auto-packing)"
msgstr ""
"Custo do pacote e prioridade de seleção (maior = preferido para embalagem "
"automática)"

