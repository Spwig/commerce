msgid "Dimensions"
msgstr "Dimensões"

msgid "Internal vs External Dimensions:"
msgstr "Dimensões internas vs externas:"

msgid ""
"• <strong>Internal dimensions</strong> are used for packing algorithm "
"calculations (determining what fits inside)"
msgstr ""
"• <strong>Dimensões internas</strong> são usadas para cálculos do algoritmo "
"de embalagem (determinando o que cabe dentro)"

msgid ""
"• <strong>Wall thickness</strong> defines the package material thickness "
"(default 0.5cm for standard cardboard)"
msgstr ""
"• <strong>Espessura da parede</strong> define a espessura do material da "
"embalagem (padrão 0,5 cm para papelão padrão)"

msgid ""
"• <strong>External dimensions</strong> are automatically calculated and sent "
"to shipping carriers for rate calculations"
msgstr ""
"• <strong>Dimensões externas</strong> são calculadas automaticamente e "
"enviadas aos transportadores de envio para cálculos de tarifas"

