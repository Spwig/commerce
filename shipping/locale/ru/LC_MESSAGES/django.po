msgstr "Заменяет стоимость доставки на конкретную сумму"

msgid "Fixed Surcharge:"
msgstr "Фиксированная надбавка:"

msgid "Adds a fixed amount to shipping cost"
msgstr "Добавляет фиксированную сумму к стоимости доставки"

msgid "Percentage Surcharge:"
msgstr "Процентная надбавка:"

msgid "Adds a percentage to shipping cost"
msgstr "Добавляет процент к стоимости доставки"

msgid "Enter the value for this rule"
msgstr "Введите значение для этого правила"

msgid "Only active rules are evaluated during checkout"
msgstr "Только активные правила учитываются при оформлении заказа"

msgid "Cancel"
msgstr "Отменить"

msgid "Next Step"
msgstr "Следующий шаг"

msgid "Percentage"
msgstr "Процент"

