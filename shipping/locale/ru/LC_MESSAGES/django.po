msgstr "Системный URL по умолчанию"

msgid "No tracking URL"
msgstr "URL отслеживания отсутствует"

msgid "System Tracking URL"
msgstr "Системный URL отслеживания"

msgid "Effective URL"
msgstr "Действующий URL"

msgid "No URL configured"
msgstr "URL не настроен"

msgid "Current URL Status"
msgstr "Текущий статус URL"

msgid "Dimensions"
msgstr "Размеры"

msgid "Internal vs External Dimensions:"
msgstr "Внутренние vs Внешние размеры:"

msgid ""
"• <strong>Internal dimensions</strong> are used for packing algorithm "
"calculations (determining what fits inside)"
msgstr ""
"• <strong>Внутренние размеры</strong> используются для вычислений алгоритма "
"упаковки (определения, что помещается внутрь)"

msgid ""
"• <strong>Wall thickness</strong> defines the package material thickness "
"(default 0.5cm for standard cardboard)"
msgstr ""
"• <strong>Толщина стенки</strong> определяет толщину материала упаковки (по "
"умолчанию 0.5 см для стандартной картона)"

msgid ""
"• <strong>External dimensions</strong> are automatically calculated and sent "
"to shipping carriers for rate calculations"
msgstr ""
"• <strong>Внешние размеры</strong> автоматически рассчитываются и "
"отправляются перевозчикам для вычисления тарифов"

msgid "Weight Constraints"
msgstr "Ограничения по весу"

msgid "Weight values in kilograms"
msgstr "Значения веса в килограммах"

msgid "Configuration"
msgstr "Настройка"

msgid ""
"Package cost and selection priority (higher = preferred for auto-packing)"
msgstr ""
"Стоимость упаковки и приоритет выбора (высокий = предпочтительный для "
"автоматической упаковки)"

msgid "Dimensions (L×W×H)"
msgstr "Размеры (Д×Ш×В)"

msgid "Volume"
msgstr "Объем"

msgid "Enter dimensions to calculate volume"
msgstr "Введите размеры для расчета объема"

msgid "Calculated Volume (Internal)"
msgstr "Рассчитанный объем (внутренний)"

msgid "Enter dimensions and wall thickness to calculate external dimensions"
msgstr "Введите размеры и толщину стенки, чтобы рассчитать внешние размеры"

msgid "External Dimensions (for carriers)"
msgstr "Внешние размеры (для перевозчиков)"

msgid "Usage"
msgstr "Использование"

msgid "Provider Information"
msgstr "Информация о провайдере"

msgid ""
"Component and User cannot be changed after creation for security and audit "
"purposes."
msgstr ""
"Компонент и Пользователь не могут быть изменены после создания по причинам "
"безопасности и аудита."

msgid "Connection Health"
msgstr "Состояние подключения"

msgid ""
"Connection health is automatically updated when you test the connection from "
"the wizard."
msgstr ""
"Состояние соединения автоматически обновляется, когда вы тестируете "
"соединение через мастер."

msgid "Create Provider"
msgstr "Создать провайдера"

msgid "Please use the Provider Connection Wizard"
msgstr "Пожалуйста, используйте Мастер подключения провайдера"

msgid ""
"For the best experience, please use the <a href=\"/admin/shipping/wizard/"
"step1/\">Provider Connection Wizard</a> to set up new providers."
msgstr ""
"Для лучшего опыта пожалуйста используйте <a href=\"/admin/shipping/wizard/"
"step1/\">Мастер подключения провайдера</a>, чтобы настроить новых "
"провайдеров."

