msgstr "सामान्य पैटर्न उदाहरण:"

msgid "Los Angeles area (90000-90999)"
msgstr "लॉस एंजिल्स क्षेत्र (90000-90999)"

msgid "New York area (10000-12999)"
msgstr "न्यू यॉर्क क्षेत्र (10000-12999)"

