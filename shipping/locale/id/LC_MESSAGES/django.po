msgstr "Jumlah Item Minimum"

msgid "Maximum Item Count"
msgstr "Jumlah Item Maksimum"

msgid "For a discount on bulk orders of 5+ items, set Minimum Item Count to 5"
msgstr ""
"Untuk diskon pada pesanan jumlah besar 5+ item, atur Jumlah Item Minimum "
"menjadi 5"

