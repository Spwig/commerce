msgstr "Restricciones de peso"

msgid "Weight values in kilograms"
msgstr "Valores de peso en kilogramos"

msgid "Configuration"
msgstr "Configuración"

msgid ""
"Package cost and selection priority (higher = preferred for auto-packing)"
msgstr ""
"Costo del paquete y prioridad de selección (mayor = preferido para el "
"empaque automático)"

