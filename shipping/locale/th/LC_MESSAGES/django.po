msgstr "ตัวอย่างรูปแบบที่พบบ่อย:"

msgid "Los Angeles area (90000-90999)"
msgstr "เขตลอสแองเจลิส (90000-90999)"

msgid "New York area (10000-12999)"
msgstr "เขตนิวยอร์ก (10000-12999)"

