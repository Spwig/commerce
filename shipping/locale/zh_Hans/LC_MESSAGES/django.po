msgid "Provider Settings"
msgstr "提供商设置"

msgid "Display Name"
msgstr "显示名称"

msgid "e.g., My Shipping Account"
msgstr "例如，我的配送账户"

msgid ""
"This name will be used to identify this provider account in your admin panel."
msgstr "此名称将用于在您的管理员面板中识别此提供商账户。"

