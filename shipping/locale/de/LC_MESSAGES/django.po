msgstr "Startdatum & -zeit"

msgid "Rule is active starting from this date/time (optional)"
msgstr "Die Regel ist ab diesem Datum/Uhrzeit aktiv (optional)"

msgid "End Date & Time"
msgstr "Enddatum & -zeit"

msgid "Rule is active until this date/time (optional)"
msgstr "Die Regel ist bis zu diesem Datum/Uhrzeit aktiv (optional)"

