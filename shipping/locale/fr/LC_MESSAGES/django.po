msgstr "Exige des produits"

msgid "No products available"
msgstr "Aucun produit disponible"

msgid "Rule only applies if cart contains at least one of these products"
msgstr ""
"La règle s'applique uniquement si le panier contient au moins un de ces "
"produits"

msgid "Requires Categories"
msgstr "Exige des catégories"

msgid "No categories available"
msgstr "Aucune catégorie disponible"

