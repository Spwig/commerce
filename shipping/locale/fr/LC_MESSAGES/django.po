msgstr "50-99: Règles de haute priorité (promotions ciblées)"

msgid "0-49: Medium priority rules (standard discounts)"
msgstr "0-49: Règles de priorité moyenne (réductions standard)"

msgid "Negative: Low priority rules (fallback/default rules)"
msgstr ""
"Négatif : Règles de faible priorité (règles de secours/règles par défaut)"

msgid "Stop evaluating lower priority rules"
msgstr "Arrêter l'évaluation des règles de priorité inférieure"

msgid "If this rule matches, don't evaluate any lower priority rules"
msgstr ""
"Si cette règle correspond, ne vérifiez aucune règle de priorité inférieure"

