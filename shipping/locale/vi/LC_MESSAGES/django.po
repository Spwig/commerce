msgstr "Trạng thái"

#, python-format
msgid "Successfully enabled shipping to %(count)d countries."
msgstr "Đã bật vận chuyển đến %(count)d quốc gia."

msgid "Enable shipping to selected countries"
msgstr "Kích hoạt vận chuyển đến các quốc gia đã chọn"

#, python-format
msgid "Successfully disabled shipping to %(count)d countries."
msgstr "Đã tắt vận chuyển đến %(count)d quốc gia."

msgid "Disable shipping to selected countries"
msgstr "Tắt vận chuyển đến các quốc gia đã chọn"

msgid "Basic Information"
msgstr "Thông tin cơ bản"

msgid "Branding"
msgstr "Thương hiệu"

msgid "Logo Attribution:"
msgstr "Ghi chú logo:"

msgid ""
"Carrier logos are trademarks of their respective owners and are used solely "
"for identification and reference purposes. No affiliation or endorsement is "
"implied."
msgstr ""
"Logo của đơn vị vận chuyển là thương hiệu thuộc sở hữu của các bên tương ứng "
"và chỉ được sử dụng nhằm mục đích nhận diện và tham khảo. Không có bất kỳ sự "
"liên kết hay ủng hộ nào được ngụ ý."

msgid "Tracking Configuration"
msgstr "Cấu hình theo dõi"

msgid "URL Override System:"
msgstr "Hệ thống ghi đè URL:"

msgid ""
"System carriers come with default tracking URLs. You can override these URLs "
"if needed."
msgstr ""
"Các đơn vị vận chuyển hệ thống đi kèm với URL theo dõi mặc định. Bạn có thể "
"ghi đè các URL này nếu cần."

#, python-brace-format
msgid ""
"Use {tracking_number} as the placeholder for the tracking number in your URL."
msgstr ""
"Sử dụng {tracking_number} làm placeholder cho số theo dõi trong URL của bạn."

msgid "Example:"
msgstr "Ví dụ:"

msgid ""
"Your override will be reported to our update server to help improve default "
"URLs for all users."
msgstr ""
"Việc ghi đè của bạn sẽ được gửi đến máy chủ cập nhật của chúng tôi nhằm giúp "
"cải thiện URL mặc định cho tất cả người dùng."

msgid "Logo"
msgstr "Logo"

msgid "No logo uploaded"
msgstr "Không có logo được tải lên"

msgid "Logo Preview"
msgstr "Xem trước logo"

msgid "Default"
msgstr "Mặc định"

msgid "Type"
msgstr "Loại"

msgid "System Default URL"
msgstr "URL mặc định của hệ thống"

msgid "No tracking URL"
msgstr "Không có URL theo dõi"

msgid "System Tracking URL"
msgstr "URL theo dõi của hệ thống"

msgid "Effective URL"
msgstr "URL hiệu lực"

msgid "No URL configured"
msgstr "Không có URL được cấu hình"

msgid "Current URL Status"
msgstr "Trạng thái URL hiện tại"

msgid "Dimensions"
msgstr "Kích thước"

msgid "Internal vs External Dimensions:"
msgstr "Kích thước nội bộ so với kích thước bên ngoài:"

msgid ""
"• <strong>Internal dimensions</strong> are used for packing algorithm "
"calculations (determining what fits inside)"
msgstr ""
"• <strong>Kích thước bên trong</strong> được sử dụng để tính toán thuật toán "
"đóng gói (xác định những gì có thể vừa trong bên trong)"

msgid ""
"• <strong>Wall thickness</strong> defines the package material thickness "
"(default 0.5cm for standard cardboard)"
msgstr ""
"• <strong>Độ dày thành</strong> xác định độ dày vật liệu bao bì (mặc định "
"0.5cm cho bìa cứng tiêu chuẩn)"

msgid ""
"• <strong>External dimensions</strong> are automatically calculated and sent "
"to shipping carriers for rate calculations"
msgstr ""
"• <strong>Kích thước bên ngoài</strong> được tính toán tự động và gửi đến "
"các đơn vị vận chuyển để tính toán giá cước"

msgid "Weight Constraints"
msgstr "Ràng buộc trọng lượng"

msgid "Weight values in kilograms"
msgstr "Giá trị trọng lượng tính theo kilogram"

msgid "Configuration"
msgstr "Cấu hình"

msgid ""
"Package cost and selection priority (higher = preferred for auto-packing)"
msgstr ""
"Chi phí bao bì và độ ưu tiên chọn (số cao hơn = được ưu tiên hơn trong đóng "
"gói tự động)"

msgid "Dimensions (L×W×H)"
msgstr "Kích thước (D×R×C)"

msgid "Volume"
msgstr "Thể tích"

msgid "Enter dimensions to calculate volume"
msgstr "Nhập kích thước để tính thể tích"

msgid "Calculated Volume (Internal)"
msgstr "Thể tích tính toán (nội bộ)"

msgid "Enter dimensions and wall thickness to calculate external dimensions"
msgstr "Nhập kích thước và độ dày thành để tính toán kích thước bên ngoài"

msgid "External Dimensions (for carriers)"
msgstr "Kích thước bên ngoài (dành cho đơn vị vận chuyển)"

msgid "Usage"
msgstr "Sử dụng"

msgid "Provider Information"
msgstr "Thông tin nhà cung cấp"

msgid ""
"Component and User cannot be changed after creation for security and audit "
"purposes."
msgstr ""
"Thành phần và Người dùng không thể thay đổi sau khi tạo vì lý do bảo mật và "
"kiểm toán."

msgid "Connection Health"
msgstr "Tình trạng kết nối"

msgid ""
"Connection health is automatically updated when you test the connection from "
"the wizard."
msgstr ""
"Tình trạng kết nối sẽ được cập nhật tự động khi bạn kiểm tra kết nối từ "
"hướng dẫn."

msgid "Create Provider"
msgstr "Tạo nhà cung cấp"

msgid "Please use the Provider Connection Wizard"
msgstr "Vui lòng sử dụng Hướng dẫn Kết nối Nhà cung cấp"

msgid ""
"For the best experience, please use the <a href=\"/admin/shipping/wizard/"
"step1/\">Provider Connection Wizard</a> to set up new providers."
msgstr ""
"Để có trải nghiệm tốt nhất, vui lòng sử dụng <a href=\"/admin/shipping/"
"wizard/step1/\">Hướng dẫn Kết nối Nhà cung cấp</a> để thiết lập nhà cung cấp "
"mới."

