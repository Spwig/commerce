msgid "Define the geographic areas covered by this shipping zone."
msgstr "Xác định các khu vực địa lý được bao phủ bởi vùng vận chuyển này."

msgid ""
"- <strong>Countries:</strong> List of ISO 3166-1 alpha-2 country codes (e."
"g., [\"US\", \"CA\", \"MX\"]). Leave empty for all countries."
msgstr ""
"- <strong>Quốc gia:</strong> Danh sách mã quốc gia theo chuẩn ISO 3166-1 "
"alpha-2 (ví dụ, [\"US\", \"CA\", \"MX\"]). Để trống để áp dụng cho tất cả "
"các quốc gia."

msgid ""
"- <strong>States:</strong> Dict mapping country codes to state codes (e.g., "
"{\"US\": [\"CA\", \"NY\"], \"CA\": [\"ON\", \"BC\"]})."
msgstr ""
"- <strong>Tỉnh/Thành phố:</strong> Từ điển ánh xạ mã quốc gia đến mã tỉnh/"
"thành phố (ví dụ, {\"US\": [\"CA\", \"NY\"], \"CA\": [\"ON\", \"BC\"]})."

#, python-brace-format
msgid ""
"- <strong>Postal Patterns:</strong> List of regex patterns for postal codes "
"(e.g., [\"^90[0-9]{3}$\"] for Los Angeles area)."
msgstr ""
"- <strong>Mẫu mã bưu điện:</strong> Danh sách các mẫu regex cho mã bưu điện "
"(ví dụ: [\"^90[0-9]{3}$\"] cho khu vực Los Angeles)."

