msgid "Country Information"
msgstr "Thông tin quốc gia"

msgid "Routing Configuration"
msgstr "Cấu hình định tuyến"

msgid ""
"Optional warehouse routing for multi-warehouse setups. Lower priority "
"numbers = higher priority for routing."
msgstr ""
"Tùy chọn định tuyến kho cho các thiết lập nhiều kho. Số ưu tiên thấp hơn = "
"độ ưu tiên cao hơn cho định tuyến."

msgid "Metadata"
msgstr "Metadata"

