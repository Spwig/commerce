msgstr "송장 %(id)s의 관세 신고서 생성에 실패했습니다: %(error)s"

#, python-format
msgid "Successfully generated %(count)d customs form(s)."
msgstr "%(count)d개의 관세 신고서가 성공적으로 생성되었습니다."

#, python-format
msgid "Failed to generate %(count)d customs form(s). See errors above."
msgstr "%(count)d개의 관세 신고서 생성에 실패했습니다. 위의 오류를 확인하세요."

msgid "Generate customs forms (CN23) for selected shipments"
msgstr "선택된 배송에 대한 관세 서식 (CN23)을 생성하세요"

