#, python-format
msgid "Successfully generated %(count)d commercial invoice(s)."
msgstr "%(count)d개의 상업용 인보이스가 성공적으로 생성되었습니다."

#, python-format
msgid "Failed to generate %(count)d commercial invoice(s). See errors above."
msgstr ""
"%(count)d개의 상업용 인보이스 생성에 실패했습니다. 위의 오류를 확인하세요."

msgid "Generate commercial invoices for selected shipments"
msgstr "선택된 배송에 대한 상업 영수증을 생성하세요"

#, python-format
