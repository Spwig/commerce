#, python-format
msgid "Failed to queue label purchase for shipment %(id)s: %(error)s"
msgstr "송장 구매를 대기열에 추가하는 데 실패했습니다. %(id)s: %(error)s"

#, python-format
msgid ""
"Successfully queued %(count)d label purchase task(s). Labels will be "
"generated in the background."
msgstr ""
"%(count)d개의 송장 구매 작업을 성공적으로 대기열에 추가했습니다. 라벨은 백그"
"라운드에서 생성됩니다."

msgid "Purchase shipping labels for selected shipments"
msgstr "선택된 배송에 대한 배송 라벨을 구매하세요"

#, python-format
msgid "Failed to generate packing slip for shipment %(id)s: %(error)s"
msgstr "송장 %(id)s의 포장지 생성에 실패했습니다: %(error)s"

#, python-format
msgid "Successfully generated %(count)d packing slip(s)."
msgstr "%(count)d개의 포장지가 성공적으로 생성되었습니다."

#, python-format
msgid "Failed to generate %(count)d packing slip(s). See errors above."
msgstr "%(count)d개의 포장지 생성에 실패했습니다. 위의 오류를 확인하세요."

msgid "Generate packing slips for selected shipments"
msgstr "선택된 배송에 대한 포장 영수증을 생성하세요"

#, python-format
msgid "Failed to generate commercial invoice for shipment %(id)s: %(error)s"
