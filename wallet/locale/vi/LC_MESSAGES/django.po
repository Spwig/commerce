msgid "Customer"
msgstr "Khách hàng"

msgid "Manual Adjustment"
msgstr "Điều chỉnh thủ công"

msgid "Promotion"
msgstr "Khuyến mãi"

msgid "Order Refund"
msgstr "Hoàn tiền đơn hàng"

msgid "Order Payment"
msgstr "Thanh toán đơn hàng"

msgid "Get wallet balance"
msgstr "Lấy số dư ví"

msgid ""
"Get the authenticated customer's wallet balance. Creates a wallet "
"automatically if the customer does not have one."
msgstr ""
"Lấy số dư ví của khách hàng đã xác thực. Tự động tạo ví nếu khách hàng chưa "
"có."

msgid "Authentication required"
msgstr "Yêu cầu xác thực"

msgid "List wallet transactions"
msgstr "Liệt kê giao dịch ví"

msgid ""
"Get the authenticated customer's wallet transaction history, ordered by most"
" recent first. Supports filtering by type, source, and status."
msgstr ""
"Lấy lịch sử giao dịch ví của khách hàng đã xác thực, được sắp xếp theo thứ "
"tự mới nhất trước. Hỗ trợ lọc theo loại, nguồn và trạng thái."

msgid "Filter by transaction type"
msgstr "Lọc theo loại giao dịch"

msgid "Filter by source"
msgstr "Lọc theo nguồn"

msgid "Filter by status"
msgstr "Lọc theo trạng thái"

msgid "Number of results (default 20, max 100)"
msgstr "Số lượng kết quả (mặc định 20, tối đa 100)"

msgid "Pagination offset"
msgstr "Độ lệch phân trang"

msgid "List customer wallets"
msgstr "Liệt kê ví khách hàng"

msgid ""
"List all customer wallets. Supports search by email or name, and filtering "
"by active status."
msgstr ""
"Liệt kê tất cả ví khách hàng. Hỗ trợ tìm kiếm theo email hoặc tên, và lọc "
"theo trạng thái hoạt động."

msgid "Search by customer email or name"
msgstr "Tìm kiếm theo email hoặc tên khách hàng"

msgid "Filter by active status"
msgstr "Lọc theo trạng thái kích hoạt"

msgid "Get wallet details"
msgstr "Lấy chi tiết ví"

msgid "Get full details of a customer wallet."
msgstr "Lấy đầy đủ thông tin về ví khách hàng."

msgid "Credit a wallet"
msgstr "Nạp ví"

msgid ""
"Manually add credit to a customer's wallet. Requires amount, currency, "
"source, and description."
msgstr ""
"Thêm số dư thủ công vào ví khách hàng. Yêu cầu số tiền, loại tiền tệ, nguồn,"
" và mô tả."

msgid "Invalid input or wallet frozen"
msgstr "Đầu vào không hợp lệ hoặc ví bị đóng băng"

msgid "Debit a wallet"
msgstr "Rút ví"

msgid ""
"Manually debit a customer's wallet. Fails if the wallet has insufficient "
"balance or is frozen."
msgstr ""
"Trừ số dư thủ công khỏi ví khách hàng. Thất bại nếu ví không đủ số dư hoặc "
"đang bị khóa."

msgid "Insufficient balance, invalid input, or wallet frozen"
msgstr "Số dư không đủ, đầu vào không hợp lệ, hoặc ví bị khóa"

msgid "Toggle wallet freeze"
msgstr "Chuyển đổi trạng thái đóng băng ví"

msgid ""
"Freeze or unfreeze a customer's wallet. A frozen wallet cannot process "
"credits or debits."
msgstr ""
"Khóa hoặc hủy khóa ví khách hàng. Một ví bị khóa không thể xử lý việc cộng "
"hoặc trừ số dư."

msgid "Wallet is frozen"
msgstr "Ví bị đóng băng"

msgid "Wallet credited successfully"
msgstr "Nạp ví thành công"

msgid "Insufficient wallet balance"
msgstr "Số dư ví không đủ"

msgid "Wallet debited successfully"
msgstr "Trừ ví thành công"

msgid "unfrozen"
msgstr "Không bị đóng băng"

msgid "frozen"
msgstr "Đang bị đóng băng"

#, python-format
msgid "Wallet %s successfully"
msgstr "Ví %s thành công"

msgid "List all transactions"
msgstr "Liệt kê tất cả giao dịch"

msgid ""
"List wallet transactions across all customers. Supports filtering by wallet,"
" type, source, status, and search."
msgstr ""
"Liệt kê các giao dịch ví của tất cả khách hàng. Hỗ trợ lọc theo ví, loại, "
"nguồn, trạng thái và tìm kiếm."

msgid "Filter by wallet ID"
msgstr "Lọc theo ID ví"

msgid "Search by customer email"
msgstr "Tìm theo email khách hàng"

msgid "Number of results (default 50, max 100)"
msgstr "Số lượng kết quả (mặc định 50, tối đa 100)"

msgid "Get transaction details"
msgstr "Lấy chi tiết giao dịch"

msgid "Get full details of a wallet transaction."
msgstr "Lấy đầy đủ thông tin về giao dịch ví."

msgid "Available Balance"
msgstr "Số dư có thể sử dụng"

msgid "Current spendable balance"
msgstr "Số dư hiện tại có thể chi tiêu"

msgid "Pending Balance"
msgstr "Số dư đang chờ"

msgid "Credits not yet available (e.g. pending refund window)"
msgstr ""
"Điểm tín dụng chưa khả dụng (ví dụ: thời gian hoàn tiền đang chờ xử lý)"

msgid "Lifetime Credited"
msgstr "Tổng số tiền đã nạp trong suốt thời gian"

msgid "Lifetime Used"
msgstr "Tổng số tiền đã sử dụng trong suốt thời gian"

msgid "Active"
msgstr "Hoạt động"

msgid "Deactivate to freeze this wallet"
msgstr "Tắt để đóng băng ví này"

msgid "Last Credited At"
msgstr "Thời điểm nạp lần cuối"

msgid "Last Used At"
msgstr "Thời điểm Sử dụng Lần cuối"

msgid "Customer Wallet"
msgstr "Ví khách hàng"

msgid "Customer Wallets"
msgstr "Các ví khách hàng"

msgid "Credit"
msgstr "Nạp"

msgid "Debit"
msgstr "Trừ"

msgid "Refund"
msgstr "Hoàn tiền"

msgid "Adjustment"
msgstr "Điều chỉnh"

msgid "Reversal"
msgstr "Ngược lại"

msgid "Completed"
msgstr "Hoàn thành"

msgid "Pending"
msgstr "Chờ xử lý"

msgid "Reversed"
msgstr "Đã đảo ngược"

msgid "Referral Reward"
msgstr "Phần thưởng giới thiệu"

msgid "Wallet"
msgstr "Ví"

msgid "Type"
msgstr "Loại"

msgid "Amount"
msgstr "Số tiền"

msgid "Always positive; transaction_type determines direction"
msgstr "Luôn dương; transaction_type xác định hướng"

msgid "Balance After"
msgstr "Số dư sau"

msgid "Wallet balance snapshot after this transaction"
msgstr "Ảnh chụp nhanh số dư ví sau giao dịch này"

msgid "Status"
msgstr "Trạng thái"

msgid "Source"
msgstr "Nguồn"

msgid "Description"
msgstr "Mô tả"

msgid "Reference ID"
msgstr "ID Tham chiếu"

msgid "External reference (reward ID, order number, etc.)"
msgstr "Tham chiếu bên ngoài (ID phần thưởng, số đơn hàng, v.v.)"

msgid "Reversed By"
msgstr "Được đảo ngược bởi"

msgid "Created By"
msgstr "Được tạo bởi"

msgid "Staff user for manual adjustments"
msgstr "Người dùng nhân viên cho các điều chỉnh thủ công"

msgid "Created At"
msgstr "Thời điểm Tạo"

msgid "Wallet Transaction"
msgstr "Giao dịch ví"

msgid "Wallet Transactions"
msgstr "Giao dịch Ví"
