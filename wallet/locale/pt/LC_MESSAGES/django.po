msgid "Customer"
msgstr "Cliente"

msgid "Manual Adjustment"
msgstr "Ajuste Manual"

msgid "Promotion"
msgstr "Promoção"

msgid "Order Refund"
msgstr "Estorno de Pedido"

msgid "Order Payment"
msgstr "Pagamento de Pedido"

msgid "Get wallet balance"
msgstr "Obter saldo da carteira"

msgid ""
"Get the authenticated customer's wallet balance. Creates a wallet "
"automatically if the customer does not have one."
msgstr ""
"Obtenha o saldo da carteira do cliente autenticado. Cria uma carteira "
"automaticamente se o cliente não tiver uma."

msgid "Authentication required"
msgstr "Autenticação necessária"

msgid "List wallet transactions"
msgstr "Listar transações da carteira"

msgid ""
"Get the authenticated customer's wallet transaction history, ordered by most"
" recent first. Supports filtering by type, source, and status."
msgstr ""
"Obtenha o histórico de transações da carteira do cliente autenticado, "
"ordenado pelos mais recentes primeiro. Suporta filtragem por tipo, fonte e "
"status."

msgid "Filter by transaction type"
msgstr "Filtrar por tipo de transação"

msgid "Filter by source"
msgstr "Filtrar por fonte"

msgid "Filter by status"
msgstr "Filtrar por status"

msgid "Number of results (default 20, max 100)"
msgstr "Número de resultados (padrão 20, máximo 100)"

msgid "Pagination offset"
msgstr "Deslocamento de paginação"

msgid "List customer wallets"
msgstr "Listar carteiras do cliente"

msgid ""
"List all customer wallets. Supports search by email or name, and filtering "
"by active status."
msgstr ""
"Liste todas as carteiras de clientes. Suporta busca por e-mail ou nome, e "
"filtragem pelo status ativo."

msgid "Search by customer email or name"
msgstr "Buscar por e-mail ou nome do cliente"

msgid "Filter by active status"
msgstr "Filtrar por status ativo"

msgid "Get wallet details"
msgstr "Obter detalhes da carteira"

msgid "Get full details of a customer wallet."
msgstr "Obter detalhes completos de uma carteira de cliente."

msgid "Credit a wallet"
msgstr "Creditar uma carteira"

msgid ""
"Manually add credit to a customer's wallet. Requires amount, currency, "
"source, and description."
msgstr ""
"Adicionar crédito manualmente à carteira de um cliente. Requer valor, moeda,"
" fonte e descrição."

msgid "Invalid input or wallet frozen"
msgstr "Entrada inválida ou carteira congelada"

msgid "Debit a wallet"
msgstr "Debitar uma carteira"

msgid ""
"Manually debit a customer's wallet. Fails if the wallet has insufficient "
"balance or is frozen."
msgstr ""
"Debitar manualmente a carteira de um cliente. Falha se a carteira tiver "
"saldo insuficiente ou estiver congelada."

msgid "Insufficient balance, invalid input, or wallet frozen"
msgstr "Saldo insuficiente, entrada inválida ou carteira congelada"

msgid "Toggle wallet freeze"
msgstr "Alternar congelamento da carteira"

msgid ""
"Freeze or unfreeze a customer's wallet. A frozen wallet cannot process "
"credits or debits."
msgstr ""
"Congelar ou descongelar a carteira de um cliente. Uma carteira congelada não"
" pode processar créditos ou débitos."

msgid "Wallet is frozen"
msgstr "Carteira está congelada"

msgid "Wallet credited successfully"
msgstr "Carteira creditada com sucesso"

msgid "Insufficient wallet balance"
msgstr "Saldo insuficiente na carteira"

msgid "Wallet debited successfully"
msgstr "Carteira debitada com sucesso"

msgid "unfrozen"
msgstr "desbloqueado"

msgid "frozen"
msgstr "bloqueado"

#, python-format
msgid "Wallet %s successfully"
msgstr "Carteira %s com sucesso"

msgid "List all transactions"
msgstr "Listar todas as transações"

msgid ""
"List wallet transactions across all customers. Supports filtering by wallet,"
" type, source, status, and search."
msgstr ""
"Liste as transações da carteira de todos os clientes. Suporta filtragem por "
"carteira, tipo, fonte, status e pesquisa."

msgid "Filter by wallet ID"
msgstr "Filtrar por ID da carteira"

msgid "Search by customer email"
msgstr "Buscar por e-mail do cliente"

msgid "Number of results (default 50, max 100)"
msgstr "Número de resultados (padrão 50, máximo 100)"

msgid "Get transaction details"
msgstr "Obter detalhes da transação"

msgid "Get full details of a wallet transaction."
msgstr "Obter detalhes completos de uma transação de carteira."

msgid "Available Balance"
msgstr "Saldo Disponível"

msgid "Current spendable balance"
msgstr "Saldo atual disponível para gastos"

msgid "Pending Balance"
msgstr "Saldo Pendente"

msgid "Credits not yet available (e.g. pending refund window)"
msgstr "Créditos ainda não disponíveis (ex.: janela de reembolso pendente)"

msgid "Lifetime Credited"
msgstr "Crédito ao longo da vida"

msgid "Lifetime Used"
msgstr "Usado ao longo da vida"

msgid "Active"
msgstr "Ativo"

msgid "Deactivate to freeze this wallet"
msgstr "Desative para bloquear esta carteira"

msgid "Last Credited At"
msgstr "Último Crédito Em"

msgid "Last Used At"
msgstr "Último Uso Em"

msgid "Customer Wallet"
msgstr "Carteira do Cliente"

msgid "Customer Wallets"
msgstr "Carteiras dos Clientes"

msgid "Credit"
msgstr "Crédito"

msgid "Debit"
msgstr "Débito"

msgid "Refund"
msgstr "Estorno"

msgid "Adjustment"
msgstr "Ajuste"

msgid "Reversal"
msgstr "Reversão"

msgid "Completed"
msgstr "Concluído"

msgid "Pending"
msgstr "Pendente"

msgid "Reversed"
msgstr "Reverso"

msgid "Referral Reward"
msgstr "Recompensa de Indicação"

msgid "Wallet"
msgstr "Carteira"

msgid "Type"
msgstr "Tipo"

msgid "Amount"
msgstr "Quantia"

msgid "Always positive; transaction_type determines direction"
msgstr "Sempre positivo; o tipo de transação determina a direção"

msgid "Balance After"
msgstr "Saldo Após"

msgid "Wallet balance snapshot after this transaction"
msgstr "Captura do saldo da carteira após esta transação"

msgid "Status"
msgstr "Status"

msgid "Source"
msgstr "Fonte"

msgid "Description"
msgstr "Descrição"

msgid "Reference ID"
msgstr "ID de Referência"

msgid "External reference (reward ID, order number, etc.)"
msgstr "Referência externa (ID de recompensa, número do pedido, etc.)"

msgid "Reversed By"
msgstr "Reverso Por"

msgid "Created By"
msgstr "Criado Por"

msgid "Staff user for manual adjustments"
msgstr "Usuário de staff para ajustes manuais"

msgid "Created At"
msgstr "Criado Em"

msgid "Wallet Transaction"
msgstr "Transação da Carteira"

msgid "Wallet Transactions"
msgstr "Transações da Carteira"
