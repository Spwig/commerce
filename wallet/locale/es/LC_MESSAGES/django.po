msgstr "Revertido"

msgid "Referral Reward"
msgstr "Recompensa por referido"

msgid "Wallet"
msgstr "Billetera"

msgid "Type"
msgstr "\"Tipo\""

msgid "Amount"
msgstr "Monto"

msgid "Always positive; transaction_type determines direction"
msgstr "Siempre positivo; el tipo de transacción determina la dirección"

msgid "Balance After"
msgstr "Saldo después"

msgid "Wallet balance snapshot after this transaction"
msgstr "Captura del saldo de la billetera después de esta transacción"

msgid "Status"
msgstr "\"Estado\""

msgid "Source"
msgstr "Fuente"

msgid "Description"
msgstr "Descripción"

msgid "Reference ID"
msgstr "ID de referencia"

msgid "External reference (reward ID, order number, etc.)"
msgstr "Referencia externa (ID de recompensa, número de pedido, etc.)"

