msgid "Customer"
msgstr "顧客"

msgid "Manual Adjustment"
msgstr "手動調整"

msgid "Promotion"
msgstr "プロモーション"

msgid "Order Refund"
msgstr "注文返金"

msgid "Order Payment"
msgstr "注文支払い"

msgid "Get wallet balance"
msgstr "ウォレット残高を取得"

msgid ""
"Get the authenticated customer's wallet balance. Creates a wallet "
"automatically if the customer does not have one."
msgstr "認証された顧客のウォレット残高を取得します。顧客がウォレットを持っていない場合は自動的にウォレットを作成します。"

msgid "Authentication required"
msgstr "認証が必要です"

msgid "List wallet transactions"
msgstr "ウォレット取引の一覧"

msgid ""
"Get the authenticated customer's wallet transaction history, ordered by most"
" recent first. Supports filtering by type, source, and status."
msgstr ""
"認証された顧客のウォレット取引履歴を取得します。最新のものから順番に並べます。タイプ、ソース、ステータスでフィルタリングをサポートしています。"

msgid "Filter by transaction type"
msgstr "取引タイプでフィルタ"

msgid "Filter by source"
msgstr "ソースでフィルタ"

msgid "Filter by status"
msgstr "ステータスでフィルタ"

msgid "Number of results (default 20, max 100)"
msgstr "結果数 (デフォルト 20, 最大 100)"

msgid "Pagination offset"
msgstr "ページネーションオフセット"

msgid "List customer wallets"
msgstr "顧客ウォレットの一覧"

msgid ""
"List all customer wallets. Supports search by email or name, and filtering "
"by active status."
msgstr "すべての顧客のウォレットを一覧表示します。メールアドレスまたは名前で検索し、アクティブ状態でフィルタリングすることも可能です。"

msgid "Search by customer email or name"
msgstr "顧客のメールアドレスまたは名前で検索"

msgid "Filter by active status"
msgstr "アクティブ状態でフィルタ"

msgid "Get wallet details"
msgstr "ウォレットの詳細を取得"

msgid "Get full details of a customer wallet."
msgstr "顧客のウォレットの詳細情報を取得します。"

msgid "Credit a wallet"
msgstr "ウォレットに資金を追加"

msgid ""
"Manually add credit to a customer's wallet. Requires amount, currency, "
"source, and description."
msgstr "顧客のウォレットに手動でクレジットを追加します。金額、通貨、ソース、説明が必要です。"

msgid "Invalid input or wallet frozen"
msgstr "無効な入力またはウォレットが凍結されています"

msgid "Debit a wallet"
msgstr "ウォレットから資金を引き出す"

msgid ""
"Manually debit a customer's wallet. Fails if the wallet has insufficient "
"balance or is frozen."
msgstr "顧客のウォレットから手動でデビットします。ウォレットの残高が不足しているか凍結されている場合は失敗します。"

msgid "Insufficient balance, invalid input, or wallet frozen"
msgstr "残高不足、無効な入力、またはウォレットが凍結されています"

msgid "Toggle wallet freeze"
msgstr "ウォレットの凍結状態を切り替え"

msgid ""
"Freeze or unfreeze a customer's wallet. A frozen wallet cannot process "
"credits or debits."
msgstr "顧客のウォレットを凍結または凍結解除します。凍結されたウォレットは、クレジットまたはデビットの処理が行えません。"

msgid "Wallet is frozen"
msgstr "ウォレットが凍結されています"

msgid "Wallet credited successfully"
msgstr "ウォレットが正常にチャージされました"

msgid "Insufficient wallet balance"
msgstr "ウォレットの残高が不足しています"

msgid "Wallet debited successfully"
msgstr "ウォレットから正常に引き落とされました"

msgid "unfrozen"
msgstr "解凍"

msgid "frozen"
msgstr "凍結"

#, python-format
msgid "Wallet %s successfully"
msgstr "ウォレット %s が正常に完了しました"

msgid "List all transactions"
msgstr "すべての取引を一覧表示"

msgid ""
"List wallet transactions across all customers. Supports filtering by wallet,"
" type, source, status, and search."
msgstr "すべての顧客のウォレット取引を一覧表示します。ウォレット、タイプ、ソース、ステータス、検索によるフィルタリングがサポートされています。"

msgid "Filter by wallet ID"
msgstr "ウォレットIDでフィルタ"

msgid "Search by customer email"
msgstr "顧客メールアドレスで検索"

msgid "Number of results (default 50, max 100)"
msgstr "結果数（デフォルト50、最大100）"

msgid "Get transaction details"
msgstr "取引詳細を取得"

msgid "Get full details of a wallet transaction."
msgstr "ウォレット取引の詳細情報を取得します。"

msgid "Available Balance"
msgstr "利用可能な残高"

msgid "Current spendable balance"
msgstr "現在利用可能な残高"

msgid "Pending Balance"
msgstr "未処理残高"

msgid "Credits not yet available (e.g. pending refund window)"
msgstr "クレジットがまだ利用可能ではありません（例: 返金保留期間中）"

msgid "Lifetime Credited"
msgstr "累計チャージ額"

msgid "Lifetime Used"
msgstr "累計使用額"

msgid "Active"
msgstr "有効"

msgid "Deactivate to freeze this wallet"
msgstr "このウォレットを凍結するには無効化してください"

msgid "Last Credited At"
msgstr "最終チャージ日時"

msgid "Last Used At"
msgstr "最終使用日時"

msgid "Customer Wallet"
msgstr "顧客ウォレット"

msgid "Customer Wallets"
msgstr "顧客ウォレット"

msgid "Credit"
msgstr "貸し出し"

msgid "Debit"
msgstr "引き出し"

msgid "Refund"
msgstr "返金"

msgid "Adjustment"
msgstr "調整"

msgid "Reversal"
msgstr "逆転"

msgid "Completed"
msgstr "完了"

msgid "Pending"
msgstr "保留"

msgid "Reversed"
msgstr "逆転済み"

msgid "Referral Reward"
msgstr "紹介報酬"

msgid "Wallet"
msgstr "ウォレット"

msgid "Type"
msgstr "タイプ"

msgid "Amount"
msgstr "金額"

msgid "Always positive; transaction_type determines direction"
msgstr "常に正数; transaction_type が方向を決定する"

msgid "Balance After"
msgstr "取引後の残高"

msgid "Wallet balance snapshot after this transaction"
msgstr "この取引後のウォレット残高のスナップショット"

msgid "Status"
msgstr "ステータス"

msgid "Source"
msgstr "ソース"

msgid "Description"
msgstr "説明"

msgid "Reference ID"
msgstr "参照ID"

msgid "External reference (reward ID, order number, etc.)"
msgstr "外部参照（報酬ID、注文番号など）"

msgid "Reversed By"
msgstr "逆転元"

msgid "Created By"
msgstr "作成者"

msgid "Staff user for manual adjustments"
msgstr "手動調整用のスタッフユーザー"

msgid "Created At"
msgstr "作成日時"

