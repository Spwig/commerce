msgid "Customer"
msgstr "ग्राहक"

msgid "Manual Adjustment"
msgstr "मैनुअल समायोजन"

msgid "Promotion"
msgstr "प्रोमोशन"

msgid "Order Refund"
msgstr "ऑर्डर रिफंड"

msgid "Order Payment"
msgstr "ऑर्डर भुगतान"

msgid "Get wallet balance"
msgstr "वॉलेट बैलेंस प्राप्त करें"

msgid ""
"Get the authenticated customer's wallet balance. Creates a wallet "
"automatically if the customer does not have one."
msgstr ""
"प्रमाणित ग्राहक के वॉलेट बैलेंस प्राप्त करें। यदि ग्राहक के पास वॉलेट नहीं "
"है तो ऑटोमैटिक रूप से एक वॉलेट बनाएं।"

msgid "Authentication required"
msgstr "अधिकृतिकरण आवश्यक है"

msgid "List wallet transactions"
msgstr "वॉलेट लेनदेन की सूची"

msgid ""
"Get the authenticated customer's wallet transaction history, ordered by most"
" recent first. Supports filtering by type, source, and status."
msgstr ""
"प्रमाणित ग्राहक के वॉलेट लेनदेन इतिहास प्राप्त करें, जो नवीनतम से पहले क्रम "
"में है। प्रकार, स्रोत और स्थिति द्वारा फ़िल्टर करने के समर्थन के साथ।"

msgid "Filter by transaction type"
msgstr "लेनदेन प्रकार द्वारा छाने"

msgid "Filter by source"
msgstr "स्रोत द्वारा छाने"

msgid "Filter by status"
msgstr "स्थिति द्वारा छाने"

msgid "Number of results (default 20, max 100)"
msgstr "परिणामों की संख्या (डिफ़ॉल्ट 20, अधिकतम 100)"

msgid "Pagination offset"
msgstr "पृष्ठभूमि अप्टाफ़स"

msgid "List customer wallets"
msgstr "ग्राहक वॉलेट की सूची"

msgid ""
"List all customer wallets. Supports search by email or name, and filtering "
"by active status."
msgstr ""
"सभी ग्राहक वॉलेट लिस्ट करें। ईमेल या नाम द्वारा खोज का समर्थन करता है, और "
"सक्रिय स्थिति द्वारा फ़िल्टर करता है।"

msgid "Search by customer email or name"
msgstr "ग्राहक ईमेल या नाम द्वारा खोजें"

msgid "Filter by active status"
msgstr "सक्रिय स्थिति द्वारा फ़िल्टर करें"

msgid "Get wallet details"
msgstr "वॉलेट विवरण प्राप्त करें"

msgid "Get full details of a customer wallet."
msgstr "एक ग्राहक के वॉलेट के पूरे विवरण प्राप्त करें।"

msgid "Credit a wallet"
msgstr "एक वॉलेट क्रेडिट करें"

msgid ""
"Manually add credit to a customer's wallet. Requires amount, currency, "
"source, and description."
msgstr ""
"एक ग्राहक के वॉलेट में मनमाने से क्रेडिट जोड़ें। राशि, मुद्रा, स्रोत और "
"विवरण की आवश्यकता होती है।"

msgid "Invalid input or wallet frozen"
msgstr "अमान्य इनपुट या वॉलेट बर्फ में जमा है"

msgid "Debit a wallet"
msgstr "एक वॉलेट डेबिट करें"

msgid ""
"Manually debit a customer's wallet. Fails if the wallet has insufficient "
"balance or is frozen."
msgstr ""
"एक ग्राहक के वॉलेट से मनमाने से डेबिट करें। यदि वॉलेट में पर्याप्त बैलेंस "
"नहीं है या फ्रीज है तो यह विफल हो जाएगा।"

msgid "Insufficient balance, invalid input, or wallet frozen"
msgstr "अपर्याप्त बैलेंस, अमान्य इनपुट या वॉलेट फ्रीज"

msgid "Toggle wallet freeze"
msgstr "वॉलेट बर्फ में जमाने के बटन को स्विच करें"

msgid ""
"Freeze or unfreeze a customer's wallet. A frozen wallet cannot process "
"credits or debits."
msgstr ""
"एक ग्राहक के वॉलेट को फ्रीज करें या अनफ्रीज करें। एक फ्रीज किया गया वॉलेट "
"क्रेडिट या डेबिट के लेनदेन को प्रक्रिया नहीं कर सकता।"

msgid "Wallet is frozen"
msgstr "वॉलेट बर्फ में जमा है"

msgid "Wallet credited successfully"
msgstr "वॉलेट सफलतापूर्वक क्रेडिट कर दिया गया"

msgid "Insufficient wallet balance"
msgstr "वॉलेट बैलेंस कम है"

msgid "Wallet debited successfully"
msgstr "वॉलेट सफलतापूर्वक डेबिट कर दिया गया"

msgid "unfrozen"
msgstr "अजमा"

msgid "frozen"
msgstr "जमा"

#, python-format
msgid "Wallet %s successfully"
msgstr "वॉलेट %s सफलतापूर्वक"

msgid "List all transactions"
msgstr "सभी लेनदेन की सूची"

msgid ""
"List wallet transactions across all customers. Supports filtering by wallet,"
" type, source, status, and search."
msgstr ""
"सभी ग्राहकों के वॉलेट लेनदेनों की सूची। वॉलेट, प्रकार, स्रोत, स्थिति और खोज "
"द्वारा फ़िल्टर करने का समर्थन करता है।"

msgid "Filter by wallet ID"
msgstr "वॉलेट ID द्वारा छाने"

msgid "Search by customer email"
msgstr "ग्राहक ईमेल द्वारा खोजें"

msgid "Number of results (default 50, max 100)"
msgstr "परिणामों की संख्या (डिफ़ॉल्ट 50, अधिकतम 100)"

msgid "Get transaction details"
msgstr "लेनदेन विवरण प्राप्त करें"

msgid "Get full details of a wallet transaction."
msgstr "एक वॉलेट लेनदेन के पूरे विवरण प्राप्त करें।"

msgid "Available Balance"
msgstr "उपलब्ध बैलेंस"

msgid "Current spendable balance"
msgstr "वर्तमान खर्च करने योग्य बैलेंस"

msgid "Pending Balance"
msgstr "पेंडिंग बैलेंस"

msgid "Credits not yet available (e.g. pending refund window)"
msgstr "क्रेडिट अभी तक उपलब्ध नहीं है (उदाहरण के लिए, अपेक्षित रिफंड विंडो)"

msgid "Lifetime Credited"
msgstr "जीवनकाल क्रेडिट किया गया"

msgid "Lifetime Used"
msgstr "जीवनकाल में उपयोग किया गया"

msgid "Active"
msgstr "सक्रिय"

msgid "Deactivate to freeze this wallet"
msgstr "इस वॉलेट को बर्फ में बंद करने के लिए अक्रिय करें"

msgid "Last Credited At"
msgstr "अंतिम क्रेडिट के समय"

msgid "Last Used At"
msgstr "अंतिम उपयोग के समय"

msgid "Customer Wallet"
msgstr "ग्राहक वॉलेट"

msgid "Customer Wallets"
msgstr "ग्राहक वॉलेट"

msgid "Credit"
msgstr "क्रेडिट"

msgid "Debit"
msgstr "डेबिट"

msgid "Refund"
msgstr "वापसी"

msgid "Adjustment"
msgstr "समायोजन"

msgid "Reversal"
msgstr "प्रतिक्षित"

msgid "Completed"
msgstr "पूर्ण"

msgid "Pending"
msgstr "पेंडिंग"

msgid "Reversed"
msgstr "प्रतिक्षित"

msgid "Referral Reward"
msgstr "संदर्भ पुरस्कार"

msgid "Wallet"
msgstr "वॉलेट"

msgid "Type"
msgstr "प्रकार"

msgid "Amount"
msgstr "राशि"

msgid "Always positive; transaction_type determines direction"
msgstr "हमेशा सकारात्मक; लेनदेन प्रकार दिशा निर्धारित करता है"

msgid "Balance After"
msgstr "बाद में बैलेंस"

msgid "Wallet balance snapshot after this transaction"
msgstr "इस लेनदेन के बाद वॉलेट बैलेंस के स्नैपशॉट"

msgid "Status"
msgstr "स्थिति"

msgid "Source"
msgstr "स्रोत"

msgid "Description"
msgstr "विवरण"

msgid "Reference ID"
msgstr "संदर्भ आईडी"

msgid "External reference (reward ID, order number, etc.)"
msgstr "बाहरी संदर्भ (पुरस्कार आईडी, आदेश संख्या, आदि)"

msgid "Reversed By"
msgstr "द्वारा पलटा गया"

msgid "Created By"
msgstr "द्वारा बनाया गया"

msgid "Staff user for manual adjustments"
msgstr "मानक उपयोगकर्ता मानव-नियंत्रित समायोजन के लिए"

msgid "Created At"
msgstr "बनाया गया"

msgid "Wallet Transaction"
msgstr "वॉलेट लेनदेन"

msgid "Wallet Transactions"
msgstr "वॉलेट लेनदेन"
