msgid "Customer"
msgstr "Cliente"

msgid "Manual Adjustment"
msgstr "Regolazione manuale"

msgid "Promotion"
msgstr "Promozione"

msgid "Order Refund"
msgstr "Rimborsare l'ordine"

msgid "Order Payment"
msgstr "Pagamento dell'ordine"

msgid "Get wallet balance"
msgstr "Ottieni saldo del portafoglio"

msgid ""
"Get the authenticated customer's wallet balance. Creates a wallet "
"automatically if the customer does not have one."
msgstr ""
"Ottieni il saldo del portafoglio del cliente autenticato. Crea "
"automaticamente un portafoglio se il cliente non ne ha uno."

msgid "Authentication required"
msgstr "Autenticazione richiesta"

msgid "List wallet transactions"
msgstr "Elenca le transazioni del portafoglio"

msgid ""
"Get the authenticated customer's wallet transaction history, ordered by most"
" recent first. Supports filtering by type, source, and status."
msgstr ""
"Ottieni la cronologia delle transazioni del portafoglio del cliente "
"autenticato, ordinata per transazione più recente in primo piano. Supporta "
"il filtro per tipo, origine e stato."

msgid "Filter by transaction type"
msgstr "Filtra per tipo di transazione"

msgid "Filter by source"
msgstr "Filtra per origine"

msgid "Filter by status"
msgstr "Filtra per stato"

msgid "Number of results (default 20, max 100)"
msgstr "Numero di risultati (predefinito 20, massimo 100)"

msgid "Pagination offset"
msgstr "Offset di paginazione"

msgid "List customer wallets"
msgstr "Elenca i portafogli dei clienti"

msgid ""
"List all customer wallets. Supports search by email or name, and filtering "
"by active status."
msgstr ""
"Elenca tutti i portafogli dei clienti. Supporta la ricerca per e-mail o "
"nome, e il filtraggio per stato attivo."

msgid "Search by customer email or name"
msgstr "Cerca per e-mail o nome del cliente"

msgid "Filter by active status"
msgstr "Filtra per stato attivo"

msgid "Get wallet details"
msgstr "Ottieni dettagli del portafoglio"

msgid "Get full details of a customer wallet."
msgstr "Ottieni i dettagli completi di un portafoglio cliente."

msgid "Credit a wallet"
msgstr "Credita un portafoglio"

msgid ""
"Manually add credit to a customer's wallet. Requires amount, currency, "
"source, and description."
msgstr ""
"Aggiungi manualmente del credito a un portafoglio cliente. Richiede importo,"
" valuta, fonte e descrizione."

msgid "Invalid input or wallet frozen"
msgstr "Input non valido o portafoglio congelato"

msgid "Debit a wallet"
msgstr "Debita un portafoglio"

msgid ""
"Manually debit a customer's wallet. Fails if the wallet has insufficient "
"balance or is frozen."
msgstr ""
"Debita manualmente un portafoglio cliente. Fallisce se il portafoglio ha un "
"saldo insufficiente o è congelato."

msgid "Insufficient balance, invalid input, or wallet frozen"
msgstr "Saldo insufficiente, input non valido o portafoglio congelato"

msgid "Toggle wallet freeze"
msgstr "Attiva/disattiva congelamento del portafoglio"

msgid ""
"Freeze or unfreeze a customer's wallet. A frozen wallet cannot process "
"credits or debits."
msgstr ""
"Congela o scongela un portafoglio cliente. Un portafoglio congelato non può "
"processare crediti o debiti."

msgid "Wallet is frozen"
msgstr "Il portafoglio è congelato"

msgid "Wallet credited successfully"
msgstr "Portafoglio creditato con successo"

msgid "Insufficient wallet balance"
msgstr "Saldo del portafoglio insufficiente"

msgid "Wallet debited successfully"
msgstr "Portafoglio addebitato con successo"

msgid "unfrozen"
msgstr "non congelato"

msgid "frozen"
msgstr "congelato"

#, python-format
msgid "Wallet %s successfully"
msgstr "Portafoglio %s riuscito"

msgid "List all transactions"
msgstr "Elenca tutte le transazioni"

msgid ""
"List wallet transactions across all customers. Supports filtering by wallet,"
" type, source, status, and search."
msgstr ""
"Elenca le transazioni del portafoglio di tutti i clienti. Supporta il filtro"
" per portafoglio, tipo, origine, stato e ricerca."

msgid "Filter by wallet ID"
msgstr "Filtra per ID portafoglio"

msgid "Search by customer email"
msgstr "Cerca per email del cliente"

msgid "Number of results (default 50, max 100)"
msgstr "Numero di risultati (predefinito 50, massimo 100)"

msgid "Get transaction details"
msgstr "Ottieni dettagli della transazione"

msgid "Get full details of a wallet transaction."
msgstr "Ottieni i dettagli completi di una transazione del portafoglio."

msgid "Available Balance"
msgstr "Saldo disponibile"

msgid "Current spendable balance"
msgstr "Saldo spendibile attuale"

msgid "Pending Balance"
msgstr "Saldo in sospeso"

msgid "Credits not yet available (e.g. pending refund window)"
msgstr "Crediti non ancora disponibili (es. finestra di rimborso in sospeso)"

msgid "Lifetime Credited"
msgstr "Credito totale"

msgid "Lifetime Used"
msgstr "Utilizzato totale"

msgid "Active"
msgstr "Attivo"

msgid "Deactivate to freeze this wallet"
msgstr "Disattiva per congelare questo portafoglio"

msgid "Last Credited At"
msgstr "Ultimo credito il"

msgid "Last Used At"
msgstr "Ultimo utilizzo il"

msgid "Customer Wallet"
msgstr "Portafoglio del cliente"

msgid "Customer Wallets"
msgstr "Portafogli dei clienti"

msgid "Credit"
msgstr "Credito"

msgid "Debit"
msgstr "Debito"

msgid "Refund"
msgstr "Rimborso"

msgid "Adjustment"
msgstr "Regolamento"

msgid "Reversal"
msgstr "Annullamento"

msgid "Completed"
msgstr "Completato"

msgid "Pending"
msgstr "In attesa"

msgid "Reversed"
msgstr "Annullato"

msgid "Referral Reward"
msgstr "Ricompensa per referral"

msgid "Wallet"
msgstr "Portafoglio"

msgid "Type"
msgstr "Tipo"

msgid "Amount"
msgstr "Importo"

msgid "Always positive; transaction_type determines direction"
msgstr "Sempre positivo; il tipo di transazione determina la direzione"

msgid "Balance After"
msgstr "Saldo dopo"

msgid "Wallet balance snapshot after this transaction"
msgstr "Cattura dello stato del saldo del portafoglio dopo questa transazione"

msgid "Status"
msgstr "Stato"

msgid "Source"
msgstr "Fonte"

msgid "Description"
msgstr "Descrizione"

msgid "Reference ID"
msgstr "ID di riferimento"

msgid "External reference (reward ID, order number, etc.)"
msgstr "Riferimento esterno (ID premio, numero ordine, ecc.)"

msgid "Reversed By"
msgstr "Annullato da"

msgid "Created By"
msgstr "Creato da"

msgid "Staff user for manual adjustments"
msgstr "Utente dello staff per regolamenti manuali"

msgid "Created At"
msgstr "Creato il"

msgid "Wallet Transaction"
msgstr "Transazione del Portafoglio"

msgid "Wallet Transactions"
msgstr "Transazioni del portafoglio"
