msgid "Customer"
msgstr "Клиент"

msgid "Manual Adjustment"
msgstr "Ручная настройка"

msgid "Promotion"
msgstr "Промоакция"

msgid "Order Refund"
msgstr "Возврат заказа"

msgid "Order Payment"
msgstr "Оплата заказа"

msgid "Get wallet balance"
msgstr "Получить баланс кошелька"

msgid ""
"Get the authenticated customer's wallet balance. Creates a wallet "
"automatically if the customer does not have one."
msgstr ""
"Получить баланс кошелька аутентифицированного клиента. Автоматически создаёт"
" кошелёк, если у клиента его нет."

msgid "Authentication required"
msgstr "Требуется аутентификация"

msgid "List wallet transactions"
msgstr "Список транзакций кошелька"

msgid ""
"Get the authenticated customer's wallet transaction history, ordered by most"
" recent first. Supports filtering by type, source, and status."
msgstr ""
"Получить историю транзакций кошелька аутентифицированного клиента, "
"отсортированную по самому свежему сначала. Поддерживает фильтрацию по типу, "
"источнику и статусу."

msgid "Filter by transaction type"
msgstr "Фильтр по типу транзакции"

msgid "Filter by source"
msgstr "Фильтр по источнику"

msgid "Filter by status"
msgstr "Фильтр по статусу"

msgid "Number of results (default 20, max 100)"
msgstr "Количество результатов (по умолчанию 20, максимум 100)"

msgid "Pagination offset"
msgstr "Смещение пагинации"

msgid "List customer wallets"
msgstr "Список кошельков клиентов"

msgid ""
"List all customer wallets. Supports search by email or name, and filtering "
"by active status."
msgstr ""
"Список всех клиентских кошельков. Поддерживает поиск по электронной почте "
"или имени, а также фильтрацию по статусу активности."

msgid "Search by customer email or name"
msgstr "Поиск по электронной почте или имени клиента"

msgid "Filter by active status"
msgstr "Фильтр по статусу активности"

msgid "Get wallet details"
msgstr "Получить детали кошелька"

msgid "Get full details of a customer wallet."
msgstr "Получить полные сведения о кошельке клиента."

msgid "Credit a wallet"
msgstr "Пополнить кошелёк"

msgid ""
"Manually add credit to a customer's wallet. Requires amount, currency, "
"source, and description."
msgstr ""
"Вручную добавить кредит в кошелек клиента. Требуется сумма, валюта, источник"
" и описание."

msgid "Invalid input or wallet frozen"
msgstr "Неверный ввод или кошелёк заморожен"

msgid "Debit a wallet"
msgstr "Списать с кошелька"

msgid ""
"Manually debit a customer's wallet. Fails if the wallet has insufficient "
"balance or is frozen."
msgstr ""
"Вручную списать средства с кошелька клиента. Операция завершится ошибкой, "
"если кошелек имеет недостаточный баланс или заморожен."

msgid "Insufficient balance, invalid input, or wallet frozen"
msgstr "Недостаточный баланс, неверный ввод или замороженный кошелёк"

msgid "Toggle wallet freeze"
msgstr "Переключить заморозку кошелька"

msgid ""
"Freeze or unfreeze a customer's wallet. A frozen wallet cannot process "
"credits or debits."
msgstr ""
"Заморозить или разморозить кошелёк клиента. Замороженный кошелёк не может "
"обрабатывать кредиты или дебеты."

msgid "Wallet is frozen"
msgstr "Кошелек заморожен"

msgid "Wallet credited successfully"
msgstr "Кошелек успешно пополнен"

msgid "Insufficient wallet balance"
msgstr "Недостаточный баланс кошелька"

msgid "Wallet debited successfully"
msgstr "С кошелька успешно снято"

msgid "unfrozen"
msgstr "разморожен"

msgid "frozen"
msgstr "заморожен"

#, python-format
msgid "Wallet %s successfully"
msgstr "Кошелёк %s успешно"

msgid "List all transactions"
msgstr "Список всех транзакций"

msgid ""
"List wallet transactions across all customers. Supports filtering by wallet,"
" type, source, status, and search."
msgstr ""
"Показать транзакции кошелька всех клиентов. Поддерживает фильтрацию по "
"кошельку, типу, источнику, статусу и поиску."

msgid "Filter by wallet ID"
msgstr "Фильтр по идентификатору кошелька"

msgid "Search by customer email"
msgstr "Поиск по электронной почте клиента"

msgid "Number of results (default 50, max 100)"
msgstr "Количество результатов (по умолчанию 50, максимум 100)"

msgid "Get transaction details"
msgstr "Получить детали транзакции"

msgid "Get full details of a wallet transaction."
msgstr "Получить полные сведения о транзакции кошелька."

msgid "Available Balance"
msgstr "Доступный баланс"

msgid "Current spendable balance"
msgstr "Текущий баланс на расход"

msgid "Pending Balance"
msgstr "Ожидающий баланс"

msgid "Credits not yet available (e.g. pending refund window)"
msgstr "Кредиты еще недоступны (например, окно ожидания возврата средств)"

msgid "Lifetime Credited"
msgstr "Накоплено за всю жизнь"

msgid "Lifetime Used"
msgstr "Использовано за всю жизнь"

msgid "Active"
msgstr "Активный"

msgid "Deactivate to freeze this wallet"
msgstr "Отключите, чтобы приостановить этот кошелёк"

msgid "Last Credited At"
msgstr "Последнее начисление в"

msgid "Last Used At"
msgstr "Последнее использование в"

msgid "Customer Wallet"
msgstr "Клиентский кошелёк"

msgid "Customer Wallets"
msgstr "Клиентские кошельки"

msgid "Credit"
msgstr "Кредит"

msgid "Debit"
msgstr "Дебет"

msgid "Refund"
msgstr "Возврат"

msgid "Adjustment"
msgstr "Корректировка"

msgid "Reversal"
msgstr "Возврат"

msgid "Completed"
msgstr "Завершено"

msgid "Pending"
msgstr "В ожидании"

msgid "Reversed"
msgstr "Возвращено"

msgid "Referral Reward"
msgstr "Награда по реферальной программе"

msgid "Wallet"
msgstr "Кошелёк"

msgid "Type"
msgstr "Тип"

msgid "Amount"
msgstr "Количество"

msgid "Always positive; transaction_type determines direction"
msgstr "Всегда положительное; направление определяет тип транзакции"

msgid "Balance After"
msgstr "Баланс после"

msgid "Wallet balance snapshot after this transaction"
msgstr "Снимок баланса кошелька после этой транзакции"

msgid "Status"
msgstr "Статус"

msgid "Source"
msgstr "Источник"

msgid "Description"
msgstr "Описание"

msgid "Reference ID"
msgstr "Идентификатор ссылки"

msgid "External reference (reward ID, order number, etc.)"
msgstr "Внешняя ссылка (ID вознаграждения, номер заказа и т.д.)"

msgid "Reversed By"
msgstr "Отменено кем"

msgid "Created By"
msgstr "Создано кем"

msgid "Staff user for manual adjustments"
msgstr "Пользователь-сотрудник для вручную внесенных изменений"

msgid "Created At"
msgstr "Создано в"

msgid "Wallet Transaction"
msgstr "Транзакция кошелька"

msgid "Wallet Transactions"
msgstr "Транзакции кошелька"
