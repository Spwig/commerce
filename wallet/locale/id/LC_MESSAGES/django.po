msgstr "Penyesuaian"

msgid "Reversal"
msgstr "Pembatalan"

msgid "Completed"
msgstr "Selesai"

msgid "Pending"
msgstr "Menunggu"

msgid "Reversed"
msgstr "Dibatalkan"

msgid "Referral Reward"
msgstr "Hadiah Referensi"

msgid "Wallet"
msgstr "Dompet"

msgid "Type"
msgstr "Jenis"

msgid "Amount"
msgstr "Jumlah"

msgid "Always positive; transaction_type determines direction"
msgstr "Selalu positif; jenis_transaksi menentukan arah"

msgid "Balance After"
msgstr "Saldo Setelah"

msgid "Wallet balance snapshot after this transaction"
msgstr "Snapshoot saldo dompet setelah transaksi ini"

msgid "Status"
msgstr "Status"

msgid "Source"
msgstr "Sumber"

msgid "Description"
msgstr "Deskripsi"

msgid "Reference ID"
msgstr "ID Referensi"

msgid "External reference (reward ID, order number, etc.)"
msgstr "Referensi eksternal (ID hadiah, nomor pesanan, dll.)"

msgid "Reversed By"
msgstr "Dibatalkan Oleh"

msgid "Created By"
msgstr "Dibuat Oleh"

msgid "Staff user for manual adjustments"
msgstr "Pengguna staf untuk penyesuaian manual"

msgid "Created At"
msgstr "Dibuat Pada"

msgid "Wallet Transaction"
msgstr "Transaksi Dompet"

msgid "Wallet Transactions"
