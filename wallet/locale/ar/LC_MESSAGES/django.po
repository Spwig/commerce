msgid "Customer"
msgstr "العميل"

msgid "Manual Adjustment"
msgstr "التعديل اليدوي"

msgid "Promotion"
msgstr "التعزيز"

msgid "Order Refund"
msgstr "استرداد طلب"

msgid "Order Payment"
msgstr "دفع الطلب"

msgid "Get wallet balance"
msgstr "الحصول على رصيد المحفظة"

msgid ""
"Get the authenticated customer's wallet balance. Creates a wallet "
"automatically if the customer does not have one."
msgstr ""
"احصل على رصيد محفظة العميل المصادق عليه. ينشئ محفظة تلقائيًا إذا لم يكن "
"للعميل واحدة."

msgid "Authentication required"
msgstr "تребى المصادقة"

msgid "List wallet transactions"
msgstr "قائمة معاملات المحفظة"

msgid ""
"Get the authenticated customer's wallet transaction history, ordered by most"
" recent first. Supports filtering by type, source, and status."
msgstr ""
"احصل على سجل المعاملات الخاصة بمحفظة العميل المصادق عليه، مُصنَّفًا حسب "
"الأحدث أولاً. يدعم التصفية حسب النوع والمصدر والحالة."

msgid "Filter by transaction type"
msgstr "الفلترة حسب نوع المعاملة"

msgid "Filter by source"
msgstr "الفلترة حسب المصدر"

msgid "Filter by status"
msgstr "الفلترة حسب الحالة"

msgid "Number of results (default 20, max 100)"
msgstr "عدد النتائج (القيمة الافتراضية 20، القصوى 100)"

msgid "Pagination offset"
msgstr "مُعرِّف التصفح"

msgid "List customer wallets"
msgstr "قائمة محفظات العملاء"

msgid ""
"List all customer wallets. Supports search by email or name, and filtering "
"by active status."
msgstr ""
"عرض جميع محفظات العملاء. يدعم البحث عبر البريد الإلكتروني أو الاسم، ويسمح "
"بالفلترة حسب الحالة النشطة."

msgid "Search by customer email or name"
msgstr "ابحث عبر بريد العميل أو اسمه"

msgid "Filter by active status"
msgstr "فلتر حسب الحالة النشطة"

msgid "Get wallet details"
msgstr "احصل على تفاصيل المحفظة"

msgid "Get full details of a customer wallet."
msgstr "احصل على تفاصيل كاملة عن محفظة العميل."

msgid "Credit a wallet"
msgstr "ائتمان المحفظة"

msgid ""
"Manually add credit to a customer's wallet. Requires amount, currency, "
"source, and description."
msgstr ""
"أضف مبلغًا يدويًا إلى محفظة العميل. يتطلب المبلغ، العملة، المصدر، والوصف."

msgid "Invalid input or wallet frozen"
msgstr "إدخال غير صحيح أو المحفظة مجمدة"

msgid "Debit a wallet"
msgstr "خصم من المحفظة"

msgid ""
"Manually debit a customer's wallet. Fails if the wallet has insufficient "
"balance or is frozen."
msgstr ""
"خصم مبلغ يدويًا من محفظة العميل. يفشل إذا كانت المحفظة تحتوي على رصيد غير "
"كافٍ أو مجمدة."

msgid "Insufficient balance, invalid input, or wallet frozen"
msgstr "رصيد غير كافٍ، إدخال غير صحيح، أو محفظة مجمدة"

msgid "Toggle wallet freeze"
msgstr "تبديل تجميد المحفظة"

msgid ""
"Freeze or unfreeze a customer's wallet. A frozen wallet cannot process "
"credits or debits."
msgstr ""
"تجميد أو إلغاء تجميد محفظة العميل. لا يمكن للمحفظة المجمدة معالجة المدخلات "
"أو المخرجات."

msgid "Wallet is frozen"
msgstr "المحفظة مجمدة"

msgid "Wallet credited successfully"
msgstr "تم إيداع المحفظة بنجاح"

msgid "Insufficient wallet balance"
msgstr "رصيد المحفظة غير كافٍ"

msgid "Wallet debited successfully"
msgstr "تم سحب المحفظة بنجاح"

msgid "unfrozen"
msgstr "غير مجمدة"

msgid "frozen"
msgstr "مجمدة"

#, python-format
msgid "Wallet %s successfully"
msgstr "المحفظة %s بنجاح"

msgid "List all transactions"
msgstr "عرض جميع المعاملات"

msgid ""
"List wallet transactions across all customers. Supports filtering by wallet,"
" type, source, status, and search."
msgstr ""
"عرض معاملات المحفظة لجميع العملاء. يدعم التصفية حسب المحفظة، النوع، المصدر، "
"الحالة، والبحث."

msgid "Filter by wallet ID"
msgstr "فلترة حسب معرّف المحفظة"

msgid "Search by customer email"
msgstr "البحث حسب بريد العميل"

msgid "Number of results (default 50, max 100)"
msgstr "عدد النتائج (القيمة الافتراضية 50، القصوى 100)"

msgid "Get transaction details"
msgstr "الحصول على تفاصيل المعاملة"

msgid "Get full details of a wallet transaction."
msgstr "احصل على تفاصيل كاملة عن معاملة المحفظة."

msgid "Available Balance"
msgstr "الرصيد المتاح"

msgid "Current spendable balance"
msgstr "الرصيد القابل للإنفاق حاليًا"

msgid "Pending Balance"
msgstr "الرصيد المعلق"

msgid "Credits not yet available (e.g. pending refund window)"
msgstr "الائتمانات غير متوفرة بعد (مثلاً: نافذة استرجاع معلقة)"

msgid "Lifetime Credited"
msgstr "الرصيد المُضاف مدى الحياة"

msgid "Lifetime Used"
msgstr "الرصيد المستخدم مدى الحياة"

msgid "Active"
msgstr "نشط"

msgid "Deactivate to freeze this wallet"
msgstr "تعطيل لجم هذا المحفظة"

msgid "Last Credited At"
msgstr "آخر مُضاف في"

msgid "Last Used At"
msgstr "الآخر المستخدم في"

msgid "Customer Wallet"
msgstr "محفظة العميل"

msgid "Customer Wallets"
msgstr "محافظ العملاء"

msgid "Credit"
msgstr "ائتمان"

msgid "Debit"
msgstr "خصم"

msgid "Refund"
msgstr "استرجاع"

msgid "Adjustment"
msgstr "تعديل"

msgid "Reversal"
msgstr "الاسترداد"

msgid "Completed"
msgstr "مكتمل"

msgid "Pending"
msgstr "معلق"

msgid "Reversed"
msgstr "تم الاسترداد"

msgid "Referral Reward"
msgstr "مكافأة الإحالة"

msgid "Wallet"
msgstr "المحفظة"

msgid "Type"
msgstr "النوع"

msgid "Amount"
msgstr "المبلغ"

msgid "Always positive; transaction_type determines direction"
msgstr "القيمة دائمًا موجبة؛ يحدد نوع المعاملة الاتجاه"

msgid "Balance After"
msgstr "الرصيد بعد"

msgid "Wallet balance snapshot after this transaction"
msgstr "快照 الميزانية في المحفظة بعد هذه المعاملة"

msgid "Status"
msgstr "الحالة"

msgid "Source"
msgstr "المصدر"

msgid "Description"
msgstr "الوصف"

msgid "Reference ID"
msgstr "رقم المراجع"

msgid "External reference (reward ID, order number, etc.)"
msgstr "المراجع الخارجية (معرّف الجائزة، رقم الطلب، إلخ)"

msgid "Reversed By"
msgstr "المرجع من قبل"

msgid "Created By"
msgstr "أنشأ بواسطة"

msgid "Staff user for manual adjustments"
msgstr "مستخدم الموظف للمعالجة اليدوية"

msgid "Created At"
msgstr "تم الإنشاء في"

msgid "Wallet Transaction"
msgstr "المعاملة في المحفظة"

msgid "Wallet Transactions"
msgstr "معاملات المحفظة"
