msgstr "過期時間"

msgid "Leave blank for no expiry."
msgstr "留空表示無過期時間。"

msgid "Created"
msgstr "建立時間"

msgid "Updated"
msgstr "已更新"

msgid "Advanced"
msgstr "高級"

msgid ""
"Restrict when this announcement is shown. Leave empty to show to everyone."
msgstr "限制此公告的顯示時間。留空表示對所有人顯示。"

msgid "Hold Ctrl / Cmd to select multiple."
msgstr "按住 Ctrl / Cmd 鍵可多選。"

msgid "Save"
msgstr "儲存"

msgid "Save & Continue"
msgstr "儲存並繼續"

msgid "Save & Add Another"
msgstr "儲存並新增另一個"

msgid "Delete"
msgstr "刪除"

msgid "Manage store announcements displayed in headers and footers"
msgstr "管理顯示在頁首和頁尾的商店公告"

msgid "All"
msgstr "全部"

msgid "Disabled"
msgstr "已停用"

msgid "Search announcements..."
msgstr "搜尋公告..."

