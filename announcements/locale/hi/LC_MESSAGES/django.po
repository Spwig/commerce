msgid "Content"
msgstr "सामग्री"

msgid "Image"
msgstr "चित्र"

msgid ""
"Optional image for modal display. Choose between banner (above content) or "
"background (behind text with overlay)."
msgstr ""
"मोडल डिस्प्ले के लिए वैकल्पिक छवि। बैनर (कंटेंट के ऊपर) या पृष्ठभूमि (टेक्स्ट के पीछे ओवरले के "
"साथ) के बीच चुनें।"

msgid "Link"
msgstr "लिंक"

msgid "Display"
msgstr "प्रदर्शन"

msgid "Visibility Rules"
msgstr "दृश्यता के नियम"

msgid ""
"Optional: restrict when this announcement is shown based on advanced "
"conditions."
msgstr "वैकल्पिक: उन्नत शर्तों के आधार पर इस घोषणा के दिखाए जाने के समय को सीमित करें।"

msgid "Title"
msgstr "शीर्षक"

msgid "No expiry"
msgstr "कोई अवधि नहीं"

msgid "Expired"
msgstr "मौजूदा तिथि"

msgid "Active"
msgstr "सक्रिय"

msgid "Status"
msgstr "स्थिति"

msgid "List active announcements"
msgstr "सक्रिय घोषणाओं की सूची"

msgid ""
"Public endpoint. Returns all enabled, non-expired announcements ordered by "
"priority ascending, then created_at descending. Used by the storefront "
"announcement widget."
msgstr ""
"सार्वजनिक अंत मार्ग। सभी सक्रिय, अमृत्त घोषणा के डेटा को प्राप्त करता है जो प्राथमिकता "
"आरोही के अनुसार, फिर created_at अवरोही के अनुसार क्रमबद्ध होता है। स्टोरफ्रंट घोषणा "
"विजेट द्वारा उपयोग किया जाता है।"

msgid "List of active announcements"
msgstr "सक्रिय घोषणाओं की सूची"

msgid "Get announcement detail"
msgstr "घोषणा विवरण प्राप्त करें"

msgid ""
"Public endpoint. Returns full announcement data including body HTML, image "
"URL, and display mode for the storefront modal. Returns 404 if the "
"announcement is inactive, expired, or does not exist."
msgstr ""
"सार्वजनिक अंत मार्ग। स्टोरफ्रंट मोडल के लिए शरीर HTML, छवि URL और प्रदर्शन मोड के साथ "
"पूर्ण घोषणा डेटा प्राप्त करता है। यदि घोषणा अक्रिय, अमृत्त या मौजूद नहीं है, तो 404 "
"लौटाता है।"

msgid "Announcement primary key"
msgstr "घोषणा प्राथमिक कुंजी"

msgid "Announcement detail"
msgstr "अनुच्छेद विवरण"

msgid "Not found, inactive, or expired"
msgstr "पाया नहीं गया, बंद है, या अमान्य हो गया"

msgid "Announcements"
msgstr "अधिसूचनाएं"

msgid "No Link"
msgstr "कोई लिंक नहीं"

msgid "Product"
msgstr "उत्पाद"

msgid "Category"
msgstr "श्रेणी"

msgid "Blog Post"
msgstr "ब्लॉग पोस्ट"

msgid "Page"
msgstr "पेज"

msgid "Custom URL"
msgstr "अनुकूलित URL"

msgid "Banner Image (above content)"
msgstr "बैनर चित्र (सामग्री के ऊपर)"

msgid "Background Image (with overlay)"
msgstr "पृष्ठभूमि चित्र (ओवरले के साथ)"

msgid "Announcement title - supports basic styling (bold, italic, color)"
msgstr "घोषणा का शीर्षक - मूल डिज़ाइन (बोल्ड, इतालवी, रंग) का समर्थन करता है"

msgid "Optional detailed content for modal display"
msgstr "मोडल डिस्प्ले के लिए वैकल्पिक विस्तृत सामग्री"

msgid "Optional image for modal display"
msgstr "मोडल प्रदर्शन के लिए वैकल्पिक चित्र"

msgid "How to display the image in the modal"
msgstr "मोडल में छवि के डिस्प्ले के तरीका"

msgid ""
"Overlay opacity when image is used as background (0 = transparent, 1 = "
"opaque)"
msgstr ""
"जब छवि पृष्ठभूमि के रूप में उपयोग की जाती है तो ओवरले के अपारदर्शिता (0 = अपारदर्शी, 1 = "
"अपारदर्शी)"

msgid "Type of link for this announcement"
msgstr "इस घोषणा के लिए लिंक के प्रकार"

msgid "Product to link to"
msgstr "लिंक करने के लिए उत्पाद"

msgid "Category to link to"
msgstr "लिंक करने के लिए श्रेणी"

msgid "Blog post to link to"
msgstr "लिंक करने के लिए ब्लॉग पोस्ट"

msgid "Page to link to"
msgstr "लिंक करने के लिए पृष्ठ"

msgid "Custom URL for the link"
msgstr "लिंक के लिए अनुकूलित URL"

msgid "Button text for modal link, e.g. \"Shop Now\""
msgstr "मोडल लिंक के लिए बटन टेक्स्ट, उदाहरण के लिए \"Shop Now\""

msgid ""
"If enabled, clicking the announcement opens a modal with full content. If "
"disabled, clicking navigates directly to the link URL."
msgstr ""
"यदि यह चालू है, तो घोषणा के क्लिक करने पर फुल कंटेंट के साथ एक मोडल खोलता है। यदि बंद है, "
"तो क्लिक करने पर तुरंत लिंक URL पर नेविगेट करता है।"

msgid "Enable or disable this announcement"
msgstr "इस अधिसूचना को सक्षम या अक्षम करें"

msgid ""
"Announcement will automatically stop displaying after this date/time. Leave "
"blank for no expiry."
msgstr ""
"इस तारीख / समय के बाद घोषणा स्वत: डिस्प्ले करना बंद कर देगा। अपरिमित के लिए रिक्त छोड़ "
"दें।"

msgid "Lower number = higher priority (displayed first)"
msgstr "कम संख्या = उच्च प्राथमिकता (पहले दिखाया जाता है)"

msgid "Visibility rules for conditional display"
msgstr "शर्ती दिखाई देने के लिए दृश्यता नियम"

msgid "Translations for announcement content"
msgstr "अनुच्छेद के लिए अनुवाद"

msgid "Announcement"
msgstr "अनुच्छेद"

msgid "Edit Announcement"
msgstr "अनुच्छेद संपादित करें"

msgid "Add Announcement"
msgstr "अनुच्छेद जोड़ें"

msgid "Please correct the errors below."
msgstr "कृपया नीचे दिए गए त्रुटियों को सुधारें।"

msgid "Announcement headline — supports bold, italic, and font color."
msgstr "घोषणा का शीर्षक — बोल्ड, इतालवी और फॉन्ट रंग का समर्थन करता है।"

msgid "Body"
msgstr "शरीर"

msgid "Optional detail text shown in the modal popup."
msgstr "मोडल पॉपअप में दिखाए गए वैकल्पिक विस्तार टेक्स्ट।"

msgid "Link Type"
msgstr "लिंक प्रकार"

msgid "Button Text"
msgstr "बटन पाठ"

msgid "E.g. \\"
msgstr "उदाहरण के लिए \""

msgid "Show Modal"
msgstr "मोडल दिखाएं"

msgid "Open details in a popup instead of navigating."
msgstr "नेविगेट के बजाय पॉपअप में विस्तार खोलें।"

msgid "Optional"
msgstr "वैकल्पिक"

msgid ""
"Image for the modal popup. Shown when a visitor clicks the announcement."
msgstr ""
"मोडल पॉपअप के लिए छवि। जब एक योजक घोषणा के क्लिक करता है तो यह दिखाया जाता है।"

msgid "Display Mode"
msgstr "प्रदर्शन मोड"

msgid "Overlay Opacity"
msgstr "ओवरले अपाचिटी"

msgid "0 = transparent, 1 = opaque"
msgstr "0 = अपारदर्शी, 1 = अपारदर्शी"

msgid "Enabled"
msgstr "सक्रिय"

msgid "Priority"
msgstr "अधिकता"

msgid "Lower = shown first"
msgstr "नीचे = पहले दिखाया जाता है"

msgid "Expires At"
msgstr "अवधि समाप्त होती है"

msgid "Leave blank for no expiry."
msgstr "कोई अवधि नहीं होने के लिए खाली छोड़ें।"

msgid "Created"
msgstr "बनाया गया"

msgid "Updated"
msgstr "अपडेट किया गया"

msgid "Advanced"
msgstr "उन्नत"

msgid ""
"Restrict when this announcement is shown. Leave empty to show to everyone."
msgstr ""
"इस घोषणा के दिखाए जाने के समय को सीमित करें। सभी के लिए दिखाए जाने के लिए रिक्त छोड़ दें।"

msgid "Hold Ctrl / Cmd to select multiple."
msgstr "कई का चयन करने के लिए Ctrl / Cmd दबाए रखें।"

msgid "Save"
msgstr "सहेजें"

msgid "Save & Continue"
msgstr "सहेजें और जारी रखें"

msgid "Save & Add Another"
msgstr "सहेजें और एक और जोड़ें"

msgid "Delete"
msgstr "हटाएं"

msgid "Manage store announcements displayed in headers and footers"
msgstr "हेडर और फूटर में दिखाए गए स्टोर घोषणा का प्रबंधन करें"

msgid "All"
msgstr "सभी"

msgid "Disabled"
msgstr "अक्षम"

msgid "Search announcements..."
msgstr "अनुप्रेषण खोजें..."

msgid "announcements"
msgstr "अनुप्रेषण"

msgid "Previous"
msgstr "पिछला"

msgid "of"
msgstr "के"

msgid "Next"
msgstr "अगला"

msgid "No Announcements Found"
msgstr "कोई अनुप्रेषण नहीं मिला"

msgid "No announcements match your search query."
msgstr "आपके खोज प्रश्न के अनुसार कोई घोषणा नहीं मिला।"

msgid ""
"Create your first announcement to display in your store's header or footer."
msgstr "अपनी स्टोर के हेडर या फूटर में दिखाने के लिए अपनी पहली घोषणा बनाएं।"

msgid "Create Announcement"
msgstr "अनुप्रेषण बनाएं"

msgid "Opens modal on click"
msgstr "क्लिक करने पर मोडल खोलें"

msgid "Modal"
msgstr "मोडल"

msgid "Direct link on click"
msgstr "क्लिक करने पर सीधा लिंक"

msgid "Direct Link"
msgstr "सीधा लिंक"

msgid "Last updated"
msgstr "अंतिम अपडेट"

msgid "ago"
msgstr "पहले"

msgid "Expires"
msgstr "मौजूदा तिथि"

msgid "Has Image"
msgstr "छवि है"

msgid "Edit"
msgstr "संपादित करें"
