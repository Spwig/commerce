msgid "Meta Description"
msgstr "Descrizione Meta"

msgid "SEO description for search engines (max 320 characters)."
msgstr "Descrizione SEO per i motori di ricerca (massimo 320 caratteri)."

msgid "Meta Keywords"
msgstr "Parole chiave Meta"

msgid "Comma-separated keywords for SEO."
msgstr "Parole chiave separate da virgola per SEO."

msgid ""
"Open Graph image displayed when this page is shared on social media "
