msgid "Meta Description"
msgstr "Deskripsi Meta"

msgid "SEO description for search engines (max 320 characters)."
msgstr "Deskripsi SEO untuk mesin pencari (maks 320 karakter)."

msgid "Meta Keywords"
msgstr "Kata Kunci Meta"

msgid "Comma-separated keywords for SEO."
msgstr "Kata kunci yang dipisahkan dengan koma untuk SEO."

msgid ""
"Open Graph image displayed when this page is shared on social media "
"(Facebook, LinkedIn, Twitter, etc.). Recommended size: 1200x630 pixels."
msgstr ""
"Gambar Open Graph yang ditampilkan saat halaman ini dibagikan di media "
"sosial (Facebook, LinkedIn, Twitter, dll.). Ukuran yang disarankan: 1200x630"
" piksel."

