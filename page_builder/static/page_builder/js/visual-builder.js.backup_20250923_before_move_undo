        text_shadow: document.getElementById('text-shadow')?.value || existingData.text_shadow || '',
        border_radius: (document.getElementById('border-radius')?.value || existingData.border_radius?.replace('px', '') || '0') + 'px',
        border: document.getElementById('border')?.value || existingData.border || '',
    };
    
    // Update text content
    if (formData.text) {
        textElement.textContent = formData.text;
        // Remove placeholder classes if text is added
        textElement.classList.remove('text-placeholder');
    } else if (textElement.classList.contains('text-placeholder')) {
        // Keep placeholder text if element is still placeholder
        return;
    }
    
    // Apply styles directly to the element
    const styles = {
        fontFamily: formData.font_family,
        fontSize: formData.font_size,
        fontWeight: formData.font_weight,
        lineHeight: formData.line_height,
        letterSpacing: formData.letter_spacing,
        textAlign: formData.text_align,
        textTransform: formData.text_transform,
        textDecoration: formData.text_decoration,
        color: formData.text_color,
        backgroundColor: formData.background_color,
        opacity: formData.opacity,
        paddingTop: formData.padding_top,
        paddingRight: formData.padding_right,
        paddingBottom: formData.padding_bottom,
        paddingLeft: formData.padding_left,
        marginTop: formData.margin_top,
        marginRight: formData.margin_right,
        marginBottom: formData.margin_bottom,
        marginLeft: formData.margin_left,
        maxWidth: formData.max_width,
        textShadow: formData.text_shadow,
        borderRadius: formData.border_radius,
        border: formData.border,
    };
    
    // Apply all styles
    Object.assign(textElement.style, styles);
}

async function refreshElement(elementId) {
    try {
        // Fetch updated element HTML using the correct AJAX endpoint
        const response = await fetch(`/ajax/element/${elementId}/`);
        if (response.ok) {
            const html = await response.text();
            const elementWrapper = document.querySelector(`[data-element-id="${elementId}"]`);
            if (elementWrapper) {
                const elementContent = elementWrapper.querySelector('.element-content');
                if (elementContent) {
                    elementContent.innerHTML = html;
                }
            }
        } else {
            console.error('Failed to refresh element:', response.status, response.statusText);
        }
    } catch (error) {
        console.error('Error refreshing element:', error);
    }
}

// Function to populate text form with existing element data
function populateTextFormWithData(elementData) {
    if (!elementData || !elementData.content) return;
    
    const content = elementData.content;
    
    // Content tab
    const textInput = document.getElementById('element-text');
    if (textInput && content.text) {
        textInput.value = content.text;
    }
    
    const allowHtml = document.getElementById('allow-html');
    if (allowHtml && content.allow_html !== undefined) {
        allowHtml.checked = content.allow_html;
    }
    
    // Typography tab
    const fontFamily = document.getElementById('font-family');
    if (fontFamily && content.font_family) {
        fontFamily.value = content.font_family;
    }
    
    const fontSize = document.getElementById('font-size');
    const fontSizeValue = document.getElementById('font-size-value');
    if (fontSize && content.font_size) {
        const sizeValue = parseInt(content.font_size);
        fontSize.value = sizeValue;
        if (fontSizeValue) fontSizeValue.textContent = sizeValue + 'px';
    }
    
    const fontWeight = document.getElementById('font-weight');
    if (fontWeight && content.font_weight) {
        fontWeight.value = content.font_weight;
    }
    
    const lineHeight = document.getElementById('line-height');
    const lineHeightValue = document.getElementById('line-height-value');
    if (lineHeight && content.line_height) {
        lineHeight.value = content.line_height;
        if (lineHeightValue) lineHeightValue.textContent = content.line_height;
    }
    
    const letterSpacing = document.getElementById('letter-spacing');
    const letterSpacingValue = document.getElementById('letter-spacing-value');
    if (letterSpacing && content.letter_spacing) {
        const spacingValue = parseFloat(content.letter_spacing);
        letterSpacing.value = spacingValue;
        if (letterSpacingValue) letterSpacingValue.textContent = spacingValue + 'px';
    }
    
    const textAlign = document.getElementById('text-align');
    if (textAlign && content.text_align) {
        textAlign.value = content.text_align;
    }
    
    const textTransform = document.getElementById('text-transform');
    if (textTransform && content.text_transform) {
        textTransform.value = content.text_transform;
    }
    
    const textDecoration = document.getElementById('text-decoration');
    if (textDecoration && content.text_decoration) {
        textDecoration.value = content.text_decoration;
    }
    
    // Colors tab
    const textColor = document.getElementById('text-color');
    if (textColor && content.text_color) {
        textColor.value = content.text_color;
    }
    
    const backgroundColor = document.getElementById('background-color');
    const bgTransparent = document.getElementById('bg-transparent');
    if (backgroundColor && bgTransparent) {
        if (content.background_color && content.background_color !== 'transparent') {
            backgroundColor.value = content.background_color;
            bgTransparent.checked = false;
            backgroundColor.disabled = false;
        } else {
            bgTransparent.checked = true;
            backgroundColor.disabled = true;
        }
    }
    
    const opacity = document.getElementById('opacity');
    const opacityValue = document.getElementById('opacity-value');
    if (opacity && content.opacity !== undefined) {
        opacity.value = content.opacity;
        if (opacityValue) opacityValue.textContent = Math.round(content.opacity * 100) + '%';
    }
    
    // Spacing tab
    const spacingInputs = [
        'padding-top', 'padding-right', 'padding-bottom', 'padding-left',
        'margin-top', 'margin-right', 'margin-bottom', 'margin-left'
    ];
    
    spacingInputs.forEach(inputId => {
        const input = document.getElementById(inputId);
        const contentKey = inputId.replace('-', '_');
        if (input && content[contentKey]) {
            // Remove 'px' suffix if present
            const value = content[contentKey].toString().replace('px', '');
            input.value = value;
        }
    });
    
    const maxWidth = document.getElementById('max-width');
    if (maxWidth && content.max_width) {
        maxWidth.value = content.max_width;
    }
    
    // Effects tab
    const textShadow = document.getElementById('text-shadow');
    if (textShadow && content.text_shadow) {
        textShadow.value = content.text_shadow;
    }
    
    const borderRadius = document.getElementById('border-radius');
    const borderRadiusValue = document.getElementById('border-radius-value');
    if (borderRadius && content.border_radius) {
        const radiusValue = parseInt(content.border_radius);
        borderRadius.value = radiusValue;
        if (borderRadiusValue) borderRadiusValue.textContent = radiusValue + 'px';
    }
    
    const border = document.getElementById('border');
    if (border && content.border) {
        border.value = content.border;
    }
    
    // Advanced tab
    const hoverEnabled = document.getElementById('hover-enabled');
    if (hoverEnabled && content.hover_effects) {
        hoverEnabled.checked = !!content.hover_effects;
    }
    
    const hoverColor = document.getElementById('hover-color');
    if (hoverColor && content.hover_color) {
        hoverColor.value = content.hover_color;
    }
    
    const customCss = document.getElementById('custom-css');
    if (customCss && content.custom_classes) {
        customCss.value = content.custom_classes;
    }
}

// Global notification function for use outside the class
function showNotification(message, type = 'info') {
    // Create notification element
    const notification = document.createElement('div');
    notification.className = `notification notification-${type}`;
    notification.innerHTML = `
        <i class="fas fa-${type === 'success' ? 'check' : type === 'error' ? 'exclamation-triangle' : 'info-circle'}"></i>
        <span>${message}</span>
    `;
    
    // Style the notification
    notification.style.cssText = `
        position: fixed;
        top: 20px;
        right: 20px;
        background: ${type === 'success' ? '#10b981' : type === 'error' ? '#ef4444' : '#3b82f6'};
        color: white;
        padding: 12px 16px;
        border-radius: 6px;
        z-index: 10000;
        display: flex;
        align-items: center;
        gap: 8px;
        box-shadow: 0 4px 6px rgba(0, 0, 0, 0.1);
        animation: slideIn 0.3s ease-out;
    `;
    
    // Add CSS for animation
    if (!document.getElementById('notification-styles')) {
        const styles = document.createElement('style');
        styles.id = 'notification-styles';
        styles.textContent = `
            @keyframes slideIn {
                from { transform: translateX(100%); opacity: 0; }
                to { transform: translateX(0); opacity: 1; }
            }
        `;
        document.head.appendChild(styles);
    }
    
    // Add to page
    document.body.appendChild(notification);
    
    // Remove after 3 seconds
    setTimeout(() => {
        if (notification.parentNode) {
            notification.parentNode.removeChild(notification);
        }
    }, 3000);
}

