        // Effects
        'box_shadow': 'boxShadow',
        'boxShadow': 'boxShadow',
        'box-shadow': 'boxShadow',
        'text_shadow': 'textShadow',
        'textShadow': 'textShadow',
        'text-shadow': 'textShadow',

        // Layout
        'width': 'width',
        'height': 'height',
        'min_width': 'minWidth',
        'minWidth': 'minWidth',
        'min-width': 'minWidth',
        'max_width': 'maxWidth',
        'maxWidth': 'maxWidth',
