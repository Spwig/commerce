                        } else if (config.direction === 'row') {
                            // Rows should span full width
                            wrapperStyle = 'width: 100%;';
                        } else if (config.flex) {
                            // Custom flex value if specified
                            wrapperStyle = `flex: ${config.flex};`;
                        } else {
                            // Default to full width
