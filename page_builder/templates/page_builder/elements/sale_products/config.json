{
  "element_type": "sale_products",
  "name": "Sale Products",
  "version": "1.0.1",
  "category": "ecommerce",
  "icon": "fas fa-percentage",
  "description": "Showcase products on sale with discount highlights",
  "inherit_base": true,
  "css_files": ["page_builder/css/elements/sale-products.css"],
  "tabs": {
    "content": {
      "label": "Content",
      "icon": "fas fa-edit",
      "order": 1,
      "properties": {
        "source_group": {
          "type": "property_group",
          "label": "Sale Source",
          "columns": 1,
          "properties": {
            "data_source": {
              "type": "select",
              "label": "Data Source",
              "default": "dynamic",
              "options": [
                {
                  "value": "dynamic",
                  "label": "Live from store"
                },
                {
                  "value": "static",
                  "label": "Manual content"
                }
              ]
            },
            "source_type": {
              "type": "select",
              "label": "Sale Source",
              "default": "all_on_sale",
              "options": [
                {
                  "value": "all_on_sale",
                  "label": "All Products On Sale"
                },
                {
                  "value": "promotion",
                  "label": "Specific Promotion"
                },
                {
                  "value": "min_discount",
                  "label": "Minimum Discount %"
                },
                {
                  "value": "ending_soon",
                  "label": "Sales Ending Soon"
                }
              ],
              "show_if": {
                "data_source": "dynamic"
              }
            },
            "promotion_id": {
              "type": "number",
              "label": "Promotion ID",
              "default": null,
              "show_if": {
                "source_type": "promotion"
              }
            },
            "min_discount": {
              "type": "number",
              "label": "Minimum Discount (%)",
              "default": 10,
              "min": 1,
              "max": 90,
              "show_if": {
                "source_type": "min_discount"
              }
            },
            "max_products": {
              "type": "number",
              "label": "Maximum Products",
              "default": 8,
              "min": 2,
              "max": 24
            }
          }
        },
        "static_products_group": {
          "type": "property_group",
          "label": "Static Products",
          "columns": 1,
          "show_if": {
            "data_source": "static"
          },
          "properties": {
            "products": {
              "type": "array",
              "label": "Static Products",
              "full_width": true,
              "item_type": "object",
              "item_properties": {
                "name": {
                  "type": "string",
                  "label": "Product Name"
                },
                "image": {
                  "type": "image",
                  "label": "Product Image"
                },
                "url": {
                  "type": "url",
                  "label": "Product URL",
                  "link_selector": true
                },
                "original_price": {
                  "type": "string",
                  "label": "Original Price"
                },
                "sale_price": {
                  "type": "string",
                  "label": "Sale Price"
                },
                "discount_percent": {
                  "type": "number",
                  "label": "Discount %"
                },
                "ends_at": {
                  "type": "string",
                  "label": "Sale Ends (ISO date)"
                }
              }
            }
          }
        }
      }
    },
    "display": {
      "label": "Display",
      "icon": "fas fa-eye",
      "order": 2,
      "properties": {
        "visibility_group": {
          "type": "property_group",
          "label": "Show/Hide Elements",
          "properties": {
            "show_discount_badge": {
              "type": "boolean",
              "label": "Show Discount Badge",
              "default": true
            },
            "show_original_price": {
              "type": "boolean",
              "label": "Show Original Price",
              "default": true
            },
            "show_savings": {
              "type": "boolean",
              "label": "Show Savings Amount",
              "default": false
            },
            "show_countdown": {
              "type": "boolean",
              "label": "Show Sale Countdown",
              "default": false
            }
          }
        }
      }
    },
    "layout": {
      "label": "Layout",
      "icon": "fas fa-th-large",
      "order": 3,
      "properties": {
        "layout_group": {
          "type": "property_group",
          "label": "Layout",
          "properties": {
            "layout": {
              "type": "select",
              "label": "Layout",
              "default": "grid",
              "options": [
                {
                  "value": "grid",
                  "label": "Grid"
                },
                {
                  "value": "carousel",
                  "label": "Carousel"
                }
              ]
            },
            "columns": {
              "type": "select",
              "label": "Columns",
              "default": "4",
              "options": [
                {
                  "value": "2",
                  "label": "2 Columns"
                },
                {
                  "value": "3",
                  "label": "3 Columns"
                },
                {
                  "value": "4",
                  "label": "4 Columns"
                },
                {
                  "value": "5",
                  "label": "5 Columns"
                }
              ],
              "show_if": {
                "layout": "grid"
              }
            }
          }
        }
      }
    },
    "header": {
      "label": "Header",
      "icon": "fas fa-heading",
      "order": 4,
      "properties": {
        "header_group": {
          "type": "property_group",
          "label": "Section Header",
          "columns": 1,
          "properties": {
            "title": {
              "type": "string",
              "label": "Section Title",
              "default": "On Sale Now",
              "translatable": true
            },
            "subtitle": {
              "type": "string",
              "label": "Section Subtitle",
              "default": "Don't miss these deals",
              "translatable": true
            }
          }
        },
        "badge_group": {
          "type": "property_group",
          "label": "Discount Badge",
          "properties": {
            "badge_style": {
              "type": "select",
              "label": "Discount Badge Style",
              "default": "ribbon",
              "options": [
                {
                  "value": "ribbon",
                  "label": "Ribbon"
                },
                {
                  "value": "circle",
                  "label": "Circle"
                },
                {
                  "value": "tag",
                  "label": "Tag"
                },
                {
                  "value": "minimal",
                  "label": "Minimal"
                }
              ]
            },
            "badge_color": {
              "type": "color",
              "label": "Badge Color",
              "default": "#ef4444"
            }
          }
        }
      }
    }
  },
  "properties": {
    "data_source": {
      "type": "select",
      "label": "Data Source",
      "default": "dynamic"
    },
    "source_type": {
      "type": "select",
      "label": "Sale Source",
      "default": "all_on_sale"
    },
    "promotion_id": {
      "type": "number",
      "label": "Promotion ID",
      "default": null
    },
    "min_discount": {
      "type": "number",
      "label": "Minimum Discount (%)",
      "default": 10,
      "min": 1,
      "max": 90
    },
    "max_products": {
      "type": "number",
      "label": "Maximum Products",
      "default": 8,
      "min": 2,
      "max": 24
    },
    "products": {
      "type": "array",
      "label": "Static Products",
      "item_type": "object"
    },
    "show_discount_badge": {
      "type": "boolean",
      "label": "Show Discount Badge",
      "default": true
    },
    "show_original_price": {
      "type": "boolean",
      "label": "Show Original Price",
      "default": true
    },
    "show_savings": {
      "type": "boolean",
      "label": "Show Savings Amount",
      "default": false
    },
    "show_countdown": {
      "type": "boolean",
      "label": "Show Sale Countdown",
      "default": false
    },
    "layout": {
      "type": "select",
      "label": "Layout",
      "default": "grid"
    },
    "columns": {
      "type": "select",
      "label": "Columns",
      "default": "4"
    },
    "title": {
      "type": "string",
      "label": "Section Title",
      "default": "On Sale Now",
      "translatable": true
    },
    "subtitle": {
      "type": "string",
      "label": "Section Subtitle",
      "default": "Don't miss these deals",
      "translatable": true
    },
    "badge_style": {
      "type": "select",
      "label": "Discount Badge Style",
      "default": "ribbon"
    },
    "badge_color": {
      "type": "color",
      "label": "Badge Color",
      "default": "#ef4444"
    }
  },
  "scripts": ["/static/page_builder/js/elements/sale-products.js"],
  "translations": {
