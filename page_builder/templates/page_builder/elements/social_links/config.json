  },
  "defaults": {
    "platforms": [
      {"platform": "facebook", "url": ""},
      {"platform": "twitter", "url": ""},
      {"platform": "instagram", "url": ""}
    ],
    "style": "icons",
    "size": "md",
    "color_scheme": "brand",
    "alignment": "center",
    "gap": 12
  }
