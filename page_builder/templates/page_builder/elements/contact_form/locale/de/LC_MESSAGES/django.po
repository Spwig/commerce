#: page_builder/templates/page_builder/elements/contact_form/template.html:13
msgid "Contact Us"
msgstr "Kontaktieren Sie uns"

#: page_builder/templates/page_builder/elements/contact_form/template.html:19
msgid "Get in touch with us. We'd love to hear from you."
msgstr "Kontaktieren Sie uns. Wir freuen uns auf Ihre Nachricht."

#: page_builder/templates/page_builder/elements/contact_form/template.html:33
msgid "First Name"
msgstr "Vorname"

#: page_builder/templates/page_builder/elements/contact_form/template.html:41
msgid "Enter your first name"
msgstr "Geben Sie Ihren Vornamen ein"

#: page_builder/templates/page_builder/elements/contact_form/template.html:48
msgid "Last Name"
msgstr "Nachname"

#: page_builder/templates/page_builder/elements/contact_form/template.html:56
msgid "Enter your last name"
msgstr "Geben Sie Ihren Nachnamen ein"

#: page_builder/templates/page_builder/elements/contact_form/template.html:65
msgid "Email Address"
msgstr "E-Mail-Adresse"

#: page_builder/templates/page_builder/elements/contact_form/template.html:73
msgid "Enter your email address"
msgstr "Geben Sie Ihre E-Mail-Adresse ein"

#: page_builder/templates/page_builder/elements/contact_form/template.html:79
msgid "Phone Number"
msgstr "Telefonnummer"

#: page_builder/templates/page_builder/elements/contact_form/template.html:87
msgid "Enter your phone number"
msgstr "Geben Sie Ihre Telefonnummer ein"

#: page_builder/templates/page_builder/elements/contact_form/template.html:96
msgid "Subject"
msgstr "Betreff"

#: page_builder/templates/page_builder/elements/contact_form/template.html:104
msgid "What is this regarding?"
msgstr "Worum geht es hier?"

#: page_builder/templates/page_builder/elements/contact_form/template.html:111
msgid "Message"
msgstr "Nachricht"

#: page_builder/templates/page_builder/elements/contact_form/template.html:119
msgid "Tell us how we can help you..."
msgstr "Erzählen Sie uns, wie wir Ihnen helfen können..."

#: page_builder/templates/page_builder/elements/contact_form/template.html:134
msgid "I agree to the"
msgstr "Ich stimme den"

#: page_builder/templates/page_builder/elements/contact_form/template.html:137
msgid "Privacy Policy"
msgstr "Datenschutzrichtlinie"

#: page_builder/templates/page_builder/elements/contact_form/template.html:138
msgid "and"
msgstr "und"

#: page_builder/templates/page_builder/elements/contact_form/template.html:141
msgid "Terms of Service"
msgstr "Nutzungsbedingungen zu"

#: page_builder/templates/page_builder/elements/contact_form/template.html:154
msgid "Send Message"
msgstr "Nachricht senden"

#: page_builder/templates/page_builder/elements/contact_form/template.html:164
msgid "Thank you for your message! We'll get back to you soon."
msgstr "Vielen Dank für Ihre Nachricht! Wir melden uns bald bei Ihnen."

#: page_builder/templates/page_builder/elements/contact_form/template.html:174
msgid "Sorry, there was an error sending your message. Please try again."
msgstr ""
"Es tut uns leid, bei der Übermittlung Ihrer Nachricht ist ein Fehler "
"aufgetreten. Bitte versuchen Sie es erneut."
