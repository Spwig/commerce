      "type": "select",
      "label": "Step Transition",
      "options": [
        {
          "value": "slide",
          "label": "Slide"
        },
        {
          "value": "fade",
          "label": "Fade"
        },
        {
          "value": "instant",
          "label": "Instant"
        }
      ],
      "default": "slide"
