    "field_style": {
      "type": "select",
      "label": "Field Style",
      "options": [
        {
          "value": "outlined",
          "label": "Outlined"
        },
        {
          "value": "filled",
          "label": "Filled"
        },
        {
          "value": "underlined",
          "label": "Underlined"
        }
      ],
      "default": "outlined"
    },
    "label_position": {
      "type": "select",
      "label": "Label Position",
      "options": [
        {
          "value": "above",
          "label": "Above"
        },
        {
          "value": "floating",
          "label": "Floating"
        },
        {
          "value": "inline",
