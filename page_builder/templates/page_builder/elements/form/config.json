        },
        {
          "value": "secondary",
          "label": "Secondary"
        },
        {
          "value": "outline",
          "label": "Outline"
        }
      ],
      "default": "primary"
    },
    "success_action": {
      "type": "select",
      "label": "Success Action",
      "options": [
        {
          "value": "message",
          "label": "Show Message"
        },
        {
          "value": "redirect",
          "label": "Redirect"
        },
        {
          "value": "replace",
          "label": "Replace Form"
        }
      ],
      "default": "replace"
