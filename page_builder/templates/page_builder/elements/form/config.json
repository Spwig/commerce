    }
  },
  "defaults": {
    "title": "Custom Form",
    "description": "Fill out this form",
    "fields": [
      {
        "type": "text",
        "name": "sample_field",
        "label": "Sample Field",
        "required": true
      }
    ],
    "button_text": "Submit"
  }
}
