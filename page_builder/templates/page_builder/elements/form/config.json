    },
    "title_shadow": {
      "type": "shadow",
      "label": "Title Shadow",
      "utility": "shadow_editor",
      "shadow_type": "text"
    },
    "description_typography": {
      "type": "typography",
      "label": "Description Typography",
      "utility": "typography_editor"
    },
    "description_color": {
      "type": "color_advanced",
      "label": "Description Color",
      "utility": "color_picker"
    },
    "description_shadow": {
      "type": "shadow",
      "label": "Description Shadow",
      "utility": "shadow_editor",
      "shadow_type": "text"
    },
    "step_indicator_style": {
      "type": "select",
