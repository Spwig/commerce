{
  "element_type": "image_accordion",
  "name": "Image Accordion",
  "description": "Interactive horizontal accordion with expandable image frames and optional content overlays",
  "version": "1.0.0",
  "category": "media",
  "icon": "fas fa-layer-group",
  "author": "Spwig",
  "element_builder_primitive": false,
  "tags": ["accordion", "gallery", "images", "interactive", "hover"],
  "supports_translation": true,
  "translation_domain": "image_accordion_element",
  "template_file": "template.html",
  "inherit_base": true,
  "css_files": ["page_builder/css/elements/image-accordion.css"],
  "disable_base_properties": ["text_color", "typography"],
  "tabs": {
    "basic": {
      "label": "Frames",
      "icon": "fas fa-images",
      "order": 1,
      "properties": {
        "frames_group": {
          "type": "property_group",
          "label": "Accordion Frames",
          "columns": 1,
          "properties": {
            "frames": {
              "type": "array",
              "label": "Frames",
              "full_width": true,
              "help_text": "Add image frames to the accordion. Each frame can have its own background image and optional content overlay.",
              "item_schema": {
                "type": "object",
                "properties": {
                  "image": {
                    "type": "image",
                    "label": "Background Image",
                    "required": true
                  },
                  "image_position": {
                    "type": "select",
                    "label": "Image Position",
                    "options": [
                      { "value": "center", "label": "Center" },
                      { "value": "top", "label": "Top" },
                      { "value": "bottom", "label": "Bottom" },
                      { "value": "left", "label": "Left" },
                      { "value": "right", "label": "Right" }
                    ],
                    "default": "center"
                  },
                  "link_url": {
                    "type": "url",
                    "label": "Link URL",
                    "link_selector": true,
                    "help_text": "Make the entire frame clickable (used when no button is set)"
                  },
                  "link_target": {
                    "type": "select",
                    "label": "Open In",
                    "options": [
                      { "value": "_self", "label": "Same Window" },
                      { "value": "_blank", "label": "New Window" }
                    ],
                    "default": "_self"
                  },
                  "show_content": {
                    "type": "boolean",
                    "label": "Show Content Overlay",
                    "default": true
                  },
                  "title": {
                    "type": "string",
                    "label": "Title",
                    "translatable": true
                  },
                  "subtitle": {
                    "type": "string",
                    "label": "Subtitle",
                    "translatable": true
                  },
                  "button_text": {
                    "type": "string",
                    "label": "Button Text",
                    "translatable": true
                  },
                  "button_url": {
                    "type": "url",
                    "label": "Button URL",
                    "link_selector": true
                  },
                  "overlay_color": {
                    "type": "color",
                    "label": "Overlay Color",
                    "default": "#000000"
                  },
                  "overlay_opacity": {
                    "type": "range",
                    "label": "Overlay Opacity",
                    "min": 0,
                    "max": 1,
                    "step": 0.1,
                    "default": 0.4
                  },
                  "overlay_style_override": {
                    "type": "select",
                    "label": "Override Style",
                    "help_text": "Override the global overlay style for this frame only",
                    "options": [
                      { "value": "", "label": "Use Global Style" },
                      { "value": "hero-bold", "label": "Hero Bold" },
                      { "value": "bottom-left", "label": "Bottom Left" },
                      { "value": "bottom-right", "label": "Bottom Right" },
                      { "value": "center-left", "label": "Center Left" },
                      { "value": "center-right", "label": "Center Right" },
                      { "value": "center-center", "label": "Center" },
                      { "value": "top-left", "label": "Top Left" },
                      { "value": "card", "label": "Card" },
                      { "value": "minimal", "label": "Minimal" }
                    ],
                    "default": ""
                  }
                }
              },
              "default": [
                {
                  "image": "",
                  "image_position": "center",
                  "show_content": true,
                  "title": "Frame One",
                  "subtitle": "Discover more",
                  "overlay_color": "#000000",
                  "overlay_opacity": 0.4
                },
                {
                  "image": "",
                  "image_position": "center",
                  "show_content": true,
                  "title": "Frame Two",
                  "subtitle": "Learn more",
                  "overlay_color": "#000000",
                  "overlay_opacity": 0.4
                },
                {
                  "image": "",
                  "image_position": "center",
                  "show_content": true,
                  "title": "Frame Three",
                  "subtitle": "Explore",
                  "overlay_color": "#000000",
                  "overlay_opacity": 0.4
                }
              ]
            }
          }
        }
      }
    },
    "layout": {
      "label": "Layout",
      "icon": "fas fa-th-large",
      "order": 2,
      "properties": {
        "sizing_group": {
          "type": "property_group",
          "label": "Sizing",
          "properties": {
            "height": {
              "type": "select",
              "label": "Accordion Height",
              "options": [
                { "value": "sm", "label": "Small (300px)" },
                { "value": "md", "label": "Medium (450px)" },
                { "value": "lg", "label": "Large (600px)" },
                { "value": "xl", "label": "Extra Large (750px)" },
                { "value": "screen", "label": "Full Screen" }
              ],
              "default": "lg"
            },
            "gap": {
              "type": "select",
              "label": "Gap Between Frames",
              "options": [
                { "value": "0", "label": "None" },
                { "value": "2", "label": "Small (0.5rem)" },
                { "value": "4", "label": "Medium (1rem)" },
                { "value": "6", "label": "Large (1.5rem)" }
              ],
              "default": "4"
            }
          }
        },
        "expand_group": {
          "type": "property_group",
          "label": "Expansion Settings",
          "properties": {
            "default_expanded": {
              "type": "select",
              "label": "Default Expanded Frame",
              "options": [
                { "value": "none", "label": "None (Equal Width)" },
                { "value": "first", "label": "First Frame" },
                { "value": "last", "label": "Last Frame" },
                { "value": "specific", "label": "Specific Frame..." }
              ],
              "default": "none",
              "help_text": "Which frame is expanded when not hovering",
              "requires_rerender": true
            },
            "expanded_frame_index": {
              "type": "number",
              "label": "Frame Number to Expand",
              "default": 1,
              "min": 1,
              "help_text": "Which frame to expand (1 = first, 2 = second, etc.)",
              "requires_rerender": true,
              "show_when": { "property": "default_expanded", "value": "specific" }
            },
            "expand_ratio": {
              "type": "select",
              "label": "Expansion Ratio",
              "options": [
                { "value": "2", "label": "2x (Moderate)" },
                { "value": "3", "label": "3x (Standard)" },
                { "value": "4", "label": "4x (Dramatic)" },
                { "value": "5", "label": "5x (Maximum)" }
              ],
              "default": "3",
              "help_text": "How much the hovered frame expands relative to others"
            }
          }
        },
        "overlay_style_group": {
          "type": "property_group",
          "label": "Overlay Style",
          "columns": 1,
          "properties": {
            "overlay_style": {
              "type": "select",
              "label": "Content Style",
              "help_text": "Choose a predefined overlay layout style for all frames",
              "options": [
                { "value": "hero-bold", "label": "Hero Bold - Large dramatic title, left aligned" },
                { "value": "bottom-left", "label": "Bottom Left - Clean minimal corner placement" },
                { "value": "bottom-right", "label": "Bottom Right - Subtle right corner" },
                {
                  "value": "center-left",
                  "label": "Center Left - Vertically centered, left aligned"
                },
                {
                  "value": "center-right",
                  "label": "Center Right - Vertically centered, right aligned"
                },
                { "value": "center-center", "label": "Center - Fully centered content" },
                { "value": "top-left", "label": "Top Left - Upper corner placement" },
                { "value": "card", "label": "Card - Content in semi-transparent box" },
                { "value": "minimal", "label": "Minimal - Title only, ultra clean" },
                { "value": "custom", "label": "Custom - Manual alignment settings" }
              ],
              "default": "bottom-left"
            },
            "content_align_v": {
              "type": "select",
              "label": "Vertical Alignment",
              "options": [
                { "value": "top", "label": "Top" },
                { "value": "center", "label": "Center" },
                { "value": "bottom", "label": "Bottom" }
              ],
              "default": "bottom",
              "show_when": { "property": "overlay_style", "value": "custom" }
            },
            "content_align_h": {
              "type": "select",
              "label": "Horizontal Alignment",
              "options": [
                { "value": "left", "label": "Left" },
                { "value": "center", "label": "Center" },
                { "value": "right", "label": "Right" }
              ],
              "default": "left",
              "show_when": { "property": "overlay_style", "value": "custom" }
            },
            "content_padding": {
              "type": "select",
              "label": "Content Padding",
              "options": [
                { "value": "4", "label": "Small" },
                { "value": "6", "label": "Medium" },
                { "value": "8", "label": "Large" },
                { "value": "12", "label": "Extra Large" }
              ],
              "default": "6",
              "show_when": { "property": "overlay_style", "value": "custom" }
            }
          }
        }
      }
    },
    "animation": {
      "label": "Animation",
      "icon": "fas fa-magic",
      "order": 3,
      "properties": {
        "transition_group": {
          "type": "property_group",
          "label": "Transition Settings",
          "properties": {
            "transition_duration": {
              "type": "select",
              "label": "Transition Duration",
              "options": [
                { "value": "200", "label": "Fast (200ms)" },
                { "value": "300", "label": "Normal (300ms)" },
                { "value": "500", "label": "Slow (500ms)" },
                { "value": "700", "label": "Very Slow (700ms)" }
              ],
              "default": "300"
            },
            "transition_timing": {
              "type": "select",
              "label": "Easing Function",
              "options": [
                { "value": "ease", "label": "Ease" },
                { "value": "ease-in-out", "label": "Ease In Out" },
                { "value": "ease-out", "label": "Ease Out" },
                { "value": "cubic-bezier(0.4, 0, 0.2, 1)", "label": "Smooth (Material)" }
              ],
              "default": "cubic-bezier(0.4, 0, 0.2, 1)"
            }
          }
        },
        "content_animation_group": {
          "type": "property_group",
          "label": "Content Animation",
          "properties": {
            "content_fade": {
              "type": "boolean",
              "label": "Fade Content on Collapse",
              "default": true,
              "help_text": "Hide content when frame is collapsed"
            },
            "content_slide": {
              "type": "boolean",
              "label": "Slide Content on Expand",
              "default": true,
              "help_text": "Animate content sliding in when frame expands"
            }
          }
        }
      }
    },
    "typography": {
      "label": "Typography",
      "icon": "fas fa-font",
      "order": 4,
      "properties": {
        "title_style_group": {
          "type": "property_group",
          "label": "Title Style",
          "properties": {
            "title_size": {
              "type": "select",
              "label": "Title Size",
              "options": [
                { "value": "lg", "label": "Large" },
                { "value": "xl", "label": "Extra Large" },
                { "value": "2xl", "label": "2X Large" },
                { "value": "3xl", "label": "3X Large" }
              ],
              "default": "2xl"
            },
            "title_color": {
              "type": "color_advanced",
              "label": "Title Color",
              "utility": "color_picker",
              "default": "#ffffff"
            }
          }
        },
        "subtitle_style_group": {
          "type": "property_group",
          "label": "Subtitle Style",
          "properties": {
            "subtitle_size": {
              "type": "select",
              "label": "Subtitle Size",
              "options": [
                { "value": "sm", "label": "Small" },
                { "value": "base", "label": "Medium" },
                { "value": "lg", "label": "Large" }
              ],
              "default": "base"
            },
            "subtitle_color": {
              "type": "color_advanced",
              "label": "Subtitle Color",
              "utility": "color_picker",
              "default": "rgba(255, 255, 255, 0.85)"
            }
          }
        },
        "button_style_group": {
          "type": "property_group",
          "label": "Button Style",
          "properties": {
            "button_style": {
              "type": "select",
              "label": "Button Style",
              "options": [
                { "value": "solid", "label": "Solid" },
                { "value": "outline", "label": "Outline" },
                { "value": "ghost", "label": "Ghost" }
              ],
              "default": "solid"
            },
            "button_size": {
              "type": "select",
              "label": "Button Size",
              "options": [
                { "value": "sm", "label": "Small" },
                { "value": "md", "label": "Medium" },
                { "value": "lg", "label": "Large" }
              ],
              "default": "md"
            }
          }
        }
      }
    },
    "responsive": {
      "label": "Responsive",
      "icon": "fas fa-mobile-alt",
      "order": 5,
      "properties": {
        "mobile_group": {
          "type": "property_group",
          "label": "Mobile Behavior",
          "columns": 1,
          "properties": {
            "mobile_layout": {
              "type": "select",
              "label": "Mobile Layout",
              "options": [
                { "value": "stack", "label": "Stack Vertically" },
                { "value": "carousel", "label": "Horizontal Scroll" },
                { "value": "collapse", "label": "Collapse to Grid" }
              ],
              "default": "stack",
              "help_text": "How the accordion behaves on mobile devices"
            },
            "mobile_height": {
              "type": "select",
              "label": "Mobile Frame Height",
              "options": [
                { "value": "200", "label": "Small (200px)" },
                { "value": "250", "label": "Medium (250px)" },
                { "value": "300", "label": "Large (300px)" },
                { "value": "auto", "label": "Auto (16:9 ratio)" }
              ],
              "default": "250"
            }
          }
        }
      }
    }
  },
  "properties": {
    "frames": {
      "type": "array",
      "label": "Frames",
      "item_schema": {
        "type": "object",
        "properties": {
          "image": { "type": "image", "label": "Background Image" },
          "image_position": { "type": "select", "label": "Image Position", "default": "center" },
          "link_url": { "type": "url", "label": "Link URL" },
          "link_target": { "type": "select", "label": "Open In", "default": "_self" },
          "show_content": { "type": "boolean", "label": "Show Content Overlay", "default": true },
          "title": { "type": "string", "label": "Title", "translatable": true },
          "subtitle": { "type": "string", "label": "Subtitle", "translatable": true },
          "button_text": { "type": "string", "label": "Button Text", "translatable": true },
          "button_url": { "type": "url", "label": "Button URL" },
          "overlay_color": { "type": "color", "label": "Overlay Color", "default": "#000000" },
          "overlay_opacity": { "type": "range", "label": "Overlay Opacity", "default": 0.4 }
        }
      }
    },
    "height": { "type": "select", "label": "Accordion Height", "default": "lg" },
    "gap": { "type": "select", "label": "Gap Between Frames", "default": "4" },
    "default_expanded": { "type": "select", "label": "Default Expanded Frame", "default": "none" },
    "expand_ratio": { "type": "select", "label": "Expansion Ratio", "default": "3" },
    "overlay_style": { "type": "select", "label": "Content Style", "default": "bottom-left" },
    "content_align_v": { "type": "select", "label": "Vertical Alignment", "default": "bottom" },
    "content_align_h": { "type": "select", "label": "Horizontal Alignment", "default": "left" },
    "content_padding": { "type": "select", "label": "Content Padding", "default": "6" },
    "transition_duration": { "type": "select", "label": "Transition Duration", "default": "300" },
    "transition_timing": {
      "type": "select",
      "label": "Easing Function",
      "default": "cubic-bezier(0.4, 0, 0.2, 1)"
    },
    "content_fade": { "type": "boolean", "label": "Fade Content on Collapse", "default": true },
    "content_slide": { "type": "boolean", "label": "Slide Content on Expand", "default": true },
    "title_size": { "type": "select", "label": "Title Size", "default": "2xl" },
    "title_color": { "type": "color_advanced", "label": "Title Color", "default": "#ffffff" },
    "subtitle_size": { "type": "select", "label": "Subtitle Size", "default": "base" },
    "subtitle_color": {
      "type": "color_advanced",
      "label": "Subtitle Color",
      "default": "rgba(255, 255, 255, 0.85)"
    },
    "button_style": { "type": "select", "label": "Button Style", "default": "solid" },
    "button_size": { "type": "select", "label": "Button Size", "default": "md" },
    "mobile_layout": { "type": "select", "label": "Mobile Layout", "default": "stack" },
    "mobile_height": { "type": "select", "label": "Mobile Frame Height", "default": "250" }
  },
  "translations": {
    "en": {
      "name": "Image Accordion",
      "description": "Interactive horizontal accordion with expandable image frames and optional content overlays"
    },
    "es": {
      "name": "Acordeon de Imagenes",
      "description": "Acordeon horizontal interactivo con marcos de imagen expandibles y superposiciones de contenido opcionales"
    },
    "fr": {
      "name": "Accordeon d'Images",
      "description": "Accordeon horizontal interactif avec des cadres d'images extensibles et des superpositions de contenu optionnelles"
    },
    "de": {
      "name": "Bild-Akkordeon",
      "description": "Interaktives horizontales Akkordeon mit erweiterbaren Bildrahmen und optionalen Inhalts-Overlays"
    },
    "pt": {
      "name": "Acordeao de Imagens",
      "description": "Acordeao horizontal interativo com molduras de imagem expansiveis e sobreposicoes de conteudo opcionais"
    },
    "zh-hans": {
      "name": "Image Accordion",
      "description": "Interactive horizontal accordion with expandable image frames"
    },
    "ja": {
      "name": "Image Accordion",
      "description": "Interactive horizontal accordion with expandable image frames"
    },
    "ar": {
      "name": "Image Accordion",
      "description": "Interactive horizontal accordion with expandable image frames"
    }
  },
  "defaults": {
    "height": "lg",
    "gap": "4",
    "default_expanded": "first",
    "expand_ratio": "3",
    "overlay_style": "bottom-left",
    "transition_duration": "300",
    "transition_timing": "cubic-bezier(0.4, 0, 0.2, 1)",
    "content_fade": true,
    "content_slide": true,
    "mobile_layout": "stack",
    "mobile_height": "250",
    "frames": [
      {
        "image": "",
        "image_position": "center",
        "show_content": true,
        "title": "Frame One",
        "subtitle": "Discover more",
        "overlay_color": "#000000",
        "overlay_opacity": 0.4
      },
      {
        "image": "",
        "image_position": "center",
        "show_content": true,
        "title": "Frame Two",
        "subtitle": "Learn more",
        "overlay_color": "#000000",
        "overlay_opacity": 0.4
      },
      {
        "image": "",
        "image_position": "center",
        "show_content": true,
        "title": "Frame Three",
        "subtitle": "Explore",
        "overlay_color": "#000000",
        "overlay_opacity": 0.4
      }
    ]
  }
}
