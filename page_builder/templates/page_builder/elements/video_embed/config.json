{
  "element_type": "video_embed",
  "name": "Video Embed",
  "description": "Embed videos from YouTube, Vimeo, or self-hosted sources",
  "version": "1.0.1",
  "category": "media",
  "icon": "fas fa-video",
  "author": "Page Builder System",
  "element_builder_primitive": true,
  "tags": ["video", "youtube", "vimeo", "embed", "media", "player"],
  "supports_translation": true,
  "translation_domain": "video_embed_element",
  "template_file": "template.html",
  "inherit_base": true,
  "css_files": ["page_builder/css/elements/video-embed.css"],
  "scripts": [
    "/static/page_builder/js/elements/video-embed.js"
  ],
  "disable_base_properties": ["text_color"],
  "tabs": {
    "basic": {
      "label": "Video",
      "icon": "fas fa-video",
      "order": 1,
      "properties": {
        "source_group": {
          "type": "property_group",
          "label": "Video Source",
          "columns": 1,
          "properties": {
            "source_type": {
              "type": "select",
              "label": "Video Source",
              "options": [
                {"value": "youtube", "label": "YouTube"},
                {"value": "vimeo", "label": "Vimeo"},
                {"value": "self_hosted", "label": "Self-Hosted / URL"}
              ],
              "default": "youtube"
            },
            "youtube_url": {
              "type": "url",
              "label": "YouTube URL",
              "help_text": "Paste a YouTube video URL (e.g., https://www.youtube.com/watch?v=...)",
              "show_if": {"source_type": "youtube"}
            },
            "vimeo_url": {
              "type": "url",
              "label": "Vimeo URL",
              "help_text": "Paste a Vimeo video URL (e.g., https://vimeo.com/...)",
              "show_if": {"source_type": "vimeo"}
            },
            "video_url": {
              "type": "url",
              "label": "Video URL",
              "help_text": "Direct URL to video file (MP4, WebM, etc.)",
              "show_if": {"source_type": "self_hosted"}
            },
            "poster_image": {
              "type": "image",
              "label": "Poster Image",
              "help_text": "Thumbnail image shown before video plays",
              "show_if": {"source_type": "self_hosted"}
            }
          }
        },
        "title_group": {
          "type": "property_group",
          "label": "Accessibility",
          "columns": 1,
          "properties": {
            "title": {
              "type": "string",
              "label": "Video Title",
              "default": "",
              "translatable": true,
              "help_text": "Accessible title for the video"
            }
          }
        }
      }
    },
    "playback": {
      "label": "Playback",
      "icon": "fas fa-play-circle",
      "order": 2,
      "properties": {
        "autoplay_group": {
          "type": "property_group",
          "label": "Autoplay & Sound",
          "properties": {
            "autoplay": {
              "type": "boolean",
              "label": "Autoplay",
              "default": false,
              "help_text": "Start playing automatically (muted by default for autoplay)"
            },
            "muted": {
              "type": "boolean",
              "label": "Muted",
              "default": false,
              "help_text": "Start with audio muted"
            },
            "loop": {
              "type": "boolean",
              "label": "Loop",
              "default": false,
              "help_text": "Repeat video when finished"
            }
          }
        },
        "controls_group": {
          "type": "property_group",
          "label": "Controls & Behavior",
          "properties": {
            "controls": {
              "type": "boolean",
              "label": "Show Controls",
              "default": true,
              "help_text": "Display video player controls"
            },
            "start_time": {
              "type": "number",
              "label": "Start Time (seconds)",
              "default": 0,
              "min": 0,
              "help_text": "Start video at specific time"
            }
          }
        },
        "performance_group": {
          "type": "property_group",
          "label": "Performance",
          "properties": {
            "lazy_load": {
              "type": "boolean",
              "label": "Lazy Load",
              "default": true,
              "help_text": "Load video only when visible (improves performance)"
            },
            "play_inline": {
              "type": "boolean",
              "label": "Play Inline (Mobile)",
              "default": true,
              "help_text": "Play inline on mobile instead of fullscreen"
            }
          }
        }
      }
    },
    "display": {
      "label": "Display",
      "icon": "fas fa-expand",
      "order": 3,
      "properties": {
        "size_group": {
          "type": "property_group",
          "label": "Size",
          "properties": {
            "aspect_ratio": {
              "type": "select",
              "label": "Aspect Ratio",
              "options": [
                {"value": "16/9", "label": "16:9 (Widescreen)"},
                {"value": "4/3", "label": "4:3 (Standard)"},
                {"value": "21/9", "label": "21:9 (Ultrawide)"},
                {"value": "1/1", "label": "1:1 (Square)"},
                {"value": "9/16", "label": "9:16 (Vertical)"},
                {"value": "auto", "label": "Auto"}
              ],
              "default": "16/9"
            },
            "max_width": {
              "type": "select",
              "label": "Max Width",
              "options": [
                {"value": "100%", "label": "Full Width"},
                {"value": "1200px", "label": "1200px"},
                {"value": "960px", "label": "960px"},
                {"value": "800px", "label": "800px"},
                {"value": "640px", "label": "640px"}
              ],
              "default": "100%"
            }
          }
        },
        "layout_group": {
          "type": "property_group",
          "label": "Layout",
          "properties": {
            "alignment": {
              "type": "select",
              "label": "Alignment",
              "options": [
                {"value": "left", "label": "Left"},
                {"value": "center", "label": "Center"},
                {"value": "right", "label": "Right"}
              ],
              "default": "center"
            }
          }
        },
        "style_group": {
          "type": "property_group",
          "label": "Style",
          "properties": {
            "rounded": {
              "type": "select",
              "label": "Corners",
              "options": [
                {"value": "", "label": "Square"},
                {"value": "sm", "label": "Slightly Rounded"},
                {"value": "md", "label": "Rounded"},
                {"value": "lg", "label": "Very Rounded"}
              ],
              "default": ""
            },
            "shadow": {
              "type": "boolean",
              "label": "Drop Shadow",
              "default": false
            }
          }
        }
      }
    },
    "privacy": {
      "label": "Privacy",
      "icon": "fas fa-user-shield",
      "order": 4,
      "properties": {
        "privacy_group": {
          "type": "property_group",
          "label": "Privacy Settings",
          "columns": 1,
          "properties": {
            "use_nocookie": {
              "type": "boolean",
              "label": "Privacy-Enhanced Mode",
              "default": true,
              "help_text": "Use youtube-nocookie.com for GDPR compliance (YouTube only)"
            },
            "show_consent": {
              "type": "boolean",
              "label": "Require Consent",
              "default": false,
              "help_text": "Show placeholder until user accepts loading third-party content"
            },
            "consent_message": {
              "type": "textarea",
              "label": "Consent Message",
              "default": "Click to load video. This will connect to third-party servers.",
              "translatable": true,
              "rows": 2,
              "full_width": true,
              "show_if": {"show_consent": true}
            }
          }
        }
      }
    }
  },
  "properties": {
    "source_type": {"type": "select", "default": "youtube"},
    "youtube_url": {"type": "url"},
    "vimeo_url": {"type": "url"},
    "video_url": {"type": "url"},
    "poster_image": {"type": "image"},
    "title": {"type": "string", "default": "", "translatable": true},
    "autoplay": {"type": "boolean", "default": false},
    "muted": {"type": "boolean", "default": false},
    "loop": {"type": "boolean", "default": false},
    "controls": {"type": "boolean", "default": true},
    "start_time": {"type": "number", "default": 0},
    "lazy_load": {"type": "boolean", "default": true},
    "play_inline": {"type": "boolean", "default": true},
    "aspect_ratio": {"type": "select", "default": "16/9"},
    "max_width": {"type": "select", "default": "100%"},
    "alignment": {"type": "select", "default": "center"},
    "rounded": {"type": "select", "default": ""},
    "shadow": {"type": "boolean", "default": false},
    "use_nocookie": {"type": "boolean", "default": true},
    "show_consent": {"type": "boolean", "default": false},
    "consent_message": {"type": "textarea", "default": "Click to load video. This will connect to third-party servers.", "translatable": true}
  },
  "translations": {
    "en": {"name": "Video Embed", "description": "Embed videos from YouTube, Vimeo, or self-hosted sources"},
    "es": {"name": "Video Incrustado", "description": "Incruste videos de YouTube, Vimeo o fuentes propias"},
    "fr": {"name": "Vidéo Intégrée", "description": "Intégrez des vidéos YouTube, Vimeo ou auto-hébergées"},
    "de": {"name": "Video Einbetten", "description": "Betten Sie Videos von YouTube, Vimeo oder selbst gehosteten Quellen ein"},
    "pt": {"name": "Vídeo Incorporado", "description": "Incorpore vídeos do YouTube, Vimeo ou fontes próprias"},
    "zh-hans": {"name": "视频嵌入", "description": "嵌入YouTube、Vimeo或自托管视频"},
    "ja": {"name": "動画埋め込み", "description": "YouTube、Vimeo、または自己ホスト動画を埋め込む"}
  }
}
