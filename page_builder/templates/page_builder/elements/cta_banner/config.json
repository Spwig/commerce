{
  "element_type": "cta_banner",
  "name": "CTA Banner",
  "description": "Call-to-action banner with background image, title, subtitle and action buttons",
  "version": "1.0.2",
  "category": "marketing",
  "icon": "fas fa-bullhorn",
  "author": "Page Builder System",
  "tags": ["cta", "banner", "call-to-action", "marketing"],
  "supports_translation": true,
  "translation_domain": "cta_banner_element",
  "template_file": "template.html",
  "inherit_base": true,
  "disable_base_properties": ["text_color", "background", "id", "custom_class", "custom_styles"],
  "tabs": {
    "basic": {
      "label": "Content",
      "icon": "fas fa-font",
      "order": 1,
      "properties": {
        "content_group": {
          "type": "property_group",
          "label": "Banner Content",
          "columns": 1,
          "properties": {
            "title": {
              "type": "string",
              "label": "Title",
              "default": "Take Action Today",
              "translatable": true,
              "required": true
            },
            "subtitle": {
              "type": "textarea",
              "label": "Subtitle",
              "default": "Join thousands of satisfied customers",
              "translatable": true,
              "rows": 2,
              "full_width": true
            },
            "text_align": {
              "type": "select",
              "label": "Text Alignment",
              "options": [
                {"value": "left", "label": "Left"},
                {"value": "center", "label": "Center"},
                {"value": "right", "label": "Right"}
              ],
              "default": "center"
            }
          }
        }
      }
    },
    "cta": {
      "label": "Buttons",
      "icon": "fas fa-hand-pointer",
      "order": 2,
      "properties": {
        "primary_cta_group": {
          "type": "property_group",
          "label": "Primary CTA",
          "properties": {
            "cta_text": {
              "type": "string",
              "label": "Text",
              "default": "Get Started",
              "translatable": true
            },
            "cta_style": {
              "type": "select",
              "label": "Style",
              "options": [
                {"value": "solid", "label": "Solid"},
                {"value": "outline", "label": "Outline"},
                {"value": "ghost", "label": "Ghost"}
              ],
              "default": "solid"
            },
            "cta_url": {
              "type": "link_selector",
              "label": "URL",
              "default": "#"
            },
            "cta_target": {
              "type": "select",
              "label": "Target",
              "options": [
                {"value": "_self", "label": "Same Window"},
                {"value": "_blank", "label": "New Window"}
              ],
              "default": "_self"
            }
          }
        },
        "secondary_cta_group": {
          "type": "property_group",
          "label": "Secondary CTA",
          "properties": {
            "secondary_cta_text": {
              "type": "string",
              "label": "Text",
              "translatable": true
            },
            "secondary_cta_url": {
              "type": "link_selector",
              "label": "URL",
              "default": "#"
            },
            "secondary_cta_target": {
              "type": "select",
              "label": "Target",
              "options": [
                {"value": "_self", "label": "Same Window"},
                {"value": "_blank", "label": "New Window"}
              ],
              "default": "_self"
            }
          }
        }
      }
    },
    "background": {
      "label": "Background",
      "icon": "fas fa-image",
      "order": 3,
      "properties": {
        "image_group": {
          "type": "property_group",
          "label": "Background Image",
          "properties": {
            "background_image": {
              "type": "image",
              "label": "Image"
            },
            "background_size": {
              "type": "select",
              "label": "Size",
              "options": [
                {"value": "cover", "label": "Cover"},
                {"value": "contain", "label": "Contain"},
                {"value": "auto", "label": "Auto"}
              ],
              "default": "cover"
            },
            "background_position": {
              "type": "select",
              "label": "Position",
              "options": [
                {"value": "center", "label": "Center"},
                {"value": "top", "label": "Top"},
                {"value": "bottom", "label": "Bottom"}
              ],
              "default": "center"
            }
          }
        },
        "color_group": {
          "type": "property_group",
          "label": "Colors",
          "columns": 1,
          "properties": {
            "background_color": {
              "type": "color",
              "label": "Background Color"
            },
            "background_gradient": {
              "type": "string",
              "label": "Gradient",
              "placeholder": "e.g., linear-gradient(135deg, #667eea 0%, #764ba2 100%)"
            }
          }
        },
        "overlay_group": {
          "type": "property_group",
          "label": "Overlay",
          "properties": {
            "background_overlay": {
              "type": "color",
              "label": "Overlay Color",
              "help_text": "Color overlay on background"
            },
            "overlay_opacity": {
              "type": "range",
              "label": "Opacity",
              "min": 0,
              "max": 1,
              "step": 0.1,
              "default": 0.5
            }
          }
        },
        "sizing_group": {
          "type": "property_group",
          "label": "Sizing",
          "columns": 1,
          "properties": {
            "min_height": {
              "type": "select",
              "label": "Minimum Height",
              "options": [
                {"value": "64", "label": "Small"},
                {"value": "80", "label": "Medium"},
                {"value": "96", "label": "Large"},
                {"value": "screen", "label": "Full Screen"}
              ],
              "default": "96"
            }
          }
        }
      }
    },
    "typography": {
      "label": "Typography",
      "icon": "fas fa-text-height",
      "order": 4,
      "properties": {
        "title_typography_group": {
          "type": "property_group",
          "label": "Title Typography",
          "properties": {
            "title_size": {
              "type": "select",
              "label": "Size",
              "options": [
                {"value": "sm", "label": "Small"},
                {"value": "md", "label": "Medium"},
                {"value": "lg", "label": "Large"},
                {"value": "xl", "label": "Extra Large"}
              ],
              "default": "md"
            },
            "title_color": {
              "type": "select",
              "label": "Color",
              "options": [
                {"value": "white", "label": "White"},
                {"value": "black", "label": "Black"},
                {"value": "gray-900", "label": "Dark Gray"},
                {"value": "blue-600", "label": "Blue"}
              ],
              "default": "white"
            }
          }
        },
        "subtitle_typography_group": {
          "type": "property_group",
          "label": "Subtitle Typography",
          "properties": {
            "subtitle_size": {
              "type": "select",
              "label": "Size",
              "options": [
                {"value": "sm", "label": "Small"},
                {"value": "md", "label": "Medium"},
                {"value": "lg", "label": "Large"}
              ],
              "default": "md"
            },
            "subtitle_color": {
              "type": "select",
              "label": "Color",
              "options": [
                {"value": "white", "label": "White"},
                {"value": "black", "label": "Black"},
                {"value": "gray-700", "label": "Gray"}
              ],
              "default": "white"
            }
          }
        }
      }
    },
    "options_tab": {
      "label": "Options",
      "icon": "fas fa-cog",
      "order": 5,
      "properties": {
        "behavior_group": {
          "type": "property_group",
          "label": "Behavior",
          "columns": 1,
          "properties": {
            "show_scroll_indicator": {
              "type": "boolean",
              "label": "Show Scroll Indicator",
              "default": false
            }
          }
        },
        "html_group": {
          "type": "property_group",
          "label": "HTML Attributes",
          "columns": 1,
          "properties": {
            "id": {
              "type": "string",
              "label": "Element ID"
            },
            "custom_class": {
              "type": "string",
              "label": "Custom CSS Classes"
            },
            "custom_styles": {
              "type": "textarea",
              "label": "Custom CSS Styles",
              "rows": 3,
              "full_width": true
            }
          }
        }
      }
    }
  },
  "properties": {
    "title": {"type": "string", "label": "Title", "default": "Take Action Today", "translatable": true, "required": true},
    "subtitle": {"type": "textarea", "label": "Subtitle", "default": "Join thousands of satisfied customers", "translatable": true, "rows": 2},
    "title_size": {"type": "select", "label": "Title Size", "options": [{"value": "sm", "label": "Small"}, {"value": "md", "label": "Medium"}, {"value": "lg", "label": "Large"}, {"value": "xl", "label": "Extra Large"}], "default": "md"},
    "title_color": {"type": "select", "label": "Title Color", "options": [{"value": "white", "label": "White"}, {"value": "black", "label": "Black"}, {"value": "gray-900", "label": "Dark Gray"}, {"value": "blue-600", "label": "Blue"}], "default": "white"},
    "subtitle_size": {"type": "select", "label": "Subtitle Size", "options": [{"value": "sm", "label": "Small"}, {"value": "md", "label": "Medium"}, {"value": "lg", "label": "Large"}], "default": "md"},
    "subtitle_color": {"type": "select", "label": "Subtitle Color", "options": [{"value": "white", "label": "White"}, {"value": "black", "label": "Black"}, {"value": "gray-700", "label": "Gray"}], "default": "white"},
    "text_align": {"type": "select", "label": "Text Alignment", "options": [{"value": "left", "label": "Left"}, {"value": "center", "label": "Center"}, {"value": "right", "label": "Right"}], "default": "center"},
    "background_image": {"type": "image", "label": "Background Image"},
    "background_size": {"type": "select", "label": "Background Size", "options": [{"value": "cover", "label": "Cover"}, {"value": "contain", "label": "Contain"}, {"value": "auto", "label": "Auto"}], "default": "cover"},
    "background_position": {"type": "select", "label": "Background Position", "options": [{"value": "center", "label": "Center"}, {"value": "top", "label": "Top"}, {"value": "bottom", "label": "Bottom"}], "default": "center"},
    "background_color": {"type": "color", "label": "Background Color"},
    "background_gradient": {"type": "string", "label": "Background Gradient", "placeholder": "e.g., linear-gradient(135deg, #667eea 0%, #764ba2 100%)"},
    "background_overlay": {"type": "color", "label": "Background Overlay", "help_text": "Color overlay on background"},
    "overlay_opacity": {"type": "range", "label": "Overlay Opacity", "min": 0, "max": 1, "step": 0.1, "default": 0.5},
    "min_height": {"type": "select", "label": "Minimum Height", "options": [{"value": "64", "label": "Small"}, {"value": "80", "label": "Medium"}, {"value": "96", "label": "Large"}, {"value": "screen", "label": "Full Screen"}], "default": "96"},
    "cta_text": {"type": "string", "label": "Primary CTA Text", "default": "Get Started", "translatable": true},
    "cta_url": {"type": "link_selector", "label": "Primary CTA URL", "default": "#"},
    "cta_target": {"type": "select", "label": "Primary CTA Target", "options": [{"value": "_self", "label": "Same Window"}, {"value": "_blank", "label": "New Window"}], "default": "_self"},
    "cta_style": {"type": "select", "label": "Primary CTA Style", "options": [{"value": "solid", "label": "Solid"}, {"value": "outline", "label": "Outline"}, {"value": "ghost", "label": "Ghost"}], "default": "solid"},
    "secondary_cta_text": {"type": "string", "label": "Secondary CTA Text", "translatable": true},
    "secondary_cta_url": {"type": "link_selector", "label": "Secondary CTA URL", "default": "#"},
    "secondary_cta_target": {"type": "select", "label": "Secondary CTA Target", "options": [{"value": "_self", "label": "Same Window"}, {"value": "_blank", "label": "New Window"}], "default": "_self"},
    "show_scroll_indicator": {"type": "boolean", "label": "Show Scroll Indicator", "default": false},
    "id": {"type": "string", "label": "Element ID"},
    "custom_class": {"type": "string", "label": "Custom CSS Classes"},
    "custom_styles": {"type": "textarea", "label": "Custom CSS Styles", "rows": 3}
  },
