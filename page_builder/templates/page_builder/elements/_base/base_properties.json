    "animations": {
      "label": "Animations",
      "icon": "fas fa-magic",
      "order": 2.5,
      "properties": {
        "entrance_animation_settings": {
          "type": "property_group",
          "label": "Entrance Animations",
          "help_text": "Configure animation effects when the element enters the viewport",
          "columns": 1,
          "properties": {
            "animation_type": {
              "type": "select",
              "label": "Type",
              "options": [
                { "value": "", "label": "None" },
                { "value": "fadeIn", "label": "Fade In" },
                { "value": "slideInUp", "label": "Slide In Up" },
                { "value": "slideInDown", "label": "Slide In Down" },
                { "value": "slideInLeft", "label": "Slide In Left" },
                { "value": "slideInRight", "label": "Slide In Right" },
                { "value": "zoomIn", "label": "Zoom In" },
                { "value": "bounceIn", "label": "Bounce In" },
                { "value": "fadeOut", "label": "Fade Out" },
                { "value": "slideOutUp", "label": "Slide Out Up" },
                { "value": "slideOutDown", "label": "Slide Out Down" },
                { "value": "slideOutLeft", "label": "Slide Out Left" },
                { "value": "slideOutRight", "label": "Slide Out Right" },
                { "value": "zoomOut", "label": "Zoom Out" },
                { "value": "pulse", "label": "Pulse" },
                { "value": "shake", "label": "Shake" },
                { "value": "bounce", "label": "Bounce" },
                { "value": "flash", "label": "Flash" },
                { "value": "spin", "label": "Spin" }
              ],
              "default": "",
              "help_text": "Choose an animation effect"
            },
            "animation_duration": {
              "type": "select",
              "label": "Duration",
              "options": [
                { "value": "0.3s", "label": "Fast (0.3s)" },
                { "value": "0.5s", "label": "Normal (0.5s)" },
                { "value": "0.8s", "label": "Slow (0.8s)" },
                { "value": "1s", "label": "Very Slow (1s)" },
                { "value": "1.5s", "label": "Extra Slow (1.5s)" }
              ],
              "default": "0.5s",
              "help_text": "How long the animation takes"
            },
            "animation_delay": {
              "type": "select",
              "label": "Delay",
              "options": [
                { "value": "0s", "label": "None" },
                { "value": "0.1s", "label": "0.1s" },
                { "value": "0.2s", "label": "0.2s" },
                { "value": "0.3s", "label": "0.3s" },
                { "value": "0.5s", "label": "0.5s" },
                { "value": "1s", "label": "1s" }
              ],
              "default": "0s",
              "help_text": "Delay before animation starts"
            },
            "animation_timing": {
              "type": "select",
              "label": "Timing",
              "options": [
                { "value": "ease", "label": "Ease" },
                { "value": "ease-in", "label": "Ease In" },
                { "value": "ease-out", "label": "Ease Out" },
                { "value": "ease-in-out", "label": "Ease In Out" },
                { "value": "linear", "label": "Linear" }
              ],
              "default": "ease-out",
              "help_text": "Animation easing function"
            },
            "animation_repeat": {
              "type": "select",
              "label": "Repeat",
              "options": [
                { "value": "1", "label": "Once" },
                { "value": "infinite", "label": "Infinite" }
              ],
              "default": "1",
              "help_text": "How many times to repeat"
            }
          }
        },
        "hover_animation_settings": {
          "type": "property_group",
          "label": "Hover Animations",
          "help_text": "Configure animation effects when hovering over the element",
          "columns": 1,
          "properties": {
            "hover_animation_type": {
              "type": "select",
              "label": "Effect",
              "options": [
                { "value": "", "label": "None" },
                { "value": "scale-up", "label": "Scale Up" },
                { "value": "scale-down", "label": "Scale Down" },
                { "value": "lift", "label": "Lift (Float Up)" },
                { "value": "rotate-cw", "label": "Rotate Clockwise" },
                { "value": "rotate-ccw", "label": "Rotate Counter-Clockwise" },
                { "value": "fade", "label": "Fade" },
                { "value": "brighten", "label": "Brighten" },
                { "value": "shadow-grow", "label": "Shadow Grow" },
                { "value": "lift-shadow", "label": "Lift with Shadow" },
                { "value": "zoom-brighten", "label": "Zoom with Brightness" },
                { "value": "pulse-scale", "label": "Pulse Scale" },
                { "value": "skew", "label": "Skew" },
                { "value": "border-glow", "label": "Border Glow" }
              ],
              "default": "",
              "help_text": "Choose a hover animation effect"
            },
            "hover_animation_duration": {
              "type": "select",
              "label": "Duration",
              "options": [
                { "value": "0.15s", "label": "Fast (0.15s)" },
                { "value": "0.3s", "label": "Normal (0.3s)" },
                { "value": "0.5s", "label": "Slow (0.5s)" },
                { "value": "0.8s", "label": "Very Slow (0.8s)" }
              ],
              "default": "0.3s",
              "help_text": "Transition duration for the hover effect"
            },
            "hover_animation_timing": {
              "type": "select",
              "label": "Timing",
              "options": [
                { "value": "ease", "label": "Ease" },
                { "value": "ease-in", "label": "Ease In" },
                { "value": "ease-out", "label": "Ease Out" },
                { "value": "ease-in-out", "label": "Ease In Out" },
                { "value": "linear", "label": "Linear" },
                { "value": "cubic-bezier(0.4, 0, 0.2, 1)", "label": "Material Design" },
                { "value": "cubic-bezier(0.68, -0.55, 0.265, 1.55)", "label": "Bounce" }
              ],
              "default": "ease-out",
              "help_text": "Timing function for the transition"
            },
            "hover_animation_intensity": {
              "type": "select",
              "label": "Intensity",
              "options": [
                { "value": "subtle", "label": "Subtle" },
                { "value": "normal", "label": "Normal" },
                { "value": "strong", "label": "Strong" }
              ],
              "default": "normal",
              "help_text": "How pronounced the effect should be",
              "show_when": {
                "property": "hover_animation_type",
                "values": [
                  "scale-up",
                  "scale-down",
                  "lift",
                  "rotate-cw",
                  "rotate-ccw",
                  "shadow-grow",
                  "lift-shadow",
                  "zoom-brighten",
                  "skew"
                ]
              }
            }
          }
        }
      }
