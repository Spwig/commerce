            "show_countdown": {
              "type": "boolean",
              "label": "Show Countdown Timer",
              "default": true
            },
            "end_date": {
              "type": "string",
              "label": "End Date (ISO format)",
              "default": "",
              "show_if": {
                "data_source": "static",
                "show_countdown": true
              }
            }
          }
        },
        "discount_group": {
          "type": "property_group",
          "label": "Discount",
          "properties": {
            "show_discount": {
              "type": "boolean",
              "label": "Show Discount Amount",
              "default": true
