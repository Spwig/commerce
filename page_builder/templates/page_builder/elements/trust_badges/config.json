{
  "element_type": "trust_badges",
  "name": "Trust Badges",
  "description": "Display trust indicators like secure checkout, money-back guarantee, and shipping badges",
  "version": "1.0.1",
  "category": "marketing",
  "icon": "fas fa-shield-alt",
  "author": "Page Builder System",
  "tags": ["trust", "badges", "security", "guarantee", "shipping", "payments"],
  "supports_translation": true,
  "translation_domain": "trust_badges_element",
  "template_file": "template.html",
  "inherit_base": true,
  "css_files": ["page_builder/css/elements/trust-badges.css"],
  "disable_base_properties": ["text_color"],
  "tabs": {
    "basic": {
      "label": "Content",
      "icon": "fas fa-shield-alt",
      "order": 1,
      "properties": {
        "header_group": {
          "type": "property_group",
          "label": "Section Header",
          "columns": 1,
          "properties": {
            "title": {
              "type": "string",
              "label": "Section Title",
              "default": "",
              "translatable": true,
              "help_text": "Optional title above badges"
            }
          }
        },
        "badges_group": {
          "type": "property_group",
          "label": "Trust Badges",
          "columns": 1,
          "properties": {
            "badges": {
              "type": "array",
              "label": "Trust Badges",
              "full_width": true,
              "help_text": "Add badges to build customer confidence",
              "item_schema": {
                "type": "object",
                "properties": {
                  "type": {
                    "type": "select",
                    "label": "Badge Type",
                    "options": [
                      { "value": "custom", "label": "Custom" },
                      { "value": "secure_checkout", "label": "Secure Checkout" },
                      { "value": "money_back", "label": "Money-Back Guarantee" },
                      { "value": "free_shipping", "label": "Free Shipping" },
                      { "value": "fast_delivery", "label": "Fast Delivery" },
                      { "value": "support_24_7", "label": "24/7 Support" },
                      { "value": "quality", "label": "Quality Guaranteed" },
                      { "value": "ssl", "label": "SSL Secure" },
                      { "value": "satisfaction", "label": "100% Satisfaction" },
                      { "value": "verified", "label": "Verified Seller" }
                    ],
                    "default": "custom"
                  },
                  "icon": {
                    "type": "icon_picker",
                    "label": "Icon",
                    "help_text": "Choose a Font Awesome icon",
                    "show_if": { "type": "custom" }
                  },
                  "image": {
                    "type": "image",
                    "label": "Badge Image",
                    "help_text": "Upload a custom badge image (optional)",
                    "show_if": { "type": "custom" }
                  },
                  "title": {
                    "type": "string",
                    "label": "Badge Title",
                    "translatable": true
                  },
                  "description": {
                    "type": "string",
                    "label": "Description",
                    "translatable": true,
                    "help_text": "Short description or tooltip text"
                  }
                }
              },
              "default": [
                {
                  "type": "secure_checkout",
                  "title": "Secure Checkout",
                  "description": "Your payment information is encrypted and secure"
                },
                {
                  "type": "money_back",
                  "title": "30-Day Returns",
                  "description": "Not satisfied? Get a full refund within 30 days"
                },
                {
                  "type": "free_shipping",
                  "title": "Free Shipping",
                  "description": "Free shipping on orders over $50"
                },
                {
                  "type": "support_24_7",
                  "title": "24/7 Support",
                  "description": "Our team is here to help anytime"
                }
              ]
            }
          }
        }
      }
    },
    "display": {
      "label": "Display",
      "icon": "fas fa-th",
      "order": 2,
      "properties": {
        "layout_group": {
          "type": "property_group",
          "label": "Layout",
          "properties": {
            "layout": {
              "type": "select",
              "label": "Layout",
              "options": [
                { "value": "inline", "label": "Inline Row" },
                { "value": "grid", "label": "Grid" },
                { "value": "stacked", "label": "Stacked Vertical" }
              ],
              "default": "inline"
            },
            "columns": {
              "type": "select",
              "label": "Grid Columns",
              "options": [
                { "value": "2", "label": "2 Columns" },
                { "value": "3", "label": "3 Columns" },
                { "value": "4", "label": "4 Columns" },
                { "value": "5", "label": "5 Columns" },
                { "value": "6", "label": "6 Columns" }
              ],
              "default": "4",
              "show_if": { "layout": "grid" }
            },
            "alignment": {
              "type": "select",
              "label": "Alignment",
              "options": [
                { "value": "left", "label": "Left" },
                { "value": "center", "label": "Center" },
                { "value": "right", "label": "Right" },
                { "value": "space-between", "label": "Space Between" }
              ],
              "default": "center"
            }
          }
        },
        "style_group": {
          "type": "property_group",
          "label": "Style",
          "properties": {
            "size": {
              "type": "select",
              "label": "Badge Size",
              "options": [
                { "value": "sm", "label": "Small" },
                { "value": "md", "label": "Medium" },
                { "value": "lg", "label": "Large" }
              ],
              "default": "md"
            },
            "style": {
              "type": "select",
              "label": "Style",
              "options": [
                { "value": "minimal", "label": "Minimal (Icon + Text)" },
                { "value": "boxed", "label": "Boxed" },
                { "value": "outlined", "label": "Outlined" },
                { "value": "icon_only", "label": "Icon Only" }
              ],
              "default": "minimal"
            }
          }
        },
        "content_group": {
          "type": "property_group",
          "label": "Content Display",
          "properties": {
            "show_descriptions": {
              "type": "boolean",
              "label": "Show Descriptions",
              "default": false,
              "help_text": "Display description text below badge titles"
            },
            "show_tooltips": {
              "type": "boolean",
              "label": "Show Tooltips",
              "default": true,
              "help_text": "Show descriptions as tooltips on hover"
            }
          }
        }
      }
    },
    "colors": {
      "label": "Colors",
      "icon": "fas fa-palette",
      "order": 3,
      "properties": {
        "colors_group": {
          "type": "property_group",
          "label": "Colors",
          "properties": {
            "icon_color": {
              "type": "color_advanced",
              "label": "Icon Color",
              "default": "",
              "utility": "color_picker"
            },
            "text_color": {
              "type": "color_advanced",
              "label": "Text Color",
              "default": "",
              "utility": "color_picker"
            },
            "badge_background": {
              "type": "color_advanced",
              "label": "Badge Background",
              "default": "",
              "utility": "color_picker"
            },
            "border_color": {
              "type": "color_advanced",
              "label": "Border Color",
              "default": "",
              "utility": "color_picker"
            }
          }
        }
      }
    }
  },
  "properties": {
    "title": { "type": "string", "default": "", "translatable": true },
    "badges": {
      "type": "array",
      "item_schema": {
        "type": "object",
        "properties": {
          "type": { "type": "select", "default": "custom" },
          "icon": { "type": "icon_picker" },
          "image": { "type": "image" },
          "title": { "type": "string", "translatable": true },
          "description": { "type": "string", "translatable": true }
        }
      }
    },
    "layout": { "type": "select", "default": "inline" },
    "columns": { "type": "select", "default": "4" },
    "size": { "type": "select", "default": "md" },
    "style": { "type": "select", "default": "minimal" },
    "alignment": { "type": "select", "default": "center" },
    "show_descriptions": { "type": "boolean", "default": false },
    "show_tooltips": { "type": "boolean", "default": true },
    "icon_color": { "type": "color_advanced", "default": "" },
    "text_color": { "type": "color_advanced", "default": "" },
    "badge_background": { "type": "color_advanced", "default": "" },
    "border_color": { "type": "color_advanced", "default": "" }
  },
  "translations": {
    "en": {
      "name": "Trust Badges",
      "description": "Display trust indicators like secure checkout, money-back guarantee, and shipping badges"
    },
    "es": {
      "name": "Insignias de Confianza",
      "description": "Muestre indicadores de confianza como pago seguro, garantía de devolución y envío"
    },
    "fr": {
      "name": "Badges de Confiance",
      "description": "Affichez des indicateurs de confiance comme le paiement sécurisé et la garantie"
    },
    "de": {
      "name": "Vertrauensabzeichen",
      "description": "Zeigen Sie Vertrauensindikatoren wie sichere Zahlung und Geld-zurück-Garantie"
    },
    "pt": {
      "name": "Selos de Confiança",
      "description": "Exiba indicadores de confiança como checkout seguro e garantia de devolução"
    },
    "zh-hans": { "name": "信任徽章", "description": "展示安全结账、退款保证和配送徽章等信任标识" },
    "ja": {
      "name": "トラストバッジ",
      "description": "安全なチェックアウト、返金保証、配送バッジなどの信頼指標を表示"
    }
  }
}
