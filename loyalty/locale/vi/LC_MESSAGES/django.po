"Chào mừng bạn đến với chương trình khách hàng thân thiết của chúng tôi! Bắt "
"đầu tích điểm ngay hôm nay."

msgid "Please join our loyalty program first."
msgstr ""
"Vui lòng tham gia chương trình khách hàng thân thiết của chúng tôi trước."

msgid "All Transactions"
msgstr "Tất cả giao dịch"

msgid "Points Redeemed"
msgstr "Điểm đã sử dụng"

msgid "Bonus Points"
msgstr "Điểm thưởng"

msgid "Adjustments"
msgstr "Điều chỉnh"

msgid "Expired Points"
msgstr "Điểm đã hết hạn"

msgid "All Rewards"
msgstr "Tất cả các phần thưởng"

msgid "Discounts"
msgstr "Giảm giá"

msgid "Free Products"
msgstr "Sản phẩm miễn phí"

msgid "Special Experiences"
msgstr "Trải nghiệm đặc biệt"

msgid "You must be a loyalty member to redeem rewards."
msgstr ""
"Bạn phải là thành viên của chương trình khách hàng thân thiết để đổi lấy "
"phần thưởng."

msgid "Failed to process redemption: {}"
msgstr "Không thể xử lý việc sử dụng điểm: {}"

msgid "Loyalty member not found."
msgstr "Không tìm thấy thành viên trung thành."

msgid "Rule activated successfully."
msgstr "Quy tắc đã được kích hoạt thành công."

msgid "Rule deactivated successfully."
msgstr "Quy tắc đã được ngừng hoạt động thành công."

msgid "Rule status updated successfully."
msgstr "Trạng thái quy tắc đã được cập nhật thành công."

msgid "Rule not found."
msgstr "Không tìm thấy quy tắc."

msgid "Manual segments cannot be automatically refreshed."
msgstr "Các phân khúc thủ công không thể được làm mới tự động."

msgid "Segment refresh has been queued."
msgstr "Làm mới phân khúc đã được xếp hàng."

msgid "Segment not found."
msgstr "Không tìm thấy phân khúc."

msgid "Campaign activated successfully."
msgstr "Chiến dịch đã được kích hoạt thành công."

msgid "Campaign cannot be activated from its current status."
msgstr "Chiến dịch không thể được kích hoạt từ trạng thái hiện tại của nó."

msgid "Campaign paused successfully."
msgstr "Chiến dịch đã được tạm dừng thành công."

msgid "Only active campaigns can be paused."
msgstr "Chỉ các chiến dịch đang hoạt động mới có thể được tạm dừng."

msgid "Invalid action."
msgstr "Hành động không hợp lệ."

msgid "Campaign not found."
msgstr "Không tìm thấy chiến dịch."

msgid "Automatically activates when specific customer actions occur"
msgstr "Kích hoạt tự động khi xảy ra các hành động cụ thể của khách hàng"

msgid "Runs at specific times or on a recurring schedule"
msgstr "Chạy vào các thời điểm cụ thể hoặc theo lịch trình lặp lại"

msgid "Manually triggered by administrators"
msgstr "Được kích hoạt thủ công bởi quản trị viên"

msgid "Targets customers based on browsing and purchase patterns"
msgstr "Định hướng khách hàng dựa trên các mẫu duyệt và mua sắm"

msgid "When a customer completes a purchase"
msgstr "Khi khách hàng hoàn thành một lần mua hàng"

msgid "Customer makes their first purchase"
msgstr "Khách hàng thực hiện lần mua hàng đầu tiên"

msgid "Customer reaches a purchase milestone"
msgstr "Khách hàng đạt được cột mốc mua hàng"

msgid "New customer creates an account"
msgstr "Khách hàng mới tạo tài khoản"

msgid "Customer's birthday"
msgstr "Sinh nhật khách hàng"

msgid "Account creation anniversary"
msgstr "Kỷ niệm ngày tạo tài khoản"

msgid "Customer moves up a tier"
msgstr "Khách hàng lên cấp độ cao hơn"

msgid "Customer moves down a tier"
msgstr "Khách hàng xuống cấp độ thấp hơn"

msgid "Customer abandons their cart"
msgstr "Khách hàng bỏ giỏ hàng"

msgid "No purchase in 90 days"
msgstr "Không có giao dịch trong 90 ngày"

msgid "Points about to expire"
msgstr "Điểm sắp hết hạn"

msgid "Customer submits a review"
msgstr "Khách hàng gửi đánh giá"

msgid "A referred customer makes a purchase"
msgstr "Một khách hàng được giới thiệu thực hiện mua hàng"

msgid "Give a fixed number of points"
msgstr "Cấp một số điểm cố định"

msgid "Multiply points earned"
msgstr "Nhân đôi điểm tích lũy"

msgid "Send a notification email"
msgstr "Gửi email thông báo"

msgid "Move customer to higher tier"
msgstr "Chuyển khách hàng lên cấp cao hơn"

msgid "Award an achievement badge"
msgstr "Trao huy hiệu thành tích"

msgid "Campaign name is required."
msgstr "Tên chiến dịch là bắt buộc."

msgid "Campaign type is required."
msgstr "Loại chiến dịch là bắt buộc."

