msgid "M2M100 Standard (418M)"
msgstr "M2M100 Chuẩn (418M)"

msgid ""
"Fast translations for 100 languages. Ideal for high-volume, basic "
"translation needs."
msgstr ""
"Dịch thuật nhanh cho 100 ngôn ngữ. Lý tưởng cho nhu cầu dịch thuật cơ bản "
"với khối lượng lớn."

