msgid "Get license product catalog"
msgstr "Lấy danh mục sản phẩm giấy phép"

msgid ""
"Returns all active license products with pricing. Used by spwig.com to "
"display product cards. HQ only."
msgstr ""
"Trả về tất cả các sản phẩm giấy phép còn hoạt động cùng giá cả. Được "
"spwig.com sử dụng để hiển thị các thẻ sản phẩm. Chỉ dành cho HQ."

msgid "Start free trial"
msgstr "Bắt đầu dùng thử miễn phí"

msgid ""
"Provision a free trial license and setup token. One trial per email address."
" HQ only."
msgstr ""
"Cấp phép dùng thử miễn phí và thiết lập token. Một lần dùng thử cho mỗi địa "
"chỉ email. Chỉ dành cho HQ."

msgid "Invalid email or trial already used"
msgstr "Email không hợp lệ hoặc lần dùng thử đã được sử dụng"

msgid "Upgrade server unreachable"
msgstr "Máy chủ nâng cấp không thể truy cập"

msgid "Initiate license checkout"
msgstr "Khởi tạo thanh toán giấy phép"

msgid ""
"Create a paid checkout for a license product. Returns embedded payment "
"configuration for Airwallex SDK. Idempotent for same email+product. HQ only."
msgstr ""
"Tạo thanh toán có phí cho sản phẩm giấy phép. Trả về cấu hình thanh toán "
"được nhúng cho SDK Airwallex. Tính chất idempotent cho cùng một email+sản "
"phẩm. Chỉ dành cho HQ."

msgid "Existing active checkout returned (idempotent)"
msgstr "Thanh toán đang hoạt động đã tồn tại (idempotent)"

msgid "Invalid input or product not found"
msgstr "Thông tin đầu vào không hợp lệ hoặc sản phẩm không tìm thấy"

msgid "No payment provider configured"
msgstr "Không có nhà cung cấp thanh toán được cấu hình"

msgid "Check license payment status"
msgstr "Kiểm tra trạng thái thanh toán giấy phép"

msgid ""
"Check payment and provisioning status for a license purchase. Called by "
"spwig.com to poll for completion. HQ only."
msgstr ""
"Kiểm tra trạng thái thanh toán và cấp phép cho việc mua giấy phép. Được gọi "
"bởi spwig.com để kiểm tra trạng thái hoàn tất. Chỉ dành cho HQ."

msgid "Payment intent not found"
msgstr "Không tìm thấy ý định thanh toán"

msgid "Check payment status by checkout ID"
msgstr "Kiểm tra trạng thái thanh toán bằng ID thanh toán"

msgid ""
"Check payment status using the checkout request ID (fallback when intent_id "
"unavailable). HQ only."
msgstr ""
"Kiểm tra trạng thái thanh toán bằng ID yêu cầu thanh toán (sử dụng làm "
"phương án dự phòng khi intent_id không khả dụng). Chỉ dành cho HQ."

msgid "Checkout request not found"
msgstr "Không tìm thấy yêu cầu thanh toán"

msgid "Get maintenance renewal info"
msgstr "Lấy thông tin gia hạn bảo trì"

#, python-format
msgid ""
"Validate a license key and return renewal pricing (25% of current list "
"price) plus maintenance status. HQ only."
msgstr ""
"Xác minh một khóa cấp phép và trả lại giá cả gia hạn (25% giá danh sách hiện"
" tại) cùng trạng thái bảo trì. Chỉ dành cho HQ."

msgid "Invalid license key"
msgstr "Mã giấy phép không hợp lệ"

msgid "License not found"
msgstr "Không tìm thấy giấy phép"

msgid "Initiate maintenance renewal checkout"
msgstr "Khởi tạo thanh toán gia hạn bảo trì"

#, python-format
msgid ""
"Create a paid checkout for maintenance renewal. Price is calculated as 25% "
"of the current list price. HQ only."
msgstr ""
"Tạo thanh toán có phí cho việc gia hạn bảo trì. Giá được tính là 25% giá "
"danh sách hiện tại. Chỉ dành cho HQ."

msgid "Invalid input"
msgstr "Đầu vào không hợp lệ"
