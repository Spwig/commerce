msgid "Get license product catalog"
msgstr "Получить каталог лицензионных продуктов"

msgid ""
"Returns all active license products with pricing. Used by spwig.com to "
"display product cards. HQ only."
msgstr ""
"Возвращает все активные лицензионные продукты с ценами. Используется "
"spwig.com для отображения карточек продуктов. Только для HQ."

msgid "Start free trial"
msgstr "Начать бесплатный пробный период"

msgid ""
"Provision a free trial license and setup token. One trial per email address."
" HQ only."
msgstr ""
"Предоставить бесплатную пробную лицензию и настроить токен. Один пробный "
"период на адрес электронной почты. Только для HQ."

msgid "Invalid email or trial already used"
msgstr "Неверный адрес электронной почты или пробный период уже использован"

msgid "Upgrade server unreachable"
msgstr "Сервер обновления недоступен"

msgid "Initiate license checkout"
msgstr "Запустить оформление лицензии"

msgid ""
"Create a paid checkout for a license product. Returns embedded payment "
"configuration for Airwallex SDK. Idempotent for same email+product. HQ only."
msgstr ""
"Создать оплачиваемую покупку для лицензионного продукта. Возвращает "
"встроенную настройку платежа для SDK Airwallex. Идемпотентно для одинакового"
" email+продукта. Только для HQ."

msgid "Existing active checkout returned (idempotent)"
msgstr "Возвращено существующее активное оформление (идемпотентное)"

msgid "Invalid input or product not found"
msgstr "Неверный ввод или продукт не найден"

msgid "No payment provider configured"
msgstr "Не настроен провайдер платежей"

msgid "Check license payment status"
msgstr "Проверить статус оплаты лицензии"

msgid ""
"Check payment and provisioning status for a license purchase. Called by "
"spwig.com to poll for completion. HQ only."
msgstr ""
"Проверьте статус оплаты и предоставления лицензии. Вызывается spwig.com для "
"опроса завершения. Только HQ."

msgid "Payment intent not found"
msgstr "Не найден намерение оплаты"

msgid "Check payment status by checkout ID"
msgstr "Проверьте статус оплаты по ID оформления заказа"

msgid ""
"Check payment status using the checkout request ID (fallback when intent_id "
"unavailable). HQ only."
msgstr ""
"Проверьте статус оплаты с использованием ID запроса оформления заказа "
"(резервный вариант, когда intent_id недоступен). Только HQ."

msgid "Checkout request not found"
msgstr "Не найден запрос на оплату"

msgid "Get maintenance renewal info"
msgstr "Получить информацию об обновлении технического обслуживания"

#, python-format
msgid ""
"Validate a license key and return renewal pricing (25% of current list "
"price) plus maintenance status. HQ only."
msgstr ""
"Проверьте ключ лицензии и верните цену обновления (25% от текущей розничной "
"цены) вместе со статусом технической поддержки. Только HQ."

msgid "Invalid license key"
msgstr "Неверный ключ лицензии"

msgid "License not found"
msgstr "Лицензия не найдена"

msgid "Initiate maintenance renewal checkout"
msgstr "Инициировать продление технического обслуживания"

#, python-format
msgid ""
"Create a paid checkout for maintenance renewal. Price is calculated as 25% "
"of the current list price. HQ only."
msgstr ""
"Создать оплачиваемую проверку для обновления технического обслуживания. Цена"
" рассчитывается как 25% от текущей розничной цены. Только для HQ."

msgid "Invalid input"
msgstr "Неверный ввод"
