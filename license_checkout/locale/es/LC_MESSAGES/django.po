msgid "Get license product catalog"
msgstr "Obtener catálogo de productos de licencia"

msgid ""
"Returns all active license products with pricing. Used by spwig.com to "
"display product cards. HQ only."
msgstr ""
"Devuelve todos los productos de licencia activos con precios. Utilizado por "
"spwig.com para mostrar tarjetas de productos. Solo para HQ."

msgid "Start free trial"
msgstr "Iniciar prueba gratuita"

msgid ""
"Provision a free trial license and setup token. One trial per email address."
" HQ only."
msgstr ""
"Proporcione una licencia de prueba gratuita y un token de configuración. Un "
"solo prueba por dirección de correo electrónico. Solo HQ."

msgid "Invalid email or trial already used"
msgstr "Correo electrónico inválido o prueba ya utilizada"

msgid "Upgrade server unreachable"
msgstr "Servidor de actualización no alcanzable"

msgid "Initiate license checkout"
msgstr "Iniciar checkout de licencia"

msgid ""
"Create a paid checkout for a license product. Returns embedded payment "
"configuration for Airwallex SDK. Idempotent for same email+product. HQ only."
msgstr ""
"Crea un pago para un producto de licencia. Devuelve la configuración de pago"
" integrada para el SDK de Airwallex. Idempotente para el mismo correo "
"electrónico + producto. Solo para HQ."

msgid "Existing active checkout returned (idempotent)"
msgstr "Checkout activo existente devuelto (idempotente)"

msgid "Invalid input or product not found"
msgstr "Entrada inválida o producto no encontrado"

msgid "No payment provider configured"
msgstr "No se ha configurado proveedor de pago"

msgid "Check license payment status"
msgstr "Verificar estado del pago de licencia"

msgid ""
"Check payment and provisioning status for a license purchase. Called by "
"spwig.com to poll for completion. HQ only."
msgstr ""
"Verifica el estado del pago y la provisión de una compra de licencia. "
"Llamado por spwig.com para verificar la finalización. Solo para HQ."

msgid "Payment intent not found"
msgstr "Intención de pago no encontrada"

msgid "Check payment status by checkout ID"
msgstr "Verificar el estado del pago mediante el ID de checkout"

msgid ""
"Check payment status using the checkout request ID (fallback when intent_id "
"unavailable). HQ only."
msgstr ""
"Verificar el estado del pago utilizando el ID de solicitud de checkout "
"(alternativa cuando intent_id no esté disponible). Solo HQ."

msgid "Checkout request not found"
msgstr "Solicitud de checkout no encontrada"

msgid "Get maintenance renewal info"
msgstr "Obtener información de renovación de mantenimiento"

#, python-format
msgid ""
"Validate a license key and return renewal pricing (25% of current list "
"price) plus maintenance status. HQ only."
msgstr ""
"Validar una clave de licencia y devolver el precio de renovación (25% del "
"precio de lista actual) más el estado de mantenimiento. Solo HQ."

msgid "Invalid license key"
msgstr "Clave de licencia inválida"

msgid "License not found"
msgstr "Licencia no encontrada"

msgid "Initiate maintenance renewal checkout"
msgstr "Iniciar checkout de renovación de mantenimiento"

#, python-format
msgid ""
"Create a paid checkout for maintenance renewal. Price is calculated as 25% "
"of the current list price. HQ only."
msgstr ""
"Crear un pago para la renovación de mantenimiento. El precio se calcula como"
" el 25% del precio de lista actual. Solo HQ."

msgid "Invalid input"
msgstr "Entrada inválida"
