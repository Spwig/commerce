msgid "Get license product catalog"
msgstr "Dapatkan katalog produk lisensi"

msgid ""
"Returns all active license products with pricing. Used by spwig.com to "
"display product cards. HQ only."
msgstr ""
"Mengembalikan semua produk lisensi aktif dengan harga. Digunakan oleh "
"spwig.com untuk menampilkan kartu produk. Hanya HQ."

msgid "Start free trial"
msgstr "Mulai uji coba gratis"

msgid ""
"Provision a free trial license and setup token. One trial per email address."
" HQ only."
msgstr ""
"Buat lisensi percobaan gratis dan token setup. Satu percobaan per alamat "
"email. Hanya HQ."

msgid "Invalid email or trial already used"
msgstr "Email tidak valid atau percobaan sudah digunakan"

msgid "Upgrade server unreachable"
msgstr "Server upgrade tidak dapat dijangkau"

msgid "Initiate license checkout"
msgstr "Mulai checkout lisensi"

msgid ""
"Create a paid checkout for a license product. Returns embedded payment "
"configuration for Airwallex SDK. Idempotent for same email+product. HQ only."
msgstr ""
"Buat checkout berbayar untuk produk lisensi. Mengembalikan konfigurasi "
"pembayaran yang disematkan untuk SDK Airwallex. Idempoten untuk email+produk"
" yang sama. Hanya HQ."

msgid "Existing active checkout returned (idempotent)"
msgstr "Checkout aktif yang sudah ada dikembalikan (idempotent)"

msgid "Invalid input or product not found"
msgstr "Input tidak valid atau produk tidak ditemukan"

msgid "No payment provider configured"
msgstr "Tidak ada penyedia pembayaran yang dikonfigurasi"

msgid "Check license payment status"
msgstr "Periksa status pembayaran lisensi"

msgid ""
"Check payment and provisioning status for a license purchase. Called by "
"spwig.com to poll for completion. HQ only."
msgstr ""
"Periksa status pembayaran dan pemberian akses untuk pembelian lisensi. "
"Dipanggil oleh spwig.com untuk memantau kelengkapan. Hanya HQ."

msgid "Payment intent not found"
msgstr "Niat pembayaran tidak ditemukan"

msgid "Check payment status by checkout ID"
msgstr "Periksa status pembayaran menggunakan ID checkout"

msgid ""
"Check payment status using the checkout request ID (fallback when intent_id "
"unavailable). HQ only."
msgstr ""
"Periksa status pembayaran menggunakan ID permintaan checkout (opsi cadangan "
"ketika intent_id tidak tersedia). Hanya HQ."

msgid "Checkout request not found"
msgstr "Permintaan checkout tidak ditemukan"

msgid "Get maintenance renewal info"
msgstr "Dapatkan informasi perpanjangan pemeliharaan"

#, python-format
msgid ""
"Validate a license key and return renewal pricing (25% of current list "
"price) plus maintenance status. HQ only."
msgstr ""
"Validasi kunci lisensi dan kembalikan harga perpanjangan (25% dari harga "
"daftar saat ini) plus status pemeliharaan. Hanya HQ."

msgid "Invalid license key"
msgstr "Kunci lisensi tidak valid"

msgid "License not found"
msgstr "Lisensi tidak ditemukan"

msgid "Initiate maintenance renewal checkout"
msgstr "Mulai checkout perpanjangan pemeliharaan"

#, python-format
msgid ""
"Create a paid checkout for maintenance renewal. Price is calculated as 25% "
"of the current list price. HQ only."
msgstr ""
"Buat checkout berbayar untuk perpanjangan pemeliharaan. Harga dihitung "
"sebagai 25% dari harga daftar saat ini. Hanya HQ."

msgid "Invalid input"
msgstr "Input tidak valid"
