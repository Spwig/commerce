msgid "Pattern Configuration"
msgstr "Configurazione del Modello"

msgid ""
"Define the license key format using placeholders:<br>• <code>{RANDOM:N}</"
"code> - N random characters<br>• <code>{CHECKSUM:N}</code> - N-digit "
"checksum<br>• <code>{PREFIX}</code> - Template prefix<br>• <code>{SUFFIX}</"
"code> - Template suffix<br>• <code>{ORDER_ID}</code> - Order number<br>• "
"<code>{PRODUCT_SKU}</code> - Product SKU<br>• <code>{DATE:FORMAT}</code> - "
"Date (YYMMDD, YYYYMMDD, etc.)"
msgstr ""
"Definisci il formato della chiave di licenza utilizzando i segnaposto:<br>• "
"<code>{RANDOM:N}</code> - N caratteri casuali<br>• <code>{CHECKSUM:N}</code> "
"- checksum di N cifre<br>• <code>{PREFIX}</code> - prefisso del modello<br>• "
"<code>{SUFFIX}</code> - suffisso del modello<br>• <code>{ORDER_ID}</code> - "
"numero dell'ordine<br>• <code>{PRODUCT_SKU}</code> - SKU del prodotto<br>• "
"<code>{DATE:FORMAT}</code> - Data (YYMMDD, YYYYMMDD, ecc.)"

