msgid "Get products in category"
msgstr "श्रेणी में उत्पाद प्राप्त करें"

msgid "List all brands"
msgstr "सभी ब्रांडों की सूची"

msgid "Get brand details"
msgstr "ब्रांड विवरण प्राप्त करें"

msgid "Get brand products"
msgstr "ब्रांड उत्पाद प्राप्त करें"

msgid "List all product attributes"
msgstr "सभी उत्पाद गुण सूची"

msgid "Get attribute details with values"
msgstr "मानों के साथ गुण विवरण प्राप्त करें"

msgid "List all products"
msgstr "सभी उत्पादों की सूची"

msgid "Get product details"
msgstr "उत्पाद विवरण प्राप्त करें"

msgid "Track product view"
msgstr "उत्पाद दृश्य प्रबंधित करें"

msgid "Get featured products"
msgstr "विशेष उत्पाद प्राप्त करें"

msgid "Search products"
msgstr "उत्पाद खोजें"

msgid "Get recently viewed products"
msgstr "हाल ही में देखे गए उत्पाद प्राप्त करें"

msgid "Find variant by attribute selection"
msgstr "गुण चयन द्वारा वैरिएंट खोजें"

msgid "Get product customization options"
msgstr "उत्पाद अनुकूलन विकल्प प्राप्त करें"

msgid "Validate customization values"
msgstr "अनुकूलन मानों की जांच करें"

msgid "Get configurator data"
msgstr "कॉन्फिगरेटर डेटा प्राप्त करें"

msgid "Validate configuration"
msgstr "कॉन्फिगरेशन का अनुमोदन करें"

msgid "Calculate configuration price"
msgstr "कॉन्फिगरेशन की कीमत गणना करें"

msgid "Get configuration presets"
msgstr "कॉन्फिगरेशन प्रीसेट प्राप्त करें"

msgid "Get trending products"
msgstr "ट्रेंडिंग उत्पाद प्राप्त करें"

msgid "Get products sorted by views in the last 7 days."
msgstr "पिछले 7 दिनों में देखे गए उत्पादों के आधार पर उत्पाद प्राप्त करें।"

msgid "Number of products (default: 12, max: 50)"
msgstr "उत्पादों की संख्या (डिफ़ॉल्ट: 12, अधिकतम: 50)"

msgid "Get bestseller products"
msgstr "बेस्टसेलर उत्पाद प्राप्त करें"

msgid "Get top-selling products based on sales count."
msgstr "बिक्री की गई उत्पादों के आधार पर शीर्ष बिक्री वाले उत्पाद प्राप्त करें।"

msgid "Time period: all, month, week (default: all)"
msgstr "समय अवधि: सभी, महीना, सप्ताह (डिफ़ॉल्ट: सभी)"

msgid "Get new arrival products"
msgstr "नए आए हुए उत्पाद प्राप्त करें"

msgid "Get recently added products."
msgstr "हाल ही में जोड़े गए उत्पाद प्राप्त करें।"

msgid "Products added in last N days (default: 30)"
msgstr "अंतिम N दिनों में जोड़े गए उत्पाद (डिफ़ॉल्ट: 30)"

msgid "Get products on sale"
msgstr "बिक्री पर उत्पाद प्राप्त करें"

msgid "Get products currently on sale (sale_price < regular price)."
msgstr "वर्तमान में बिक्री पर उत्पाद प्राप्त करें (बिक्री मूल्य < सामान्य मूल्य)"

msgid "Number of products (default: 24, max: 100)"
msgstr "उत्पादों की संख्या (डिफ़ॉल्ट: 24, अधिकतम: 100)"

msgid "Get clearance products"
msgstr "स्वीकृति उत्पाद प्राप्त करें"

msgid "Get products marked as clearance items."
msgstr "स्वीकृत आइटम के रूप में चिह्नित उत्पाद प्राप्त करें।"

msgid "Get bundle products"
msgstr "बैगल उत्पाद प्राप्त करें"

msgid "Get products that are bundles (contain multiple items)."
msgstr "बंडल (एक से अधिक आइटम शामिल) वाले उत्पाद प्राप्त करें।"

msgid "Get digital products"
msgstr "डिजिटल उत्पाद प्राप्त करें"

msgid "Get downloadable/digital products."
msgstr "डाउनलोड करने योग्य/डिजिटल उत्पाद प्राप्त करें।"

msgid "Get gift cards"
msgstr "गिफ्ट कार्ड प्राप्त करें"

msgid "Get available gift card products."
msgstr "उपलब्ध गिफ्ट कार्ड उत्पाद प्राप्त करें।"

msgid "Get related products"
msgstr "संबंधित उत्पाद प्राप्त करें"

msgid ""
"Get products related to a specific product (same category, brand, or "
"attributes)."
msgstr "एक विशिष्ट उत्पाद से संबंधित उत्पाद प्राप्त करें (समान श्रेणी, ब्रांड या गुणधर्म)।"

msgid "Number of products (default: 8, max: 20)"
msgstr "उत्पादों की संख्या (डिफ़ॉल्ट: 8, अधिकतम: 20)"

msgid "Get similar products"
msgstr "समान उत्पाद प्राप्त करें"

msgid "Get products with similar attributes (size, color, price range)."
msgstr "एक जैसे गुणों (आकार, रंग, मूल्य परिसर) वाले उत्पाद प्राप्त करें।"

msgid "Get frequently bought together"
msgstr "अक्सर एक साथ खरीदे गए वस्तुओं को प्राप्त करें"

msgid "Get products frequently purchased together with this product."
msgstr "इस उत्पाद के साथ अक्सर खरीदे गए उत्पाद प्राप्त करें।"

msgid "Number of products (default: 4, max: 10)"
msgstr "उत्पादों की संख्या (डिफ़ॉल्ट: 4, अधिकतम: 10)"

msgid "Get upsell products"
msgstr "अपसेल उत्पाद प्राप्त करें"

msgid "Get higher-priced alternatives or upgrades for this product."
msgstr "इस उत्पाद के लिए उच्च मूल्य वाले विकल्पों या अपग्रेड प्राप्त करें।"

msgid "Get cross-sell products"
msgstr "क्रॉस-बेच उत्पाद प्राप्त करें"

msgid "Get complementary products that go well with this product."
msgstr "इस उत्पाद के साथ अच्छा मिलता है उत्पादों को प्राप्त करें।"

msgid "Get full configurator data"
msgstr "पूर्ण संfigurator डेटा प्राप्त करें"

msgid ""
"Returns the complete configurator payload for a configurable product, "
"including all slots with their options, compatibility rules, presets, and "
"pricing strategy. Used by the frontend configurator wizard to render the "
"step-by-step configuration interface."
msgstr ""
"एक संfigurable उत्पाद के लिए पूर्ण कॉन्फिगरेटर पेलोड लौटाता है, जिसमें सभी स्लॉट शामिल "
"होते हैं, जिनके विकल्प, संगतता नियम, पूर्वनिर्धारित रूप और मूल्य रणनीति शामिल होते हैं। "
"फ्रंटएंड कॉन्फिगरेटर विजार्ड द्वारा चरण-दर-चरण कॉन्फिगरेशन इंटरफ़ेस रेंडर करने के लिए उपयोग "
"किया जाता है।"

msgid "Product not found or not configurable"
msgstr "उत्पाद नहीं मिला या असंभव है"

msgid "Validate a configuration"
msgstr "एक विन्यास की जांच करें"

msgid ""
"Validates a complete or partial configuration against slot requirements and "
"compatibility rules. Returns validity status, any errors, and the calculated "
"total price if valid."
msgstr ""
"एक पूर्ण या आंशिक विन्यास को स्लॉट आवश्यकताओं और संगतता नियमों के खिलाफ जांचता है। वैधता "
"स्थिति, कोई भी त्रुटि, और यदि वैध है तो गणना किए गए कुल मूल्य लौटाता है।"

msgid "Invalid request body"
msgstr "अमान्य अनुरोध शरीर"

msgid ""
"Calculate the total price for a partial or complete configuration. Does not "
"validate compatibility — use the validate endpoint for full validation."
msgstr ""
"एक आंशिक या पूर्ण विन्यास के लिए कुल मूल्य की गणना करें। संगतता की जांच नहीं करता है — पूर्ण "
"जांच के लिए वैलिडेट एंडपॉइंट का उपयोग करें।"

msgid ""
"Returns pre-built configuration presets with calculated prices. Presets "
"provide starting configurations customers can use and then customize."
msgstr ""
"पूर्व-निर्मित संfiguration प्रीसेट्स जो गणना किए गए मूल्यों के साथ लौटाते हैं। प्रीसेट्स "
"ग्राहकों के लिए शुरुआती संfiguration प्रदान करते हैं जिनका उपयोग करके फिर उन्हें अनुकूलित "
"किया जा सकता है।"

msgid "List all collections"
msgstr "सभी संग्रहों की सूची"

msgid "Get collection details"
msgstr "संग्रह विवरण प्राप्त करें"

msgid "Get products in collection"
msgstr "संग्रह में उत्पाद प्राप्त करें"

msgid "List all reviews"
msgstr "सभी समीक्षाओं की सूची"

msgid "Get review details"
msgstr "समीक्षा विवरण प्राप्त करें"

msgid "Create a review"
msgstr "एक समीक्षा बनाएं"

msgid "Update a review"
msgstr "एक समीक्षा अपडेट करें"

msgid "Partially update a review"
msgstr "एक समीक्षा को आंशिक रूप से अपडेट करें"

msgid "Delete a review"
msgstr "एक समीक्षा हटाएं"

msgid "Mark review as helpful"
msgstr "समीक्षा को उपयोगी चिह्नित करें"

msgid "Get catalog statistics"
msgstr "कैटलॉग सांख्यिकी प्राप्त करें"

msgid ""
"Retrieve catalog-wide statistics including total products, featured "
"products, products in stock, category count, brand count, and collection "
"count. Useful for dashboard displays and analytics."
msgstr ""
"कुल उत्पादों, विशेष उत्पादों, स्टॉक में उत्पादों, श्रेणी गणना, ब्रांड गणना और संग्रह गणना "
"शामिल करके कैटलॉग-वार सांख्यिकी जानकारी प्राप्त करें। डैशबोर्ड प्रदर्शन और विश्लेषण के लिए "
"उपयोगी है।"

msgid "Catalog statistics"
msgstr "कैटलॉग सांख्यिकी"

msgid "Get product recommendations"
msgstr "उत्पाद रिकॉमेंडेशन प्राप्त करें"

msgid ""
"\n"
"    Returns product recommendations for upselling opportunities such as mini-"
"cart empty state,\n"
"    checkout page suggestions, or related products sections.\n"
"\n"
"    **Priority Logic:**\n"
"    1. Featured products are returned first\n"
"    2. If fewer featured products than requested limit, fills with latest "
"published products\n"
"\n"
"    **Use Cases:**\n"
"    - Mini-cart empty state: Show popular items to encourage purchases\n"
"    - Checkout cross-sells: Display complementary products\n"
"    - Homepage recommendations: Highlight featured inventory\n"
"    "
msgstr ""
"\n"
"    उत्पाद अनुशंसाएं लौटाता है जो छोटे कार्ट रिक्त स्थिति, चेकआउट पृष्ठ सुझाव या संबंधित "
"उत्पादों के अनुभाग के लिए अपसेलिंग के अवसरों के लिए हैं। **प्राथमिकता तर्क:** 1. पहले विशेष "
"उत्पाद लौटाए जाते हैं 2. यदि अनुरोधित सीमा से कम विशेष उत्पाद हैं, तो नवीनतम प्रकाशित "
"उत्पादों के साथ भर दिया जाता है। **उपयोग केस:** - छोटे कार्ट रिक्त स्थिति: खरीद को "
"उत्प्रेरित करने के लिए लोकप्रिय आइटम दिखाएं - चेकआउट क्रॉस-बेच: संबंधित उत्पादों का प्रदर्शन "
"करें - होमपेज अनुशंसाएं: विशेष इनवेंटरी का उल्लेख करें\n"
"    "

msgid "Maximum number of products to return (1-10, default: 4)"
msgstr "वापस लौटाने के लिए अधिकतम उत्पादों की संख्या (1-10, पूर्वनिर्धारित: 4)"

msgid "List of recommended products"
msgstr "रिकॉमेंड किए गए उत्पादों की सूची"

msgid ""
"Retrieve catalog statistics including product counts, category counts, etc."
msgstr "कैटलॉग सांख्यिकी जैसे उत्पाद गिनती, श्रेणी गिनती आदि रिक्वेस्ट करें"

msgid "Get available filter options"
msgstr "उपलब्ध फ़िल्टर विकल्प प्राप्त करें"

msgid ""
"Retrieve all available filter options for product filtering including "
"categories, brands, price ranges, and product types. Used to populate filter "
"UI components."
msgstr ""
"उत्पाद के फ़िल्टरिंग के लिए उपलब्ध सभी फ़िल्टर विकल्प प्राप्त करें, जिसमें श्रेणियाँ, ब्रांड, मूल्य "
"परिसर और उत्पाद प्रकार शामिल हैं। फ़िल्टर UI घटकों को भरने के लिए उपयोग किया जाता है।"

msgid "Available filter options"
msgstr "उपलब्ध फ़िल्टर विकल्प"

msgid "Check stock at specific warehouses"
msgstr "विशिष्ट वर्कशॉप में स्टॉक की जांच करें"

msgid ""
"Check real-time stock availability for a product at specific warehouse "
"locations. Optionally calculate distance from customer location. Returns on-"
"hand, allocated, and available quantities per warehouse."
msgstr ""
"विशिष्ट डिपो स्थानों पर एक उत्पाद के वास्तविक समय में स्टॉक उपलब्धता की जांच करें। ग्राहक "
"स्थान से दूरी की गणना करना आवश्यक नहीं है। प्रत्येक डिपो के लिए हाथ में, आवंटित और उपलब्ध "
"मात्रा लौटाता है।"

msgid ""
"Comma-separated list of warehouse codes to check (e.g., 'MAIN-WH,WC-WH')"
msgstr "जांच के लिए वर्कशॉप कोड की एक कोमा-अलग लिस्ट (उदा., 'MAIN-WH,WC-WH')"

msgid "Customer's postal code for distance calculation"
msgstr "ग्राहक का डिस्टेंस कैलकुलेशन के लिए पोस्टल कोड"

msgid "List all pickup locations"
msgstr "सभी पिकअप स्थानों की सूची"

msgid ""
"Get all warehouse locations that support customer pickup (buy online, pick "
"up in store). Optionally filter by product availability and calculate "
"distances from customer location."
msgstr ""
"सभी वर्कशॉप स्थानों को प्राप्त करें जो ग्राहक द्वारा खरीदे जाने के लिए समर्थन करते हैं "
"(ऑनलाइन खरीदें, स्टोर में ले जाएं)। उत्पाद उपलब्धता के आधार पर वैकल्पिक रूप से फ़िल्टर करें और "
"ग्राहक स्थान से दूरी की गणना करें।"

msgid "Filter to only locations with stock of this product"
msgstr "केवल ऐसे स्थानों के लिए फ़िल्टर करें जहां इस उत्पाद का स्टॉक है"

msgid "Customer latitude for distance calculation"
msgstr "ग्राहक की अक्षांश दूरी की गणना के लिए"

msgid "Customer longitude for distance calculation"
msgstr "ग्राहक की देशांतर दूरी की गणना के लिए"

msgid "Check gift card balance"
msgstr "गिफ्ट कार्ड बैलेंस जांचें"

msgid ""
"Check the balance of a gift card without requiring authentication. Public "
"endpoint."
msgstr ""
"एक गिफ्ट कार्ड के बैलेंस की जांच करें बिना सत्यापन की आवश्यकता के। सार्वजनिक एंडपॉइंट।"

msgid "Gift card found"
msgstr "गिफ्ट कार्ड मिला"

msgid "Gift card not found"
msgstr "गिफ्ट कार्ड नहीं मिला"

msgid "Invalid request (missing code)"
msgstr "अमान्य अनुरोध (कोड अपूर्ण)"

msgid "Get product availability"
msgstr "उत्पाद उपलब्धता प्राप्त करें"

msgid ""
"\n"
"    Returns comprehensive stock availability and fulfillment information for "
"a product.\n"
"\n"
"    **Features:**\n"
"    - Stock status (in_stock, low_stock, out_of_stock, preorder, backorder)\n"
"    - Warehouse location display (if enabled)\n"
"    - Notify Me availability (if product is out of stock)\n"
"    - Pre-order information with release dates\n"
"    - Backorder availability\n"
"    - Respects cascading settings: Product > Category > Site-wide\n"
"\n"
"    **Use cases:**\n"
"    - Product page stock display\n"
"    - Cart validation\n"
"    - Stock status badges\n"
"    "
msgstr ""
"\n"
"    एक उत्पाद के लिए व्यापक स्टॉक उपलब्धता और पूर्ति जानकारी लौटाता है। **विशेषताएं:** "
"- स्टॉक स्थिति (in_stock, low_stock, out_of_stock, preorder, backorder) - डिपो "
"स्थान प्रदर्शन (यदि सक्षम है) - मुझे सूचना दें उपलब्धता (यदि उत्पाद स्टॉक से बाहर है) - आदेश "
"पूर्व जानकारी के साथ रिलीज तिथियां - बैकऑर्डर उपलब्धता - ड्रॉप-डाउन सेटिंग्स का सम्मान "
"करता है: उत्पाद > श्रेणी > साइट-व्यापी **उपयोग केस:** - उत्पाद पृष्ठ स्टॉक प्रदर्शन - "
"कार्ट वैधता - स्टॉक स्थिति बैज\n"
"    "

msgid "ISO 3166-1 alpha-2 country code (e.g., US, GB, AU) for regional stock"
msgstr "क्षेत्रीय स्टॉक के लिए ISO 3166-1 अल्फा-2 देश कोड (उदाहरण के लिए, US, GB, AU)"

msgid "Specific variant ID to check availability for"
msgstr "उपलब्धता के लिए जांच के लिए विशिष्ट वेरिएंट आईडी"

msgid "Product availability data"
msgstr "उत्पाद उपलब्धता डेटा"

msgid "Subscribe to stock notification"
msgstr "स्टॉक सूचना के लिए सदस्यता लें"

msgid ""
"\n"
"    Subscribe to receive an email notification when a product comes back in "
"stock.\n"
"\n"
"    **Rate limiting:** This endpoint should be rate-limited to prevent "
"abuse.\n"
"    "
msgstr ""
"\n"
"    एक उत्पाद के स्टॉक में वापस आने पर ईमेल सूचना प्राप्त करने के लिए सदस्यता लें। **दर "
"सीमा नियंत्रण:** इस अंत में दर सीमा नियंत्रण करना चाहिए ताकि दुर्विस्तार को रोका जा "
"सके।\n"
"    "

msgid "Successfully subscribed"
msgstr "सफलतापूर्वक सदस्यता ली"

msgid "Invalid email or already subscribed"
msgstr "अमान्य ईमेल या पहले से ही सदस्यता ली गई है"

msgid "List product attribute assignments"
msgstr "उत्पाद गुण आवंटन सूची"

msgid ""
"Returns all attributes assigned to a product with their allowed values and "
"full value sets. **Admin only.**"
msgstr ""
"एक उत्पाद के सभी विशेषताओं को लौटता है जिनके अनुमत मान और पूर्ण मान सेट होते हैं। **केवल "
"प्रशासक।**"

msgid "List of attribute assignments with values"
msgstr "मानों के साथ गुण आवंटनों की सूची"

msgid "Search available attributes"
msgstr "उपलब्ध गुण खोजें"

msgid ""
"Returns attributes not yet assigned to the product, filtered by optional "
"search query. **Admin only.**"
msgstr ""
"उत्पाद के लिए अभी तक आवंटित नहीं किए गए विशेषताओं को लौटता है, जो एक वैकल्पिक खोज "
"प्रश्न द्वारा फ़िल्टर किया गया है। **केवल प्रशासक।**"

msgid "Search query to filter attribute names"
msgstr "एट्रिब्यूट नामों को फ़िल्टर करने के लिए खोज प्रश्न"

msgid "List of available attributes"
msgstr "उपलब्ध गुणों की सूची"

msgid "Add attribute to product"
msgstr "उत्पाद के लिए एट्रिब्यूट जोड़ें"

msgid ""
"Creates a new attribute assignment for the product. All attribute values are "
"enabled by default. **Admin only.**"
msgstr ""
"उत्पाद के लिए एक नया एट्रिब्यूट असाइनमेंट बनाता है। सभी एट्रिब्यूट मानों को पूर्वनिर्धारित "
"रूप से सक्रिय कर दिया जाता है। **केवल प्रशासक।**"

msgid "Attribute assigned successfully"
msgstr "एट्रिब्यूट सफलतापूर्वक निर्धारित कर दिया गया"

msgid "Invalid request or attribute already assigned"
msgstr "अमान्य अनुरोध या एट्रिब्यूट पहले से निर्धारित किया गया है"

msgid "Product or attribute not found"
msgstr "उत्पाद या एट्रिब्यूट नहीं मिला"

msgid "Remove attribute from product"
msgstr "उत्पाद से एट्रिब्यूट हटाएं"

msgid ""
"Deletes an attribute assignment. Returns count of variants that used this "
"attribute. **Admin only.**"
msgstr ""
"एक एट्रिब्यूट निर्धारण को हटाता है। इस एट्रिब्यूट का उपयोग करने वाले वेरिएंट्स की संख्या "
"लौटाता है। **केवल प्रशासक**"

msgid "Attribute removed successfully"
msgstr "एट्रिब्यूट सफलतापूर्वक हटा दिया गया"

msgid "Assignment not found"
msgstr "निर्धारण नहीं मिला"

msgid "Update allowed attribute values"
msgstr "अनुमोदित गुण मान अपडेट करें"

msgid ""
"Replaces the set of allowed values for an attribute assignment. **Admin only."
"**"
msgstr "एक एट्रिब्यूट आवंटन के लिए अनुमोदित मूल्यों के सेट को बदलता है। **केवल प्रशासक।**"

msgid "Values updated successfully"
msgstr "मान सफलतापूर्वक अपडेट कर दिए गए"

msgid "Invalid request"
msgstr "अमान्य अनुरोध"

msgid "Catalog"
msgstr "कैटलॉग"

msgid "Enter amounts separated by commas (e.g., 25, 50, 100)"
msgstr "अपने अल्पविराम द्वारा राशि दर्ज करें (उदा., 25, 50, 100)"

#, python-format
msgid ""
"Invalid value \"%(value)s\". Please enter numbers only, separated by commas."
msgstr ""
"अमान्य मान \"%(value)s\"। कृपया केवल संख्याएं दर्ज करें, आप उन्हें अपने बीच कोमा से अलग कर "
"सकते हैं।"

#, python-format
msgid "All amounts must be positive numbers. Found: %(value)s"
msgstr "सभी राशि सकारात्मक संख्याएं होनी चाहिए। पाया: %(value)s"

msgid ""
"Select attribute values for this variant. Only values for attributes "
"assigned to this product are shown."
msgstr ""
"इस वेरिएंट के लिए गुण मान चुनें। केवल इस उत्पाद के लिए निर्धारित गुणों के मान दिखाए जाते हैं।"

msgid ""
"No attributes assigned to this product yet. Add attributes in the 'Product "
"Attributes & Variations' section above."
msgstr ""
"अभी तक इस उत्पाद के लिए कोई गुण निर्धारित नहीं हैं। ऊपर 'उत्पाद गुण और वेरिएंट्स' अनुभाग "
"में गुण जोड़ें।"

msgid "Validate a license key"
msgstr "एक लाइसेंस की जांच करें"

msgid ""
"\n"
"    Validate a license key without activating it.\n"
"\n"
"    This endpoint checks:\n"
"    - License key exists and is valid format\n"
"    - License is active (not suspended, expired, or revoked)\n"
"    - License has not exceeded expiration date\n"
"    - Optionally validates key is for a specific product\n"
"\n"
"    **Public endpoint** - no authentication required.\n"
"    Use this for quick validation checks before activation.\n"
"    "
msgstr ""
"\n"
"    एक लाइसेंस की जांच करें बिना इसे सक्रिय करे। यह एंडपॉइंट जांचता है: - लाइसेंस की जांच "
"करें और यह मान्य प्रारूप है - लाइसेंस सक्रिय है (सस्पेंड, अतीत या रद्द नहीं है) - लाइसेंस अपनी "
"अवधि के बाहर नहीं है - वैकल्पिक रूप से जांच करें कि की एक विशिष्ट उत्पाद के लिए है "
"**सार्वजनिक एंडपॉइंट** - कोई प्रमाणीकरण आवश्यक नहीं है। इसका उपयोग सक्रियता से पहले "
"त्वरित जांच के लिए करें।\n"
"    "

msgid "Activate a license on a device"
msgstr "एक उपकरण पर एक लाइसेंस सक्रिय करें"

msgid ""
"\n"
"    Activate a license key on a specific device.\n"
"\n"
"    This endpoint:\n"
"    - Validates the license key\n"
"    - Checks activation limits\n"
"    - Registers the device with a unique fingerprint\n"
"    - Tracks IP address and device information\n"
"    - Dispatches webhook events\n"
"    - Syncs to external providers (if configured)\n"
"\n"
"    **Public endpoint** - no authentication required.\n"
"\n"
"    **Device Fingerprint:** Should be a unique, stable identifier for the "
"device.\n"
"    Recommended format: hash of (CPU ID + MAC address + motherboard serial) "
"or similar.\n"
"    "
msgstr ""
"\n"
"    एक विशिष्ट उपकरण पर एक लाइसेंस की जांच करें। यह एंडपॉइंट: - लाइसेंस की जांच करें - "
"सक्रियता सीमा की जांच करें - उपकरण के साथ एक अद्वितीय अंगूठा छाप दर्ज करें - आईपी पता "
"और उपकरण जानकारी के ट्रैक करें - वेबहुक घटनाओं के बर्ताने के लिए - बाहरी प्रदाताओं के साथ "
"सिंक करें (यदि स्थापित किया गया है) **सार्वजनिक एंडपॉइंट** - कोई प्रमाणीकरण आवश्यक नहीं "
"है। **उपकरण अंगूठा छाप:** उपकरण के लिए एक अद्वितीय और स्थायी पहचानकर्ता होना चाहिए। "
"सिफारिश किया गया प्रारूप: (CPU ID + MAC पता + मदरबोर्ड अनुक्रम) के हैश या इसके "
"समान।\n"
"    "

msgid "Invalid request or activation failed"
msgstr "अमान्य अनुरोध या सक्रियता विफल रही"

msgid "License not found"
msgstr "लाइसेंस नहीं मिला"

msgid "Deactivate a license from a device"
msgstr "एक उपकरण से एक लाइसेंस अक्रिय करें"

msgid ""
"\n"
"    Deactivate a license key from a specific device.\n"
"\n"
"    This frees up an activation slot for use on another device.\n"
"    Requires the device fingerprint that was used during activation.\n"
"\n"
"    **Public endpoint** - no authentication required.\n"
"    "
msgstr ""
"\n"
"    एक विशिष्ट उपकरण से एक लाइसेंस की अस्थायी रूप से बंद करें। यह दूसरे उपकरण पर उपयोग के "
"लिए एक एक्टिवेशन स्लॉट को खाली कर देता है। एक्टिवेशन के दौरान उपयोग किए गए उपकरण के "
"फिंगरप्रिंट की आवश्यकता होती है। **सार्वजनिक अंत मार्ग** - प्रमाणीकरण की आवश्यकता नहीं "
"होती।\n"
"    "

msgid "Invalid request or deactivation failed"
msgstr "अमान्य अनुरोध या डिएक्टिवेशन विफल रहा"

msgid "License or activation not found"
msgstr "लाइसेंस या एक्टिवेशन नहीं मिला"

msgid "Get license information"
msgstr "लाइसेंस जानकारी प्राप्त करें"

msgid ""
"\n"
"    Retrieve detailed information about a license key.\n"
"\n"
"    Returns license status, activation details, expiration info, and "
"activation history.\n"
"\n"
"    **Public endpoint** - no authentication required.\n"
"    "
msgstr ""
"\n"
"    एक लाइसेंस कुंजी के बारे में विस्तृत जानकारी प्राप्त करें। लाइसेंस स्थिति, सक्रियता विवरण, "
"समाप्ति जानकारी और सक्रियता ऐतिहासिक जानकारी लौटाता है। **सार्वजनिक अंत मार्ग** - "
"प्रमाणीकरण की आवश्यकता नहीं।\n"
"    "

msgid "List license pools"
msgstr "लाइसेंस पूल सूची"

msgid "List all license pools. **Admin only.**"
msgstr "सभी लाइसेंस पूलों की सूची। **केवल प्रशासक।**"

msgid "Get license pool details"
msgstr "लाइसेंस पूल विवरण प्राप्त करें"

msgid "Get details of a specific license pool. **Admin only.**"
msgstr "एक विशिष्ट लाइसेंस पूल के विवरण प्राप्त करें। **केवल प्रशासक।**"

msgid "Bulk generate license keys"
msgstr "बैच लाइसेंस कुंजी उत्पन्न करें"

msgid ""
"\n"
"    Generate license keys in bulk for a license pool.\n"
"\n"
"    This endpoint can be used to:\n"
"    - Generate all remaining keys for a pool\n"
"    - Generate a specific number of additional keys\n"
"\n"
"    **Admin only.**\n"
"    **May run as background task for large batches (>1000 keys).**\n"
"    "
msgstr ""
"\n"
"    एक लाइसेंस पूल के लिए बैच में लाइसेंस कुंजियां उत्पादित करें। इस अंत मार्ग का उपयोग किया "
"जा सकता है: - एक पूल के लिए शेष सभी कुंजियों की उत्पत्ति - एक विशिष्ट संख्या में अतिरिक्त "
"कुंजियों की उत्पत्ति **केवल प्रशासक।** **बड़े बैच (1000 से अधिक कुंजियां) के लिए पृष्ठभूमि "
"कार्य के रूप में चल सकता है।**\n"
"    "

msgid "Pool not found"
msgstr "पूल नहीं मिला"

msgid "License key to validate"
msgstr "सत्यापित करने के लिए लाइसेंस की चाबी"

msgid "Optional product ID to validate key against"
msgstr "की के खिलाफ जांच के लिए वैकल्पिक उत्पाद ID"

msgid "License key to activate"
msgstr "सक्रिय करने के लिए लाइसेंस की चाबी"

msgid "Unique device identifier"
msgstr "यूनिक डिवाइस आइडेंटिफायर"

msgid "Human-readable device name (e.g., 'John's MacBook Pro')"
msgstr "मनुष्य द्वारा पढ़ा जा सकने वाला उपकरण नाम (उदा., 'जॉन का मैकबुक प्रो')"

msgid "Additional device information (OS, version, etc.)"
msgstr "अतिरिक्त उपकरण जानकारी (ओएस, संस्करण, आदि)"

msgid "License key"
msgstr "लाइसेंस की"

msgid "Device fingerprint to deactivate"
msgstr "अक्टिवेट करने के लिए डिवाइस फिंगरप्रिंट"

msgid "License pool ID to generate keys for"
msgstr "की उत्पन्न करने के लिए लाइसेंस पूल ID"

msgid "Number of keys to generate (defaults to pool.total_keys)"
msgstr "उत्पन्न करने के लिए की की संख्या (डिफ़ॉल्ट पूल.total_keys के रूप में होता है)"

msgid "Celery task ID for background generation (if async)"
msgstr "पृष्ठभूमि उत्पन्न के लिए Celery कार्य ID (यदि एसिंक्रोनस)"

msgid "License key to get information for"
msgstr "जानकारी के लिए लाइसेंस की"

msgid "Default Region"
msgstr "डिफ़ॉल्ट क्षेत्र"

msgid "Main Warehouse"
msgstr "मुख्य डिपो"

msgid "Use Site Default"
msgstr "साइट के डिफ़ॉल्ट का उपयोग करें"

msgid "Grid"
msgstr "ग्रिड"

msgid "List"
msgstr "सूची"

msgid "Carousel"
msgstr "कैरोसेल"

msgid "Masonry"
msgstr "मॉन्स्ट्री"

msgid "Featured"
msgstr "विशेष"

msgid "Accordion"
msgstr "एकोर्डियन"

msgid "Page Template"
msgstr "पृष्ठ टेम्पलेट"

msgid ""
"Override the site default category page template. Leave empty to use the "
"site default from Design settings."
msgstr ""
"साइट के डिफ़ॉल्ट श्रेणी पृष्ठ टेम्पलेट को ओवरराइड करें। डिज़ाइन सेटिंग्स से साइट डिफ़ॉल्ट का "
"उपयोग करने के लिए खाली छोड़ दें।"

msgid "out of stock action override"
msgstr "आउट ऑफ स्टॉक क्रिया के ओवरराइड"

msgid "Hide from listings"
msgstr "सूची से छिपाएं"

msgid "Show as unavailable"
msgstr "अव्यवहार्य के रूप में दिखाएं"

msgid "Show \"Notify Me\" button"
msgstr "मुझे सूचना दें बटन दिखाएं"

msgid "Allow backorders"
msgstr "बैकऑर्डर्स की अनुमति दें"

msgid "Override site-wide out-of-stock behavior for products in this category"
msgstr "इस श्रेणी में उत्पादों के लिए साइट-व्यापी स्टॉक बाहर व्यवहार को ओवरराइड करें"

msgid "allow backorders override"
msgstr "बैकऑर्डर्स के ओवरराइड की अनुमति दें"

msgid ""
"Override site-wide backorder setting for products in this category (None = "
"inherit from site)"
msgstr ""
"इस श्रेणी में उत्पादों के लिए साइट-व्यापी बैकऑर्डर सेटिंग को ओवरराइड करें (कोई नहीं = साइट "
"से अनुग्रह)"

msgid "Category"
msgstr "श्रेणी"

msgid "Categories"
msgstr "श्रेणियां"

msgid "Simple Product"
msgstr "सरल उत्पाद"

msgid "Variable Product"
msgstr "चर उत्पाद"

msgid "Digital Product"
msgstr "डिजिटल उत्पाद"

msgid "Product Bundle"
msgstr "उत्पाद बंडल"

msgid "Customizable Product"
msgstr "अनुकूलनीय उत्पाद"

msgid "Configurable Product"
msgstr "संfigurable उत्पाद"

msgid "Booking Product"
msgstr "बुकिंग उत्पाद"

msgid "Dynamic Pricing (convert from base currency)"
msgstr "आधार मुद्रा से परिवर्तित करते हुए गतिशील मूल्य"

msgid "Fixed Pricing (set prices per currency)"
msgstr "मुद्रा के अनुसार मूल्यों की सेटिंग करते हुए निश्चित मूल्य"

msgid "Pricing Strategy"
msgstr "मूल्य रणनीति"

msgid ""
"How to calculate prices in different currencies. Dynamic: Auto-convert using "
"exchange rates. Fixed: Set custom prices per currency."
msgstr ""
"अलग-अलग मुद्राओं में मूल्यों की गणना कैसे करें। गतिशील: विनिमय दर का उपयोग करके स्वचालित "
"परिवर्तित करें। निश्चित: मुद्रा के अनुसार विशिष्ट मूल्यों को सेट करें।"

msgid "Fixed Price"
msgstr "फिक्स्ड प्राइस"

msgid "Percentage Discount"
msgstr "प्रतिशत छूट"

msgid "Sum of Components"
msgstr "घटकों के योग"

msgid "Bundle Pricing Strategy"
msgstr "बंडल मूल्य रणनीति"

msgid ""
"How to calculate bundle price. Fixed: Use the price field. Percentage "
"Discount: Apply discount to component sum. Components Sum: Total of all "
"components."
msgstr ""
"बंडल मूल्य की गणना कैसे करें। निश्चित: मूल्य क्षेत्र का उपयोग करें। प्रतिशत छूट: घटक योग पर "
"छूट लागू करें। घटक योग: सभी घटकों का कुल।"

msgid "Bundle Discount Percentage"
msgstr "बंडल छूट प्रतिशत"

#, python-format
msgid ""
"Discount percentage off component total (e.g., 15.00 for 15% off). Only used "
"with 'Percentage Discount' strategy."
msgstr ""
"कंपोनेंट के कुल मूल्य पर छूट प्रतिशत (उदाहरण के लिए, 15.00 के लिए 15% छूट). केवल 'प्रतिशत "
"छूट' रणनीति के साथ उपयोग किया जाता है।"

msgid "Customer Chooses Amount"
msgstr "ग्राहक राशि चुनता है"

msgid "Both Fixed and Custom"
msgstr "फिक्स्ड और कस्टम दोनों"

msgid "Denomination Type"
msgstr "राशि प्रकार"

msgid ""
"How customers select gift card value. Fixed: Choose from preset amounts. "
"Custom: Enter any amount. Both: Preset amounts + custom option."
msgstr ""
"ग्राहक गिफ्ट कार्ड मूल्य कैसे चुनते हैं। निश्चित: पूर्व-सेट मात्राओं से चुनें। विशिष्ट: कोई भी "
"राशि दर्ज करें। दोनों: पूर्व-सेट मात्राएं + विशिष्ट विकल्प।"

msgid ""
"List of preset amounts (e.g., [25, 50, 100, 200]). Currency symbol not "
"needed."
msgstr ""
"पूर्व-सेट मात्राओं की सूची (उदा., [25, 50, 100, 200])। मुद्रा प्रतीक की आवश्यकता नहीं है।"

msgid "Minimum Amount"
msgstr "न्यूनतम राशि"

msgid "Minimum value for custom amount gift cards"
msgstr "विशिष्ट राशि गिफ्ट कार्ड के लिए न्यूनतम मान"

msgid "Maximum Amount"
msgstr "अधिकतम राशि"

msgid "Maximum value for custom amount gift cards"
msgstr "विशिष्ट राशि गिफ्ट कार्ड के लिए अधिकतम मान"

msgid "Expires After (Days)"
msgstr "के बाद समाप्त हो जाता है (दिन)"

msgid "Days until gift card expires after purchase (0 = never expires)"
msgstr ""
"खरीदारी के बाद गिफ्ट कार्ड के अप्रचलित होने तक के दिन (0 = कभी नहीं अप्रचलित होता)"

msgid "Gift Card Currency"
msgstr "गिफ्ट कार्ड मुद्रा"

msgid ""
"Currency for issued gift cards. Leave blank for store's base currency. When "
"set, gift cards are issued in this currency with value converted at the "
"exchange rate at time of purchase."
msgstr ""
"वितरित गिफ्ट कार्ड के लिए मुद्रा। स्टोर की आधार मुद्रा के लिए खाली छोड़ दें। जब इसे सेट "
"किया जाता है, तो गिफ्ट कार्ड इस मुद्रा में जारी किया जाता है और मूल्य खरीदारी के समय के "
"विनिमय दर पर परिवर्तित किया जाता है।"

msgid "Allow Customization"
msgstr "अनुकूलन की अनुमति दें"

msgid ""
"Does this product support customer customization (text, images, choices)?"
msgstr "क्या यह उत्पाद ग्राहक अनुकूलन (टेक्स्ट, चित्र, विकल्प) का समर्थन करता है?"

msgid "Preview Template"
msgstr "पूर्व दृश्य टेम्पलेट"

msgid "Template name for rendering customization preview (optional)"
msgstr "अनुकूलन पूर्वावलोकन के लिए टेम्पलेट नाम (वैकल्पिक)"

msgid "Base Price + Adjustments"
msgstr "मूल कीमत + समायोजन"

msgid "Configurator Pricing Strategy"
msgstr "कॉन्फिगरेटर मूल्य रणनीति"

msgid ""
"How the final price is calculated. Sum of Components: total of all selected "
"options. Base + Adjustments: base price plus per-option surcharges. Fixed: "
"use the product price field."
msgstr ""
"अंतिम मूल्य कैसे गणना किया जाता है। घटकों का योग: सभी चुने गए विकल्पों का कुल। आधार + "
"समायोजन: आधार मूल्य और प्रति-विकल्प अतिरिक्त शुल्क। निश्चित: उत्पाद मूल्य क्षेत्र का उपयोग "
"करें।"

msgid "Configurator Base Price"
msgstr "कॉन्फिगरेटर मूल कीमत"

msgid ""
"Starting price for 'Base Price + Adjustments' strategy. Each option's price "
"adjustment is added to this amount."
msgstr ""
"'आधार मूल्य + समायोजन' रणनीति के लिए शुरुआती मूल्य। प्रत्येक विकल्प के मूल्य समायोजन को इस "
"राशि में जोड़ दिया जाता है।"

msgid "Enable Subscription"
msgstr "सदस्यता को एनेबल करें"

msgid ""
"Allow customers to purchase this product as a subscription with recurring "
"billing"
msgstr ""
"ग्राहकों को इस उत्पाद की खरीदारी के लिए सदस्यता के रूप में अनुमति दें जो बार-बार भुगतान के "
"साथ होता है"

msgid "Subscription Plans"
msgstr "सदस्यता योजनाएं"

msgid ""
"Available subscription plans for this product. Customers can choose from "
"these plans."
msgstr "इस उत्पाद के लिए उपलब्ध सदस्यता योजनाएं। ग्राहक इन योजनाओं से चुन सकते हैं।"

msgid "Allow One-Time Purchase"
msgstr "एक बार की खरीद की अनुमति दें"

msgid ""
"Allow customers to buy this product without a subscription. If disabled, "
"subscription is required."
msgstr ""
"ग्राहकों को इस उत्पाद को सदस्यता के बिना खरीदने की अनुमति दें। यदि अक्षम कर दिया जाता "
"है, तो सदस्यता आवश्यक है।"

msgid "Default to Subscription"
msgstr "सदस्यता के डिफ़ॉल्ट करें"

msgid ""
"Pre-select subscription option in the product interface (one-time purchase "
"must also be allowed)"
msgstr ""
"उत्पाद इंटरफ़ेस में सदस्यता विकल्प को पूर्व चयनित करें (एक बार की खरीदारी भी अनुमति देने की "
"आवश्यकता होती है)"

msgid "Override category/site out-of-stock behavior for this product"
msgstr "इस उत्पाद के लिए श्रेणी/साइट स्टॉक बाहर व्यवहार को ओवरराइड करें"

msgid "is pre-order"
msgstr "प्री-ऑर्डर है"

msgid "Enable pre-order for this product (useful for upcoming releases)"
msgstr "इस उत्पाद के लिए पूर्व-आदेश सक्षम करें (आगामी लॉन्च के लिए उपयोगी)"

msgid "pre-order release date"
msgstr "प्री-ऑर्डर जारी तिथि"

msgid "Expected release/availability date for pre-orders"
msgstr "प्री-ऑर्डर के लिए अपेक्षित जारी/उपलब्धता तिथि"

msgid "pre-order message"
msgstr "प्री-ऑर्डर संदेश"

msgid "Custom pre-order message (e.g., \"Ships March 2025\")"
msgstr "कस्टम पूर्व-आदेश संदेश (उदा., \"मार्च 2025 में भेजा जाएगा\")"

msgid "Preferred Shipping Package"
msgstr "प्राथमिक शिपिंग पैकेज"

msgid ""
"Default package to use for shipping this product. If set, package dimensions "
"will be used instead of product dimensions for shipping calculations."
msgstr ""
"इस उत्पाद के लिए डिलीवरी के लिए डिफ़ॉल्ट पैकेज का उपयोग करें। यदि निर्धारित किया गया "
"है, तो डिलीवरी की गणना के लिए उत्पाद आयाम के बजाय पैकेज आयाम का उपयोग किया जाएगा।"

msgid "GTIN"
msgstr "जीटीआईएन"

msgid "Global Trade Item Number (GTIN-8, GTIN-12, GTIN-13, or GTIN-14)"
msgstr "वैश्विक व्यापार आइटम संख्या (GTIN-8, GTIN-12, GTIN-13, या GTIN-14)"

msgid "EAN"
msgstr "ईएएन"

msgid "European Article Number (EAN-13 or EAN-8)"
msgstr "यूरोपीय लेखा संख्या (EAN-13 या EAN-8)"

msgid "UPC"
msgstr "यूपीसी"

msgid "Universal Product Code (UPC-A or UPC-E)"
msgstr "सार्वभौमिक उत्पाद कोड (UPC-A या UPC-E)"

msgid "ISBN"
msgstr "आईएसबीएन"

msgid "International Standard Book Number (ISBN-10 or ISBN-13, for books)"
msgstr "अंतरराष्ट्रीय मानक पुस्तक संख्या (ISBN-10 या ISBN-13, पुस्तक के लिए)"

msgid "ASIN"
msgstr "एएसआईएन"

msgid "Amazon Standard Identification Number"
msgstr "एमएसआईएन"

msgid "MPN"
msgstr "एमपीएन"

msgid "Manufacturer Part Number"
msgstr "निर्माता भाग संख्या"

msgid "HS Code"
msgstr "एचएस कोड"

msgid ""
"Harmonized System code (6-12 digits) for customs classification. Required "
"for international shipping. Look up at hts.usitc.gov"
msgstr ""
"कस्टम वर्गीकरण के लिए समन्वित प्रणाली कोड (6-12 अंक)। अंतरराष्ट्रीय शिपमेंट के लिए आवश्यक "
"है। hts.usitc.gov पर खोजें"

msgid "Country of Origin"
msgstr "उत्पत्ति देश"

msgid ""
"ISO 3166-1 alpha-2 country code where product was manufactured. Required for "
"international shipping. Example: US, CN, DE"
msgstr ""
"उत्पाद जिस देश में बना था, वहां का ISO 3166-1 अल्फा-2 देश कोड। अंतरराष्ट्रीय शिपमेंट के "
"लिए आवश्यक है। उदाहरण: US, CN, DE"

msgid "Customs Unit Price"
msgstr "कुस्तम इकाई मूल्य"

msgid ""
"Declared value per unit for customs purposes. May differ from retail price. "
"Use cost or wholesale price if retail is significantly higher."
msgstr ""
"कस्टम के लिए प्रति इकाई घोषित मूल्य। यह खुदरा मूल्य से अलग हो सकता है। यदि खुदरा मूल्य "
"बहुत अधिक है तो लागत या थोक मूल्य का उपयोग करें।"

msgid "Export License Number"
msgstr "निर्यात लाइसेंस संख्या"

msgid ""
"Required for controlled/restricted items (ITAR, EAR). Leave blank for most "
"products."
msgstr ""
"नियंत्रित/सीमित वस्तुओं (ITAR, EAR) के लिए आवश्यक है। अधिकांश उत्पादों के लिए खाली छोड़ दें।"

msgid "Export License Expiry"
msgstr "निर्यात लाइसेंस की अवधि समाप्ति"

msgid "Expiration date of export license"
msgstr "निर्यात लाइसेंस की अवधि समाप्ति की तारीख"

msgid "Classic"
msgstr "क्लासिक"

msgid "Full Width"
msgstr "पूर्ण चौड़ाई"

msgid "Gallery Focus"
msgstr "गैलरी फोकस"

msgid "Digital"
msgstr "डिजिटल"

msgid ""
"Override the site default product page template. Leave empty to use the site "
"default from Design settings."
msgstr ""
"साइट के डिफ़ॉल्ट उत्पाद पृष्ठ टेम्पलेट को ओवरराइड करें। डिज़ाइन सेटिंग्स से साइट के डिफ़ॉल्ट का "
"उपयोग करने के लिए खाली छोड़ दें।"

msgid "Is Digital Product"
msgstr "डिजिटल उत्पाद है"

msgid ""
"Check if this product includes digital downloads (e.g., files, licenses). "
"Can be combined with any product type for scenarios like variable digital "
"products (software with Basic/Pro editions) or customizable digital products "
"(custom designs)."
msgstr ""
"चेक करें कि यह उत्पाद डिजिटल डाउनलोड (जैसे, फ़ाइलें, लाइसेंस) शामिल करता है। यह किसी भी "
"उत्पाद प्रकार के साथ संयोजित किया जा सकता है जैसे कि वैरिएबल डिजिटल उत्पाद (बेसिक/प्रो "
"सॉफ्टवेयर संस्करणों वाला) या अनुकूलित डिजिटल उत्पाद (कस्टम डिज़ाइन) के मामले में।"

msgid "Hide from Storefront"
msgstr "स्टोरफ्रंट से छिपाएं"

msgid ""
"Hide this product from catalog listings and search results. The product "
"remains available as a configurator option or bundle component."
msgstr ""
"कैटलॉग सूची और खोज परिणामों से इस उत्पाद को छिपाएं। उत्पाद एक कॉन्फ़िगरेटर विकल्प या "
"बॉन्डल कंपोनेंट के रूप में उपलब्ध रहता है।"

msgid "License Key Template"
msgstr "लाइसेंस की टेम्पलेट"

msgid ""
"Custom license key format for digital products. If not set, uses default "
"format."
msgstr ""
"डिजिटल उत्पादों के लिए कस्टम लाइसेंस की जगह फॉर्मेट। यदि नहीं सेट किया गया है, तो "
"डिफ़ॉल्ट फॉर्मेट का उपयोग करता है।"

msgid "Perpetual"
msgstr "अनंत"

msgid "Subscription"
msgstr "सदस्यता"

msgid "Trial"
msgstr "परीक्षण"

msgid "Not For Resale"
msgstr "पुनर्विक्रय के लिए नहीं"

msgid "Educational"
msgstr "शैक्षिक"

msgid "Standard"
msgstr "मानक"

msgid "Default License Type"
msgstr "डिफ़ॉल्ट लाइसेंस प्रकार"

msgid "Default license type for this product when licenses are generated."
