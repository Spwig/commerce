msgstr "用逗号分隔金额（例如：25, 50, 100）"

#, python-format
msgid ""
"Invalid value \"%(value)s\". Please enter numbers only, separated by commas."
msgstr "无效值 \"%(value)s\"。请输入仅数字，用逗号分隔。"

