msgstr "Số lượng"

msgid ""
"For \"Add\" and \"Remove\": amount to change. For \"Set\": new on_hand value."
msgstr ""
"Đối với \"Thêm\" và \"Trừ\": số lượng thay đổi. Đối với \"Đặt\": giá trị mới "
"trên tay."

msgid "Reason"
msgstr "Lý do"

