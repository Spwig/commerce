msgstr "Thêm tồn kho (tăng on_hand)"

msgid "Remove stock (decrease on_hand)"
msgstr "Xóa tồn kho (giảm on_hand)"

msgid "Set stock to specific value"
msgstr "Đặt tồn kho thành giá trị cụ thể"

msgid "Adjustment Type"
msgstr "Loại điều chỉnh"

