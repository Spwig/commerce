msgstr ""
"{updated} khóa giấy phép đã bị hủy và tất cả các kích hoạt thiết bị đã được "
"xóa."

msgid "🚫 Revoke selected license keys"
msgstr "🚫 Hủy khóa cấp phép đã chọn"

