msgstr "Hiển thị nút \"Thông báo cho tôi\""

msgid "Allow backorders"
msgstr "Cho phép đặt hàng trước"

msgid "Override site-wide out-of-stock behavior for products in this category"
msgstr ""
"Ghi đè hành vi hết hàng toàn trang web cho các sản phẩm trong danh mục này"

msgid "allow backorders override"
msgstr "Ghi đè cho phép đặt hàng trước"

msgid ""
"Override site-wide backorder setting for products in this category (None = "
"inherit from site)"
msgstr ""
"Ghi đè cài đặt đặt hàng trước toàn trang web cho các sản phẩm trong danh mục "
"này (None = kế thừa từ trang web)"

msgid "Category"
msgstr "Danh mục"

msgid "Categories"
msgstr "Danh mục"

msgid "Simple Product"
msgstr "Sản phẩm đơn giản"

msgid "Variable Product"
msgstr "Sản phẩm có biến thể"

msgid "Digital Product"
msgstr "Sản phẩm số"

msgid "Product Bundle"
msgstr "Gói sản phẩm"

msgid "Customizable Product"
msgstr "Sản phẩm tùy chỉnh"

msgid "Configurable Product"
msgstr "Sản phẩm cấu hình được"

msgid "Booking Product"
msgstr "Sản phẩm đặt chỗ"

msgid "Dynamic Pricing (convert from base currency)"
msgstr "Giá động (chuyển đổi từ tiền tệ cơ sở)"

msgid "Fixed Pricing (set prices per currency)"
msgstr "Giá cố định (đặt giá theo từng loại tiền tệ)"

msgid "Pricing Strategy"
msgstr "Chiến lược định giá"

msgid ""
"How to calculate prices in different currencies. Dynamic: Auto-convert using "
"exchange rates. Fixed: Set custom prices per currency."
msgstr ""
"Cách tính giá ở các loại tiền tệ khác nhau. Động: Tự động chuyển đổi sử dụng "
"tỷ giá hối đoái. Cố định: Thiết lập giá tùy chỉnh theo từng loại tiền tệ."

msgid "Fixed Price"
msgstr "Giá cố định"

msgid "Percentage Discount"
msgstr "Giảm giá theo tỷ lệ phần trăm"

msgid "Sum of Components"
msgstr "Tổng các thành phần"

msgid "Bundle Pricing Strategy"
msgstr "Chiến lược định giá gói"

msgid ""
"How to calculate bundle price. Fixed: Use the price field. Percentage "
"Discount: Apply discount to component sum. Components Sum: Total of all "
"components."
msgstr ""
"Cách tính giá gói. Cố định: Sử dụng trường giá. Giảm giá phần trăm: Áp dụng "
"giảm giá cho tổng các thành phần. Tổng thành phần: Tổng của tất cả các thành "
"phần."

msgid "Bundle Discount Percentage"
msgstr "Tỷ lệ giảm giá gói"

#, python-format
msgid ""
"Discount percentage off component total (e.g., 15.00 for 15% off). Only used "
"with 'Percentage Discount' strategy."
msgstr ""
"Phần trăm giảm giá trên tổng thành phần (ví dụ: 15.00 cho 15% giảm giá). Chỉ "
"được sử dụng với chiến lược 'Giảm giá theo phần trăm'."

msgid "Customer Chooses Amount"
msgstr "Khách hàng chọn số lượng"

msgid "Both Fixed and Custom"
msgstr "Cả cố định và tùy chỉnh"

msgid "Denomination Type"
msgstr "Loại mệnh giá"

msgid ""
"How customers select gift card value. Fixed: Choose from preset amounts. "
"Custom: Enter any amount. Both: Preset amounts + custom option."
msgstr ""
"Cách khách hàng chọn giá trị thẻ quà tặng. Cố định: Chọn từ các số tiền được "
"đặt sẵn. Tùy chỉnh: Nhập bất kỳ số tiền nào. Cả hai: Số tiền được đặt sẵn + "
"tùy chọn tùy chỉnh."

msgid ""
"List of preset amounts (e.g., [25, 50, 100, 200]). Currency symbol not "
"needed."
msgstr ""
"Danh sách các số tiền được đặt sẵn (ví dụ: [25, 50, 100, 200]). Không cần ký "
"hiệu tiền tệ."

msgid "Minimum Amount"
msgstr "Số tiền tối thiểu"

msgid "Minimum value for custom amount gift cards"
msgstr "Giá trị tối thiểu cho các thẻ quà tặng tùy chỉnh"

msgid "Maximum Amount"
msgstr "Số tiền tối đa"

msgid "Maximum value for custom amount gift cards"
msgstr "Giá trị tối đa cho các thẻ quà tặng tùy chỉnh"

msgid "Expires After (Days)"
msgstr "Hết hạn sau (ngày)"

msgid "Days until gift card expires after purchase (0 = never expires)"
msgstr ""
"Số ngày trước khi thẻ quà tặng hết hạn sau khi mua (0 = không bao giờ hết "
"hạn)"

msgid "Gift Card Currency"
msgstr "Tiền tệ thẻ quà tặng"

msgid ""
"Currency for issued gift cards. Leave blank for store's base currency. When "
"set, gift cards are issued in this currency with value converted at the "
"exchange rate at time of purchase."
msgstr ""
"Tiền tệ cho thẻ quà tặng được phát hành. Để trống để sử dụng tiền tệ cơ bản "
"của cửa hàng. Khi được thiết lập, thẻ quà tặng sẽ được phát hành bằng tiền "
"tệ này với giá trị được chuyển đổi theo tỷ giá tại thời điểm mua hàng."

msgid "Allow Customization"
msgstr "Cho phép tùy chỉnh"

msgid ""
"Does this product support customer customization (text, images, choices)?"
msgstr ""
"Sản phẩm này có hỗ trợ tùy chỉnh của khách hàng (text, hình ảnh, lựa chọn) "
"không?"

msgid "Preview Template"
msgstr "Xem trước mẫu"

msgid "Template name for rendering customization preview (optional)"
msgstr "Tên mẫu để hiển thị trước tùy chỉnh (tùy chọn)"

msgid "Base Price + Adjustments"
msgstr "Giá cơ bản + điều chỉnh"

msgid "Configurator Pricing Strategy"
msgstr "Chiến lược định giá cấu hình"

msgid ""
"How the final price is calculated. Sum of Components: total of all selected "
"options. Base + Adjustments: base price plus per-option surcharges. Fixed: "
"use the product price field."
msgstr ""
"Cách tính giá cuối cùng. Tổng các thành phần: tổng của tất cả các tùy chọn "
"đã chọn. Cơ sở + điều chỉnh: giá cơ sở cộng với phụ phí theo tùy chọn. Cố "
"định: sử dụng trường giá sản phẩm."

msgid "Configurator Base Price"
msgstr "Giá cơ bản cấu hình"

msgid ""
"Starting price for 'Base Price + Adjustments' strategy. Each option's price "
"adjustment is added to this amount."
msgstr ""
"Giá bắt đầu cho chiến lược 'Giá cơ sở + Điều chỉnh'. Mỗi điều chỉnh giá của "
"tùy chọn sẽ được thêm vào số tiền này."

msgid "Enable Subscription"
msgstr "Kích hoạt đăng ký"

msgid ""
"Allow customers to purchase this product as a subscription with recurring "
"billing"
msgstr ""
"Cho phép khách hàng mua sản phẩm này như một đăng ký với thanh toán định kỳ"

msgid "Subscription Plans"
msgstr "Kế hoạch đăng ký"

msgid ""
"Available subscription plans for this product. Customers can choose from "
"these plans."
msgstr ""
"Các kế hoạch đăng ký có sẵn cho sản phẩm này. Khách hàng có thể chọn từ các "
"kế hoạch này."

msgid "Allow One-Time Purchase"
msgstr "Cho phép mua một lần"

msgid ""
"Allow customers to buy this product without a subscription. If disabled, "
"subscription is required."
msgstr ""
"Cho phép khách hàng mua sản phẩm này mà không cần đăng ký. Nếu bị tắt, đăng "
"ký là bắt buộc."

msgid "Default to Subscription"
msgstr "Mặc định là đăng ký"

msgid ""
"Pre-select subscription option in the product interface (one-time purchase "
"must also be allowed)"
msgstr ""
"Tự động chọn tùy chọn đăng ký trong giao diện sản phẩm (mua một lần cũng "
"phải được phép)"

msgid "Override category/site out-of-stock behavior for this product"
msgstr "Ghi đè hành vi hết hàng của danh mục/trang web cho sản phẩm này"

msgid "is pre-order"
msgstr "là đặt trước"

msgid "Enable pre-order for this product (useful for upcoming releases)"
msgstr ""
"Kích hoạt đặt hàng trước cho sản phẩm này (hữu ích cho các bản phát hành sắp "
"tới)"

msgid "pre-order release date"
msgstr "Ngày phát hành đặt trước"

msgid "Expected release/availability date for pre-orders"
msgstr "Ngày dự kiến phát hành/có sẵn cho đặt trước"

msgid "pre-order message"
msgstr "Thông báo đặt trước"

msgid "Custom pre-order message (e.g., \"Ships March 2025\")"
msgstr ""
"Thông điệp đặt hàng trước tùy chỉnh (ví dụ: \"Giao hàng tháng 3 năm 2025\")"

msgid "Preferred Shipping Package"
msgstr "Gói vận chuyển ưa thích"

msgid ""
"Default package to use for shipping this product. If set, package dimensions "
"will be used instead of product dimensions for shipping calculations."
msgstr ""
"Gói mặc định để sử dụng cho việc giao hàng sản phẩm này. Nếu được thiết lập, "
"kích thước gói sẽ được sử dụng thay vì kích thước sản phẩm trong tính toán "
"giao hàng."

msgid "GTIN"
msgstr "GTIN"

msgid "Global Trade Item Number (GTIN-8, GTIN-12, GTIN-13, or GTIN-14)"
msgstr ""
"Số mặt hàng thương mại toàn cầu (GTIN-8, GTIN-12, GTIN-13 hoặc GTIN-14)"

msgid "EAN"
msgstr "EAN"

msgid "European Article Number (EAN-13 or EAN-8)"
msgstr "Số mặt hàng châu Âu (EAN-13 hoặc EAN-8)"

msgid "UPC"
msgstr "UPC"

msgid "Universal Product Code (UPC-A or UPC-E)"
msgstr "Mã sản phẩm toàn cầu (UPC-A hoặc UPC-E)"

msgid "ISBN"
msgstr "ISBN"

msgid "International Standard Book Number (ISBN-10 or ISBN-13, for books)"
msgstr "Số tiêu chuẩn quốc tế cho sách (ISBN-10 hoặc ISBN-13)"

msgid "ASIN"
msgstr "ASIN"

msgid "Amazon Standard Identification Number"
msgstr "Amazon Standard Identification Number"

msgid "MPN"
msgstr "MPN"

msgid "Manufacturer Part Number"
msgstr "Số phần của nhà sản xuất"

msgid "HS Code"
msgstr "Mã HS"

msgid ""
"Harmonized System code (6-12 digits) for customs classification. Required "
"for international shipping. Look up at hts.usitc.gov"
msgstr ""
"Mã hệ thống hài hòa (6-12 chữ số) dùng để phân loại hải quan. Yêu cầu khi "
"vận chuyển quốc tế. Tra cứu tại hts.usitc.gov"

msgid "Country of Origin"
msgstr "Quốc gia xuất xứ"

msgid ""
"ISO 3166-1 alpha-2 country code where product was manufactured. Required for "
"international shipping. Example: US, CN, DE"
msgstr ""
"Mã quốc gia theo tiêu chuẩn ISO 3166-1 alpha-2 nơi sản phẩm được sản xuất. "
"Yêu cầu khi vận chuyển quốc tế. Ví dụ: US, CN, DE"

msgid "Customs Unit Price"
msgstr "Giá đơn vị hàng hóa hải quan"

msgid ""
"Declared value per unit for customs purposes. May differ from retail price. "
"Use cost or wholesale price if retail is significantly higher."
msgstr ""
"Giá trị khai báo cho mỗi đơn vị dùng cho mục đích hải quan. Có thể khác với "
"giá bán lẻ. Sử dụng giá vốn hoặc giá sỉ nếu giá bán lẻ cao hơn đáng kể."

msgid "Export License Number"
msgstr "Số giấy phép xuất khẩu"

msgid ""
"Required for controlled/restricted items (ITAR, EAR). Leave blank for most "
"products."
msgstr ""
"Yêu cầu đối với các mặt hàng được kiểm soát/hạn chế (ITAR, EAR). Để trống "
"đối với hầu hết các sản phẩm."

msgid "Export License Expiry"
msgstr "Hết hạn giấy phép xuất khẩu"

msgid "Expiration date of export license"
msgstr "Ngày hết hạn giấy phép xuất khẩu"

msgid "Classic"
msgstr "Klassik"

msgid "Full Width"
msgstr "Chiếm toàn bộ chiều rộng"

msgid "Gallery Focus"
msgstr "Tập trung vào thư viện ảnh"

msgid "Digital"
msgstr "Số"

msgid ""
"Override the site default product page template. Leave empty to use the site "
"default from Design settings."
msgstr ""
"Ghi đè mẫu trang sản phẩm mặc định của trang web. Để trống để sử dụng mẫu "
"mặc định từ cài đặt Thiết kế."

msgid "Is Digital Product"
msgstr "Là sản phẩm số"

msgid ""
"Check if this product includes digital downloads (e.g., files, licenses). "
"Can be combined with any product type for scenarios like variable digital "
"products (software with Basic/Pro editions) or customizable digital products "
"(custom designs)."
msgstr ""
"Kiểm tra xem sản phẩm này có bao gồm các tệp tải về kỹ thuật số (ví dụ: tệp "
"tin, giấy phép). Có thể kết hợp với bất kỳ loại sản phẩm nào trong các "
"trường hợp như sản phẩm kỹ thuật số có thể thay đổi (phần mềm với các phiên "
"bản Cơ bản/Chuyên nghiệp) hoặc sản phẩm kỹ thuật số có thể tùy chỉnh (thiết "
"kế tùy chỉnh)."

msgid "Hide from Storefront"
msgstr "Ẩn khỏi gian hàng"

msgid ""
"Hide this product from catalog listings and search results. The product "
"remains available as a configurator option or bundle component."
msgstr ""
"Ẩn sản phẩm này khỏi danh sách thư viện và kết quả tìm kiếm. Sản phẩm vẫn có "
"thể sử dụng như một tùy chọn thiết lập hoặc thành phần gói."

msgid "License Key Template"
msgstr "Mẫu khóa giấy phép"

msgid ""
"Custom license key format for digital products. If not set, uses default "
"format."
msgstr ""
"Định dạng khóa giấy phép tùy chỉnh cho sản phẩm kỹ thuật số. Nếu không được "
"thiết lập, sẽ sử dụng định dạng mặc định."

msgid "Perpetual"
msgstr "Vĩnh viễn"

msgid "Subscription"
msgstr "Ký gửi"

msgid "Trial"
msgstr "Thử nghiệm"

msgid "Not For Resale"
msgstr "Không bán lại"

msgid "Educational"
msgstr "Giáo dục"

msgid "Standard"
msgstr "Tiêu chuẩn"

msgid "Default License Type"
msgstr "Loại giấy phép mặc định"

msgid "Default license type for this product when licenses are generated."
msgstr "Loại giấy phép mặc định cho sản phẩm này khi giấy phép được tạo."

msgid "Default Max Activations"
msgstr "Số lần kích hoạt tối đa mặc định"

msgid ""
"Default maximum device activations per license. Leave blank for unlimited."
msgstr ""
"Số lần kích hoạt thiết bị tối đa mặc định cho mỗi giấy phép. Để trống để "
"không giới hạn."

msgid "Default Validity (Days)"
msgstr "Thời hạn mặc định (ngày)"

msgid ""
"Default license validity in days from issue date. Leave blank for never "
"expires."
msgstr ""
"Tính hợp lệ mặc định của giấy phép tính theo ngày kể từ ngày cấp. Để trống "
"để giấy phép không bao giờ hết hạn."

msgid "License Provider"
msgstr "Nhà cung cấp giấy phép"

msgid "External provider to sync licenses to when orders are placed."
msgstr "Cung cấp bên ngoài để đồng bộ giấy phép khi đặt hàng."

msgid "External Product ID"
msgstr "ID sản phẩm bên ngoài"

msgid "Product/Policy ID in the external license provider system."
msgstr "Mã sản phẩm/Chính sách trong hệ thống cung cấp giấy phép bên ngoài."

msgid "Generate License Key"
msgstr "Tạo khóa giấy phép"

msgid ""
"Generate a license key when this product is purchased. Enable for software "
"licenses, API keys, or activation codes."
msgstr ""
"Tạo khóa giấy phép khi sản phẩm này được mua. Bật tính năng này cho giấy "
"phép phần mềm, khóa API hoặc mã kích hoạt."

msgid "When payment is confirmed"
msgstr "Khi thanh toán được xác nhận"

msgid "When order is created"
msgstr "Khi đơn hàng được tạo"

msgid "Manual only (admin generates)"
msgstr "Chỉ thủ công (admin tạo)"

msgid "Generate License"
msgstr "Tạo giấy phép"

msgid "When to automatically generate the license key for this product."
msgstr "Khi nào tạo khóa giấy phép tự động cho sản phẩm này."

msgid "All Channels"
msgstr "Tất cả các kênh"

msgid "Online Only"
msgstr "Chỉ trực tuyến"

msgid "In-Store Only"
msgstr "Chỉ tại cửa hàng"

msgid "sales channel"
msgstr "kênh bán hàng"

msgid "Where this product can be sold"
msgstr "Nơi sản phẩm này có thể được bán"

msgid "barcode"
msgstr "mã vạch"

msgid "EAN/UPC barcode for POS scanning"
msgstr "Mã vạch EAN/UPC cho quét tại điểm bán hàng"

msgid "Tags"
msgstr ""

msgid "Tags for product organization and filtering"
msgstr ""

msgid "Whether this product has been soft deleted"
msgstr "Liệu sản phẩm này có bị xóa mềm hay không"

msgid "When this product was soft deleted"
msgstr "Khi sản phẩm này bị xóa mềm"

msgid "User who deleted this product"
msgstr "Người dùng đã xóa sản phẩm này"

msgid "Price must be greater than zero."
msgstr "Giá phải lớn hơn không."

msgid "HS code must be 6-12 digits. Example: 620342 or 62034235"
msgstr "Mã HS phải là 6-12 chữ số. Ví dụ: 620342 hoặc 62034235"

msgid "Country code must be 2-letter ISO code. Example: US, CA, DE"
msgstr "Mã quốc gia phải là mã ISO 2 chữ cái. Ví dụ: US, CA, DE"

msgid "Customs unit price is required when HS code is specified"
msgstr "Giá đơn vị hải quan là bắt buộc khi mã HS được chỉ định"

msgid "Export license expiry date must be in the future"
msgstr "Ngày hết hạn giấy phép xuất khẩu phải là ngày trong tương lai"

msgid "Gift card currency can only be set on gift card products."
msgstr ""
"Loại tiền cho thẻ quà tặng chỉ có thể được đặt trên sản phẩm thẻ quà tặng."

#, python-format
msgid "Currency \"%(currency)s\" is not in the store's supported currencies."
msgstr ""
"Đơn vị tiền tệ \"%(currency)s\" không nằm trong danh sách tiền tệ được hỗ "
"trợ của cửa hàng."

msgid "Bundle product this item belongs to"
msgstr "Sản phẩm gói mà mặt hàng này thuộc về"

msgid "Product included in this bundle"
msgstr "Sản phẩm được bao gồm trong bộ sưu tập này"

msgid "Specific variant (if component is variable product)"
msgstr "Biến thể cụ thể (nếu thành phần là sản phẩm có thể thay đổi)"

msgid "How many of this component are included"
msgstr "Số lượng thành phần này được bao gồm"

msgid "Display order in bundle"
msgstr "Thứ tự hiển thị trong bộ sưu tập"

msgid "Can customers exclude this item? (for customizable bundles)"
msgstr ""
"Khách hàng có thể loại bỏ mặt hàng này không? (cho các gói có thể tùy chỉnh)"

msgid ""
"If True, customer chooses variant at purchase time. If False, use the pre-"
"selected component_variant."
msgstr ""
"Nếu là True, khách hàng chọn biến thể tại thời điểm mua. Nếu là False, sử "
"dụng biến thể đã được chọn sẵn."

msgid "Bundle Item"
msgstr "Sản phẩm trong bộ sưu tập"

msgid "Bundle Items"
msgstr "Các sản phẩm trong bộ sưu tập"

msgid "A bundle cannot contain itself."
msgstr "Một bộ sưu tập không thể chứa chính nó."

msgid ""
"Bundle products cannot be used as components. Only simple and variable "
"products are allowed."
msgstr ""
"Sản phẩm gói không thể được sử dụng làm thành phần. Chỉ cho phép sản phẩm "
"đơn giản và sản phẩm có thể thay đổi."

#, python-format
msgid "Variant %(variant)s does not belong to product %(product)s."
msgstr "Biến thể %(variant)s không thuộc sản phẩm %(product)s."

msgid "Simple products cannot have variants."
msgstr "Sản phẩm đơn giản không thể có biến thể."

msgid "Customer variant selection is only available for variable products."
msgstr ""
"Việc chọn biến thể của khách hàng chỉ có sẵn cho sản phẩm có thể thay đổi."

msgid "Requires"
msgstr "Yêu cầu"

msgid "Recommends"
msgstr "Khuyến nghị"

msgid "Required product"
msgstr "Sản phẩm bắt buộc"

msgid "Dependency type"
msgstr "Loại phụ thuộc"

msgid "Customer message"
msgstr "Thông báo cho khách hàng"

msgid ""
"Custom message shown to the customer. Leave blank for automatic message."
msgstr ""
"Thông báo tùy chỉnh hiển thị cho khách hàng. Để trống để sử dụng thông báo "
"tự động."

msgid "Sort order"
msgstr "Thứ tự sắp xếp"

msgid "product dependency"
msgstr "phụ thuộc sản phẩm"

msgid "product dependencies"
msgstr "các phụ thuộc sản phẩm"

msgid "A product cannot depend on itself."
msgstr "Một sản phẩm không thể phụ thuộc vào chính nó."

msgid "Currency code (e.g., 'USD', 'EUR')"
msgstr "Mã tiền tệ (ví dụ: 'USD', 'EUR')"

msgid "Price in this currency"
msgstr "Giá theo tiền tệ này"

msgid "Sale price in this currency (optional)"
msgstr "Giá bán trong loại tiền tệ này (tùy chọn)"

msgid "Active"
msgstr "Đang hoạt động"

msgid "Whether this price is active and should be used"
msgstr "Liệu giá này có đang hoạt động và nên được sử dụng không"

msgid "Product Price"
msgstr "Giá sản phẩm"

msgid "Product Prices"
msgstr "Giá sản phẩm"

msgid "Currency code to apply this rule to"
msgstr "Mã tiền tệ để áp dụng quy tắc này"

msgid "Round Down to nearest whole number (e.g., $19.50 → $19.00)"
msgstr "Làm tròn xuống đến số nguyên gần nhất (ví dụ: $19.50 → $19.00)"

msgid "Round Up to nearest whole number (e.g., $19.50 → $20.00)"
msgstr "Làm tròn lên đến số nguyên gần nhất (ví dụ: $19.50 → $20.00)"

msgid "Charm .99 ending (e.g., $20.50 → $19.99)"
