msgstr "Xuất báo cáo tồn kho (CSV)"

msgid ""
"{len(low_stock_items)} low stock item(s) marked for reorder: {items_list}"
msgstr ""
"{len(low_stock_items)} mặt hàng tồn kho thấp được đánh dấu để đặt lại: "
"{items_list}"

msgid "No low stock items in selection"
msgstr "Không có mặt hàng tồn kho thấp trong lựa chọn"

msgid "Mark low stock items for reorder"
msgstr "Đánh dấu các mặt hàng tồn kho thấp để đặt lại"

