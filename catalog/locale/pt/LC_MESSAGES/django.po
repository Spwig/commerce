msgstr "Latitude do cliente para cálculo de distância"

msgid "Customer longitude for distance calculation"
msgstr "Longitude do cliente para cálculo de distância"

msgid "Check gift card balance"
msgstr "Verificar saldo do cartão-presente"

msgid ""
"Check the balance of a gift card without requiring authentication. Public "
"endpoint."
msgstr ""
"Verifique o saldo de um cartão-presente sem necessidade de autenticação. "
"Ponto de extremidade público."

