msgstr "Pengidentifikasi perangkat unik"

msgid "Human-readable device name (e.g., 'John's MacBook Pro')"
msgstr ""
"Nama perangkat yang dapat dibaca manusia (misalnya, 'John's MacBook Pro')"

msgid "Additional device information (OS, version, etc.)"
msgstr "Informasi perangkat tambahan (OS, versi, dll.)"

msgid "License key"
msgstr "Kunci lisensi"

msgid "Device fingerprint to deactivate"
msgstr "Sidik jari perangkat untuk menonaktifkan"

msgid "License pool ID to generate keys for"
msgstr "ID pool lisensi untuk menghasilkan kunci"

msgid "Number of keys to generate (defaults to pool.total_keys)"
msgstr "Jumlah kunci yang akan dihasilkan (defaultnya adalah pool.total_keys)"

msgid "Celery task ID for background generation (if async)"
msgstr "ID tugas Celery untuk pembuatan latar belakang (jika asinkron)"

msgid "License key to get information for"
msgstr "Kunci lisensi untuk mendapatkan informasi"

