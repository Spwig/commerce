msgstr "Тип корректировки"

msgid "Quantity"
msgstr "Количество"

msgid "For \"Add\" and \"Remove\": amount to change. For \"Set\": new on_hand value."
msgstr ""
"Для \"Добавить\" и \"Удалить\": сумма изменений. Для \"Установить\": новое "
"значение на_hand."

msgid "Reason"
msgstr "Причина"

msgid "Optional: Explain why this adjustment is being made"
msgstr "Необязательно: объясните, почему производится эта корректировка"

msgid "Adjust Stock Levels"
msgstr "Корректировка уровней запасов"

msgid "Adjust stock levels"
msgstr "Корректировка уровней запасов"

msgid "Export stock report (CSV)"
msgstr "Экспортировать отчет о запасах (CSV)"

msgid ""
"{len(low_stock_items)} low stock item(s) marked for reorder: {items_list}"
msgstr ""
"{len(low_stock_items)} товар(ов) с низким запасом отмечено(ы) для повторного"
" заказа: {items_list}"

msgid "No low stock items in selection"
msgstr "В выборке нет товаров с низким запасом"

msgid "Mark low stock items for reorder"
msgstr "Отметить товары с низким запасом для повторного заказа"

msgid "Movement Details"
msgstr "Детали перемещения"

msgid "Context"
msgstr "Контекст"

