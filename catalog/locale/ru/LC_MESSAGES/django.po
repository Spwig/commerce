msgstr "{updated} лицензионный ключ(и) успешно активирован(ы)."

msgid "✅ Activate selected license keys"
msgstr "✅ Активировать выбранные ключи лицензии"

#, python-brace-format
msgid "{updated} license key(s) suspended successfully."
msgstr "{updated} лицензионный ключ(и) успешно приостановлен(ы)."

msgid "⏸️ Suspend selected license keys"
msgstr "⏸️ Приостановить выбранные ключи лицензии"

#, python-brace-format
msgid "{updated} license key(s) revoked and all device activations removed."
msgstr ""
"{updated} лицензионный ключ(и) отозван(ы), и все активации устройств "
"удалены."

msgid "🚫 Revoke selected license keys"
msgstr "🚫 Отозвать выбранные ключи лицензии"

msgid "📥 Export selected license keys to CSV"
msgstr "📥 Экспортировать выбранные ключи лицензии в CSV"

#, python-brace-format
msgid "{regenerated} license key(s) regenerated. Old keys have been revoked."
msgstr ""
"{regenerated} лицензионный ключ(и) перегенерирован(ы). Старые ключи были "
"отозваны."

msgid "🔄 Regenerate selected license keys"
msgstr "🔄 Перегенерировать выбранные ключи лицензии"

#, python-brace-format
msgid "Successfully sent license key email to {sent_count} customer(s)."
msgstr ""
"Успешно отправлен email с лицензионным ключом {sent_count} клиенту(ам)."

#, python-brace-format
msgid ""
"Failed to send email for {failed_count} license key(s). Check that customers"
" have valid email addresses."
msgstr ""
"Не удалось отправить email для {failed_count} лицензионного(ых) ключа(ей). "
"Проверьте, чтобы у клиентов были действительные email-адреса."

msgid "📧 Resend license key email"
msgstr "📧 Переслать email с ключом лицензии"

msgid "Pattern Configuration"
msgstr "Настройка шаблона"

msgid ""
"Define the license key format using placeholders:<br>• "
"<code>{RANDOM:N}</code> - N random characters<br>• <code>{CHECKSUM:N}</code>"
" - N-digit checksum<br>• <code>{PREFIX}</code> - Template prefix<br>• "
"<code>{SUFFIX}</code> - Template suffix<br>• <code>{ORDER_ID}</code> - Order"
" number<br>• <code>{PRODUCT_SKU}</code> - Product SKU<br>• "
"<code>{DATE:FORMAT}</code> - Date (YYMMDD, YYYYMMDD, etc.)"
msgstr ""
"Определите формат лицензионного ключа с использованием заполнителей:<br>• "
"<code>{RANDOM:N}</code> - N случайных символов<br>• "
"<code>{CHECKSUM:N}</code> - контрольная сумма из N цифр<br>• "
