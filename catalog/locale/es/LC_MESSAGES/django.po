msgstr "Datos de disponibilidad del producto"

msgid "Subscribe to stock notification"
msgstr "Suscribirse a notificación de stock"

msgid ""
"\n"
"    Subscribe to receive an email notification when a product comes back in stock.\n"
"\n"
"    **Rate limiting:** This endpoint should be rate-limited to prevent abuse.\n"
"    "
msgstr ""
"\n"
"    Suscríbase para recibir una notificación por correo electrónico cuando un producto vuelva a estar disponible. **Limitación de tasa:** Este extremo debe limitarse para prevenir el abuso.\n"
"    "

msgid "Successfully subscribed"
msgstr "Suscripción exitosa"

msgid "Invalid email or already subscribed"
msgstr "Correo electrónico inválido o ya suscrito"

