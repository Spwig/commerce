msgid "Pattern Configuration"
msgstr "Configuración de patrón"

msgid ""
"Define the license key format using placeholders:<br>• "
"<code>{RANDOM:N}</code> - N random characters<br>• <code>{CHECKSUM:N}</code>"
" - N-digit checksum<br>• <code>{PREFIX}</code> - Template prefix<br>• "
"<code>{SUFFIX}</code> - Template suffix<br>• <code>{ORDER_ID}</code> - Order"
" number<br>• <code>{PRODUCT_SKU}</code> - Product SKU<br>• "
"<code>{DATE:FORMAT}</code> - Date (YYMMDD, YYYYMMDD, etc.)"
msgstr ""
"Defina el formato de la clave de licencia usando marcadores de "
"posición:<br>• <code>{RANDOM:N}</code> - N caracteres aleatorios<br>• "
"<code>{CHECKSUM:N}</code> - Suma de control de N dígitos<br>• "
"<code>{PREFIX}</code> - Prefijo del modelo<br>• <code>{SUFFIX}</code> - "
"Sufijo del modelo<br>• <code>{ORDER_ID}</code> - Número de orden<br>• "
"<code>{PRODUCT_SKU}</code> - SKU del producto<br>• "
"<code>{DATE:FORMAT}</code> - Fecha (YYMMDD, YYYYMMDD, etc.)"

