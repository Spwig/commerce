msgstr "المنطقة الافتراضية"

msgid "Main Warehouse"
msgstr "المخزن الرئيسي"

msgid "Use Site Default"
msgstr "استخدم القيمة الافتراضية للموقع"

msgid "Grid"
msgstr " Сетка"

msgid "List"
msgstr " Список"

msgid "Carousel"
msgstr "الشريحة"

msgid "Masonry"
msgstr " Кирпичная кладка"

msgid "Featured"
msgstr "مميز"

msgid "Accordion"
msgstr "القائمة المطوية"

msgid "Page Template"
msgstr "قالب الصفحة"

msgid ""
"Override the site default category page template. Leave empty to use the "
"site default from Design settings."
msgstr ""
"تجاوز القالب الافتراضي للصفحة الفئوية للموقع. اترك الفراغ لاستخدام القيمة "
"الافتراضية من إعدادات التصميم."

msgid "out of stock action override"
msgstr "إعادة تعيين إجراء نفاد المخزون"

msgid "Hide from listings"
msgstr "إخفاء من القوائم"

msgid "Show as unavailable"
msgstr "عرض كغير متاح"

