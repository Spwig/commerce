msgstr "{updated} مفتاح الترخيص تم تفعيله بنجاح."

msgid "✅ Activate selected license keys"
msgstr "✅ تفعيل مفاتيح الترخيص المحددة"

#, python-brace-format
msgid "{updated} license key(s) suspended successfully."
msgstr "{updated} مفتاح الترخيص تم تعليقه بنجاح."

msgid "⏸️ Suspend selected license keys"
msgstr "⏸️ تعليق مفاتيح الترخيص المحددة"

#, python-brace-format
msgid "{updated} license key(s) revoked and all device activations removed."
msgstr "{updated} تم إلغاء مفاتيح الترخيص وإزالة جميع عمليات التفعيل للأجهزة."

msgid "🚫 Revoke selected license keys"
msgstr "🚫 سحب مفاتيح الترخيص المحددة"

msgid "📥 Export selected license keys to CSV"
msgstr "📥 تصدير مفاتيح الرخصة المحددة إلى CSV"

#, python-brace-format
