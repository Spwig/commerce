msgid "Pattern Configuration"
msgstr "Musterkonfiguration"

msgid ""
"Define the license key format using placeholders:<br>• <code>{RANDOM:N}</"
"code> - N random characters<br>• <code>{CHECKSUM:N}</code> - N-digit "
"checksum<br>• <code>{PREFIX}</code> - Template prefix<br>• <code>{SUFFIX}</"
"code> - Template suffix<br>• <code>{ORDER_ID}</code> - Order number<br>• "
"<code>{PRODUCT_SKU}</code> - Product SKU<br>• <code>{DATE:FORMAT}</code> - "
"Date (YYMMDD, YYYYMMDD, etc.)"
msgstr ""
"Definieren Sie das Format der Lizenzschlüssel mithilfe von Platzhaltern:"
"<br>• <code>{RANDOM:N}</code> - N zufällige Zeichen<br>• <code>{CHECKSUM:N}</"
"code> - N-stellige Prüfsumme<br>• <code>{PREFIX}</code> - Vorlage "
"Präfix<br>• <code>{SUFFIX}</code> - Vorlage Suffix<br>• <code>{ORDER_ID}</"
"code> - Bestellnummer<br>• <code>{PRODUCT_SKU}</code> - Produkt-SKU<br>• "
"<code>{DATE:FORMAT}</code> - Datum (YYMMDD, YYYYMMDD, usw.)"

