msgid "Failed to connect to the SMS provider."
msgstr "การเชื่อมต่อกับผู้ให้บริการ SMS ล้มเหลว"

msgid "Account"
msgstr "บัญชี"

msgid "Configure how this account should be used."
msgstr "ตั้งค่าว่าควรใช้บัญชีนี้อย่างไร"

msgid "Set as default for SMS messages"
msgstr "ตั้งเป็นค่าเริ่มต้นสำหรับข้อความ SMS"

msgid "Set as default for WhatsApp messages"
msgstr "ตั้งเป็นค่าเริ่มต้นสำหรับข้อความ WhatsApp"

msgid "Connection test failed"
msgstr "การทดสอบการเชื่อมต่อล้มเหลว"

msgid ""
"Check your credentials and try again, or save anyway if you're sure they're "
"correct."
msgstr ""
"ตรวจสอบข้อมูลการรับรองและลองอีกครั้ง "
"หรือบันทึกไว้ก็ได้หากคุณมั่นใจว่าข้อมูลถูกต้อง"

msgid "Save account anyway (not recommended)"
msgstr "บันทึกบัญชีต่อไป (ไม่แนะนำ)"

msgid "Create Account"
msgstr "สร้างบัญชี"

msgid "Please select a provider"
msgstr "กรุณาเลือกผู้ให้บริการ"

msgid "Selected provider is not available"
msgstr "ผู้ให้บริการที่เลือกไม่สามารถใช้งานได้"

msgid "Provider not found"
msgstr "ไม่พบผู้ให้บริการ"

msgid "Unable to get credential schema"
msgstr "ไม่สามารถรับโครงสร้างข้อมูลการเข้าสู่ระบบได้"

#, python-format
msgid "Missing required fields: %(fields)s"
msgstr "ขาดฟิลด์ที่จำเป็น: %(fields)s"

msgid "Connection test failed. Check your credentials and try again."
msgstr "การทดสอบการเชื่อมต่อล้มเหลว ตรวจสอบข้อมูลการรับรองและลองอีกครั้ง"

msgid "SMS provider account created successfully!"
msgstr "บัญชีผู้ให้บริการ SMS ถูกสร้างขึ้นแล้ว!"

#, python-format
msgid "Failed to create account: %(error)s"
msgstr "ไม่สามารถสร้างบัญชีได้: %(error)s"

msgid "SMS Providers"
msgstr "ผู้ให้บริการ SMS"

msgid "Provider is already installed. Configure it now."
msgstr "ผู้ให้บริการถูกติดตั้งไว้แล้ว โปรดตั้งค่าทันที"

msgid "Provider not found on update server."
msgstr "ไม่พบผู้ให้บริการบนเซิร์ฟเวอร์อัปเดต"

msgid "Could not determine provider version."
msgstr "ไม่สามารถระบุเวอร์ชันของผู้ให้บริการได้。"

#, python-format
msgid "Failed to download provider: %(error)s"
msgstr "ล้มเหลวในการดาวน์โหลดผู้ให้บริการ: %(error)s"

#, python-format
msgid "Failed to install provider: %(error)s"
msgstr "ล้มเหลวในการติดตั้งผู้ให้บริการ: %(error)s"

#, python-format
msgid "Provider \"%(name)s\" installed successfully! Configure it now."
msgstr "ผู้ให้บริการ \"%(name)s\" ติดตั้งสำเร็จแล้ว! โปรดตั้งค่าทันที"

msgid "Provider not installed."
msgstr "ผู้ให้บริการยังไม่ได้ติดตั้ง"

#, python-format
msgid "Could not connect to update server: %(error)s"
msgstr "ไม่สามารถเชื่อมต่อกับเซิร์ฟเวอร์อัปเดตได้: %(error)s"

msgid "Could not determine latest version."
msgstr "ไม่สามารถระบุเวอร์ชันล่าสุดได้。"

#, python-format
msgid "Provider \"%(name)s\" is already up to date (v%(version)s)."
msgstr "ผู้ให้บริการ \"%%(name)s\" ได้รับการอัปเดตแล้ว (v%%(version)s)"

#, python-format
msgid "Failed to download update: %(error)s"
msgstr "ล้มเหลวในการดาวน์โหลดอัปเดต: %(error)s"

#, python-format
msgid "Failed to install update: %(error)s"
msgstr "ล้มเหลวในการติดตั้งอัปเดต: %(error)s"

#, python-format
msgid "Provider \"%(name)s\" updated successfully to v%(version)s!"
msgstr "ผู้ให้บริการ \"%%(name)s\" ได้รับการอัปเดตสำเร็จไปที่ v%%(version)s!"

