msgid "Without completing setup, the following features won't work properly:"
msgstr ""
"Nếu không hoàn tất cài đặt, các tính năng sau sẽ không hoạt động đúng cách:"

msgid "Customer payments (no payment methods configured)"
msgstr ""
"Thanh toán của khách hàng (không có phương thức thanh toán được cấu hình)"

msgid "Order processing and notifications"
msgstr "Xử lý đơn hàng và thông báo"

msgid "Site branding and customization"
msgstr "Thương hiệu và tùy chỉnh trang web"

msgid "Contact information and support channels"
msgstr "Thông tin liên hệ và kênh hỗ trợ"

msgid "Currency and localization settings"
msgstr "Tiền tệ và cài đặt địa phương hóa"

msgid "You can always return to complete the setup later from the dashboard."
msgstr "Bạn luôn có thể quay lại hoàn tất cài đặt sau này từ bảng điều khiển."

msgid "Yes, Skip Setup"
msgstr "Có, bỏ qua cài đặt"

msgid "No, Continue Setup"
msgstr "Không, tiếp tục cài đặt"

msgid "Store Setup Wizard"
msgstr "Hướng dẫn cài đặt cửa hàng"

msgid "Let's get your e-commerce store configured!"
msgstr "Hãy bắt đầu cấu hình cửa hàng thương mại điện tử của bạn!"

msgid "Step"
msgstr "Bước"

msgid "of"
msgstr "của"

msgid "This step is optional - you can skip it and configure later"
msgstr "Bước này là tùy chọn - bạn có thể bỏ qua và cấu hình sau này"

msgid ""
"Payment providers are configured through the dedicated Payment Provider "
"admin. You can set up Stripe, PayPal, and other providers there."
msgstr ""
"Các nhà cung cấp thanh toán được cấu hình thông qua bảng quản trị Payment "
"Provider chuyên dụng. Bạn có thể thiết lập Stripe, PayPal và các nhà cung "
"cấp khác tại đó."

msgid "Previous"
msgstr "Trước"

msgid "Skip the entire setup wizard"
msgstr "Bỏ qua toàn bộ hướng dẫn cài đặt"

msgid "Skip This Step"
msgstr "Bỏ qua bước này"

msgid "Save & Continue"
msgstr "Lưu và tiếp tục"

msgid "Save & Finish Later"
msgstr "Lưu và hoàn thành sau"

msgid "Set up your store identity"
msgstr "Thiết lập danh tính cửa hàng của bạn"

msgid "Your contact details and business address"
msgstr "Thông tin liên hệ và địa chỉ doanh nghiệp của bạn"

msgid "Set your currency, language, and timezone"
msgstr "Thiết lập tiền tệ, ngôn ngữ và múi giờ của bạn"

msgid "Configure how you accept payments"
msgstr "Cấu hình cách bạn nhận thanh toán"

msgid "Optional settings to customize your store"
msgstr "Cài đặt tùy chọn để tùy chỉnh cửa hàng của bạn"

msgid "Configure your store details"
msgstr "Cấu hình chi tiết cửa hàng của bạn"

msgid "Set up contact details"
msgstr "Thiết lập thông tin liên hệ"

msgid "Configure currency, language, and timezone"
msgstr "Cấu hình tiền tệ, ngôn ngữ và múi giờ"

msgid "Review payment provider setup"
msgstr "Xem lại cài đặt nhà cung cấp thanh toán"

msgid "Add your business location"
msgstr "Thêm vị trí kinh doanh của bạn"

msgid "Configure store preferences"
msgstr "Cấu hình sở thích cửa hàng"

msgid "Set up email preferences"
msgstr "Thiết lập sở thích email"

msgid "Configure SEO defaults"
msgstr "Cấu hình mặc định SEO"

msgid "Add social media links"
msgstr "Thêm liên kết mạng xã hội"

msgid ""
"Setup wizard skipped. You can complete setup anytime from the dashboard."
msgstr ""
"Hướng dẫn cài đặt đã bị bỏ qua. Bạn có thể hoàn tất cài đặt bất kỳ lúc nào "
"từ bảng điều khiển."

msgid "Error saving settings. Please try again."
msgstr "Lỗi khi lưu cài đặt. Vui lòng thử lại."

msgid "Default Region"
msgstr "Khu vực mặc định"

msgid "Main Warehouse"
msgstr "Kho chính"
