msgstr "भुगतान प्रदाताओं का विन्यास करें"

msgid "Connect payment providers to start accepting payments from customers."
msgstr "ग्राहकों से भुगतान को स्वीकार करना शुरू करने के लिए भुगतान प्रदाताओं को जोड़ें।"

msgid "Manage Payment Providers"
msgstr "भुगतान प्रदाताओं का प्रबंधन करें"

msgid "Customize Your Store"
msgstr "अपने स्टोर को अनुकूलित करें"

msgid ""
"Upload your logo, customize colors, and make your store look professional."
msgstr "अपना लोगो अपलोड करें, रंगों को अनुकूलित करें और अपने स्टोर को व्यावसायिक दिखाएं।"

msgid "Site Settings"
msgstr "साइट सेटिंग्स"

msgid "Complete these when you have time to enhance your store:"
msgstr "जब आपके पास समय हो तो अपने स्टोर को बेहतर बनाने के लिए इन्हें पूरा करें:"

msgid "Your Store Summary"
msgstr "आपके स्टोर का सारांश"

msgid "Setup Progress:"
msgstr "सेटअप प्रगति:"

msgid "Essential Items:"
msgstr "आवश्यक आइटम:"

msgid "Setup Started:"
msgstr "सेटअप शुरू किया गया:"

msgid "Not started"
msgstr "शुरू नहीं किया गया"

msgid "Last Updated:"
msgstr "अंतिम अपडेट:"

msgid "Run Setup Again"
msgstr "सेटअप फिर से चलाएं"

msgid "Go to Dashboard"
msgstr "डैशबोर्ड पर जाएं"

msgid "Add First Product"
msgstr "पहला उत्पाद जोड़ें"

msgid "Your store is ready. Fine-tune settings anytime."
msgstr "आपका स्टोर तैयार है। कोई भी समय पर सेटिंग्स को बेहतर बनाएं।"

#, python-format
msgid ""
"\n"
"                    Store Setup: %(completed)s of %(total)s steps complete\n"
"                "
msgstr ""
"\n"
"                    स्टोर सेटअप: %(completed)s ऑफ %(total)s स्टेप्स पूरा\n"
"                "

