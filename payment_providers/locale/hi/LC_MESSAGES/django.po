msgstr "क्या ग्राहक कार्रवाई आवश्यक है (3DS, आदि)"

msgid "Action details if requires_action is true."
msgstr "यदि requires_action सच है तो कार्रवाई विवरण।"

msgid "When this payment intent expires."
msgstr "जब यह भुगतान इंटेंट समाप्त हो जाता है।"

msgid "Error details if payment failed."
msgstr "यदि भुगतान विफल हो जाता है तो त्रुटि विवरण।"

msgid "Order ID."
msgstr "आदेश ID।"

msgid "Whether customer action is required."
msgstr "ग्राहक के कार्रवाई की आवश्यकता है या नहीं।"

msgid "Provider-specific payment method data for confirmation."
msgstr "पुष्टि के लिए प्रदाता विशिष्ट भुगतान विधि डेटा।"

msgid "Optional reason for cancellation."
msgstr "रद्द के लिए वैकल्पिक कारण।"

msgid "Payment provider account ID."
msgstr "भुगतान प्रोवाइडर खाता ID।"

msgid "Token from provider SDK representing the payment method."
msgstr "भुगतान विधि को दर्शाने वाला प्रदाता एसडीके से प्राप्त टोकन।"

msgid "Whether to set this as the default payment method."
msgstr "क्या इसे डिफ़ॉल्ट भुगतान विधि के रूप में सेट करें।"

msgid "Create payment intent"
msgstr "भुगतान इंटेंट बनाएं"

msgid ""
"\n"
"Create a payment intent for checkout.\n"
"\n"
"**Process:**\n"
"1. Creates an Order with `payment_status='unpaid'` (stock is allocated)\n"
"2. Creates a PaymentIntent with the selected payment provider\n"
"3. Returns `checkout_url` (hosted) or `client_secret` (embedded)\n"
"\n"
"**Authentication:** Optional - supports guest checkout with session cookie.\n"
"\n"
"**Checkout Flows:**\n"
"- **Hosted checkout:** Redirect user to `checkout_url` returned in response\n"
"- **Embedded checkout:** Use `client_secret` with provider's JavaScript SDK\n"
"\n"
"**Retry Handling:**\n"
"If payment fails, the customer can retry. A new PaymentIntent will be "
"created\n"
"for the same Order (stock remains allocated).\n"
"\n"
"**Security:**\n"
"- Checkout session is validated for ownership\n"
"- Provider must be active and connected\n"
"- Amounts are validated against checkout session totals\n"
"        "
msgstr ""
"\n"
"Create a payment intent for checkout.\n"
"\n"
"**Process:**\n"
"1. Creates an Order with `payment_status='unpaid'` (stock is allocated)\n"
"2. Creates a PaymentIntent with the selected payment provider\n"
"3. Returns `checkout_url` (hosted) or `client_secret` (embedded)\n"
"\n"
"**Authentication:** Optional - supports guest checkout with session cookie.\n"
"\n"
"**Checkout Flows:**\n"
"- **Hosted checkout:** Redirect user to `checkout_url` returned in response\n"
"- **Embedded checkout:** Use `client_secret` with provider's JavaScript SDK\n"
"\n"
"**Retry Handling:**\n"
"If payment fails, the customer can retry. A new PaymentIntent will be "
"created\n"
"for the same Order (stock remains allocated).\n"
"\n"
"**Security:**\n"
"- Checkout session is validated for ownership\n"
"- Provider must be active and connected\n"
"- Amounts are validated against checkout session totals\n"
"        "

msgid "Payment intent created successfully"
msgstr "भुगतान इंटेंट सफलतापूर्वक बनाया गया"

msgid "Invalid request, checkout not ready, or validation failed"
msgstr "अमान्य अनुरोध, चेकआउट तैयार नहीं है, या जांच विफल रही"

msgid "Checkout session not found"
msgstr "चेकआउट सत्र नहीं मिला"

msgid "Payment provider not found or not configured"
msgstr "भुगतान प्रदाता नहीं मिला या संfigत नहीं किया गया।"

msgid "Get payment intent status"
msgstr "भुगतान इंटेंट की स्थिति प्राप्त करें"

msgid ""
"\n"
"        Get the current status of a payment intent.\n"
"\n"
"        Use this endpoint to:\n"
"        - Check payment status after hosted checkout redirect\n"
"        - Poll for status during processing\n"
"        - Get order details after successful payment\n"
"\n"
"        **Statuses**:\n"
"        - `created`: Intent created, awaiting payment method\n"
"        - `requires_payment_method`: Needs payment method\n"
"        - `requires_action`: Customer action required (3DS)\n"
"        - `processing`: Payment is processing\n"
"        - `succeeded`: Payment successful\n"
"        - `failed`: Payment failed\n"
"        - `canceled`: Payment was canceled\n"
"        "
msgstr ""
"\n"
"        Get the current status of a payment intent.\n"
"\n"
"        Use this endpoint to:\n"
"        - Check payment status after hosted checkout redirect\n"
"        - Poll for status during processing\n"
"        - Get order details after successful payment\n"
"\n"
"        **Statuses**:\n"
"        - `created`: Intent created, awaiting payment method\n"
"        - `requires_payment_method`: Needs payment method\n"
"        - `requires_action`: Customer action required (3DS)\n"
"        - `processing`: Payment is processing\n"
"        - `succeeded`: Payment successful\n"
"        - `failed`: Payment failed\n"
"        - `canceled`: Payment was canceled\n"
"        "

msgid "Payment intent UUID"
msgstr "भुगतान इंटेंट UUID"

msgid ""
"Payment intent details (full handler data for active intents, status-only "
"for terminal states)"
msgstr ""
"भुगतान इंटेंट विवरण (सक्रिय इंटेंट के लिए पूरा हैंडलर डेटा, टर्मिनल स्थितियों के लिए केवल "
"स्थिति)"

msgid "Payment intent not found"
msgstr "भुगतान इंटेंट नहीं मिला"

msgid "Confirm payment intent"
msgstr "भुगतान इंटेंट की पुष्टि करें"

msgid ""
"\n"
"        Confirm a payment intent after customer completes required action.\n"
"\n"
"        Use this endpoint after:\n"
"        - 3DS authentication completes\n"
"        - Customer authorizes payment on redirect\n"
"        - Any other required customer action\n"
"\n"
"        The confirmation may succeed immediately or require additional "
"actions.\n"
"        "
msgstr ""
"\n"
"        Confirm a payment intent after customer completes required action.\n"
"\n"
"        Use this endpoint after:\n"
"        - 3DS authentication completes\n"
"        - Customer authorizes payment on redirect\n"
"        - Any other required customer action\n"
"\n"
"        The confirmation may succeed immediately or require additional "
"actions.\n"
"        "

msgid "Confirmation result"
msgstr "पुष्टि परिणाम"

msgid "Confirmation failed"
msgstr "पुष्टि विफल रही"

msgid "Cancel payment intent"
msgstr "भुगतान इंटेंट रद्द करें"

msgid ""
"\n"
"        Cancel a payment intent.\n"
"\n"
"        This will:\n"
"        - Cancel the payment intent with the provider\n"
"        - Cancel the associated order (if no other active intents)\n"
"        - Release allocated stock\n"
"\n"
"        **Note**: Cannot cancel intents in terminal states (succeeded, "
"failed, canceled).\n"
"        "
msgstr ""
"\n"
"        Cancel a payment intent.\n"
"\n"
"        This will:\n"
"        - Cancel the payment intent with the provider\n"
"        - Cancel the associated order (if no other active intents)\n"
"        - Release allocated stock\n"
"\n"
"        **Note**: Cannot cancel intents in terminal states (succeeded, "
"failed, canceled).\n"
"        "

